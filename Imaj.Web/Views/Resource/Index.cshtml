@using Imaj.Web.Authorization
@model ResourceIndexViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["Resource"];
    var canAdd = await PermissionViewService.CanExecuteMethodAsync(1032);
}

<div class="space-y-8">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">@Localizer["ResourceSearch"]</h2>
    </div>

    <form method="get" action="/Resource/List" class="bg-white border border-gray-200 shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <div class="bg-blue-50 p-4 rounded-md border border-blue-200 max-w-4xl mx-auto">
                <h3 class="text-lg font-semibold text-gray-700 mb-4 border-b border-blue-200 pb-2">@Localizer["MainCriteria"]</h3>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <label class="md:col-span-3 text-sm font-medium text-blue-900 md:text-right">@Localizer["Code"]</label>
                    <input type="text"
                           name="Code"
                           value="@Model.Filter.Code"
                           maxlength="8"
                           class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm uppercase">

                    <label class="md:col-span-3 text-sm font-medium text-blue-900 md:text-right">@Localizer["SequenceNo"]</label>
                    <div class="md:col-span-3 grid grid-cols-2 gap-2">
                        <input type="number" name="SequenceFrom" value="@Model.Filter.SequenceFrom" min="0" class="shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <input type="number" name="SequenceTo" value="@Model.Filter.SequenceTo" min="0" class="shadow-sm border-gray-300 rounded-md sm:text-sm">
                    </div>
                </div>

                <div class="mt-3 grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <label class="md:col-span-3 text-sm font-medium text-blue-900 md:text-right">@Localizer["Function"]</label>
                    <select name="FunctionId" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">@Localizer["AllOption"]</option>
                        @foreach (var option in Model.FunctionOptions)
                        {
                            if (Model.Filter.FunctionId == option.Id)
                            {
                                <option value="@option.Id" selected>@option.Name</option>
                            }
                            else
                            {
                                <option value="@option.Id">@option.Name</option>
                            }
                        }
                    </select>

                    <label class="md:col-span-3 text-sm font-medium text-blue-900 md:text-right">@Localizer["ResoCat"]</label>
                    <select name="ResoCatId" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">@Localizer["AllOption"]</option>
                        @foreach (var option in Model.ResoCatOptions)
                        {
                            if (Model.Filter.ResoCatId == option.Id)
                            {
                                <option value="@option.Id" selected>@option.Name</option>
                            }
                            else
                            {
                                <option value="@option.Id">@option.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="mt-3 grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <label class="md:col-span-3 text-sm font-medium text-blue-900 md:text-right">@Localizer["Invalid"]</label>
                    <select name="IsInvalid" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">@Localizer["AllOption"]</option>
                        @if (Model.Filter.IsInvalid == false)
                        {
                            <option value="false" selected>@Localizer["No"]</option>
                        }
                        else
                        {
                            <option value="false">@Localizer["No"]</option>
                        }

                        @if (Model.Filter.IsInvalid == true)
                        {
                            <option value="true" selected>@Localizer["Yes"]</option>
                        }
                        else
                        {
                            <option value="true">@Localizer["Yes"]</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
                <span class="text-sm text-blue-900 font-semibold">@Localizer["First"]</span>
                <input type="number" name="First" value="@(Model.Filter.First.HasValue && Model.Filter.First.Value > 0 ? Model.Filter.First.Value : (Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 16))" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">
                <span class="text-sm text-blue-900 font-semibold">@Localizer["PageSize"]</span>
                <input type="number" name="PageSize" value="@(Model.Filter.PageSize <= 0 ? 16 : Model.Filter.PageSize)" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">
                <input type="hidden" name="Page" value="1">

                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                    @Localizer["Search"]
                </button>
                <button type="reset" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                    @Localizer["Clear"]
                </button>
            </div>
        </div>
    </form>

    @if (canAdd)
    {
        <div class="bg-white border border-gray-200 shadow sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6 max-w-4xl mx-auto space-y-4">
                <h3 class="text-3xl font-bold text-orange-600 text-center">@Localizer["ResourceCreation"]</h3>

                <form method="get" action="/Resource/Create" class="bg-blue-50 p-4 rounded-md border border-blue-200">
                    <h4 class="text-lg font-semibold text-gray-700 mb-4 border-b border-blue-200 pb-2">@Localizer["Resource"]</h4>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                        <label class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Function"]</label>
                        <div class="md:col-span-8">
                            <select name="functionId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                                <option value="">@Localizer["SelectPrompt"]</option>
                                @foreach (var option in Model.FunctionOptions)
                                {
                                    if (Model.CreateFunctionId == option.Id)
                                    {
                                        <option value="@option.Id" selected>@option.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@option.Id">@option.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <label class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["ResoCat"]</label>
                        <div class="md:col-span-8">
                            <select name="resoCatId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                                <option value="">@Localizer["SelectPrompt"]</option>
                                @foreach (var option in Model.ResoCatOptions)
                                {
                                    if (Model.CreateResoCatId == option.Id)
                                    {
                                        <option value="@option.Id" selected>@option.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@option.Id">@option.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <label class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Code"]</label>
                        <div class="md:col-span-8">
                            <input type="text" name="code" value="@Model.CreateCode" maxlength="8" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm uppercase">
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                            @Localizer["Resource"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
