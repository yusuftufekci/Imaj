@using System.Net
@using System.Text.Json
@using System.Collections.Generic
@using System.Globalization
@model ResourceEditViewModel

@{
    ViewData["Title"] = Localizer["Resource"];
    var selectedIds = Model.SelectedIds ?? new List<string>();
    var languageNameById = Model.Languages
        .GroupBy(x => x.Id)
        .ToDictionary(x => x.Key, x => x.First().Name);

    var initialState = new
    {
        functions = Model.FunctionOptions.Select(x => new
        {
            id = x.Id,
            name = x.Name
        }),
        resoCats = Model.ResoCatOptions.Select(x => new
        {
            id = x.Id,
            name = x.Name
        }),
        form = new
        {
            functionId = Model.FunctionId,
            resoCatId = Model.ResoCatId,
            code = Model.Code,
            sequence = Model.Sequence,
            isInvalid = Model.IsInvalid,
        }
    };

    string BuildEditUrl(int index)
    {
        if (selectedIds.Count == 0)
        {
            return "#";
        }

        if (index < 0)
        {
            index = 0;
        }
        if (index >= selectedIds.Count)
        {
            index = selectedIds.Count - 1;
        }

        var selected = selectedIds[index];
        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/Resource/Edit?id={WebUtility.UrlEncode(selected)}&currentIndex={index}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    string BuildDetailUrl()
    {
        var targetId = Model.Id?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
        var url = $"/Resource/Detail?id={WebUtility.UrlEncode(targetId)}";

        if (selectedIds.Count > 0)
        {
            var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
            url += $"&currentIndex={Model.CurrentIndex}&selectedIds={idsQuery}";
        }

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    string ResolveLanguageName(ResourceLocalizedNameViewModel localizedName)
    {
        if (!string.IsNullOrWhiteSpace(localizedName.LanguageName))
        {
            return localizedName.LanguageName;
        }

        if (languageNameById.TryGetValue(localizedName.LanguageId, out var fallbackName) &&
            !string.IsNullOrWhiteSpace(fallbackName))
        {
            return fallbackName;
        }

        return localizedName.LanguageId > 0
            ? localizedName.LanguageId.ToString(CultureInfo.InvariantCulture)
            : string.Empty;
    }
}

<div x-data='resourceEditorPage(@Html.Raw(JsonSerializer.Serialize(initialState)))' class="space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">@Localizer["Resource"]</h2>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="rounded-md bg-red-50 border border-red-200 p-4">
            <div asp-validation-summary="All" class="text-sm text-red-700"></div>
        </div>
    }

    <form method="post" action="/Resource/Update" class="space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

        @foreach (var selectedId in selectedIds)
        {
            <input type="hidden" name="SelectedIds" value="@selectedId" />
        }

        <div class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["Resource"]</h3>
            </div>

            <div class="p-4 space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["Function"]</label>
                    <div class="md:col-span-9">
                        <select name="FunctionId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                            <option value="">@Localizer["SelectPrompt"]</option>
                            @foreach (var option in Model.FunctionOptions)
                            {
                                var selected = Model.FunctionId.HasValue && Model.FunctionId.Value == option.Id;
                                <option value="@option.Id" selected="@(selected ? "selected" : null)">@option.Name</option>
                            }
                        </select>
                    </div>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["ResoCat"]</label>
                    <div class="md:col-span-9">
                        <select name="ResoCatId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                            <option value="">@Localizer["SelectPrompt"]</option>
                            @foreach (var option in Model.ResoCatOptions)
                            {
                                var selected = Model.ResoCatId.HasValue && Model.ResoCatId.Value == option.Id;
                                <option value="@option.Id" selected="@(selected ? "selected" : null)">@option.Name</option>
                            }
                        </select>
                    </div>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["Code"]</label>
                    <div class="md:col-span-9">
                        <input type="text" name="Code" x-model="form.code" maxlength="8" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm uppercase">
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Language"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            @for (var index = 0; index < Model.Names.Count; index++)
                            {
                                var localizedName = Model.Names[index];
                                var languageName = ResolveLanguageName(localizedName);

                                <tr>
                                    <td class="px-4 py-2">
                                        <input type="hidden" name="Names[@index].LanguageId" value="@localizedName.LanguageId" />
                                        <input type="text"
                                               value="@languageName"
                                               readonly
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm bg-gray-100 text-gray-700 cursor-not-allowed">
                                    </td>
                                    <td class="px-4 py-2">
                                        <input type="text"
                                               name="Names[@index].Name"
                                               value="@localizedName.Name"
                                               maxlength="32"
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm"
                                               placeholder="@Localizer["Name"]">
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["SequenceNo"]</label>
                    <div class="md:col-span-3">
                        <input type="number" name="Sequence" x-model.number="form.sequence" min="0" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                    </div>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["Invalid"]</label>
                    <div class="md:col-span-3">
                        <input type="checkbox" name="IsInvalid" value="true" x-model="form.isInvalid" class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                    </div>
                </div>
            </div>
        </div>

        <partial name="_DetailNavigator" model="@(new DetailNavigatorViewModel
        {
            Header = Localizer["Resource"],
            CurrentIndex = Model.CurrentIndex,
            TotalCount = Model.TotalSelected,
            FirstUrl = BuildEditUrl(0),
            PreviousUrl = BuildEditUrl(Model.CurrentIndex - 1),
            NextUrl = BuildEditUrl(Model.CurrentIndex + 1),
            LastUrl = BuildEditUrl(selectedIds.Count - 1),
            FormAction = "/Resource/Edit",
            SelectedIds = selectedIds,
            ReturnUrl = Model.ReturnUrl
        })" />

        <div class="flex items-center justify-center gap-3">

            <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                @Localizer["Edit"]
            </button>
            <a href="@BuildDetailUrl()" class="inline-flex items-center px-6 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Back"]</a>
        </div>
    </form>
</div>

<script>
    function resourceEditorPage(initialState) {
        return {
            functions: initialState.functions || [],
            resoCats: initialState.resoCats || [],
            form: {
                functionId: (initialState.form && initialState.form.functionId) ? Number(initialState.form.functionId) : '',
                resoCatId: (initialState.form && initialState.form.resoCatId) ? Number(initialState.form.resoCatId) : '',
                code: (initialState.form && initialState.form.code) ? initialState.form.code : '',
                sequence: (initialState.form && typeof initialState.form.sequence !== 'undefined') ? Number(initialState.form.sequence) : 0,
                isInvalid: !!(initialState.form && initialState.form.isInvalid),
            }
        };
    }
</script>
