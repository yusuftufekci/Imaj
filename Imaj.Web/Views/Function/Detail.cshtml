@using System.Net
@using System.Collections.Generic
@using Imaj.Web.Authorization
@model FunctionDetailViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["Function"];
    var canEdit = await PermissionViewService.CanExecuteMethodAsync(1005);
    var selectedIds = Model.SelectedIds ?? new List<string>();
    var showRuleSection = Model.Reservable && Model.IntervalId.HasValue;

    string BuildDetailUrl(int index)
    {
        if (selectedIds.Count == 0)
        {
            return "#";
        }

        if (index < 0)
        {
            index = 0;
        }
        if (index >= selectedIds.Count)
        {
            index = selectedIds.Count - 1;
        }

        var selected = selectedIds[index];
        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/Function/Detail?id={WebUtility.UrlEncode(selected)}&currentIndex={index}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    string BuildEditUrl()
    {
        var targetId = Model.Id?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
        if (selectedIds.Count > 0)
        {
            targetId = selectedIds[Model.CurrentIndex];
        }

        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/Function/Edit?id={WebUtility.UrlEncode(targetId)}&currentIndex={Model.CurrentIndex}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    var firstUrl = BuildDetailUrl(0);
    var previousUrl = BuildDetailUrl(Model.CurrentIndex - 1);
    var nextUrl = BuildDetailUrl(Model.CurrentIndex + 1);
    var lastUrl = BuildDetailUrl(selectedIds.Count - 1);

    var navigatorModel = new DetailNavigatorViewModel
    {
        CurrentIndex = Model.CurrentIndex,
        TotalCount = Model.TotalSelected,
        FirstUrl = firstUrl,
        PreviousUrl = previousUrl,
        NextUrl = nextUrl,
        LastUrl = lastUrl,
        FormAction = "/Function/Detail",
        SelectedIds = selectedIds,
        ReturnUrl = Model.ReturnUrl
    };
}

<div class="space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">@Localizer["Function"]</h2>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mobile-detail-grid">
        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden mobile-table-panel">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["Function"]</h3>
            </div>

            <div class="px-4 py-4 space-y-4">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Language"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            @if (Model.Names.Count > 0)
                            {
                                foreach (var name in Model.Names)
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-sm text-gray-900">@name.LanguageName</td>
                                        <td class="px-4 py-2 text-sm text-gray-900">@name.Name</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["ReservationRange"]</span>
                    <span class="md:col-span-8 text-gray-900">@(string.IsNullOrWhiteSpace(Model.IntervalName) ? "-" : Model.IntervalName)</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["ReservationCompatible"]</span>
                    <span class="md:col-span-8">
                        <input type="checkbox" disabled @(Model.Reservable ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                    </span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["SelectTimeType"]</span>
                    <span class="md:col-span-8">
                        <input type="checkbox" disabled @(Model.WorkMandatory ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                    </span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["ProductSelectionRequired"]</span>
                    <span class="md:col-span-8">
                        <input type="checkbox" disabled @(Model.ProdMandatory ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                    </span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Invalid"]</span>
                    <span class="md:col-span-8">
                        <input type="checkbox" disabled @(Model.IsInvalid ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                    </span>
                </div>
            </div>
        </section>

        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden mobile-table-panel">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["Product"]</h3>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Code"]</th>
                            <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                            <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase">@Localizer["Invalid"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 bg-white">
                        @if (Model.Products.Count > 0)
                        {
                            foreach (var product in Model.Products)
                            {
                                <tr>
                                    <td class="px-4 py-2 text-sm text-gray-900">@product.Code</td>
                                    <td class="px-4 py-2 text-sm text-gray-900">@product.Name</td>
                                    <td class="px-4 py-2 text-center">
                                        <input type="checkbox" disabled @(product.Invisible ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    @if (showRuleSection)
    {
        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden mobile-table-panel">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">Kural</h3>
            </div>

            @if (Model.Rules.Count > 0)
            {
                <div class="divide-y divide-gray-200">
                    @foreach (var rule in Model.Rules)
                    {
                        <div class="p-4 grid grid-cols-1 xl:grid-cols-12 gap-4">
                            <div class="xl:col-span-5 space-y-2">
                                <div class="text-sm">
                                    <span class="font-semibold text-blue-900">Ad:</span>
                                    <span class="text-gray-900">@rule.Name</span>
                                </div>
                                <div class="text-sm">
                                    <span class="font-semibold text-blue-900">Minimum Deger:</span>
                                    <span class="text-gray-900">@rule.MinValue</span>
                                </div>
                                <div class="text-sm">
                                    <span class="font-semibold text-blue-900">Maksimum Deger:</span>
                                    <span class="text-gray-900">@rule.MaxValue</span>
                                </div>
                            </div>

                            <div class="xl:col-span-7">
                                <h4 class="text-sm font-semibold text-blue-900 mb-2">@Localizer["ResoCat"]</h4>
                                @if (rule.ResoCats.Count > 0)
                                {
                                    <div class="flex flex-wrap gap-2">
                                        @foreach (var resoCat in rule.ResoCats)
                                        {
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium border @(resoCat.Invisible ? "bg-red-50 text-red-700 border-red-200" : "bg-blue-50 text-blue-700 border-blue-200")">
                                                @resoCat.Name
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-sm text-gray-500">@Localizer["NoRecordsFound"]</p>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="p-4 text-sm text-gray-500">Kural kaydi yok.</div>
            }
        </section>
    }

    @if (Model.TotalSelected > 0)
    {
        <partial name="~/Views/Shared/_DetailNavigator.cshtml" model="navigatorModel" />
    }

    <div class="flex items-center justify-center gap-3 responsive-action-group">
        @if (canEdit)
        {
            <a href="@BuildEditUrl()" class="inline-flex items-center px-5 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none">
                @Localizer["Edit"]
            </a>
        }
        <a href="@Model.ReturnUrl" class="inline-flex items-center px-5 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Back"]</a>
    </div>
</div>
