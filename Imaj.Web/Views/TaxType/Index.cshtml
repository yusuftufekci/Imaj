@using Imaj.Web.Authorization
@model TaxTypeIndexViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = "Vergi Tipi Sorgulama";
    var canAdd = await PermissionViewService.CanExecuteMethodAsync(1241);
}

<div class="space-y-8">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">Vergi Tipi Sorgulama</h2>
    </div>

    <form method="get" action="/TaxType/List" class="bg-white border border-gray-200 shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <div class="bg-blue-50 p-4 rounded-md border border-blue-200 max-w-4xl mx-auto">
                <h3 class="text-lg font-semibold text-gray-700 mb-4 border-b border-blue-200 pb-2">Kriterler</h3>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <label class="md:col-span-3 text-sm font-medium text-blue-900 md:text-right">Kod</label>
                    <input type="text"
                           name="Code"
                           value="@Model.Filter.Code"
                           maxlength="8"
                           class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm uppercase">

                    <label class="md:col-span-3 text-sm font-medium text-blue-900 md:text-right">Gecersiz</label>
                    <select name="IsInvalid" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">Tumu</option>
                        @if (Model.Filter.IsInvalid == false)
                        {
                            <option value="false" selected>Hayir</option>
                        }
                        else
                        {
                            <option value="false">Hayir</option>
                        }

                        @if (Model.Filter.IsInvalid == true)
                        {
                            <option value="true" selected>Evet</option>
                        }
                        else
                        {
                            <option value="true">Evet</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
                <span class="text-sm text-blue-900 font-semibold">Ilk</span>
                <input type="number" name="Page" value="@(Model.Filter.Page <= 0 ? 1 : Model.Filter.Page)" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">
                <span class="text-sm text-blue-900 font-semibold">Sayfa Boyu</span>
                <input type="number" name="PageSize" value="@(Model.Filter.PageSize <= 0 ? 16 : Model.Filter.PageSize)" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">

                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                    Sorgula
                </button>
                <button type="reset" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                    Temizle
                </button>
            </div>
        </div>
    </form>

    @if (canAdd)
    {
        <div class="bg-white border border-gray-200 shadow sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6 max-w-5xl mx-auto space-y-4">
                <h3 class="text-3xl font-bold text-orange-600 text-center">Vergi Tipi Yaratma</h3>

                <form method="get" action="/TaxType/Create" class="bg-blue-50 p-4 rounded-md border border-blue-200">
                    <h4 class="text-lg font-semibold text-gray-700 mb-4 border-b border-blue-200 pb-2">On Bilgiler</h4>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                        <label class="md:col-span-4 text-blue-900 font-semibold md:text-right">Kod</label>
                        <div class="md:col-span-8">
                            <input type="text" name="code" value="@Model.CreateCode" maxlength="8" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm uppercase" />
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                            Yeni Vergi Tipi Yarat
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
