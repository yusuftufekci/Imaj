@using System.Text.Json
@using System.Globalization
@model TaxTypeCreateViewModel

@{
    ViewData["Title"] = Localizer["TaxType"];
    var languageNameById = Model.Languages
        .GroupBy(x => x.Id)
        .ToDictionary(x => x.Key, x => x.First().Name);

    string ResolveLanguageName(TaxTypeLocalizedNameViewModel localizedName)
    {
        if (!string.IsNullOrWhiteSpace(localizedName.LanguageName))
        {
            return localizedName.LanguageName;
        }

        if (languageNameById.TryGetValue(localizedName.LanguageId, out var fallbackName) &&
            !string.IsNullOrWhiteSpace(fallbackName))
        {
            return fallbackName;
        }

        return localizedName.LanguageId > 0
            ? localizedName.LanguageId.ToString(CultureInfo.InvariantCulture)
            : string.Empty;
    }

    var initialState = new
    {
        form = new
        {
            isInvalid = Model.IsInvalid,
            automaticForward = Model.AutomaticForward
        }
    };
}

<div x-data='taxTypeCreatePage(@Html.Raw(JsonSerializer.Serialize(initialState)))' class="space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">Vergi Tipi</h2>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="rounded-md bg-red-50 border border-red-200 p-4">
            <div asp-validation-summary="All" class="text-sm text-red-700"></div>
        </div>
    }

    <form method="post" action="/TaxType/Save" class="space-y-4">
        @Html.AntiForgeryToken()

        <div class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">Vergi Tipi</h3>
            </div>

            <div class="p-4 space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["Code"]</label>
                    <div class="md:col-span-3">
                        <input type="text"
                               name="Code"
                               value="@Model.Code"
                               maxlength="8"
                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm uppercase"
                               required />
                    </div>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["TaxRate"]</label>
                    <div class="md:col-span-3">
                        <input type="number"
                               name="TaxPercentage"
                               value="@Model.TaxPercentage"
                               min="0"
                               max="100"
                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm"
                               required />
                    </div>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["Invalid"]</label>
                    <div class="md:col-span-3">
                        <input type="checkbox" name="IsInvalid" value="true" x-model="form.isInvalid" class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["Name"]</h3>
            </div>

            <div class="p-4 space-y-4">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Language"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Fatura Son-Eki</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            @for (var index = 0; index < Model.Names.Count; index++)
                            {
                                var localizedName = Model.Names[index];
                                var languageName = ResolveLanguageName(localizedName);

                                <tr>
                                    <td class="px-4 py-2">
                                        <input type="hidden" name="Names[@index].LanguageId" value="@localizedName.LanguageId" />
                                        <input type="text"
                                               value="@languageName"
                                               readonly
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm bg-gray-100 text-gray-700 cursor-not-allowed">
                                    </td>
                                    <td class="px-4 py-2">
                                        <input type="text"
                                               name="Names[@index].Name"
                                               value="@localizedName.Name"
                                               maxlength="32"
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm"
                                               placeholder="Vergi tipi adi" />
                                    </td>
                                    <td class="px-4 py-2">
                                        <input type="text"
                                               name="Names[@index].InvoLinePostfix"
                                               value="@localizedName.InvoLinePostfix"
                                               maxlength="32"
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm"
                                               placeholder="@Localizer["Notes"]" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-center gap-3">
            <label class="inline-flex items-center text-sm text-gray-700">
                <input type="checkbox" name="AutomaticForward" value="true" x-model="form.automaticForward" class="mr-2 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                @Localizer["AutomaticForward"]
            </label>

            <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                @Localizer["Save"]
            </button>
            <a href="/TaxType" class="inline-flex items-center px-6 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                @Localizer["Cancel"]
            </a>
        </div>
    </form>
</div>

<script>
    function taxTypeCreatePage(initialState) {
        return {
            form: {
                isInvalid: !!(initialState.form && initialState.form.isInvalid),
                automaticForward: !!(initialState.form && initialState.form.automaticForward)
            }
        };
    }
</script>
