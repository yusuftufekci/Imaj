@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Imaj.Web.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@inject IPermissionViewService PermissionViewService
@model ProductReportViewModel

@{
    ViewData["Title"] = Localizer["ProductReport"];
    var canDownloadDetailed = await PermissionViewService.CanExecuteMethodAsync(1754);
}

<div x-data="productReport()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@product-selected.window="handleProductSelection($event.detail)" class="job-page-shell job-index-shell job-index-reference report-index-reference product-report-index-reference page-shell--wide space-y-2">
    <div class="text-center job-index-heading">
        <h2 class="job-page-title job-page-title--orange">
            @Localizer["ProductReport"]
        </h2>
    </div>

    <section class="dense-panel report-index-panel">
        <div class="dense-panel__header">
            <h3 class="dense-panel__title">@Localizer["MainCriteria"]</h3>
        </div>
        <div class="dense-panel__body mobile-stack-form">
            <div class="dense-form-grid report-index-criteria-list">
                <div class="dense-form-row">
                    <label for="ProductReportStartDate">@Localizer["StartDate"]</label>
                    <input type="date" name="start-date" id="ProductReportStartDate" x-model="startDate" class="dense-input" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="dense-form-row">
                    <label for="ProductReportEndDate">@Localizer["EndDate"]</label>
                    <input type="date" name="end-date" id="ProductReportEndDate" x-model="endDate" class="dense-input" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="dense-form-row">
                    <label for="ProductReportGroup">@Localizer["ProductGroup"]</label>
                    <select id="ProductReportGroup" name="product-group" x-model="productFilter.productGroup" class="dense-input">
                        <option value="">@Localizer["SelectPrompt"]</option>
                        <template x-for="grp in productGroups" :key="grp.id">
                            <option :value="grp.name" x-text="grp.name"></option>
                        </template>
                    </select>
                </div>
                <div class="dense-form-row">
                    <label>@Localizer["Product"]</label>
                    <div class="report-index-selector">
                        <span class="report-index-selector__value" x-text="selectedProductName || '-'"></span>
                        <span class="report-index-selector__separator">-</span>
                        <button type="button" @@click="$dispatch('product-select-open', { targetId: 'mainProduct' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                            @Localizer["Select"]
                        </button>
                    </div>
                </div>
                <div class="dense-form-row">
                    <label>@Localizer["Customer"]</label>
                    <div class="report-index-selector">
                        <span class="report-index-selector__value" x-text="selectedCustomerName || '-'"></span>
                        <span class="report-index-selector__separator">-</span>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'main' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                            @Localizer["Select"]
                        </button>
                    </div>
                </div>
            </div>

            <div class="report-index-panel__actions">
                <div class="job-index-action-group report-index-report-group responsive-action-group">
                    @if (canDownloadDetailed)
                    {
                        <button type="button" @@click="downloadDetailedReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                            @Localizer["DetailedProductReportTitle"] - Excel
                        </button>
                        <button type="button" @@click="openDetailedReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                            @Localizer["DetailedProductReportTitle"] - PDF
                        </button>
                    }
                    else
                    {
                        <span class="text-sm text-gray-500">@Localizer["ReportDataUnavailable"]</span>
                    }
                </div>
            </div>
        </div>
    </section>

    <partial name="_ProductSelectModal" />
    <partial name="_CustomerSelectModal" />
</div>

<script>
    function productReport() {
        return {
            startDate: '@Model.StartDate.ToString("yyyy-MM-dd")',
            endDate: '@Model.EndDate.ToString("yyyy-MM-dd")',
            selectedProductName: '',
            selectedProductCode: '',
            isReportLoading: false,
            selectedCustomerName: '',
            selectedCustomerCode: '',
            messages: {
                startEndDateRequired: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartEndDateRequired"].Value)),
                endDateBeforeStart: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateBeforeStart"].Value)),
                reportDataUnavailable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ReportDataUnavailable"].Value)),
                reportLoading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value)),
                reportLoadingDetail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PrintReportStarted"].Value))
            },

            productGroups: [],

            productFilter: {
                // Just keeping any local filter state if needed for the main page, though mostly handled in modal
                productGroup: ''
            },
            
            async init() {
                try {
                    const response = await fetch('/Product/GetProductGroups');
                    if (response.ok) {
                        this.productGroups = await response.json();
                    }
                } catch (e) {
                    console.error('@Localizer["DataLoadError"]', e);
                }
            },
            
            // Shared Modal Handlers
            handleCustomerSelection(detail) {
                 if(detail.targetId === 'main') {
                    this.selectedCustomerName = detail.customer.name;
                    this.selectedCustomerCode = detail.customer.code;
                 }
            },
            
            handleProductSelection(detail) {
                if(detail.targetId === 'mainProduct') {
                    this.selectedProductName = detail.product.name;
                    this.selectedProductCode = detail.product.code;
                }
            },

            showError(message) {
                if (window.Toast && typeof window.Toast.error === 'function') {
                    window.Toast.error(message);
                    return;
                }

                alert(message);
            },

            showLoading() {
                if (typeof Swal === 'undefined') {
                    return;
                }

                Swal.fire({
                    title: this.messages.reportLoading,
                    text: this.messages.reportLoadingDetail,
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
            },

            hideLoading() {
                if (typeof Swal !== 'undefined' && Swal.isVisible()) {
                    Swal.close();
                }
            },

            normalizeErrorMessage(rawMessage, fallback) {
                if (!rawMessage) {
                    return fallback;
                }

                const text = rawMessage.trim();
                if (!text) {
                    return fallback;
                }

                if (text.startsWith('<')) {
                    return fallback;
                }

                const textarea = document.createElement('textarea');
                textarea.innerHTML = text;
                return textarea.value || fallback;
            },

            buildReportParams() {
                if (!this.startDate || !this.endDate) {
                    this.showError(this.messages.startEndDateRequired);
                    return null;
                }

                if (this.endDate < this.startDate) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                const params = new URLSearchParams({
                    startDate: this.startDate,
                    endDate: this.endDate
                });

                if (this.productFilter.productGroup) {
                    params.append('productGroup', this.productFilter.productGroup);
                }
                if (this.selectedProductCode) {
                    params.append('productCode', this.selectedProductCode);
                }
                if (this.selectedProductName) {
                    params.append('productName', this.selectedProductName);
                }
                if (this.selectedCustomerCode) {
                    params.append('customerCode', this.selectedCustomerCode);
                }
                if (this.selectedCustomerName) {
                    params.append('customerName', this.selectedCustomerName);
                }

                return params;
            },

            async downloadDetailedReport() {
                const params = this.buildReportParams();
                if (!params) {
                    return;
                }

                if (this.isReportLoading) {
                    return;
                }

                this.isReportLoading = true;
                this.showLoading();
                let loadingClosed = false;

                try {
                    const response = await fetch(`/ProductReport/DownloadDetailedExcel?${params.toString()}`, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        const rawMessage = await response.text();
                        const fallback = this.messages.reportDataUnavailable;
                        this.hideLoading();
                        loadingClosed = true;
                        this.showError(this.normalizeErrorMessage(rawMessage, fallback));
                        return;
                    }

                    const blob = await response.blob();
                    const contentDisposition = response.headers.get('content-disposition') || '';
                    const fileNameUtfMatch = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
                    const fileNameMatch = contentDisposition.match(/filename=\"?([^\";]+)\"?/i);

                    let fileName = 'report.xlsx';
                    if (fileNameUtfMatch && fileNameUtfMatch[1]) {
                        fileName = decodeURIComponent(fileNameUtfMatch[1]);
                    } else if (fileNameMatch && fileNameMatch[1]) {
                        fileName = fileNameMatch[1];
                    }

                    const objectUrl = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = objectUrl;
                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(objectUrl);
                } catch (error) {
                    const fallback = (window.imajTexts && window.imajTexts.connectionError)
                        || (window.imajTexts && window.imajTexts.genericError)
                        || this.messages.reportDataUnavailable;

                    this.hideLoading();
                    loadingClosed = true;
                    this.showError(fallback);
                } finally {
                    if (!loadingClosed) {
                        this.hideLoading();
                    }

                    this.isReportLoading = false;
                }
            },

            openDetailedReportPage() {
                const params = this.buildReportParams();
                if (!params) {
                    return;
                }

                window.open(`/ProductReport/ViewDetailedReport?${params.toString()}`, '_blank', 'noopener');
            }
        }
    }
</script>
