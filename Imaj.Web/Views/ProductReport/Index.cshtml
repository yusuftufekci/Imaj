@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Imaj.Web.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@inject IPermissionViewService PermissionViewService
@model ProductReportViewModel

@{
    ViewData["Title"] = Localizer["ProductReport"];
    var canDownloadDetailed = await PermissionViewService.CanExecuteMethodAsync(1754);
}

<div x-data="productReport()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@product-selected.window="handleProductSelection($event.detail)" class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
             <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["ProductSearchTitle"]
            </h2>
        </div>
    </div>

    <div class="bg-white shadow sm:rounded-lg border border-gray-200 w-full max-w-5xl mx-auto text-left">
        <div class="px-4 py-5 sm:p-6 space-y-6">
            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                
                <!-- Date Range -->
                <div class="sm:col-span-3">
                    <label for="start-date" class="block text-sm font-medium text-gray-700">@Localizer["StartDate"]</label>
                    <div class="mt-1">
                        <input type="date" name="start-date" id="start-date" x-model="startDate" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <div class="sm:col-span-3">
                    <label for="end-date" class="block text-sm font-medium text-gray-700">@Localizer["EndDate"]</label>
                    <div class="mt-1">
                        <input type="date" name="end-date" id="end-date" x-model="endDate" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <!-- Product Group -->
                <div class="sm:col-span-6">
                    <label for="product-group" class="block text-sm font-medium text-gray-700">@Localizer["ProductGroup"]</label>
                    <div class="mt-1">
                        <select id="product-group" name="product-group" x-model="productFilter.productGroup" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            <option value="">@Localizer["SelectPrompt"]</option>
                            <template x-for="grp in productGroups" :key="grp.id">
                                <option :value="grp.name" x-text="grp.name"></option>
                            </template>
                        </select>
                    </div>
                </div>

                <!-- Product Selection -->
                <div class="sm:col-span-6">
                     <label class="block text-sm font-medium text-gray-700">@Localizer["Product"]</label>
                     <div class="mt-1 flex rounded-md shadow-sm">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="selectedProductName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300" placeholder="@Localizer["AllOption"]">
                        </div>
                        <button type="button" @@click="$dispatch('product-select-open', { targetId: 'mainProduct' })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                             <span>@Localizer["Select"]</span>
                        </button>
                    </div>
                </div>

                <!-- Customer Selection -->
                <div class="sm:col-span-6">
                     <label class="block text-sm font-medium text-gray-700">@Localizer["Customer"]</label>
                      <div class="mt-1 flex rounded-md shadow-sm">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="selectedCustomerName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300" placeholder="@Localizer["AllOption"]">
                        </div>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'main' })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                             <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                             <span>@Localizer["Select"]</span>
                        </button>
                    </div>
                </div>

            </div>

            <div class="pt-6 border-t border-gray-200">
                <div class="flex flex-wrap items-center justify-center gap-3">
                @if (canDownloadDetailed)
                {
                    <button type="button" @@click="downloadDetailedReport()" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["PrintReport"]
                    </button>
                }
                else
                {
                    <span class="text-sm text-gray-500">@Localizer["ReportDataUnavailable"]</span>
                }
                </div>
            </div>
        </div>
    </div>

    <partial name="_ProductSelectModal" />
    <partial name="_CustomerSelectModal" />
</div>

<script>
    function productReport() {
        return {
            startDate: '@Model.StartDate.ToString("yyyy-MM-dd")',
            endDate: '@Model.EndDate.ToString("yyyy-MM-dd")',
            selectedProductName: '',
            selectedProductCode: '',
            
            selectedCustomerName: '',
            selectedCustomerCode: '',

            productGroups: [],

            productFilter: {
                // Just keeping any local filter state if needed for the main page, though mostly handled in modal
                productGroup: ''
            },
            
            async init() {
                try {
                    const response = await fetch('/Product/GetProductGroups');
                    if (response.ok) {
                        this.productGroups = await response.json();
                    }
                } catch (e) {
                    console.error('@Localizer["DataLoadError"]', e);
                }
            },
            
            // Shared Modal Handlers
            handleCustomerSelection(detail) {
                 if(detail.targetId === 'main') {
                    this.selectedCustomerName = detail.customer.name;
                    this.selectedCustomerCode = detail.customer.code;
                 }
            },
            
            handleProductSelection(detail) {
                if(detail.targetId === 'mainProduct') {
                    this.selectedProductName = detail.product.name;
                    this.selectedProductCode = detail.product.code;
                }
            },

            downloadDetailedReport() {
                if (!this.startDate || !this.endDate) {
                    alert('');
                    return;
                }

                const params = new URLSearchParams({
                    startDate: this.startDate,
                    endDate: this.endDate
                });

                if (this.productFilter.productGroup) {
                    params.append('productGroup', this.productFilter.productGroup);
                }
                if (this.selectedProductCode) {
                    params.append('productCode', this.selectedProductCode);
                }
                if (this.selectedProductName) {
                    params.append('productName', this.selectedProductName);
                }
                if (this.selectedCustomerCode) {
                    params.append('customerCode', this.selectedCustomerCode);
                }
                if (this.selectedCustomerName) {
                    params.append('customerName', this.selectedCustomerName);
                }

                window.location.href = `/ProductReport/DownloadDetailedExcel?${params.toString()}`;
            }
        }
    }
</script>
