@using Imaj.Web.Authorization
@using Imaj.Web.Models.Components
@using System.Text.Json
@model UserListViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["User"];
    var canView = await PermissionViewService.CanExecuteMethodAsync(970);
    var canEdit = await PermissionViewService.CanExecuteMethodAsync(971);

    var queryParts = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Filter.Code))
    {
        queryParts.Add($"Code={System.Net.WebUtility.UrlEncode(Model.Filter.Code)}");
    }

    if (!string.IsNullOrWhiteSpace(Model.Filter.Name))
    {
        queryParts.Add($"Name={System.Net.WebUtility.UrlEncode(Model.Filter.Name)}");
    }

    if (Model.Filter.IsInvalid.HasValue)
    {
        queryParts.Add($"IsInvalid={Model.Filter.IsInvalid.Value.ToString().ToLowerInvariant()}");
    }

    if (Model.Filter.First.HasValue && Model.Filter.First.Value > 0)
    {
        queryParts.Add($"First={Model.Filter.First.Value}");
    }

    var queryString = string.Join("&", queryParts);
    var allCodesJson = JsonSerializer.Serialize(Model.Items.Select(x => x.Code).ToList());
}

<div x-data="userListPage()" class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["UserList"]
            </h2>
        </div>
    </div>

    <form x-ref="listForm" method="post" action="/User/Detail">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

        <div class="bg-white shadow sm:rounded-lg border border-gray-200 mt-6">
            <div class="px-4 py-5 sm:p-6 space-y-4">
                <h3 class="text-md font-bold text-gray-700 bg-blue-100 p-2 rounded">@Localizer["UserList"]</h3>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-blue-100">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider w-12">
                                    <input type="checkbox" @@click="toggleAll" :checked="allSelected" class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                </th>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">@Localizer["Code"]</th>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">@Localizer["Name"]</th>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">@Localizer["Language"]</th>
                                <th class="px-6 py-3 text-center text-xs font-bold text-gray-700 uppercase tracking-wider">@Localizer["AllEmployees"]</th>
                                <th class="px-6 py-3 text-center text-xs font-bold text-gray-700 uppercase tracking-wider">@Localizer["Invalid"]</th>
                                <th class="px-6 py-3 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">@Localizer["Company"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            @if (Model.Items.Count > 0)
                            {
                                foreach (var item in Model.Items)
                                {
                                    <tr class="hover:bg-gray-50 cursor-pointer" @@click="toggleRow('@item.Code')">
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <input type="checkbox"
                                                   name="selectedIds"
                                                   value="@item.Code"
                                                   x-model="selectedIds"
                                                   @@click.stop
                                                   class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">@item.Code</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.Name</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.LanguageName</td>
                                        <td class="px-6 py-4 whitespace-nowrap text-center">
                                            <input type="checkbox" disabled @(item.AllEmployee ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-center">
                                            <input type="checkbox" disabled @(item.IsInvalid ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@item.CompanyName</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="px-6 py-10 text-center text-sm text-gray-500">@Localizer["NoRecordsFound"]</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-4 space-y-4">
            @if (Model.TotalCount > 0)
            {
                <partial name="Components/_Pagination" model="@(new PaginationModel
                {
                    CurrentPage = Model.Page,
                    TotalCount = Model.TotalCount,
                    PageSize = Model.PageSize,
                    BaseUrl = "/User/List",
                    QueryString = queryString
                })" />
            }
            else
            {
                <p class="text-center text-gray-500 text-sm">@Localizer["NoRecordsFound"]</p>
            }

            <div class="flex justify-center flex-wrap gap-2">
                @if (canView)
                {
                    <button type="button" @@click="submitTo('/User/Detail')" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["View"]
                    </button>
                }
                @if (canEdit)
                {
                    <button type="button" @@click="submitTo('/User/Edit')" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none">
                        @Localizer["Edit"]
                    </button>
                }
                <a href="/User" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Back"]</a>
            </div>
        </div>
    </form>
</div>

<script>
    function userListPage() {
        return {
            selectedIds: [],
            allPageIds: @Html.Raw(allCodesJson),

            get allSelected() {
                return this.allPageIds.length > 0 && this.selectedIds.length === this.allPageIds.length;
            },

            toggleAll() {
                if (this.allSelected) {
                    this.selectedIds = [];
                } else {
                    this.selectedIds = [...this.allPageIds];
                }
            },

            toggleRow(code) {
                const index = this.selectedIds.indexOf(code);
                if (index === -1) {
                    this.selectedIds.push(code);
                } else {
                    this.selectedIds.splice(index, 1);
                }
            },

            submitTo(action) {
                if (this.selectedIds.length === 0) {
                    if (window.Toast && typeof window.Toast.error === 'function') {
                        window.Toast.error('Lutfen en az bir kullanici secin.');
                    } else {
                        alert('Lutfen en az bir kullanici secin.');
                    }
                    return;
                }

                this.$refs.listForm.action = action;
                this.$refs.listForm.submit();
            }
        };
    }
</script>
