@model UserChangePasswordViewModel

@{
    ViewData["Title"] = Localizer["ChangePassword"];
}

<div class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["ChangePassword"]
            </h2>
        </div>
    </div>

    <div class="w-full max-w-2xl mx-auto text-left">
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["ChangePassword"]</h3>
            </div>

            <form method="post" action="/User/ChangePassword" class="p-6 space-y-4">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="rounded-md bg-red-50 p-3 text-sm text-red-700"></div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <label asp-for="CurrentPassword" class="md:col-span-4 text-sm font-medium text-gray-700 md:text-right">
                        @Localizer["CurrentPassword"]
                    </label>
                    <div class="md:col-span-8">
                        <input asp-for="CurrentPassword" type="password" autocomplete="current-password" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm" />
                        <span asp-validation-for="CurrentPassword" class="text-sm text-red-600"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <label asp-for="NewPassword" class="md:col-span-4 text-sm font-medium text-gray-700 md:text-right">
                        @Localizer["NewPassword"]
                    </label>
                    <div class="md:col-span-8">
                        <input asp-for="NewPassword" type="password" autocomplete="new-password" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm" />
                        <span asp-validation-for="NewPassword" class="text-sm text-red-600"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                    <label asp-for="ConfirmNewPassword" class="md:col-span-4 text-sm font-medium text-gray-700 md:text-right">
                        @Localizer["ConfirmNewPassword"]
                    </label>
                    <div class="md:col-span-8">
                        <input asp-for="ConfirmNewPassword" type="password" autocomplete="new-password" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-sm text-red-600"></span>
                    </div>
                </div>

                <div class="pt-2 flex justify-center">
                    <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["ChangePassword"]
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
