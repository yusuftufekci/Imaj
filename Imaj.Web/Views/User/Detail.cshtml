@using System.Net
@using Imaj.Web.Authorization
@model UserDetailViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["User"];
    var canEdit = await PermissionViewService.CanExecuteMethodAsync(971);

    string BuildDetailUrl(int index)
    {
        if (Model.SelectedIds == null || Model.SelectedIds.Count == 0)
        {
            return "#";
        }

        if (index < 0)
        {
            index = 0;
        }
        if (index >= Model.SelectedIds.Count)
        {
            index = Model.SelectedIds.Count - 1;
        }

        var selected = Model.SelectedIds[index];
        var idsQuery = string.Join("&selectedIds=", Model.SelectedIds.Select(WebUtility.UrlEncode));
        var url = $"/User/Detail?id={WebUtility.UrlEncode(selected)}&currentIndex={index}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    string BuildEditUrl()
    {
        if (Model.SelectedIds == null || Model.SelectedIds.Count == 0)
        {
            return $"/User/Edit?id={WebUtility.UrlEncode(Model.Code)}";
        }

        var idsQuery = string.Join("&selectedIds=", Model.SelectedIds.Select(WebUtility.UrlEncode));
        var url = $"/User/Edit?id={WebUtility.UrlEncode(Model.SelectedIds[Model.CurrentIndex])}&currentIndex={Model.CurrentIndex}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }
}

<div class="space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">@Localizer["User"]</h2>
    </div>

    <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden mobile-table-panel">
        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
            <h3 class="text-lg font-semibold text-gray-800">@Localizer["User"]</h3>
        </div>
        <div class="px-4 py-4">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-x-4 gap-y-3 items-center text-sm">
                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Company"]</span>
                <span class="md:col-span-8 text-gray-900">@Model.CompanyName</span>

                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Code"]</span>
                <span class="md:col-span-8 text-gray-900">@Model.Code</span>

                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Name"]</span>
                <span class="md:col-span-8 text-gray-900">@Model.Name</span>

                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Language"]</span>
                <span class="md:col-span-8 text-gray-900">@Model.LanguageName</span>

                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["AllEmployees"]</span>
                <span class="md:col-span-8">
                    <input type="checkbox" disabled @(Model.AllEmployee ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                </span>

                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Invalid"]</span>
                <span class="md:col-span-8">
                    <input type="checkbox" disabled @(Model.IsInvalid ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                </span>
            </div>
        </div>
    </section>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mobile-detail-grid">
        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden mobile-table-panel">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["Role"]</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase w-12">@Localizer["Selected"]</th>
                            <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @if (Model.Roles.Count > 0)
                        {
                            foreach (var role in Model.Roles)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-2"><input type="checkbox" disabled class="h-4 w-4 text-gray-400 border-gray-300 rounded"></td>
                                    <td class="px-4 py-2 text-sm text-gray-900">@role.Name</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden mobile-table-panel">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["Function"]</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase w-12">@Localizer["Selected"]</th>
                            <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @if (Model.Functions.Count > 0)
                        {
                            foreach (var function in Model.Functions)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-2"><input type="checkbox" disabled class="h-4 w-4 text-gray-400 border-gray-300 rounded"></td>
                                    <td class="px-4 py-2 text-sm text-gray-900">@function.Name</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="2" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden mobile-table-panel">
        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
            <h3 class="text-lg font-semibold text-gray-800">@Localizer["Employee"]</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase w-12">@Localizer["Selected"]</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Code"]</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @if (Model.Employees.Count > 0)
                    {
                        foreach (var employee in Model.Employees)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-2"><input type="checkbox" disabled class="h-4 w-4 text-gray-400 border-gray-300 rounded"></td>
                                <td class="px-4 py-2 text-sm text-gray-900">@employee.Code</td>
                                <td class="px-4 py-2 text-sm text-gray-900">@employee.Name</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <div class="space-y-4 pt-2">
        <partial name="_DetailNavigator" model="@(new DetailNavigatorViewModel
        {
            Header = Localizer["User"],
            CurrentIndex = Model.CurrentIndex,
            TotalCount = Model.TotalSelected,
            FirstUrl = BuildDetailUrl(0),
            PreviousUrl = BuildDetailUrl(Model.CurrentIndex - 1),
            NextUrl = BuildDetailUrl(Model.CurrentIndex + 1),
            LastUrl = BuildDetailUrl(Model.SelectedIds.Count - 1),
            FormAction = "/User/Detail",
            SelectedIds = Model.SelectedIds,
            ReturnUrl = Model.ReturnUrl
        })" />

        <div class="flex justify-center gap-2 flex-wrap responsive-action-group">
            @if (canEdit)
            {
                <a href="@BuildEditUrl()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                    @Localizer["Edit"]
                </a>
            }
            <a href="@(string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/User/List" : Model.ReturnUrl)" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Back"]</a>
        </div>
    </div>
</div>
