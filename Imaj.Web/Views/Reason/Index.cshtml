@using Imaj.Web.Authorization
@model ReasonIndexViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["Reason"];
    var canAdd = await PermissionViewService.CanExecuteMethodAsync(1052);
    var firstValue = Model.Filter.First.HasValue && Model.Filter.First.Value > 0
        ? Model.Filter.First.Value
        : (Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 16);
}

<div class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["ReasonSearch"]
            </h2>
        </div>
    </div>

    <form method="get" action="/Reason/List" class="w-full max-w-4xl mx-auto text-left">
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["MainCriteria"]</h3>
            </div>
            <div class="px-4 py-5 sm:p-6 space-y-6 mobile-stack-form">
                <div class="space-y-4">

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                        <label class="md:col-span-4 text-sm font-medium text-gray-700 md:text-right">@Localizer["Code"]</label>
                        <input type="text"
                               name="Code"
                               value="@Model.Filter.Code"
                               maxlength="8"
                               class="md:col-span-4 shadow-sm border-gray-300 rounded-md sm:text-sm uppercase">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                        <label class="md:col-span-4 text-sm font-medium text-gray-700 md:text-right">@Localizer["Category"]</label>
                        <select name="ReasonCatId" class="md:col-span-4 shadow-sm border-gray-300 rounded-md sm:text-sm">
                            <option value="">@Localizer["AllOption"]</option>
                            @foreach (var option in Model.ReasonCatOptions)
                            {
                                if (Model.Filter.ReasonCatId == option.Id)
                                {
                                    <option value="@option.Id" selected>@option.Name</option>
                                }
                                else
                                {
                                    <option value="@option.Id">@option.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
                        <label class="md:col-span-4 text-sm font-medium text-gray-700 md:text-right">@Localizer["Invalid"]</label>
                        <select name="IsInvalid" class="md:col-span-4 shadow-sm border-gray-300 rounded-md sm:text-sm">
                            <option value="">@Localizer["AllOption"]</option>
                            @if (Model.Filter.IsInvalid == false)
                            {
                                <option value="false" selected>@Localizer["No"]</option>
                            }
                            else
                            {
                                <option value="false">@Localizer["No"]</option>
                            }

                            @if (Model.Filter.IsInvalid == true)
                            {
                                <option value="true" selected>@Localizer["Yes"]</option>
                            }
                            else
                            {
                                <option value="true">@Localizer["Yes"]</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="pt-6 border-t border-gray-200">
                    <div class="flex flex-wrap items-center justify-center gap-3 responsive-inline-group">
                        <label class="text-sm text-blue-900 font-semibold">@Localizer["First"]</label>
                        <input type="number" name="First" value="@firstValue" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <label class="text-sm text-blue-900 font-semibold">@Localizer["PageSize"]</label>
                        <input type="number" name="PageSize" value="@(Model.Filter.PageSize <= 0 ? 16 : Model.Filter.PageSize)" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <input type="hidden" name="Page" value="1">

                        <button type="submit" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                            @Localizer["Search"]
                        </button>
                        <a href="/Reason" class="inline-flex items-center px-4 py-1 border border-gray-300 text-sm font-medium rounded shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                            @Localizer["Clear"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (canAdd)
    {
        <div class="text-center mt-10">
            <h2 class="text-xl font-bold text-orange-600 mb-4">@Localizer["ReasonCreation"]</h2>
            <div class="bg-gradient-to-b from-white to-blue-50 shadow sm:rounded-lg border border-gray-200 inline-block w-full max-w-4xl overflow-hidden">
                <div class="px-4 py-3 bg-blue-100 border-b border-blue-200 text-left">
                    <h3 class="text-lg font-semibold text-gray-800">@Localizer["PreInformation"]</h3>
                </div>
                <form method="get" action="/Reason/Create" class="p-6 space-y-4 mobile-stack-form">

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                        <label class="md:col-span-4 text-gray-700 font-medium md:text-right">@Localizer["Code"]</label>
                        <div class="md:col-span-8">
                            <input type="text" name="code" value="@Model.CreateCode" maxlength="8" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm uppercase">
                        </div>

                        <label class="md:col-span-4 text-gray-700 font-medium md:text-right">@Localizer["Category"]</label>
                        <div class="md:col-span-8">
                            <select name="reasonCatId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                                <option value="">@Localizer["SelectPrompt"]</option>
                                @foreach (var option in Model.ReasonCatOptions)
                                {
                                    if (Model.CreateReasonCatId == option.Id)
                                    {
                                        <option value="@option.Id" selected>@option.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@option.Id">@option.Name</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="pt-2 flex justify-center">
                        <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                            @Localizer["Reason"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
