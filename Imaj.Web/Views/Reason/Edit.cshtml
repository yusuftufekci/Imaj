@using System.Net
@using System.Text.Json
@using System.Collections.Generic
@model ReasonEditViewModel

@{
    ViewData["Title"] = "Gerekce Degistir";
    var selectedIds = Model.SelectedIds ?? new List<string>();

    var initialState = new
    {
        names = Model.Names.Select(x => new
        {
            languageId = x.LanguageId,
            name = x.Name
        }),
        languages = Model.Languages.Select(x => new
        {
            id = x.Id,
            name = x.Name
        }),
        reasonCats = Model.ReasonCatOptions.Select(x => new
        {
            id = x.Id,
            name = x.Name
        }),
        form = new
        {
            reasonCatId = Model.ReasonCatId,
            code = Model.Code,
            isInvalid = Model.IsInvalid,
            automaticForward = Model.AutomaticForward
        }
    };

    string BuildEditUrl(int index)
    {
        if (selectedIds.Count == 0)
        {
            return "#";
        }

        if (index < 0)
        {
            index = 0;
        }

        if (index >= selectedIds.Count)
        {
            index = selectedIds.Count - 1;
        }

        var selected = selectedIds[index];
        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/Reason/Edit?id={WebUtility.UrlEncode(selected)}&currentIndex={index}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    string BuildDetailUrl()
    {
        var targetId = Model.Id?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
        var url = $"/Reason/Detail?id={WebUtility.UrlEncode(targetId)}";

        if (selectedIds.Count > 0)
        {
            var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
            url += $"&currentIndex={Model.CurrentIndex}&selectedIds={idsQuery}";
        }

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }
}

<div x-data='reasonEditorPage(@Html.Raw(JsonSerializer.Serialize(initialState)))' class="space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">Gerekce</h2>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="rounded-md bg-red-50 border border-red-200 p-4">
            <div asp-validation-summary="All" class="text-sm text-red-700"></div>
        </div>
    }

    <form method="post" action="/Reason/Update" class="space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

        @foreach (var selectedId in selectedIds)
        {
            <input type="hidden" name="SelectedIds" value="@selectedId" />
        }

        <div class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">Gerekce</h3>
            </div>

            <div class="p-4 space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Kod</label>
                    <div class="md:col-span-9">
                        <input type="text" name="Code" x-model="form.code" maxlength="8" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm uppercase">
                    </div>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Kategori</label>
                    <div class="md:col-span-9">
                        <select name="ReasonCatId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                            <option value="">Seciniz</option>
                            @foreach (var option in Model.ReasonCatOptions)
                            {
                                var selected = Model.ReasonCatId.HasValue && Model.ReasonCatId.Value == option.Id;
                                <option value="@option.Id" selected="@(selected ? "selected" : null)">@option.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Dil</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Ad</th>
                                <th class="px-4 py-2 text-right text-xs font-semibold text-gray-700 uppercase w-24">Islem</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            <template x-for="(nameItem, index) in names" :key="index">
                                <tr>
                                    <td class="px-4 py-2">
                                        <select :name="'Names[' + index + '].LanguageId'" x-model.number="nameItem.languageId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                                            <template x-for="language in languages" :key="language.id">
                                                <option :value="language.id" x-text="language.name"></option>
                                            </template>
                                        </select>
                                    </td>
                                    <td class="px-4 py-2">
                                        <input type="text"
                                               :name="'Names[' + index + '].Name'"
                                               x-model="nameItem.name"
                                               maxlength="32"
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm"
                                               placeholder="Gerekce adi">
                                    </td>
                                    <td class="px-4 py-2 text-right">
                                        <button type="button" @@click="removeLanguage(index)" class="text-red-600 font-semibold hover:underline">Sil</button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>

                <div class="text-sm">
                    <button type="button" @@click="addLanguage" class="text-blue-700 font-semibold hover:underline">Dil Ekle</button>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Gecersiz</label>
                    <div class="md:col-span-3">
                        <input type="checkbox" name="IsInvalid" value="true" x-model="form.isInvalid" class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                    </div>
                </div>
            </div>
        </div>

        <partial name="_DetailNavigator" model="@(new DetailNavigatorViewModel
        {
            Header = "Gerekce Navigasyonu",
            CurrentIndex = Model.CurrentIndex,
            TotalCount = Model.TotalSelected,
            FirstUrl = BuildEditUrl(0),
            PreviousUrl = BuildEditUrl(Model.CurrentIndex - 1),
            NextUrl = BuildEditUrl(Model.CurrentIndex + 1),
            LastUrl = BuildEditUrl(selectedIds.Count - 1),
            FormAction = "/Reason/Edit",
            SelectedIds = selectedIds,
            ReturnUrl = Model.ReturnUrl
        })" />

        <div class="flex items-center justify-center gap-3">
            <label class="inline-flex items-center text-sm text-gray-700">
                <input type="checkbox" name="AutomaticForward" value="true" x-model="form.automaticForward" class="mr-2 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                Otomatik Ilerle
            </label>

            <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                Degistir
            </button>
            <a href="@BuildDetailUrl()" class="inline-flex items-center px-6 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                Geri
            </a>
        </div>
    </form>
</div>

<script>
    function reasonEditorPage(initialState) {
        return {
            languages: initialState.languages || [],
            reasonCats: initialState.reasonCats || [],
            names: (initialState.names && initialState.names.length > 0)
                ? initialState.names
                : [{ languageId: (initialState.languages && initialState.languages.length > 0 ? initialState.languages[0].id : 1), name: '' }],
            form: {
                reasonCatId: (initialState.form && initialState.form.reasonCatId) ? Number(initialState.form.reasonCatId) : '',
                code: (initialState.form && initialState.form.code) ? initialState.form.code : '',
                isInvalid: !!(initialState.form && initialState.form.isInvalid),
                automaticForward: !!(initialState.form && initialState.form.automaticForward)
            },

            addLanguage() {
                this.names.push({
                    languageId: this.getNextLanguageId(),
                    name: ''
                });
            },

            removeLanguage(index) {
                if (this.names.length === 1) {
                    this.names[0].name = '';
                    return;
                }

                this.names.splice(index, 1);
            },

            getNextLanguageId() {
                if (!this.languages || this.languages.length === 0) {
                    return 1;
                }

                const usedLanguageIds = new Set(this.names.map(x => Number(x.languageId)));
                const available = this.languages.find(x => !usedLanguageIds.has(Number(x.id)));
                return available ? Number(available.id) : Number(this.languages[0].id);
            }
        };
    }
</script>
