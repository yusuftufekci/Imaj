@using System.Net
@using System.Collections.Generic
@using Imaj.Web.Authorization
@model EmployeePageDetailViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["Employee"];
    var canEdit = await PermissionViewService.CanExecuteMethodAsync(1220);
    var selectedIds = Model.SelectedIds ?? new List<string>();

    string BuildDetailUrl(int index)
    {
        if (selectedIds.Count == 0)
        {
            return "#";
        }

        if (index < 0)
        {
            index = 0;
        }

        if (index >= selectedIds.Count)
        {
            index = selectedIds.Count - 1;
        }

        var selected = selectedIds[index];
        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/Employee/Detail?id={WebUtility.UrlEncode(selected)}&currentIndex={index}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    string BuildEditUrl()
    {
        var targetId = Model.Id?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
        if (selectedIds.Count > 0)
        {
            targetId = selectedIds[Model.CurrentIndex];
        }

        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/Employee/Edit?id={WebUtility.UrlEncode(targetId)}&currentIndex={Model.CurrentIndex}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    var firstUrl = BuildDetailUrl(0);
    var previousUrl = BuildDetailUrl(Model.CurrentIndex - 1);
    var nextUrl = BuildDetailUrl(Model.CurrentIndex + 1);
    var lastUrl = BuildDetailUrl(selectedIds.Count - 1);

    var navigatorModel = new DetailNavigatorViewModel
    {
        CurrentIndex = Model.CurrentIndex,
        TotalCount = Model.TotalSelected,
        FirstUrl = firstUrl,
        PreviousUrl = previousUrl,
        NextUrl = nextUrl,
        LastUrl = lastUrl,
        FormAction = "/Employee/Detail",
        SelectedIds = selectedIds,
        ReturnUrl = Model.ReturnUrl
    };
}

<div class="space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">@Localizer["Employee"]</h2>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["BasicInfo"]</h3>
            </div>
            <div class="p-4 grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Code"]</span>
                <span class="md:col-span-8 text-gray-900">@Model.Code</span>

                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Name"]</span>
                <span class="md:col-span-8 text-gray-900">@Model.Name</span>

                <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">@Localizer["Invalid"]</span>
                <span class="md:col-span-8">
                    <input type="checkbox" disabled @(Model.IsInvalid ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded" />
                </span>
            </div>
        </section>

        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["Function"] (@Model.Functions.Count)</h3>
            </div>
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase w-12">@Localizer["Selected"]</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                        <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase">@Localizer["WorkAmountUpdate"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @if (Model.Functions.Count > 0)
                    {
                        foreach (var item in Model.Functions)
                        {
                            <tr>
                                <td class="px-4 py-2"><input type="checkbox" disabled class="h-4 w-4 text-gray-400 border-gray-300 rounded" /></td>
                                <td class="px-4 py-2 text-sm text-gray-900">@item.FunctionName</td>
                                <td class="px-4 py-2 text-center"><input type="checkbox" disabled @(item.WorkAmountUpdate ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded" /></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="px-4 py-2 bg-gray-50 border-t border-gray-200 flex items-center gap-2 text-sm">
                <span class="text-blue-900 font-semibold">@Localizer["PageSize"]</span>
                <span class="w-10 text-center border border-gray-300 rounded bg-white">16</span>
                <span class="text-blue-700 font-semibold">@Localizer["Add"]</span>
            </div>
        </section>

        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["WorkType"] (@Model.WorkTypes.Count)</h3>
            </div>
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase w-12">@Localizer["Selected"]</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                        <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase">@Localizer["DefaultValue"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @if (Model.WorkTypes.Count > 0)
                    {
                        foreach (var item in Model.WorkTypes)
                        {
                            <tr>
                                <td class="px-4 py-2"><input type="checkbox" disabled class="h-4 w-4 text-gray-400 border-gray-300 rounded" /></td>
                                <td class="px-4 py-2 text-sm text-gray-900">@item.WorkTypeName</td>
                                <td class="px-4 py-2 text-center"><input type="checkbox" disabled @(item.IsDefault ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded" /></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="px-4 py-2 bg-gray-50 border-t border-gray-200 flex items-center gap-2 text-sm">
                <span class="text-blue-900 font-semibold">@Localizer["PageSize"]</span>
                <span class="w-10 text-center border border-gray-300 rounded bg-white">16</span>
                <span class="text-blue-700 font-semibold">@Localizer["Add"]</span>
            </div>
        </section>

        <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["OvertimeType"] (@Model.TimeTypes.Count)</h3>
            </div>
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase w-12">@Localizer["Selected"]</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                        <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase">@Localizer["DefaultValue"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    @if (Model.TimeTypes.Count > 0)
                    {
                        foreach (var item in Model.TimeTypes)
                        {
                            <tr>
                                <td class="px-4 py-2"><input type="checkbox" disabled class="h-4 w-4 text-gray-400 border-gray-300 rounded" /></td>
                                <td class="px-4 py-2 text-sm text-gray-900">@item.TimeTypeName</td>
                                <td class="px-4 py-2 text-center"><input type="checkbox" disabled @(item.IsDefault ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded" /></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="px-4 py-4 text-sm text-gray-500 text-center">@Localizer["NoRecordsFound"]</td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="px-4 py-2 bg-gray-50 border-t border-gray-200 flex items-center gap-2 text-sm">
                <span class="text-blue-900 font-semibold">@Localizer["PageSize"]</span>
                <span class="w-10 text-center border border-gray-300 rounded bg-white">16</span>
                <span class="text-blue-700 font-semibold">@Localizer["Add"]</span>
            </div>
        </section>
    </div>

    @if (Model.TotalSelected > 0)
    {
        <partial name="~/Views/Shared/_DetailNavigator.cshtml" model="navigatorModel" />
    }

    <div class="flex items-center justify-center gap-3">
        @if (canEdit)
        {
            <a href="@BuildEditUrl()" class="inline-flex items-center px-5 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none">
                @Localizer["Edit"]
            </a>
        }
        <a href="@Model.ReturnUrl" class="inline-flex items-center px-5 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
            @Localizer["Back"]
        </a>
    </div>
</div>
