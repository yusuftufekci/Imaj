@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Home"];
}

<div class="space-y-8">
    <!-- Welcome Section -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8 flex flex-col md:flex-row md:items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">@Localizer["Welcome"], <span class="text-red-600">@User.Identity?.Name</span></h1>
            <p class="mt-2 text-lg text-gray-600">@Localizer["PanelTitle"]</p>
        </div>
        <div class="mt-4 md:mt-0">
             <span class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 FOCUS:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                @Localizer["TodaysDate"]: @DateTime.Now.ToString("dd MMMM yyyy")
            </span>
        </div>
    </div>
</div>
