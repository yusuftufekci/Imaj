@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Home"];
}

<div class="space-y-8">
    <!-- Welcome Section -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8 flex flex-col md:flex-row md:items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">@Localizer["Welcome"], <span class="text-red-600">@User.Identity?.Name</span></h1>
            <p class="mt-2 text-lg text-gray-600">@Localizer["PanelTitle"]</p>
        </div>
        <div class="mt-4 md:mt-0">
             <span class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-red-600 hover:bg-red-700 FOCUS:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                @Localizer["TodaysDate"]: @DateTime.Now.ToString("dd MMMM yyyy")
            </span>
        </div>
    </div>

    <!-- Quick Access / Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Takvim -->
        <a href="#" class="block group">
             <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md hover:border-red-300 transition-all duration-200 h-full">
                <div class="flex items-center justify-between mb-4">
                    <div class="bg-indigo-50 p-3 rounded-full group-hover:bg-indigo-100 transition-colors">
                        <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-red-600 transition-colors">@Localizer["Calendar"]</h3>
                <p class="mt-1 text-sm text-gray-500">@Localizer["CalendarDesc"]</p>
            </div>
        </a>

        <!-- Müşteri -->
        <a href="/Customer" class="block group">
             <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md hover:border-red-300 transition-all duration-200 h-full">
                <div class="flex items-center justify-between mb-4">
                    <div class="bg-green-50 p-3 rounded-full group-hover:bg-green-100 transition-colors">
                         <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    </div>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-red-600 transition-colors">@Localizer["Customers"]</h3>
                <p class="mt-1 text-sm text-gray-500">@Localizer["CustomerDesc"]</p>
            </div>
        </a>

        <!-- Rezervasyon -->
         <a href="#" class="block group">
             <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md hover:border-red-300 transition-all duration-200 h-full">
                <div class="flex items-center justify-between mb-4">
                    <div class="bg-orange-50 p-3 rounded-full group-hover:bg-orange-100 transition-colors">
                        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-red-600 transition-colors">@Localizer["Reservations"]</h3>
                <p class="mt-1 text-sm text-gray-500">@Localizer["ReservationDesc"]</p>
            </div>
        </a>

        <!-- İşler -->
         <a href="/Job" class="block group">
             <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-200 hover:shadow-md hover:border-red-300 transition-all duration-200 h-full">
                <div class="flex items-center justify-between mb-4">
                    <div class="bg-blue-50 p-3 rounded-full group-hover:bg-blue-100 transition-colors">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                </div>
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-red-600 transition-colors">@Localizer["JobTracking"]</h3>
                <p class="mt-1 text-sm text-gray-500">@Localizer["JobDesc"]</p>
            </div>
        </a>
    </div>

    <!-- Stats Section -->
    <div class="bg-white shadow-sm border border-gray-200 rounded-lg overflow-hidden">
        <div class="px-4 py-5 sm:px-6 border-b border-gray-200">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
                @Localizer["SystemStatus"]
            </h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
            <dl class="grid grid-cols-1 gap-5 sm:grid-cols-3">
                <div class="px-4 py-5 bg-gray-50 shadow-sm rounded-lg overflow-hidden sm:p-6 border border-gray-100">
                    <dt class="text-sm font-medium text-gray-500 truncate">
                        @Localizer["ActiveProjects"]
                    </dt>
                    <dd class="mt-1 text-3xl font-semibold text-gray-900">
                        12
                    </dd>
                </div>
                <div class="px-4 py-5 bg-gray-50 shadow-sm rounded-lg overflow-hidden sm:p-6 border border-gray-100">
                    <dt class="text-sm font-medium text-gray-500 truncate">
                        @Localizer["PendingTasks"]
                    </dt>
                    <dd class="mt-1 text-3xl font-semibold text-gray-900">
                        4
                    </dd>
                </div>
                <div class="px-4 py-5 bg-gray-50 shadow-sm rounded-lg overflow-hidden sm:p-6 border border-gray-100">
                    <dt class="text-sm font-medium text-gray-500 truncate">
                        @Localizer["CompletedTasksThisMonth"]
                    </dt>
                    <dd class="mt-1 text-3xl font-semibold text-gray-900">
                        24
                    </dd>
                </div>
            </dl>
        </div>
    </div>
</div>
