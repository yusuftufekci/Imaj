@using System.Net
@using System.Collections.Generic
@using System.Globalization
@model ResoCatEditViewModel

@{
    ViewData["Title"] = Localizer["ResoCat"];
    var selectedIds = Model.SelectedIds ?? new List<string>();
    var languageNameById = Model.Languages
        .GroupBy(x => x.Id)
        .ToDictionary(x => x.Key, x => x.First().Name);

    string BuildDetailUrl()
    {
        var targetId = Model.Id?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
        if (selectedIds.Count > 0)
        {
            targetId = selectedIds[Model.CurrentIndex];
        }

        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/ResoCat/Detail?id={WebUtility.UrlEncode(targetId)}&currentIndex={Model.CurrentIndex}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    string ResolveLanguageName(ResoCatLocalizedNameViewModel localizedName)
    {
        if (!string.IsNullOrWhiteSpace(localizedName.LanguageName))
        {
            return localizedName.LanguageName;
        }

        if (languageNameById.TryGetValue(localizedName.LanguageId, out var languageName) &&
            !string.IsNullOrWhiteSpace(languageName))
        {
            return languageName;
        }

        return localizedName.LanguageId > 0
            ? localizedName.LanguageId.ToString(CultureInfo.InvariantCulture)
            : string.Empty;
    }
}

<div class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["ResoCat"]
            </h2>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="rounded-md bg-red-50 border border-red-200 p-4">
            <div asp-validation-summary="All" class="text-sm text-red-700"></div>
        </div>
    }

    <form method="post" action="/ResoCat/Update" class="space-y-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model.Id" />
        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />

        @foreach (var selectedId in selectedIds)
        {
            <input type="hidden" name="SelectedIds" value="@selectedId" />
        }

        <div class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 pt-4 sm:px-6">
                <h3 class="text-md font-bold text-gray-700 bg-blue-100 p-2 rounded">@Localizer["ResoCat"]</h3>
            </div>
            <div class="px-4 pb-5 sm:px-6 sm:pb-6">
                <div class="mt-4 overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200 resocat-names-table">
                        <colgroup>
                            <col class="resocat-names-language-col" />
                            <col />
                            <col class="resocat-names-action-col" />
                        </colgroup>
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Language"]</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">@Localizer["Name"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            @for (var index = 0; index < Model.Names.Count; index++)
                            {
                                var localizedName = Model.Names[index];
                                var languageName = ResolveLanguageName(localizedName);

                                <tr>
                                    <td class="px-4 py-2">
                                        <input type="hidden" name="Names[@index].LanguageId" value="@localizedName.LanguageId" />
                                        <input type="text"
                                               value="@languageName"
                                               readonly
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm bg-gray-100 text-gray-700 cursor-not-allowed">
                                    </td>
                                    <td class="px-4 py-2">
                                        <input type="text"
                                               name="Names[@index].Name"
                                               value="@localizedName.Name"
                                               maxlength="32"
                                               class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm"
                                               placeholder="@Localizer["Name"]">
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">@Localizer["Invalid"]</label>
                    <div class="md:col-span-3">
                        <input asp-for="IsInvalid" class="h-4 w-4 text-indigo-600 border-gray-300 rounded" />
                    </div>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-center gap-4 py-2 flex-wrap">
            <label class="inline-flex items-center text-sm text-gray-700">
                <input asp-for="AutomaticForward" class="mr-2 h-4 w-4 text-indigo-600 border-gray-300 rounded" />
                @Localizer["AutomaticForward"]
            </label>

            <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                @Localizer["Edit"]
            </button>
            <a href="@BuildDetailUrl()" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
