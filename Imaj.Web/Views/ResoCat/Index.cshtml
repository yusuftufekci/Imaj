@using Imaj.Web.Authorization
@model ResoCatIndexViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["ResoCat"];
    var canAdd = await PermissionViewService.CanExecuteMethodAsync(989);
    var firstValue = Model.Filter.First.HasValue && Model.Filter.First.Value > 0
        ? Model.Filter.First.Value
        : (Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 16);
}

<div class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["ResourceCategorySearch"]
            </h2>
        </div>
    </div>

    <form method="get" action="/ResoCat/List" class="w-full max-w-4xl mx-auto text-left">
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["MainCriteria"]</h3>
            </div>
            <div class="px-4 py-5 sm:p-6 space-y-6 mobile-stack-form">
                <div class="space-y-4">

                    <div class="grid grid-cols-12 gap-4 items-center">
                        <label class="col-span-4 lg:col-start-2 text-right text-sm font-medium text-gray-700">@Localizer["Invalid"]</label>
                        <div class="col-span-8 lg:col-span-5">
                            <select name="IsInvalid" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                <option value="">@Localizer["AllOption"]</option>
                                @if (Model.Filter.IsInvalid == false)
                                {
                                    <option value="false" selected>@Localizer["No"]</option>
                                }
                                else
                                {
                                    <option value="false">@Localizer["No"]</option>
                                }

                                @if (Model.Filter.IsInvalid == true)
                                {
                                    <option value="true" selected>@Localizer["Yes"]</option>
                                }
                                else
                                {
                                    <option value="true">@Localizer["Yes"]</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                <div class="pt-6 border-t border-gray-200">
                    <div class="flex flex-wrap items-center justify-center gap-3 responsive-inline-group">
                        <label class="text-sm text-blue-900 font-semibold">@Localizer["First"]</label>
                        <input type="number" name="First" value="@firstValue" min="1" class="w-20 shadow-sm border-gray-300 rounded-md sm:text-sm text-center">
                        <label class="text-sm text-blue-900 font-semibold">@Localizer["PageSize"]</label>
                        <input type="number" name="PageSize" value="@(Model.Filter.PageSize <= 0 ? 16 : Model.Filter.PageSize)" min="1" class="w-20 shadow-sm border-gray-300 rounded-md sm:text-sm text-center">
                        <input type="hidden" name="Page" value="1">

                        <button type="submit" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                            @Localizer["Search"]
                        </button>
                        <a href="/ResoCat" class="inline-flex items-center px-4 py-1 border border-gray-300 text-sm font-medium rounded shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                            @Localizer["Clear"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>

    @if (canAdd)
    {
        <div class="text-center mt-10">
            <h2 class="text-xl font-bold text-orange-600 mb-4">@Localizer["ResourceCategoryCreation"]</h2>
            <div class="bg-gradient-to-b from-white to-blue-50 shadow sm:rounded-lg border border-gray-200 inline-block w-full max-w-4xl p-6">
                <div class="pt-2 flex justify-center">
                    <a href="/ResoCat/Create" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["CreateNewResourceCategory"]
                    </a>
                </div>
            </div>
        </div>
    }
</div>
