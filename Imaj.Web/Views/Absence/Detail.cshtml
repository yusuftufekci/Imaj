@using System.Net
@using System.Collections.Generic
@using System.Globalization
@model AbsenceDetailViewModel

@{
    ViewData["Title"] = "Mazeret";
    var selectedIds = Model.SelectedIds ?? new List<string>();

    string BuildDetailUrl(int index)
    {
        if (selectedIds.Count == 0)
        {
            return "#";
        }

        if (index < 0)
        {
            index = 0;
        }
        if (index >= selectedIds.Count)
        {
            index = selectedIds.Count - 1;
        }

        var selected = selectedIds[index];
        var idsQuery = string.Join("&selectedIds=", selectedIds.Select(WebUtility.UrlEncode));
        var url = $"/Absence/Detail?id={WebUtility.UrlEncode(selected)}&currentIndex={index}&selectedIds={idsQuery}";

        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }

        return url;
    }

    var firstUrl = BuildDetailUrl(0);
    var previousUrl = BuildDetailUrl(Model.CurrentIndex - 1);
    var nextUrl = BuildDetailUrl(Model.CurrentIndex + 1);
    var lastUrl = BuildDetailUrl(selectedIds.Count - 1);

    var navigatorModel = new DetailNavigatorViewModel
    {
        CurrentIndex = Model.CurrentIndex,
        TotalCount = Model.TotalSelected,
        FirstUrl = firstUrl,
        PreviousUrl = previousUrl,
        NextUrl = nextUrl,
        LastUrl = lastUrl,
        FormAction = "/Absence/Detail",
        SelectedIds = selectedIds,
        ReturnUrl = Model.ReturnUrl
    };

    var uiCulture = CultureInfo.CurrentUICulture;
}

<div class="space-y-6">
    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">Rezervasyon / Mazeret</h2>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
        <section class="xl:col-span-2 bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">Temel Bilgiler</h3>
            </div>

            <div class="p-4 space-y-3 text-sm">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center">
                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Fonksiyon</span>
                    <span class="md:col-span-8 text-gray-900">@Model.FunctionName</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Baslangic Tarihi</span>
                    <span class="md:col-span-8 text-gray-900">@Model.StartDate.ToString("dd/MM/yyyy HH:mm dddd", uiCulture)</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Bitis Tarihi</span>
                    <span class="md:col-span-8 text-gray-900">@Model.EndDate.ToString("dd/MM/yyyy HH:mm dddd", uiCulture)</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Gerekce</span>
                    <span class="md:col-span-8 text-gray-900">@Model.ReasonName</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Ad</span>
                    <span class="md:col-span-8 text-gray-900">@Model.Name</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Ilgili</span>
                    <span class="md:col-span-8 text-gray-900">@Model.Contact</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Durum</span>
                    <span class="md:col-span-8 text-gray-900">@Model.StateName</span>

                    <span class="md:col-span-4 text-blue-900 font-semibold md:text-right">Degerlendirildi</span>
                    <span class="md:col-span-8">
                        <input type="checkbox" disabled @(Model.Evaluated ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                    </span>
                </div>
            </div>
        </section>

        <section class="xl:col-span-1 bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                <h3 class="text-lg font-semibold text-gray-800">Notlar</h3>
            </div>

            <div class="p-4">
                <textarea readonly class="w-full h-44 shadow-sm border-gray-300 rounded-md sm:text-sm bg-gray-50">@Model.Notes</textarea>
            </div>
        </section>
    </div>

    <section class="bg-white border border-gray-200 shadow sm:rounded-lg overflow-hidden">
        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
            <h3 class="text-lg font-semibold text-gray-800">Kaynak (@Model.Resources.Count)</h3>
        </div>

        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Kod</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Ad</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Fonksiyon</th>
                        <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Kategori</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200 bg-white">
                    @if (Model.Resources.Count > 0)
                    {
                        foreach (var resource in Model.Resources)
                        {
                            <tr>
                                <td class="px-4 py-2 text-sm text-gray-900">@resource.Code</td>
                                <td class="px-4 py-2 text-sm text-gray-900">@resource.Name</td>
                                <td class="px-4 py-2 text-sm text-gray-900">@resource.FunctionName</td>
                                <td class="px-4 py-2 text-sm text-gray-900">@resource.ResoCatName</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-4 py-4 text-sm text-gray-500 text-center">Kayit yok.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @if (Model.TotalSelected > 0)
    {
        <partial name="~/Views/Shared/_DetailNavigator.cshtml" model="navigatorModel" />
    }

    <div class="flex items-center justify-center gap-3">
        <a href="@Model.ReturnUrl" class="inline-flex items-center px-5 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
            Geri
        </a>
    </div>
</div>
