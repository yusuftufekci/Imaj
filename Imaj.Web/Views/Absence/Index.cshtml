@using System.Text.Json
@using Imaj.Web.Authorization
@model AbsenceIndexViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = "Mazeret Sorgulama";
    var canAdd = await PermissionViewService.CanExecuteMethodAsync(1086);

    var initialState = new
    {
        filterResourceIds = Model.Filter.ResourceIds,
        functionOptions = Model.FunctionOptions.Select(x => new
        {
            id = x.Id,
            name = x.Name
        })
    };
}

<div x-data='absenceIndexPage(@Html.Raw(JsonSerializer.Serialize(initialState)))'
     @@absence-resource-selected.window="handleResourceSelection($event.detail)"
     class="space-y-8">

    <div class="text-center">
        <h2 class="text-3xl font-bold text-orange-600">Mazeret Sorgulama</h2>
    </div>

    <form method="get" action="/Absence/List" class="bg-white border border-gray-200 shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6 space-y-4">
            <div class="bg-blue-50 p-4 rounded-md border border-blue-200 max-w-5xl mx-auto">
                <h3 class="text-lg font-semibold text-gray-700 mb-4 border-b border-blue-200 pb-2">Mazeret Kriterleri</h3>

                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Fonksiyon</label>
                    <select name="FunctionId" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">Tumu</option>
                        @foreach (var option in Model.FunctionOptions)
                        {
                            if (Model.Filter.FunctionId == option.Id)
                            {
                                <option value="@option.Id" selected>@option.Name</option>
                            }
                            else
                            {
                                <option value="@option.Id">@option.Name</option>
                            }
                        }
                    </select>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Gerekce</label>
                    <select name="ReasonId" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">Tumu</option>
                        @foreach (var option in Model.ReasonOptions)
                        {
                            if (Model.Filter.ReasonId == option.Id)
                            {
                                <option value="@option.Id" selected>@option.Name</option>
                            }
                            else
                            {
                                <option value="@option.Id">@option.Name</option>
                            }
                        }
                    </select>
                </div>

                <div class="mt-3 grid grid-cols-1 md:grid-cols-12 gap-4 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Ad</label>
                    <input type="text"
                           name="Name"
                           value="@Model.Filter.Name"
                           maxlength="32"
                           class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Ilgili</label>
                    <input type="text"
                           name="Contact"
                           value="@Model.Filter.Contact"
                           maxlength="32"
                           class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                </div>

                <div class="mt-3 grid grid-cols-1 md:grid-cols-12 gap-4 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Baslangic Tarihi Araligi</label>
                    <div class="md:col-span-9 grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <input type="datetime-local"
                               name="StartDateFrom"
                               value="@(Model.Filter.StartDateFrom.HasValue ? Model.Filter.StartDateFrom.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)"
                               class="shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <input type="datetime-local"
                               name="StartDateTo"
                               value="@(Model.Filter.StartDateTo.HasValue ? Model.Filter.StartDateTo.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)"
                               class="shadow-sm border-gray-300 rounded-md sm:text-sm">
                    </div>
                </div>

                <div class="mt-3 grid grid-cols-1 md:grid-cols-12 gap-4 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Bitis Tarihi Araligi</label>
                    <div class="md:col-span-9 grid grid-cols-1 sm:grid-cols-2 gap-2">
                        <input type="datetime-local"
                               name="EndDateFrom"
                               value="@(Model.Filter.EndDateFrom.HasValue ? Model.Filter.EndDateFrom.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)"
                               class="shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <input type="datetime-local"
                               name="EndDateTo"
                               value="@(Model.Filter.EndDateTo.HasValue ? Model.Filter.EndDateTo.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)"
                               class="shadow-sm border-gray-300 rounded-md sm:text-sm">
                    </div>
                </div>

                <div class="mt-3 grid grid-cols-1 md:grid-cols-12 gap-4 items-center text-sm">
                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Durum</label>
                    <select name="StateId" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">Tumu</option>
                        @foreach (var option in Model.StateOptions)
                        {
                            if (Model.Filter.StateId == option.Id)
                            {
                                <option value="@option.Id" selected>@option.Name</option>
                            }
                            else
                            {
                                <option value="@option.Id">@option.Name</option>
                            }
                        }
                    </select>

                    <label class="md:col-span-3 text-blue-900 font-semibold md:text-right">Degerlendirildi</label>
                    <select name="Evaluated" class="md:col-span-3 shadow-sm border-gray-300 rounded-md sm:text-sm">
                        <option value="">Tumu</option>
                        @if (Model.Filter.Evaluated == false)
                        {
                            <option value="false" selected>Hayir</option>
                        }
                        else
                        {
                            <option value="false">Hayir</option>
                        }

                        @if (Model.Filter.Evaluated == true)
                        {
                            <option value="true" selected>@Localizer["Yes"]</option>
                        }
                        else
                        {
                            <option value="true">@Localizer["Yes"]</option>
                        }
                    </select>
                </div>
            </div>

            <div class="bg-blue-50 p-4 rounded-md border border-blue-200 max-w-5xl mx-auto">
                <h3 class="text-lg font-semibold text-gray-700 mb-4 border-b border-blue-200 pb-2">Kaynak Kriterleri</h3>

                <div class="flex flex-wrap items-center justify-center gap-3 text-sm">
                    <span class="text-blue-900 font-semibold">Kaynak</span>
                    <button type="button"
                            @@click="openFilterResourceModal"
                            class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                        Sec
                    </button>

                    <span class="text-gray-700" x-show="filterResourceIds.length > 0" x-text="`${filterResourceIds.length} kaynak secildi`"></span>

                    <button x-show="filterResourceIds.length > 0"
                            type="button"
                            @@click="clearFilterResources"
                            class="text-red-600 font-semibold hover:underline">
                        @Localizer["Clear"]
                    </button>

                    <template x-for="resourceId in filterResourceIds" :key="resourceId">
                        <input type="hidden" name="ResourceIds" :value="resourceId">
                    </template>
                </div>
            </div>

            <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
                <span class="text-sm text-blue-900 font-semibold">Ilk</span>
                <input type="number" name="Page" value="@(Model.Filter.Page <= 0 ? 1 : Model.Filter.Page)" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">
                <span class="text-sm text-blue-900 font-semibold">Sayfa Boyu</span>
                <input type="number" name="PageSize" value="@(Model.Filter.PageSize <= 0 ? 16 : Model.Filter.PageSize)" min="1" class="w-20 text-center shadow-sm border-gray-300 rounded-md sm:text-sm">

                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                    Sorgula
                </button>
                <button type="reset" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                    @Localizer["Clear"]
                </button>
            </div>
        </div>
    </form>

    @if (canAdd)
    {
        <div class="bg-white border border-gray-200 shadow sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6 max-w-5xl mx-auto space-y-4">
                <h3 class="text-3xl font-bold text-orange-600 text-center">Mazeret Yaratma</h3>

                <form method="get" action="/Absence/Create" class="bg-blue-50 p-4 rounded-md border border-blue-200">
                    <h4 class="text-lg font-semibold text-gray-700 mb-4 border-b border-blue-200 pb-2">On Bilgiler</h4>

                    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center text-sm">
                        <label class="md:col-span-4 text-blue-900 font-semibold md:text-right">Fonksiyon</label>
                        <div class="md:col-span-8">
                            <select name="functionId" class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                                <option value="">Seciniz</option>
                                @foreach (var option in Model.FunctionOptions)
                                {
                                    if (Model.CreateFunctionId == option.Id)
                                    {
                                        <option value="@option.Id" selected>@option.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@option.Id">@option.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <label class="md:col-span-4 text-blue-900 font-semibold md:text-right">Baslangic Tarihi</label>
                        <div class="md:col-span-8">
                            <input type="datetime-local"
                                   name="startDate"
                                   value="@(Model.CreateStartDate.HasValue ? Model.CreateStartDate.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)"
                                   class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                        </div>

                        <label class="md:col-span-4 text-blue-900 font-semibold md:text-right">Bitis Tarihi</label>
                        <div class="md:col-span-8">
                            <input type="datetime-local"
                                   name="endDate"
                                   value="@(Model.CreateEndDate.HasValue ? Model.CreateEndDate.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)"
                                   class="w-full shadow-sm border-gray-300 rounded-md sm:text-sm">
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                            Yeni Mazeret Yarat
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }

    <partial name="_AbsenceResourceSelectModal" />
</div>

@section Scripts {
    <script src="~/js/components/absence-resource-select-modal.js" asp-append-version="true"></script>
    <script>
        function absenceIndexPage(initialState) {
            return {
                functionOptions: initialState.functionOptions || [],
                filterResourceIds: (initialState.filterResourceIds || []).map(x => Number(x)).filter(x => x > 0),

                openFilterResourceModal() {
                    this.$dispatch('absence-resource-select-open', {
                        targetId: 'absence-filter-resources',
                        isMultiSelect: true,
                        excludeIds: this.filterResourceIds.join(','),
                        functionOptions: this.functionOptions
                    });
                },

                clearFilterResources() {
                    this.filterResourceIds = [];
                },

                handleResourceSelection(detail) {
                    if (!detail || detail.targetId !== 'absence-filter-resources') {
                        return;
                    }

                    const resources = detail.resources || [];
                    for (const resource of resources) {
                        const resourceId = Number(resource.resourceId);
                        if (resourceId > 0 && !this.filterResourceIds.includes(resourceId)) {
                            this.filterResourceIds.push(resourceId);
                        }
                    }
                }
            };
        }
    </script>
}
