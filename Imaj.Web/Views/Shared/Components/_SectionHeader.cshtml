@*
    Section Header Component
    Sayfa section başlıkları için reusable partial view
    
    Kullanım:
    <partial name="Components/_SectionHeader" model="new SectionHeaderModel { Title = \"@Localizer["CustomerSearch"]\", Subtitle = \"Alt başlık\" }" />
*@

@model Imaj.Web.Models.Components.SectionHeaderModel

<div class="@(Model.HasBorder ? "border-b pb-4 mb-4" : "mb-4")">
    <h3 class="text-lg leading-6 font-medium text-orange-600 @(Model.IsCentered ? "text-center" : "")">
        @Model.Title
    </h3>
    @if (!string.IsNullOrEmpty(Model.Subtitle))
    {
        <p class="mt-1 text-sm text-gray-500 @(Model.IsCentered ? "text-center" : "")">
            @Model.Subtitle
        </p>
    }
</div>
