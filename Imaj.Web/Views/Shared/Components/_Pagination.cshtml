@*
    Pagination Component
    Sayfalama için reusable partial view
    
    Kullanım:
    <partial name="Components/_Pagination" model="new PaginationModel { CurrentPage = 1, TotalCount = 100, PageSize = 20 }" />
    
    Özellikler:
    - İlk/Son sayfa butonları
    - Önceki/Sonraki sayfa butonları
    - Sayfa numaraları (mevcut sayfa etrafında 2 sayfa gösterir)
    - Toplam kayıt ve sayfa bilgisi
*@

@using Imaj.Web
@using Microsoft.Extensions.Localization
@model Imaj.Web.Models.Components.PaginationModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
    var showFirst = Model.CurrentPage > 1;
    var showPrevious = Model.CurrentPage > 1;
    var showNext = Model.CurrentPage < totalPages;
    var showLast = Model.CurrentPage < totalPages;

    var queryString = string.IsNullOrWhiteSpace(Model.QueryString) ? string.Empty : "?" + Model.QueryString;
    var separator = string.IsNullOrWhiteSpace(Model.QueryString) ? "?" : "&";
    string BuildUrl(int page) => $"{Model.BaseUrl}{queryString}{separator}page={page}&pageSize={Model.PageSize}";
}

<div class="bg-white px-4 py-3 border-t border-gray-200 sm:px-6">
    <!-- Mobile -->
    <div class="space-y-3 sm:hidden">
        <p class="text-center text-sm text-gray-700">
            @Localizer["Page"] <span class="font-medium">@Model.CurrentPage</span> / <span class="font-medium">@Math.Max(totalPages, 1)</span>
            · @Localizer["Total"] <span class="font-medium">@Model.TotalCount</span> @Localizer["Records"]
        </p>
        <div class="grid grid-cols-2 gap-2">
            @if (showPrevious)
            {
                <a href="@BuildUrl(Model.CurrentPage - 1)"
                   class="inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                    @Localizer["Previous"]
                </a>
            }
            else
            {
                <span class="inline-flex items-center justify-center px-4 py-2 border border-gray-200 text-sm font-medium rounded-md text-gray-400 bg-gray-50 cursor-not-allowed">
                    @Localizer["Previous"]
                </span>
            }

            @if (showNext)
            {
                <a href="@BuildUrl(Model.CurrentPage + 1)"
                   class="inline-flex items-center justify-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                    @Localizer["Next"]
                </a>
            }
            else
            {
                <span class="inline-flex items-center justify-center px-4 py-2 border border-gray-200 text-sm font-medium rounded-md text-gray-400 bg-gray-50 cursor-not-allowed">
                    @Localizer["Next"]
                </span>
            }
        </div>
    </div>
    
    <!-- Desktop -->
    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
        <div>
            <p class="text-sm text-gray-700">
                @Localizer["Total"] <span class="font-medium">@Model.TotalCount</span> @Localizer["Records"]
                @if (totalPages > 1)
                {
                    <text>, @Localizer["Page"] <span class="font-medium">@Model.CurrentPage</span> / <span class="font-medium">@totalPages</span></text>
                }
            </p>
        </div>
        <div>
            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                
                @* First Page Button *@
                @if (showFirst)
                {
                    <a href="@BuildUrl(1)" 
                       class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                       title="@Localizer["First"]">
                        <span class="sr-only">@Localizer["First"]</span>
                        <!-- Çift ok sola (<<) -->
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M15.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 010 1.414zm-6 0a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 1.414L5.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                        </svg>
                    </a>
                }
                else
                {
                    <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400 cursor-not-allowed">
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M15.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 010 1.414zm-6 0a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 1.414L5.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                        </svg>
                    </span>
                }
                
                @* Previous Page Button *@
                @if (showPrevious)
                {
                    <a href="@BuildUrl(Model.CurrentPage - 1)" 
                       class="relative inline-flex items-center px-2 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                       title="@Localizer["Previous"]">
                        <span class="sr-only">@Localizer["Previous"]</span>
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                    </a>
                }
                else
                {
                    <span class="relative inline-flex items-center px-2 py-2 border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400 cursor-not-allowed">
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                    </span>
                }
                
                @* Page Numbers *@
                @{
                    // Sayfa 1 her zaman göster
                    if (Model.CurrentPage > 3)
                    {
                        <a href="@BuildUrl(1)" 
                           class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                            1
                        </a>
                        
                        // Çok uzaksa "..." göster
                        if (Model.CurrentPage > 4)
                        {
                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">
                                ...
                            </span>
                        }
                    }
                    
                    // Mevcut sayfa etrafındaki sayfalar
                    for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(totalPages, Model.CurrentPage + 2); i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <span class="relative inline-flex items-center px-4 py-2 border border-indigo-500 bg-indigo-50 text-sm font-medium text-indigo-600">
                                @i
                            </span>
                        }
                        else
                        {
                            <a href="@BuildUrl(i)" 
                               class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                                @i
                            </a>
                        }
                    }
                    
                    // Son sayfa her zaman göster
                    if (Model.CurrentPage < totalPages - 2)
                    {
                        // Çok uzaksa "..." göster
                        if (Model.CurrentPage < totalPages - 3)
                        {
                            <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">
                                ...
                            </span>
                        }
                        
                        <a href="@BuildUrl(totalPages)" 
                           class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50">
                            @totalPages
                        </a>
                    }
                }
                
                @* Next Page Button *@
                @if (showNext)
                {
                    <a href="@BuildUrl(Model.CurrentPage + 1)" 
                       class="relative inline-flex items-center px-2 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                       title="@Localizer["Next"]">
                        <span class="sr-only">@Localizer["Next"]</span>
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                        </svg>
                    </a>
                }
                else
                {
                    <span class="relative inline-flex items-center px-2 py-2 border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400 cursor-not-allowed">
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                        </svg>
                    </span>
                }
                
                @* Last Page Button *@
                @if (showLast)
                {
                    <a href="@BuildUrl(totalPages)" 
                       class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                       title="@Localizer["Last"]">
                        <span class="sr-only">@Localizer["Last"]</span>
                        <!-- Çift ok sağa (>>) -->
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M10.293 15.707a1 1 0 010-1.414L14.586 10l-4.293-4.293a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                            <path fill-rule="evenodd" d="M4.293 15.707a1 1 0 010-1.414L8.586 10 4.293 5.707a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                        </svg>
                    </a>
                }
                else
                {
                    <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400 cursor-not-allowed">
                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M10.293 15.707a1 1 0 010-1.414L14.586 10l-4.293-4.293a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                            <path fill-rule="evenodd" d="M4.293 15.707a1 1 0 010-1.414L8.586 10 4.293 5.707a1 1 0 111.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                        </svg>
                    </span>
                }
                
            </nav>
        </div>
    </div>
</div>
