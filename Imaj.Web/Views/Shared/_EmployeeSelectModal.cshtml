
<!-- Employee Selection Modal -->
<div x-data="employeeSelectModal()" @@employee-select-open.window="openModal($event.detail)" x-show="isOpen" class="fixed z-10 inset-0 overflow-y-auto" style="display: none;">
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
        <div x-show="isOpen" @@click="closeModal()" class="fixed inset-0 transition-opacity" aria-hidden="true">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
        </div>

        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <div x-show="isOpen" class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-4xl sm:w-full">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">
                    Çalışan Seçimi
                </h3>
                
                <!-- Search & Toolbar -->
                <div class="flex justify-between items-center mb-4">
                        <div class="relative rounded-md shadow-sm w-1/3">
                        <input type="text" x-model="searchTerm" @@input.debounce.500ms="search(1)" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" placeholder="İsim veya kod ile ara...">
                    </div>
                    <div class="flex items-center space-x-2 text-sm text-gray-500">
                        <span>Göster:</span>
                        <select x-model="pageSize" @@change="search(1)" class="mt-1 block w-20 py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                            <option>10</option>
                            <option>20</option>
                            <option>50</option>
                        </select>
                    </div>
                </div>

                <!-- Table -->
                <div class="flex flex-col">
                    <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                        <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                            <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                                <table class="min-w-full divide-y divide-gray-200">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-left" x-show="isMultiSelect">
                                                <span class="sr-only">Seç</span>
                                            </th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kod</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ad Soyad</th>
                                            <th scope="col" class="relative px-6 py-3" x-show="!isMultiSelect">
                                                <span class="sr-only">Seç</span>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-gray-200">
                                        <template x-for="employee in items" :key="employee.code">
                                            <tr class="hover:bg-gray-50 cursor-pointer" @@click="isMultiSelect ? toggleSelection(employee) : select(employee)">
                                                <td class="px-6 py-4 whitespace-nowrap" x-show="isMultiSelect">
                                                    <input type="checkbox" :checked="isSelected(employee)" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="employee.code"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500" x-text="employee.name"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium" x-show="!isMultiSelect">
                                                    <button class="text-indigo-600 hover:text-indigo-900">Seç</button>
                                                </td>
                                            </tr>
                                        </template>
                                        <tr x-show="items.length === 0">
                                            <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500">Kayıt bulunamadı.</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Pagination -->
                <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6 mt-2">
                    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                        <div>
                            <p class="text-sm text-gray-700">
                                Toplam <span class="font-medium" x-text="totalCount"></span> kayıt, Sayfa <span class="font-medium" x-text="currentPage"></span>
                            </p>
                        </div>
                        <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                <button @@click="if(currentPage > 1) search(currentPage - 1)" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    Önceki
                                </button>
                                <button @@click="search(currentPage + 1)" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    Sonraki
                                </button>
                            </nav>
                        </div>
                    </div>
                </div>

            </div>
            <!-- Footer Actions -->
            <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse border-t border-gray-200">
                <button x-show="!isMultiSelect" type="button" @@click="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Kapat
                </button>
                
                <button x-show="isMultiSelect" type="button" @@click="submitMultiSelection()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
                    Seçilenleri Ekle (<span x-text="selectedItems.length"></span>)
                </button>
                <button x-show="isMultiSelect" type="button" @@click="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Vazgeç
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    function employeeSelectModal() {
        return {
            isOpen: false,
            targetId: '',
            isMultiSelect: false,
            
            searchTerm: '',
            pageSize: 10,
            currentPage: 1,
            totalCount: 0,
            items: [],
            
            selectedItems: [], // Array of employee objects
            
            openModal(detail) {
                this.isOpen = true;
                this.targetId = detail.targetId;
                this.isMultiSelect = detail.isMultiSelect || false;
                this.selectedItems = [];
                this.search(1);
            },

            closeModal() {
                this.isOpen = false;
            },

            async search(page) {
                this.currentPage = page;
                try {
                    const response = await fetch(`/OvertimeReport/SearchEmployees?term=${this.searchTerm}&page=${page}&pageSize=${this.pageSize}`);
                    const result = await response.json();
                    this.items = result.items;
                    this.totalCount = result.totalCount;
                } catch (e) {
                    console.error("Employee search failed", e);
                }
            },

            // Single Select
            select(emp) {
                this.$dispatch('employee-selected', {
                    employee: emp, // Single object
                    targetId: this.targetId
                });
                this.closeModal();
            },
            
            // Multi Select Helpers
            toggleSelection(emp) {
                if (!this.isMultiSelect) return;
                
                const index = this.selectedItems.findIndex(x => x.code === emp.code);
                if (index > -1) {
                    this.selectedItems.splice(index, 1);
                } else {
                    this.selectedItems.push(emp);
                }
            },
            
            isSelected(emp) {
                return this.selectedItems.some(x => x.code === emp.code);
            },
            
            submitMultiSelection() {
                this.$dispatch('employee-selected', {
                    employees: this.selectedItems, // Array
                    targetId: this.targetId
                });
                this.closeModal();
            }
        }
    }
</script>
