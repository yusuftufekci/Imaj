
<!-- Employee Selection Modal (v6.0 - Full Screen Fix) -->
<!-- x-cloak style: Alpine yüklenene kadar gizli kalmasını sağlar -->
<style>
    [x-cloak] { display: none !important; }
    
    /* Modal ortalama için özel stil - tüm ekran boyutlarında çalışır */
    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
        overflow-y: auto;
    }
    
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background-color: rgba(107, 114, 128, 0.75);
        z-index: 40;
    }
    
    .modal-content {
        position: relative;
        z-index: 50;
        background-color: white;
        border-radius: 0.5rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        width: 100%;
        max-width: 64rem; /* max-w-5xl */
        max-height: 90vh;
        overflow-y: auto;
        margin: auto;
    }
</style>

<div x-data 
     x-show="$store.employeeModal.isOpen" 
     x-cloak 
     class="modal-overlay"
     aria-labelledby="modal-title" 
     role="dialog" 
     aria-modal="true">
     
    <!-- Backdrop: Tıklandığında modal kapanır -->
    <div x-show="$store.employeeModal.isOpen" 
         x-on:click="$store.employeeModal.close()" 
         class="modal-backdrop" 
         aria-hidden="true"></div>

    <!-- Modal Panel: Her zaman ekranın ortasında görünür -->
    <div x-show="$store.employeeModal.isOpen" 
         class="modal-content">
         
        <!-- Header -->
        <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4 border-b border-gray-100">
            <div class="flex justify-between items-center mb-2">
                <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">
                    Çalışan Sorgulama
                </h3>
                <button x-on:click="$store.employeeModal.close()" class="text-gray-400 hover:text-gray-500 focus:outline-none">
                    <span class="sr-only">Kapat</span>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            
            <!-- Filter Panel -->
            <div class="bg-gray-50 p-4 rounded-md mb-4 border border-gray-200">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <!-- Kod -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kod</label>
                        <input type="text" x-model="$store.employeeModal.filter.code" x-on:keyup.enter="$store.employeeModal.search(1)" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                    </div>
                    
                    <!-- Ad -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ad</label>
                        <input type="text" x-model="$store.employeeModal.filter.name" x-on:keyup.enter="$store.employeeModal.search(1)" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                    </div>
                    
                    <!-- Fonksiyon -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Fonksiyon</label>
                        <select x-model="$store.employeeModal.filter.functionId" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            <option value="">Tümü</option>
                            <template x-for="func in $store.employeeModal.functions" :key="func.id">
                                <option :value="func.id" x-text="func.name"></option>
                            </template>
                        </select>
                    </div>
                    
                    <!-- Durum -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Durum</label>
                        <select x-model="$store.employeeModal.filter.status" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            <option value="0">Tümü</option>
                            <option value="1">Sadece Geçerli</option>
                            <option value="2">Sadece Geçersiz</option>
                        </select>
                    </div>
                </div>
                <div class="mt-4 flex justify-end space-x-2">
                    <button x-on:click="$store.employeeModal.clearFilter()" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                        Temizle
                    </button>
                    <button x-on:click="$store.employeeModal.search(1)" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                        Sorgula
                    </button>
                </div>
            </div>

            <!-- Table -->
            <div class="flex flex-col">
                <div class="overflow-x-auto">
                    <div class="inline-block min-w-full align-middle">
                        <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th scope="col" class="px-6 py-3 text-left" x-show="$store.employeeModal.isMultiSelect">
                                            <span class="sr-only">Seç</span>
                                        </th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kod</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ad Soyad</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Durum</th>
                                        <th scope="col" class="relative px-6 py-3" x-show="!$store.employeeModal.isMultiSelect">
                                            <span class="sr-only">Seç</span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    <template x-for="employee in $store.employeeModal.items" :key="employee.id">
                                        <tr class="hover:bg-gray-50 cursor-pointer" :class="{'bg-red-50': employee.invisible}" x-on:click="$store.employeeModal.isMultiSelect ? $store.employeeModal.toggleSelection(employee) : $store.employeeModal.select(employee)">
                                            <td class="px-6 py-4 whitespace-nowrap" x-show="$store.employeeModal.isMultiSelect">
                                                <input type="checkbox" :checked="$store.employeeModal.isSelected(employee)" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="employee.code"></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500" x-text="employee.name"></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                                 <span x-show="employee.invisible" class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Geçersiz</span>
                                                 <span x-show="!employee.invisible" class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Geçerli</span>
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium" x-show="!$store.employeeModal.isMultiSelect">
                                                <button class="text-indigo-600 hover:text-indigo-900">Seç</button>
                                            </td>
                                        </tr>
                                    </template>
                                    <tr x-show="$store.employeeModal.items.length === 0">
                                        <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500">
                                            Kayıt bulunamadı.
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Pagination -->
            <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6 mt-2">
                <div class="flex items-center space-x-2">
                     <span class="text-sm text-gray-700">Sayfa Boyu:</span>
                    <select x-model="$store.employeeModal.filter.pageSize" x-on:change="$store.employeeModal.search(1)" class="block w-20 py-1 px-2 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                        <option>10</option>
                        <option>20</option>
                        <option>50</option>
                        <option>100</option>
                    </select>
                </div>
                
                <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-center">
                    <p class="text-sm text-gray-700">
                        Toplam <span class="font-medium" x-text="$store.employeeModal.totalCount"></span> kayıt, Sayfa <span class="font-medium" x-text="$store.employeeModal.currentPage"></span>
                    </p>
                </div>
                
                <div>
                    <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                        <button x-on:click="if($store.employeeModal.currentPage > 1) $store.employeeModal.search($store.employeeModal.currentPage - 1)" :disabled="$store.employeeModal.currentPage <= 1" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 disabled:opacity-50">
                            Önceki
                        </button>
                        <button x-on:click="if($store.employeeModal.items.length >= $store.employeeModal.filter.pageSize) $store.employeeModal.search($store.employeeModal.currentPage + 1)" :disabled="$store.employeeModal.items.length < $store.employeeModal.filter.pageSize" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 disabled:opacity-50">
                            Sonraki
                        </button>
                    </nav>
                </div>
            </div>

        </div>
        <!-- Footer Actions -->
        <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse border-t border-gray-200">
            <button x-show="!$store.employeeModal.isMultiSelect" type="button" x-on:click="$store.employeeModal.close()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                Kapat
            </button>
            
            <button x-show="$store.employeeModal.isMultiSelect" type="button" x-on:click="$store.employeeModal.submitMultiSelection()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
                Seçilenleri Ekle (<span x-text="$store.employeeModal.selectedItems.length"></span>)
            </button>
            <button x-show="$store.employeeModal.isMultiSelect" type="button" x-on:click="$store.employeeModal.close()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                Vazgeç
            </button>
        </div>
    </div>
</div>
