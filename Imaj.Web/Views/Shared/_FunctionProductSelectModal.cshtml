@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
<div x-data="functionProductSelectModal()"
     @@function-product-select-open.window="openModal($event.detail)"
     x-show="isOpen"
     x-cloak
     class="modal-overlay"
     x-on:keydown.escape.window="closeModal()"
     aria-labelledby="function-product-modal-title"
     role="dialog"
     aria-modal="true">

    <div x-show="isOpen" x-on:click="closeModal()" class="modal-backdrop" aria-hidden="true"></div>

    <div x-show="isOpen" class="modal-content modal-content--xl" tabindex="-1">
        <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4 border-b border-gray-100">
            <div class="flex justify-between items-center mb-2">
                <h3 class="text-lg leading-6 font-medium text-gray-900 font-bold text-orange-600" id="function-product-modal-title">
                    @Localizer["ProductSelectionTitle"]
                </h3>
                <button x-on:click="closeModal()" class="text-gray-400 hover:text-gray-500 focus:outline-none">
                    <span class="sr-only">@Localizer["Close"]</span>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="bg-gray-50 p-4 rounded-md mb-4 border border-gray-200">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center">
                    <label class="md:col-span-2 text-sm font-medium text-gray-700 md:text-right">@Localizer["Code"]</label>
                    <input type="text" x-model="filter.code" x-on:keyup.enter="search(1)" class="md:col-span-4 shadow-sm border-gray-300 rounded-md sm:text-sm focus:ring-indigo-500 focus:border-indigo-500">

                    <label class="md:col-span-2 text-sm font-medium text-gray-700 md:text-right">@Localizer["Name"]</label>
                    <input type="text" x-model="filter.name" x-on:keyup.enter="search(1)" class="md:col-span-4 shadow-sm border-gray-300 rounded-md sm:text-sm focus:ring-indigo-500 focus:border-indigo-500">

                    <label class="md:col-span-2 text-sm font-medium text-gray-700 md:text-right">@Localizer["Invalid"]</label>
                    <select x-model="filter.isInvalid" class="md:col-span-2 shadow-sm border-gray-300 rounded-md sm:text-sm focus:ring-indigo-500 focus:border-indigo-500">
                        <option value="">@Localizer["All"]</option>
                        <option value="false">@Localizer["No"]</option>
                        <option value="true">@Localizer["Yes"]</option>
                    </select>
                </div>

                <div class="mt-4 flex justify-end space-x-2">
                    <button type="button" @@click="resetFilter()" class="inline-flex items-center px-3 py-2 border border-gray-300 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                        @Localizer["Clear"]
                    </button>
                    <button type="button" @@click="search(1)" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">
                        @Localizer["Search"]
                    </button>
                </div>
            </div>

            <div class="flex flex-col">
                <div class="modal-table-wrap">
                    <div class="inline-block min-w-full align-middle">
                        <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th scope="col" class="px-6 py-3 text-left" x-show="isMultiSelect">
                                            <span class="sr-only">@Localizer["Select"]</span>
                                        </th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Code"]</th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Name"]</th>
                                        <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Invalid"]</th>
                                        <th scope="col" class="relative px-6 py-3" x-show="!isMultiSelect">
                                            <span class="sr-only">@Localizer["Select"]</span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    <template x-for="productItem in items" :key="productItem.id">
                                        <tr class="hover:bg-gray-50 cursor-pointer" :class="{'bg-red-50': productItem.invisible}" @@click="isMultiSelect ? toggleSelection(productItem) : select(productItem)">
                                            <td class="px-6 py-4 whitespace-nowrap" x-show="isMultiSelect">
                                                <input type="checkbox" :checked="isSelected(productItem)" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="productItem.code"></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900" x-text="productItem.name"></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-center text-sm">
                                                <input type="checkbox" disabled :checked="productItem.invisible" class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium" x-show="!isMultiSelect">
                                                <button class="text-indigo-600 hover:text-indigo-900">@Localizer["Select"]</button>
                                            </td>
                                        </tr>
                                    </template>
                                    <tr x-show="items.length === 0">
                                        <td colspan="5" class="px-6 py-10 text-center text-sm text-gray-500">@Localizer["NoRecordsFound"]</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-pagination bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6 mt-2">
                <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-start">
                    <p class="text-sm text-gray-700">
                        @Localizer["Total"] <span class="font-medium" x-text="totalCount"></span> @Localizer["Records"], @Localizer["Page"] <span class="font-medium" x-text="page"></span>
                    </p>
                </div>
                <div>
                    <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                        <button type="button" @@click="search(page - 1)" :disabled="page <= 1" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 disabled:opacity-50">
                            @Localizer["Previous"]
                        </button>
                        <button type="button" @@click="search(page + 1)" :disabled="!hasMore" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 disabled:opacity-50">
                            @Localizer["Next"]
                        </button>
                    </nav>
                </div>
            </div>
        </div>

        <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse border-t border-gray-200">
            <button x-show="isMultiSelect" type="button" @@click="submitMultiSelection()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none sm:ml-3 sm:w-auto sm:text-sm">
                @Localizer["AddSelected"] (<span x-text="selectedItems.length"></span>)
            </button>
            <button type="button" @@click="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none sm:mt-0 sm:w-auto sm:text-sm">
                @Localizer["Close"]
            </button>
        </div>
    </div>
</div>
