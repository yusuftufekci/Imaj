<div x-data="roleSelectModal()"
     @@role-select-open.window="openModal($event.detail)"
     x-show="isOpen"
     x-on:keydown.escape.window="closeModal()"
     class="fixed inset-0 z-[70] overflow-y-auto p-4"
     style="display: none;">

    <div x-show="isOpen" @@click="closeModal()" class="fixed inset-0 bg-gray-500/75" aria-hidden="true"></div>

    <div class="relative z-[71] min-h-full flex items-center justify-center py-6">
        <div x-show="isOpen" class="w-full max-w-4xl bg-white rounded-lg text-left overflow-hidden shadow-xl">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4 space-y-4">
                <h3 class="text-lg font-medium text-center text-orange-600 font-bold">Rol Secimi</h3>

                <div class="bg-blue-50 p-4 rounded-md border border-blue-200">
                    <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center">
                        <label class="md:col-span-2 text-sm font-medium text-blue-900 md:text-right">Ad</label>
                        <input type="text" x-model="filter.name" x-on:keyup.enter="search(1)" class="md:col-span-4 shadow-sm border-gray-300 rounded-md sm:text-sm">

                        <label class="md:col-span-2 text-sm font-medium text-blue-900 md:text-right">Gecersiz</label>
                        <select x-model="filter.isInvalid" class="md:col-span-2 shadow-sm border-gray-300 rounded-md sm:text-sm">
                            <option value="">Tumu</option>
                            <option value="false">Hayir</option>
                            <option value="true">Evet</option>
                        </select>
                    </div>

                    <div class="mt-3 flex justify-end gap-2">
                        <button type="button" @@click="resetFilter()" class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50">
                            Temizle
                        </button>
                        <button type="button" @@click="search(1)" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700">
                            Sorgula
                        </button>
                    </div>
                </div>

                <div class="overflow-x-auto border border-gray-200 rounded-md">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase w-12" x-show="isMultiSelect">Sec</th>
                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-700 uppercase">Ad</th>
                                <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase">Gecersiz</th>
                                <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase">Global</th>
                                <th class="px-4 py-2 text-center text-xs font-semibold text-gray-700 uppercase">Tum Menu</th>
                                <th class="px-4 py-2 text-right text-xs font-semibold text-gray-700 uppercase" x-show="!isMultiSelect">Islem</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200 bg-white">
                            <template x-for="role in items" :key="role.id">
                                <tr class="hover:bg-gray-50 cursor-pointer" @@click="isMultiSelect ? toggleSelection(role) : select(role)">
                                    <td class="px-4 py-2" x-show="isMultiSelect">
                                        <input type="checkbox" :checked="isSelected(role)" class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                    </td>
                                    <td class="px-4 py-2 text-sm text-gray-900" x-text="role.name"></td>
                                    <td class="px-4 py-2 text-center"><input type="checkbox" disabled :checked="role.invisible" class="h-4 w-4 text-gray-400 border-gray-300 rounded"></td>
                                    <td class="px-4 py-2 text-center"><input type="checkbox" disabled :checked="role.global" class="h-4 w-4 text-gray-400 border-gray-300 rounded"></td>
                                    <td class="px-4 py-2 text-center"><input type="checkbox" disabled :checked="role.allMenu" class="h-4 w-4 text-gray-400 border-gray-300 rounded"></td>
                                    <td class="px-4 py-2 text-right text-sm" x-show="!isMultiSelect">
                                        <button type="button" class="text-indigo-600 hover:text-indigo-900">Sec</button>
                                    </td>
                                </tr>
                            </template>
                            <tr x-show="items.length === 0">
                                <td colspan="6" class="px-4 py-8 text-sm text-gray-500 text-center">Kayit bulunamadi.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="flex items-center justify-between text-sm">
                    <div class="text-gray-600">
                        Toplam <span class="font-semibold" x-text="totalCount"></span> kayit
                    </div>
                    <div class="flex items-center gap-2">
                        <button type="button" @@click="search(page - 1)" :disabled="page <= 1" class="px-3 py-1 border border-gray-300 rounded text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50">Onceki</button>
                        <span class="text-gray-700">Sayfa <span x-text="page"></span></span>
                        <button type="button" @@click="search(page + 1)" :disabled="!hasMore" class="px-3 py-1 border border-gray-300 rounded text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50">Sonraki</button>
                    </div>
                </div>
            </div>

            <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse border-t border-gray-200">
                <button x-show="isMultiSelect" type="button" @@click="submitMultiSelection()" class="inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-sm font-medium text-white hover:bg-indigo-700 sm:ml-3 sm:w-auto">
                    Secilenleri Ekle (<span x-text="selectedItems.length"></span>)
                </button>
                <button type="button" @@click="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 sm:mt-0 sm:w-auto">
                    Kapat
                </button>
            </div>
        </div>
    </div>
</div>
