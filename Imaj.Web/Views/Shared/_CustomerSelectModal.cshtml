@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
<div x-data="customerSelectModal()"
     @@customer-select-open.window="openModal($event.detail)"
     x-show="showModal" 
     class="fixed z-50 inset-0 overflow-y-auto" 
     style="display: none;">
    
    <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
        <div x-show="showModal" @@click="closeModal()" class="fixed inset-0 transition-opacity" aria-hidden="true">
             <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
        </div>

        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <div x-show="showModal" class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-6xl sm:w-full">
            <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4 text-center text-orange-600 font-bold">
                    @Localizer["CustomerSearchTitle"]
                </h3>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                    <!-- Panel 1: Main Criteria -->
                    <div class="bg-blue-50 p-3 rounded border border-blue-200 shadow-sm">
                        <h4 class="font-semibold text-gray-700 mb-2 border-b border-blue-200 pb-1">@Localizer["MainCriteria"]</h4>
                        <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["Code"]</label>
                            <input type="text" x-model="filter.code" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                        <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["Name"]</label>
                            <input type="text" x-model="filter.name" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                         <div class="grid grid-cols-12 gap-2 items-center">
                            <label class="col-span-3 text-right pr-2">@Localizer["Invalid"]</label>
                            <select x-model="filter.isInvalid" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm py-0">
                                <option value="">@Localizer["All"]</option>
                                <option value="false">@Localizer["No"]</option>
                                <option value="true">@Localizer["Yes"]</option>
                            </select>
                        </div>
                    </div>

                    <!-- Panel 2: Address -->
                    <div class="bg-blue-50 p-3 rounded border border-blue-200 shadow-sm">
                        <h4 class="font-semibold text-gray-700 mb-2 border-b border-blue-200 pb-1">@Localizer["AddressSearch"]</h4>
                         <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["City"]</label>
                            <input type="text" x-model="filter.city" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                         <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["AreaCode"]</label>
                            <input type="text" x-model="filter.areaCode" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                         <div class="grid grid-cols-12 gap-2 items-center">
                            <label class="col-span-3 text-right pr-2">@Localizer["Country"]</label>
                            <input type="text" x-model="filter.country" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                    </div>

                     <!-- Panel 3: Contact -->
                    <div class="bg-blue-50 p-3 rounded border border-blue-200 shadow-sm">
                        <h4 class="font-semibold text-gray-700 mb-2 border-b border-blue-200 pb-1">@Localizer["ContactSearch"]</h4>
                        <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["Owner"]</label>
                            <input type="text" x-model="filter.owner" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                        <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["Related"]</label>
                            <input type="text" x-model="filter.relatedPerson" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                         <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["Phone"]</label>
                            <input type="text" x-model="filter.phone" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                        <div class="grid grid-cols-12 gap-2 items-center mb-2">
                            <label class="col-span-3 text-right pr-2">@Localizer["Fax"]</label>
                            <input type="text" x-model="filter.fax" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                        <div class="grid grid-cols-12 gap-2 items-center">
                            <label class="col-span-3 text-right pr-2">@Localizer["Email"]</label>
                            <input type="text" x-model="filter.email" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                        </div>
                    </div>

                    <!-- Right Column Stack -->
                    <div class="space-y-4">
                         <!-- Panel 4: Invoice -->
                         <div class="bg-blue-50 p-3 rounded border border-blue-200 shadow-sm">
                            <h4 class="font-semibold text-gray-700 mb-2 border-b border-blue-200 pb-1">@Localizer["InvoiceSearch"]</h4>
                            <div class="grid grid-cols-12 gap-2 items-center mb-2">
                                <label class="col-span-3 text-right pr-2">@Localizer["TaxOffice"]</label>
                                <input type="text" x-model="filter.taxOffice" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                            </div>
                             <div class="grid grid-cols-12 gap-2 items-center">
                                <label class="col-span-3 text-right pr-2">@Localizer["TaxNumber"]</label>
                                <input type="text" x-model="filter.taxNumber" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm">
                            </div>
                        </div>
                        
                        <!-- Panel 5: Job -->
                         <div class="bg-blue-50 p-3 rounded border border-blue-200 shadow-sm">
                            <h4 class="font-semibold text-gray-700 mb-2 border-b border-blue-200 pb-1">@Localizer["JobSearch"]</h4>
                            <div class="grid grid-cols-12 gap-2 items-center">
                                <label class="col-span-3 text-right pr-2">@Localizer["Status"]</label>
                                 <select x-model="filter.jobStateId" class="col-span-9 border-gray-400 rounded-md shadow-sm h-7 text-sm py-0">
                                     <option value="">@Localizer["All"]</option>
                                     <template x-for="status in jobStatuses" :key="status.id">
                                         <option :value="status.id" x-text="status.name"></option>
                                     </template>
                                </select>
                            </div>
                        </div>
                    </div>

                </div>
                
                <!-- Search Actions -->
                <div class="mt-4 flex justify-center space-x-2">
                     <button type="button" @@click="search(1)" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        @Localizer["Search"]
                    </button>
                    <button type="button" @@click="resetFilter()" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        @Localizer["Clear"]
                    </button>
                </div>

                <!-- Results Table -->
                <div class="mt-6 flex flex-col" x-show="hasSearched">
                    <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                         <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                            <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                                <table class="min-w-full divide-y divide-gray-200">
                                    <thead class="bg-gray-50">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Code"]</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Name"]</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["City"]</th>
                                             <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Phone"]</th>
                                            <th scope="col" class="relative px-6 py-3">
                                                <span class="sr-only">@Localizer["Select"]</span>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="bg-white divide-y divide-gray-200">
                                        <template x-for="customer in items" :key="customer.code">
                                            <tr class="hover:bg-gray-50 cursor-pointer" @@click="select(customer)">
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500" x-text="customer.code"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="customer.name"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500" x-text="customer.city"></td>
                                                 <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500" x-text="customer.phone"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                                    <button class="text-indigo-600 hover:text-indigo-900">@Localizer["Select"]</button>
                                                </td>
                                            </tr>
                                        </template>
                                       <tr x-show="items.length === 0">
                                            <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">@Localizer["NoRecordsFound"]</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                     <!-- Pagination -->
                    <div class="bg-white px-4 py-3 flex items-center justify-between border-t border-gray-200 sm:px-6 mt-2" x-show="items.length > 0">
                        <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                            <div>
                                <p class="text-sm text-gray-700">
                                    @Localizer["Total"] <span class="font-medium" x-text="totalCount"></span> @Localizer["Records"]
                                </p>
                            </div>
                            <div>
                                <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                    <button @@click="if(page > 1) search(page - 1)" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                        @Localizer["Previous"]
                                    </button>
                                    <button @@click="search(page + 1)" class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                        @Localizer["Next"]
                                    </button>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
             <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" @@click="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    @Localizer["Close"]
                </button>
            </div>
        </div>
    </div>
</div>

@* JavaScript artık wwwroot/js/components/customer-select-modal.js dosyasından yükleniyor *@
