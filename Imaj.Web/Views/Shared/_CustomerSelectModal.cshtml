@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
<div x-data="customerSelectModal()"
     @@customer-select-open.window="openModal($event.detail)"
     x-show="showModal"
     x-cloak
     x-on:keydown.escape.window="closeModal()"
     class="modal-overlay"
     aria-labelledby="customer-select-modal-title"
     role="dialog"
     aria-modal="true">
    <div x-show="showModal" @@click="closeModal()" class="modal-backdrop" aria-hidden="true"></div>

    <div x-show="showModal" class="modal-content modal-content--xl customer-page-shell" tabindex="-1">
        <div class="bg-white px-4 pt-4 pb-3 sm:p-5">
            <h3 id="customer-select-modal-title" class="customer-page-title customer-page-title--orange text-center mb-4">
                @Localizer["CustomerSearchTitle"]
            </h3>

            <div class="dense-panel-grid mobile-stack-form">
                <div class="dense-panel-grid__column">
                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h4 class="dense-panel__title">@Localizer["MainCriteria"]</h4>
                        </div>
                        <div class="dense-panel__body">
                            <div class="dense-form-grid">
                                <div class="dense-form-row">
                                    <label>@Localizer["Code"]</label>
                                    <input type="text" x-model="filter.code" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Name"]</label>
                                    <input type="text" x-model="filter.name" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Invalid"]</label>
                                    <select x-model="filter.isInvalid" class="dense-input">
                                        <option value="">@Localizer["All"]</option>
                                        <option value="false">@Localizer["No"]</option>
                                        <option value="true">@Localizer["Yes"]</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h4 class="dense-panel__title">@Localizer["ContactSearch"]</h4>
                        </div>
                        <div class="dense-panel__body">
                            <div class="dense-form-grid">
                                <div class="dense-form-row">
                                    <label>@Localizer["Owner"]</label>
                                    <input type="text" x-model="filter.owner" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Related"]</label>
                                    <input type="text" x-model="filter.relatedPerson" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Phone"]</label>
                                    <input type="text" x-model="filter.phone" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Fax"]</label>
                                    <input type="text" x-model="filter.fax" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Email"]</label>
                                    <input type="text" x-model="filter.email" class="dense-input">
                                </div>
                            </div>
                        </div>
                    </section>
                </div>

                <div class="dense-panel-grid__column">
                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h4 class="dense-panel__title">@Localizer["AddressSearch"]</h4>
                        </div>
                        <div class="dense-panel__body">
                            <div class="dense-form-grid">
                                <div class="dense-form-row">
                                    <label>@Localizer["City"]</label>
                                    <input type="text" x-model="filter.city" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["AreaCode"]</label>
                                    <input type="text" x-model="filter.areaCode" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Country"]</label>
                                    <input type="text" x-model="filter.country" class="dense-input">
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h4 class="dense-panel__title">@Localizer["InvoiceSearch"]</h4>
                        </div>
                        <div class="dense-panel__body">
                            <div class="dense-form-grid">
                                <div class="dense-form-row">
                                    <label>@Localizer["TaxOffice"]</label>
                                    <input type="text" x-model="filter.taxOffice" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["TaxNumber"]</label>
                                    <input type="text" x-model="filter.taxNumber" class="dense-input">
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h4 class="dense-panel__title">@Localizer["JobSearch"]</h4>
                        </div>
                        <div class="dense-panel__body dense-panel__body--tight">
                            <div class="dense-form-grid">
                                <div class="dense-form-row">
                                    <label>@Localizer["Status"]</label>
                                    <select x-model="filter.jobStatus" class="dense-input">
                                        <option value="">@Localizer["All"]</option>
                                        <template x-for="status in jobStatuses" :key="status.id">
                                            <option :value="status.id" x-text="status.name"></option>
                                        </template>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </div>

            <div class="dense-toolbar mt-3">
                <button type="button" @@click="search(1)" class="inline-flex items-center border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    @Localizer["Search"]
                </button>
                <button type="button" @@click="resetFilter()" class="inline-flex items-center border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    @Localizer["Clear"]
                </button>
            </div>

            <div class="mt-4" x-show="hasSearched">
                <div class="customer-table-card">
                    <div class="customer-table-wrap">
                        <table class="customer-table customer-table--compact">
                            <thead>
                                <tr>
                                    <th scope="col">@Localizer["Code"]</th>
                                    <th scope="col">@Localizer["Name"]</th>
                                    <th scope="col">@Localizer["City"]</th>
                                    <th scope="col">@Localizer["Phone"]</th>
                                    <th scope="col" class="text-right">
                                        <span class="sr-only">@Localizer["Select"]</span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <template x-for="customer in items" :key="customer.code">
                                    <tr class="cursor-pointer" @@click="select(customer)">
                                        <td class="whitespace-nowrap" x-text="customer.code"></td>
                                        <td class="whitespace-nowrap font-medium" x-text="customer.name"></td>
                                        <td class="whitespace-nowrap" x-text="customer.city"></td>
                                        <td class="whitespace-nowrap" x-text="customer.phone"></td>
                                        <td class="whitespace-nowrap text-right">
                                            <button class="text-indigo-600 hover:text-indigo-900">@Localizer["Select"]</button>
                                        </td>
                                    </tr>
                                </template>
                                <tr x-show="items.length === 0">
                                    <td colspan="5" class="text-center text-sm text-gray-500">@Localizer["NoRecordsFound"]</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="customer-footer-bar" x-show="items.length > 0">
                        <div class="text-sm text-gray-700 text-center sm:hidden">
                            @Localizer["Page"] <span class="font-medium" x-text="page"></span> / <span class="font-medium" x-text="Math.max(totalPages, 1)"></span>
                        </div>
                        <div class="hidden sm:block">
                            <p class="customer-footer-bar__meta">
                                @Localizer["Total"] <span class="font-medium" x-text="totalCount"></span> @Localizer["Records"]
                            </p>
                        </div>
                        <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                <button type="button" @@click="if(page > 1) search(page - 1)" class="relative inline-flex items-center px-3 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" :disabled="page <= 1">
                                    @Localizer["Previous"]
                                </button>
                                <button type="button" @@click="search(page + 1)" class="relative inline-flex items-center px-3 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" :disabled="page >= totalPages">
                                    @Localizer["Next"]
                                </button>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="customer-footer-bar customer-footer-bar--center">
            <button type="button" @@click="closeModal()" class="inline-flex justify-center rounded-md border border-gray-300 shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                @Localizer["Close"]
            </button>
        </div>
    </div>
</div>

@* JavaScript artık wwwroot/js/components/customer-select-modal.js dosyasından yükleniyor *@
