@using Imaj.Web
@using Microsoft.Extensions.Localization
@using System.Net
@model Imaj.Web.Models.DetailNavigatorViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    var navigatorQueryParts = new List<string>();
    foreach (var id in Model.SelectedIds)
    {
        navigatorQueryParts.Add("selectedIds=" + WebUtility.UrlEncode(id));
    }

    if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
    {
        navigatorQueryParts.Add("returnUrl=" + WebUtility.UrlEncode(Model.ReturnUrl));
    }

    var navigatorBaseUrl = Model.FormAction;
    if (navigatorQueryParts.Count > 0)
    {
        navigatorBaseUrl += "?" + string.Join("&", navigatorQueryParts);
    }
}

<div class="bg-gray-50 p-3 rounded-lg border border-gray-200 space-y-3">
    <div class="grid grid-cols-2 gap-2 sm:hidden">
        <a href="@Model.FirstUrl" class="inline-flex items-center justify-center px-3 py-2 rounded-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
            @Localizer["First"]
        </a>
        <a href="@Model.LastUrl" class="inline-flex items-center justify-center px-3 py-2 rounded-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
            @Localizer["Last"]
        </a>
        <a href="@Model.PreviousUrl" class="inline-flex items-center justify-center px-3 py-2 rounded-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
            @Localizer["Previous"]
        </a>
        <a href="@Model.NextUrl" class="inline-flex items-center justify-center px-3 py-2 rounded-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
            @Localizer["Next"]
        </a>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-center">
        <div class="hidden sm:flex items-center shadow-sm rounded-md">
            <a href="@Model.FirstUrl" class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                <span class="sr-only">@Localizer["First"]</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M15.707 15.707a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 010 1.414zm-6 0a1 1 0 01-1.414 0l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 1.414L5.414 10l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                </svg>
            </a>
            <a href="@Model.PreviousUrl" class="-ml-px relative inline-flex items-center px-2 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                <span class="sr-only">@Localizer["Previous"]</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L8.414 10l4.293 4.293a1 1 0 01-1.414 1.414l-5-5a1 1 0 010-1.414l5-5a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
            </a>
            <a href="@Model.NextUrl" class="-ml-px relative inline-flex items-center px-2 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                <span class="sr-only">@Localizer["Next"]</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L11.586 10 7.293 5.707a1 1 0 011.414-1.414l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
            </a>
            <a href="@Model.LastUrl" class="-ml-px relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                <span class="sr-only">@Localizer["Last"]</span>
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L15.586 10l-5.293-5.293a1 1 0 010-1.414zm-6 0a1 1 0 011.414 0l-6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L9.586 10 4.293 4.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
            </a>
        </div>

        <div data-detail-navigator
             data-base-url="@navigatorBaseUrl"
             data-total-count="@Model.TotalCount"
             class="flex items-center justify-center gap-2 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm w-full sm:w-auto">
            <span>@Localizer["RecordLabel"]:</span>
            <input type="text"
                   name="currentIndex"
                   value="@(Model.CurrentIndex + 1)"
                   onkeydown="if (event.key === 'Enter') { event.preventDefault(); window.navigateDetailNavigator(this); }"
                   class="w-14 p-0 text-center border-none focus:ring-0 text-indigo-600 font-bold bg-transparent" />
            <span class="text-gray-400">/ @Model.TotalCount</span>
            <button type="button" onclick="window.navigateDetailNavigator(this)" class="hidden">@Localizer["Go"]</button>
        </div>
    </div>
</div>

<script>
    if (typeof window.navigateDetailNavigator !== 'function') {
        window.navigateDetailNavigator = function (element) {
            const container = element.closest('[data-detail-navigator]');
            if (!container) {
                return;
            }

            const input = container.querySelector('input[name="currentIndex"]');
            const totalCount = Number(container.dataset.totalCount || 0);
            const parsedValue = Number(input && input.value ? input.value : 1);

            let currentIndex = Number.isFinite(parsedValue) ? parsedValue : 1;
            if (totalCount > 0) {
                currentIndex = Math.min(Math.max(currentIndex, 1), totalCount);
            } else {
                currentIndex = Math.max(currentIndex, 1);
            }

            const baseUrl = container.dataset.baseUrl || '';
            const separator = baseUrl.includes('?') ? '&' : '?';
            window.location.href = `${baseUrl}${separator}currentIndex=${currentIndex - 1}`;
        };
    }
</script>
