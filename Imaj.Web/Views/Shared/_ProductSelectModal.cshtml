@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
<!-- Product Selection Modal -->
<div x-data="productSelectModal()" x-init="init()" @@product-select-open.window="openModal($event.detail)" x-show="isOpen" x-cloak x-on:keydown.escape.window="closeModal()" class="modal-overlay" aria-labelledby="product-select-modal-title" role="dialog" aria-modal="true">
    <div x-show="isOpen" @@click="closeModal()" class="modal-backdrop" aria-hidden="true"></div>

    <div x-show="isOpen" class="modal-content modal-content--xl product-select-modal" tabindex="-1">
            <div class="product-select-modal__body">
                <h3 id="product-select-modal-title" class="product-select-modal__title">
                    @Localizer["ProductSearchTitle"]
                </h3>
                
                <!-- Search Criteria Box -->
                <div x-show="showFilter" class="bg-gray-50 p-4 rounded-md mb-4 border border-gray-200 product-select-modal__filters">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm product-select-modal__filter-grid">
                            <div class="flex flex-col">
                            <label class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1 product-select-modal__label">@Localizer["Code"]</label>
                            <input type="text" x-model="filter.code" class="border-gray-300 rounded-md shadow-sm sm:text-sm focus:ring-indigo-500 focus:border-indigo-500 product-select-modal__input">
                        </div>

                        <div class="flex flex-col">
                            <label class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1 product-select-modal__label">@Localizer["ProductCategory"]</label>
                            <select x-model="filter.category" class="border-gray-300 rounded-md shadow-sm sm:text-sm focus:ring-indigo-500 focus:border-indigo-500 product-select-modal__input">
                                <option value="">@Localizer["All"]</option>
                                <template x-for="cat in categories" :key="cat.id">
                                    <option :value="cat.name" x-text="cat.name"></option>
                                </template>
                            </select>
                        </div>

                            <div class="flex flex-col">
                            <label class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1 product-select-modal__label">@Localizer["ProductGroup"]</label>
                            <select x-model="filter.productGroup" class="border-gray-300 rounded-md shadow-sm sm:text-sm focus:ring-indigo-500 focus:border-indigo-500 product-select-modal__input">
                                <option value="">@Localizer["All"]</option>
                                <template x-for="grp in productGroups" :key="grp.id">
                                    <option :value="grp.name" x-text="grp.name"></option>
                                </template>
                            </select>
                        </div>

                            <div class="flex flex-col">
                            <label class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1 product-select-modal__label">@Localizer["Function"]</label>
                            <select x-model="filter.function"
                                    @@change="onFunctionChanged()"
                                    :disabled="isFunctionLocked"
                                    :class="{ 'bg-gray-100 text-gray-500 cursor-not-allowed': isFunctionLocked }"
                                    class="border-gray-300 rounded-md shadow-sm sm:text-sm focus:ring-indigo-500 focus:border-indigo-500 product-select-modal__input">
                                <option value="" x-show="!isFunctionLocked">@Localizer["All"]</option>
                                <option x-show="isFunctionLocked && lockedFunctionId && !hasFunctionOption(lockedFunctionId)"
                                        :value="lockedFunctionId"
                                        x-text="lockedFunctionName || lockedFunctionId"></option>
                                <template x-for="func in functions" :key="func.id">
                                    <option :value="String(func.id)" x-text="func.name"></option>
                                </template>
                            </select>
                        </div>

                            <div class="flex flex-col">
                            <label class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1 product-select-modal__label">@Localizer["Invalid"]</label>
                            <select x-model="filter.isInvalid" class="border-gray-300 rounded-md shadow-sm sm:text-sm focus:ring-indigo-500 focus:border-indigo-500 product-select-modal__input">
                                <option value="">@Localizer["All"]</option>
                                <option value="false">@Localizer["No"]</option>
                                <option value="true">@Localizer["Yes"]</option>
                            </select>
                        </div>
                    </div>

                    <!-- Search Buttons -->
                    <div class="mt-4 flex justify-end space-x-2 product-select-modal__filter-actions">
                        <button type="button" @@click="search(1)" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            @Localizer["Search"]
                        </button>
                            <button type="button" @@click="resetFilter()" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            @Localizer["Clear"]
                        </button>
                    </div>
                </div>

                <!-- Product List Table -->
                <div class="product-select-modal__table-wrap modal-table-wrap">
                                    <table class="product-select-modal__table">
                                    <thead class="product-select-modal__thead">
                                        <tr>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider product-select-modal__th" x-show="isMultiSelect">@Localizer["Selected"]</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider product-select-modal__th" x-show="isMultiSelect">@Localizer["Quantity"]</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider product-select-modal__th">@Localizer["Code"]</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider product-select-modal__th">@Localizer["Name"]</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider product-select-modal__th">@Localizer["Category"]</th>
                                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider product-select-modal__th">@Localizer["Group"]</th>
                                            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider product-select-modal__th">@Localizer["Price"]</th>
                                            <th scope="col" class="relative px-6 py-3 product-select-modal__th" x-show="!isMultiSelect">
                                                <span class="sr-only">@Localizer["Select"]</span>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <template x-for="prod in items" :key="prod.code">
                                            <tr class="hover:bg-gray-50 cursor-pointer product-select-modal__row" @@click="isMultiSelect ? toggleSelection(prod) : select(prod)">
                                                <td class="px-6 py-4 whitespace-nowrap product-select-modal__td" x-show="isMultiSelect">
                                                    <input type="checkbox"
                                                           :checked="isSelected(prod)"
                                                           @@click.stop="toggleSelection(prod)"
                                                           class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap product-select-modal__td" x-show="isMultiSelect">
                                                    <input type="number"
                                                           min="0"
                                                           step="0.01"
                                                           :value="prod.quantity"
                                                           @@click.stop
                                                           @@input="updateQuantity(prod, $event.target.value)"
                                                           class="w-20 rounded-md border border-gray-300 px-2 py-1 text-sm text-right shadow-sm focus:border-indigo-500 focus:ring-indigo-500 product-select-modal__quantity">
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 product-select-modal__td product-select-modal__cell-code" x-text="prod.code"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 product-select-modal__td product-select-modal__cell-name" x-text="prod.name"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 product-select-modal__td" x-text="prod.category"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 product-select-modal__td" x-text="prod.productGroup"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-right text-gray-500 product-select-modal__td product-select-modal__cell-number" x-text="formatPrice(prod.price)"></td>
                                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium product-select-modal__td product-select-modal__cell-action" x-show="!isMultiSelect">
                                                    <button class="text-indigo-600 hover:text-indigo-900">@Localizer["Select"]</button>
                                                </td>
                                            </tr>
                                        </template>
                                        <tr x-show="items.length === 0">
                                            <td :colspan="isMultiSelect ? 7 : 6" class="px-6 py-4 text-center text-sm text-gray-500 product-select-modal__empty">
                                                <span x-show="!hasSearched">@Localizer["SearchPrompt"]</span>
                                                <span x-show="hasSearched">@Localizer["NoRecordsFound"]</span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                </div>
                    <!-- Pagination -->
                <div class="modal-pagination product-select-modal__pagination">
                    <div class="text-sm text-gray-700 text-center sm:hidden">
                        @Localizer["Page"] <span class="font-medium" x-text="page"></span> / <span class="font-medium" x-text="Math.max(totalPages, 1)"></span>
                    </div>
                    <div class="hidden sm:block">
                        <div>
                            <p class="text-sm text-gray-700">
                                @Localizer["Total"] <span class="font-medium" x-text="totalCount"></span> @Localizer["Records"]
                            </p>
                        </div>
                    </div>
                    <div>
                        <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                            <button type="button" @@click="if(page > 1) search(page - 1)" class="relative inline-flex items-center px-3 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" :disabled="page <= 1">
                                @Localizer["Previous"]
                            </button>
                            <button type="button" @@click="search(page + 1)" class="relative inline-flex items-center px-3 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50" :disabled="page >= totalPages">
                                @Localizer["Next"]
                            </button>
                        </nav>
                    </div>
                </div>

            </div>
            <div class="product-select-modal__footer">
                <button x-show="!isMultiSelect" type="button" @@click="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    @Localizer["Close"]
                </button>

                <button x-show="isMultiSelect" type="button" @@click="submitMultiSelection()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
                    @Localizer["AddSelected"] (<span x-text="selectedItems.length"></span>)
                </button>
                <button x-show="isMultiSelect" type="button" @@click="closeModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    @Localizer["Cancel"]
                </button>
            </div>
    </div>
</div>

@* JavaScript artık wwwroot/js/components/product-select-modal.js dosyasından yükleniyor *@
