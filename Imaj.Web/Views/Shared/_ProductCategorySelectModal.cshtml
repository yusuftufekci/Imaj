@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
<div x-data="productCategoryModal()" 
     x-show="isOpen" 
     x-on:open-product-category-modal.window="open()"
     x-cloak 
     class="modal-overlay"
     x-on:keydown.escape.window="close()"
     aria-labelledby="modal-title" 
     role="dialog" 
     aria-modal="true">
     
    <!-- Backdrop -->
    <div x-show="isOpen" 
         x-on:click="close()" 
         class="modal-backdrop"
         aria-hidden="true"></div>

    <!-- Modal Panel -->
    <div x-show="isOpen" 
         class="modal-content modal-content--md"
         tabindex="-1">
         
        <!-- Header -->
        <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4 border-b border-gray-100 flex justify-between items-center">
            <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">
                @Localizer["ProductCategories"]
            </h3>
            <button type="button" x-on:click="close()" class="bg-white rounded-md text-gray-400 hover:text-gray-500 focus:outline-none">
                <span class="sr-only">@Localizer["Close"]</span>
                <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <!-- Body -->
        <div class="px-4 py-4 sm:px-6">
            <!-- Loading State -->
            <div x-show="isLoading" class="flex justify-center py-8">
                <svg class="animate-spin -ml-1 mr-3 h-8 w-8 text-indigo-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span class="text-gray-500 text-lg">@Localizer["Loading"]</span>
            </div>

            <!-- Table -->
                <div x-show="!isLoading" class="flex flex-col">
                <div class="modal-table-wrap -my-2 sm:-mx-6 lg:-mx-8">
                    <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                        <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <!-- Checkbox Header (Select All logic can be here, but removing per request for independence) -->
                                        <th scope="col" class="px-6 py-3 text-left w-10">
                                            <span class="sr-only">@Localizer["Select"]</span>
                                        </th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                            @Localizer["Name"]
                                        </th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                            @Localizer["TaxCode"]
                                        </th>
                                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                            @Localizer["TaxName"]
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y divide-gray-200">
                                    <template x-for="(item, index) in items" :key="item.id">
                                        <tr class="hover:bg-gray-50 cursor-pointer" x-on:click="toggleSelection(item)">
                                            <td class="px-6 py-4 whitespace-nowrap">
                                                <input type="checkbox" :checked="isSelected(item)" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded pointer-events-none">
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900" x-text="item.name"></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500" x-text="item.taxCode"></td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500" x-text="item.taxName"></td>
                                        </tr>
                                    </template>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse border-t border-gray-200">
             <button type="button" x-on:click="submit()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-indigo-600 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:ml-3 sm:w-auto sm:text-sm">
                @Localizer["AddSelected"] (<span x-text="selectedItems.length"></span>)
            </button>
            <button type="button" x-on:click="close()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                @Localizer["Cancel"]
            </button>
        </div>
    </div>
</div>

<script>
    function productCategoryModal() {
        return {
            isOpen: false,
            isLoading: false,
            items: [],
            selectedItems: [],
            
            init() {
                // Pre-fetch logic or just wait for open
            },
            
            async open() {
                this.isOpen = true;
                this.selectedItems = []; // Her açılışta seçimi sıfırla, ya da mevcutları korumak istiyorsan dışarıdan parametre al
                
                if (this.items.length === 0) {
                    await this.loadCategories();
                }
            },
            
            close() {
                this.isOpen = false;
            },
            
            async loadCategories() {
                this.isLoading = true;
                try {
                    const response = await fetch('/Customer/GetProductCategories');
                    if (response.ok) {
                        this.items = await response.json();
                    } else {
                        console.error('Failed to categories');
                    }
                } catch (e) {
                    console.error('Error loading categories', e);
                } finally {
                    this.isLoading = false;
                }
            },
            
            toggleSelection(item) {
                const index = this.selectedItems.findIndex(i => i.id === item.id);
                if (index > -1) {
                    this.selectedItems.splice(index, 1);
                } else {
                    // Primitive kopya yerine objeyi ekle
                    this.selectedItems.push(item);
                }
            },

            isSelected(item) {
                return this.selectedItems.some(i => i.id === item.id);
            },
            
            submit() {
                this.$dispatch('product-categories-selected', { items: this.selectedItems });
                this.close();
            }
        }
    }
</script>
