@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Imaj</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="//unpkg.com/alpinejs" defer></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased">
    <div class="min-h-screen flex flex-col">
        <!-- Top Bar: Company Info & User Profile -->
        <div class="bg-slate-900 text-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-10 flex items-center justify-between text-sm">
                <div class="flex items-center space-x-4">
                    <span class="font-medium tracking-wide">IMAJ POST-PRODÜKSİYON HİZMETLERİ</span>
                    <span class="hidden sm:inline text-slate-400">|</span>
                    <span class="hidden sm:inline text-slate-400">KOCAL</span>
                </div>
                <div class="flex items-center space-x-6">
                    <span class="text-slate-300">Sesam Imaj Bilgi Sistemi 2.0.7</span>
                    <div class="flex items-center space-x-3">
                        <a href="/Culture/SetLanguage?culture=tr-TR&returnUrl=@Context.Request.Path" class="hover:text-white text-slate-300 transition-colors">TR</a>
                        <span class="text-slate-400">|</span>
                        <a href="/Culture/SetLanguage?culture=en-US&returnUrl=@Context.Request.Path" class="hover:text-white text-slate-300 transition-colors">EN</a>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-slate-400">|</span>
                            <a href="/Auth/Logout" class="hover:text-red-400 text-slate-300 transition-colors">@Localizer["Logout"]</a>
                        }
                        else
                        {
                            <span class="text-slate-400">|</span>
                            <a href="/Auth/Login" class="hover:text-white text-slate-300 transition-colors">@Localizer["Login"]</a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Navigation -->
        <header class="bg-white shadow-lg sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-16">
                   <div class="flex">
                        <div class="flex-shrink-0 flex items-center">
                             <!-- Example Logo using text if no image provided, styled to look like a brand -->
                            <a href="/" class="text-3xl font-black italic text-red-600 tracking-tighter hover:opacity-80 transition-opacity">imaj</a>
                        </div>
                        <div class="hidden md:ml-10 md:flex md:space-x-1">
                            <!-- Menu Items -->
                            @{
                                var menuItems = new[] 
                                { 
                                    new { Key = "Home", Label = Localizer["Home"].Value, Url = "/" },
                                    new { Key = "Calendar", Label = Localizer["Calendar"].Value, Url = "#" },
                                    new { Key = "Customer", Label = Localizer["Customer"].Value, Url = "/Customer" },
                                    new { Key = "Reservation", Label = Localizer["Reservation"].Value, Url = "#" },
                                    new { Key = "Job", Label = Localizer["Job"].Value, Url = "/Job" },
                                    new { Key = "Invoice", Label = Localizer["Invoice"].Value, Url = "/Invoice" },
                                    new { Key = "OvertimeReport", Label = Localizer["OvertimeReport"].Value, Url = "/OvertimeReport" },
                                    new { Key = "ProductReport", Label = "Ürün Raporu", Url = "/ProductReport" }
                                };
                            }
                            @foreach (var item in menuItems)
                            {
                                <a href="@item.Url" class="inline-flex items-center px-4 pt-1 border-b-2 border-transparent text-sm font-medium text-gray-600 hover:text-red-600 hover:border-red-600 transition-all duration-200">
                                    @item.Label
                                </a>
                            }
                        </div>
                    </div>
                     <!-- Mobile menu button placeholder -->
                    <div class="-mr-2 flex items-center md:hidden">
                        <button type="button" class="bg-white inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" aria-controls="mobile-menu" aria-expanded="false">
                            <span class="sr-only">Open main menu</span>
                            <svg class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
             <!-- Mobile Menu (Hidden by default) -->
            <div class="md:hidden hidden" id="mobile-menu">
                <div class="pt-2 pb-3 space-y-1">
                     @foreach (var item in menuItems)
                    {
                        <a href="#" class="bg-indigo-50 border-indigo-500 text-indigo-700 block pl-3 pr-4 py-2 border-l-4 text-base font-medium">@item.Label</a>
                    }
                </div>
            </div>
        </header>

        <main class="flex-grow bg-gray-50">
            <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
                 @RenderBody()
            </div>
        </main>

        <footer class="bg-slate-900 border-t border-slate-800 text-slate-400">
            <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
                <div class="md:flex md:items-center md:justify-between">
                    <div class="flex justify-center md:order-2">
                        <p class="text-sm">
                            @Localizer["InformationSystem"] &copy; @DateTime.Now.Year
                        </p>
                    </div>
                    <div class="mt-8 md:mt-0 md:order-1">
                        <p class="text-center text-sm">
                           @Localizer["ServiceQuality"]
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>
</body>
</html>
