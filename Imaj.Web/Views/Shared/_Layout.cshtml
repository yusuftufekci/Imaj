@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Imaj.Web.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@inject IPermissionViewService PermissionViewService

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Imaj</title>
    <!-- TailwindCSS (Local Build) -->
    <link rel="stylesheet" href="~/css/tailwind.output.css" asp-append-version="true" />
    <script src="//unpkg.com/alpinejs" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased">
    <div class="min-h-screen flex flex-col">
        <!-- Top Bar: Company Info & User Profile -->
        <div class="bg-slate-900 text-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-between text-sm flex-wrap gap-2">
                <div class="flex items-center space-x-4">
                    <span class="font-medium tracking-wide">IMAJ POST-PRODÜKSİYON HİZMETLERİ</span>
                    <span class="hidden sm:inline text-slate-400">|</span>
                    <span class="hidden sm:inline text-slate-400">KOCAL</span>
                </div>
                <!-- ... existing top bar right side ... -->
                <div class="flex items-center space-x-6">
                    <span class="text-slate-300">Sesam Imaj Bilgi Sistemi 2.0.7</span>
                    <div class="flex items-center space-x-3">
                        <a href="/Culture/SetLanguage?culture=tr-TR&returnUrl=@Context.Request.Path" class="hover:text-white text-slate-300 transition-colors">TR</a>
                        <span class="text-slate-400">|</span>
                        <a href="/Culture/SetLanguage?culture=en-US&returnUrl=@Context.Request.Path" class="hover:text-white text-slate-300 transition-colors">EN</a>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-slate-400">|</span>
                            <a href="/Auth/Logout" class="hover:text-red-400 text-slate-300 transition-colors">@Localizer["Logout"]</a>
                        }
                        else
                        {
                            <span class="text-slate-400">|</span>
                            <a href="/Auth/Login" class="hover:text-white text-slate-300 transition-colors">@Localizer["Login"]</a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Navigation -->
        <header class="bg-white shadow-lg sticky top-0 z-50 nav-header" x-data="{ mobileMenuOpen: false }">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-start md:items-center min-h-[4rem] py-2">
                   <div class="flex flex-1 min-w-0">
                        <div class="flex-shrink-0 flex items-center pr-4 mt-1 md:mt-0">
                             <!-- Example Logo using text if no image provided, styled to look like a brand -->
                            <a href="/" class="text-3xl font-black italic text-red-600 tracking-tighter hover:opacity-80 transition-opacity">imaj</a>
                        </div>
                        <div class="nav-menu-container">
                            <!-- Menu Items -->
                            @{
                                var visibleMenuItems = User.Identity?.IsAuthenticated == true
                                    ? await PermissionViewService.GetVisibleMenuItemsAsync()
                                    : Array.Empty<Imaj.Web.Models.Authorization.VisibleMenuItem>();

                                var menuItems = visibleMenuItems
                                    .Select(item => new
                                    {
                                        item.Key,
                                        Label = item.Key switch
                                        {
                                            "Home" => Localizer["Home"].Value,
                                            "User" => Localizer["User"].Value,
                                            "Employee" => Localizer["Employee"].Value,
                                            "ResoCat" => Localizer["ResoCat"].Value,
                                            "Function" => Localizer["Function"].Value,
                                            "WorkType" => Localizer["WorkType"].Value,
                                            "TimeType" => Localizer["TimeType"].Value,
                                            "TaxType" => Localizer["TaxType"].Value,
                                            "ProdCat" => Localizer["ProdCat"].Value,
                                            "ProdGrp" => Localizer["ProdGrp"].Value,
                                            "Product" => Localizer["Product"].Value,
                                            "Resource" => Localizer["Resource"].Value,
                                            "Reason" => Localizer["Reason"].Value,
                                            "Absence" => Localizer["Absence"].Value,
                                            "Customer" => Localizer["Customer"].Value,
                                            "Job" => Localizer["Job"].Value,
                                            "Invoice" => Localizer["Invoice"].Value,
                                            "OvertimeReport" => Localizer["OvertimeReport"].Value,
                                            "ProductReport" => "Ürün Raporu",
                                            _ => item.Label
                                        },
                                        item.Url
                                    })
                                    .ToList();
                            }
                            @foreach (var item in menuItems)
                            {
                                <a href="@item.Url" class="nav-menu-item">
                                    @item.Label
                                </a>
                            }
                        </div>
                    </div>
                     <!-- Mobile menu button placeholder -->
                    <div class="-mr-2 flex items-center md:hidden">
                        <button type="button" @@click="mobileMenuOpen = !mobileMenuOpen" class="bg-white inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" aria-controls="mobile-menu" :aria-expanded="mobileMenuOpen.toString()">
                            <span class="sr-only">Menüyü aç</span>
                            <!-- Hamburger icon -->
                            <svg class="h-6 w-6" :class="{'hidden': mobileMenuOpen, 'block': !mobileMenuOpen }" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                            <!-- Close icon -->
                            <svg class="h-6 w-6" :class="{'block': mobileMenuOpen, 'hidden': !mobileMenuOpen }" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
             <!-- Mobile Menu (Hidden by default) -->
            <div class="md:hidden" id="mobile-menu" x-show="mobileMenuOpen" style="display: none;">
                <div class="pt-2 pb-3 space-y-1 bg-white shadow-inner max-h-96 overflow-y-auto">
                     @foreach (var item in menuItems)
                    {
                        <a href="@item.Url" class="block pl-3 pr-4 py-2 border-l-4 border-transparent text-base font-medium text-gray-600 hover:bg-gray-50 hover:border-indigo-500 hover:text-indigo-700">@item.Label</a>
                    }
                </div>
            </div>
        </header>

        <main class="flex-grow bg-gray-50">
            <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
                 @RenderBody()
            </div>
        </main>

        <footer class="bg-slate-900 border-t border-slate-800 text-slate-400">
            <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
                <div class="md:flex md:items-center md:justify-between">
                    <div class="flex justify-center md:order-2">
                        <p class="text-sm">
                            @Localizer["InformationSystem"] &copy; @DateTime.Now.Year
                        </p>
                    </div>
                    <div class="mt-8 md:mt-0 md:order-1">
                        <p class="text-center text-sm">
                           @Localizer["ServiceQuality"]
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <!-- Site JavaScript -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Component Scripts -->
    <script src="~/js/components/customer-select-modal.js" asp-append-version="true"></script>
    <script src="~/js/components/employee-select-modal.js" asp-append-version="true"></script>
    <script src="~/js/components/product-select-modal.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            @if (TempData["SuccessMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Başarılı!',
                    text: '@Html.Raw(TempData["SuccessMessage"])',
                    confirmButtonColor: '#3085d6',
                    confirmButtonText: 'Tamam'
                });
                </text>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <text>
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                    text: '@Html.Raw(TempData["ErrorMessage"])',
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Tamam'
                });
                </text>
            }
        });
    </script>
</body>
</html>
