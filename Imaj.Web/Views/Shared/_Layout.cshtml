@using System.Globalization
@using System.Text.Json
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Imaj.Web.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@inject IPermissionViewService PermissionViewService
@inject IAntiforgery Antiforgery

@{
    var canShowChangePassword = User.Identity?.IsAuthenticated == true &&
        await PermissionViewService.CanExecuteMethodAsync(1039m);
    var antiForgeryTokens = Antiforgery.GetAndStoreTokens(Context);
    var topBarUserCode = User.Identity?.IsAuthenticated == true ? User.Identity?.Name : null;
    var currentUrl = $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content="@antiForgeryTokens.RequestToken" />
    <title>@ViewData["Title"] - Imaj</title>
    <!-- TailwindCSS (Local Build) -->
    <link rel="stylesheet" href="~/css/tailwind.output.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.9/dist/cdn.min.js" integrity="sha384-9Ax3MmS9AClxJyd5/zafcXXjxmwFhZCdsT6HJoJjarvCaAkJlk5QDzjLJm+Wdx5F" crossorigin="anonymous" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.3/dist/sweetalert2.all.min.js" integrity="sha384-BX77tysPwMmjY87hyuYr8cUvUQiHJMvAjLu9iWF4Ls6HQLzalVw0fm/Ez1VwzAv7" crossorigin="anonymous"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased">
    <div class="min-h-screen flex flex-col">
        <!-- Top Bar: Company Info & User Profile -->
        <div class="bg-slate-900 text-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-between text-sm flex-wrap gap-2">
                <div class="layout-topbar-group flex items-center space-x-4">
                    <span class="font-medium tracking-wide">IMAJ POST-PRODÜKSİYON HİZMETLERİ</span>
                    @if (!string.IsNullOrWhiteSpace(topBarUserCode))
                    {
                        <span class="hidden sm:inline text-slate-400">|</span>
                        <span class="hidden sm:inline text-slate-400">@topBarUserCode</span>
                    }
                </div>
                <!-- ... existing top bar right side ... -->
                <div class="layout-topbar-group flex items-center space-x-6">
                    <span class="text-slate-300">@Localizer["SystemVersion"]</span>
                    <div class="layout-topbar-links flex items-center space-x-3">
                        <a asp-controller="Culture"
                           asp-action="SetLanguage"
                           asp-route-culture="tr-TR"
                           asp-route-returnUrl="@currentUrl"
                           class="hover:text-white text-slate-300 transition-colors">TR</a>
                        <span class="text-slate-400">|</span>
                        <a asp-controller="Culture"
                           asp-action="SetLanguage"
                           asp-route-culture="en-US"
                           asp-route-returnUrl="@currentUrl"
                           class="hover:text-white text-slate-300 transition-colors">EN</a>

                        @if (canShowChangePassword)
                        {
                            <span class="text-slate-400">|</span>
                            <a href="/User/ChangePassword" class="hover:text-white text-slate-300 transition-colors">@Localizer["ChangePassword"]</a>
                        }
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="text-slate-400">|</span>
                            <a href="/Auth/Logout" class="hover:text-red-400 text-slate-300 transition-colors">@Localizer["Logout"]</a>
                        }
                        else
                        {
                            <span class="text-slate-400">|</span>
                            <a href="/Auth/Login" class="hover:text-white text-slate-300 transition-colors">@Localizer["Login"]</a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Navigation -->
        <header class="bg-white shadow-lg sticky top-0 z-50 nav-header"
                x-data="{ mobileMenuOpen: false }"
                x-on:keydown.escape.window="mobileMenuOpen = false"
                x-on:resize.window="if (window.innerWidth >= 768) mobileMenuOpen = false">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between items-start md:items-center min-h-[4rem] py-2">
                   <div class="flex flex-1 min-w-0">
                        <div class="flex-shrink-0 flex items-center pr-4 mt-1 md:mt-0">
                             <!-- Example Logo using text if no image provided, styled to look like a brand -->
                            <a href="/" class="text-3xl font-black italic text-red-600 tracking-tighter hover:opacity-80 transition-opacity">imaj</a>
                        </div>
                        <div class="nav-menu-container">
                            <!-- Menu Items -->
                            @{
                                var visibleMenuItems = User.Identity?.IsAuthenticated == true
                                    ? await PermissionViewService.GetVisibleMenuItemsAsync()
                                    : Array.Empty<Imaj.Web.Models.Authorization.VisibleMenuItem>();

                                var menuItems = visibleMenuItems
                                    .Select(item => new
                                    {
                                        item.Key,
                                        Label = item.Key switch
                                        {
                                            "Home" => Localizer["Home"].Value,
                                            "User" => Localizer["User"].Value,
                                            "Employee" => Localizer["Employee"].Value,
                                            "ResoCat" => Localizer["ResoCat"].Value,
                                            "Function" => Localizer["Function"].Value,
                                            "WorkType" => Localizer["WorkType"].Value,
                                            "TimeType" => Localizer["TimeType"].Value,
                                            "TaxType" => Localizer["TaxType"].Value,
                                            "ProdCat" => Localizer["ProdCat"].Value,
                                            "ProdGrp" => Localizer["ProdGrp"].Value,
                                            "Product" => Localizer["Product"].Value,
                                            "Resource" => Localizer["Resource"].Value,
                                            "Reason" => Localizer["Reason"].Value,
                                            "Absence" => Localizer["Absence"].Value,
                                            "Customer" => Localizer["Customer"].Value,
                                            "Job" => Localizer["Job"].Value,
                                            "JobEntry" => Localizer["JobEntry"].Value,
                                            "Invoice" => Localizer["Invoice"].Value,
                                            "OvertimeReport" => Localizer["OvertimeReport"].Value,
                                            "ProductReport" => Localizer["ProductReportMenu"].Value,
                                            _ => item.Label
                                        },
                                        item.Url
                                    })
                                    .ToList();
                            }
                            @foreach (var item in menuItems)
                            {
                                <a href="@item.Url" class="nav-menu-item">
                                    @item.Label
                                </a>
                            }
                        </div>
                    </div>
                     <!-- Mobile menu button placeholder -->
                    <div class="-mr-2 flex items-center md:hidden">
                        <button type="button"
                                @@click="mobileMenuOpen = !mobileMenuOpen"
                                class="bg-white inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
                                aria-controls="mobile-menu"
                                :aria-expanded="mobileMenuOpen.toString()">
                            <span class="sr-only">@Localizer["OpenMenu"]</span>
                            <!-- Hamburger icon -->
                            <svg class="h-6 w-6" :class="{'hidden': mobileMenuOpen, 'block': !mobileMenuOpen }" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                            <!-- Close icon -->
                            <svg class="h-6 w-6" :class="{'block': mobileMenuOpen, 'hidden': !mobileMenuOpen }" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
             <!-- Mobile Menu (Hidden by default) -->
            <div class="md:hidden" id="mobile-menu" x-cloak x-show="mobileMenuOpen" style="display: none;">
                <div class="mobile-menu-panel pt-2 pb-3 space-y-1 bg-white shadow-inner overflow-y-auto"
                     x-on:click.outside="mobileMenuOpen = false">
                     @foreach (var item in menuItems)
                    {
                        <a href="@item.Url"
                           @@click="mobileMenuOpen = false"
                           class="block pl-3 pr-4 py-3 border-l-4 border-transparent text-base font-medium text-gray-600 hover:bg-gray-50 hover:border-indigo-500 hover:text-indigo-700">
                            @item.Label
                        </a>
                    }
                </div>
            </div>
        </header>

        <main class="flex-grow bg-gray-50">
            <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
                 @RenderBody()
            </div>
        </main>

        <footer class="bg-slate-900 border-t border-slate-800 text-slate-400">
            <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
                <div class="md:flex md:items-center md:justify-between">
                    <div class="flex justify-center md:order-2">
                        <p class="text-sm">
                            @Localizer["InformationSystem"] &copy; @DateTime.Now.Year
                        </p>
                    </div>
                    <div class="mt-8 md:mt-0 md:order-1">
                        <p class="text-center text-sm">
                           @Localizer["ServiceQuality"]
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <script>
        window.imajTexts = @Html.Raw(JsonSerializer.Serialize(new
        {
            successTitle = Localizer["SuccessTitle"].Value,
            errorTitle = Localizer["ErrorTitle"].Value,
            ok = Localizer["Ok"].Value,
            yes = Localizer["ConfirmYes"].Value,
            cancel = Localizer["ConfirmCancel"].Value,
            genericError = Localizer["GenericError"].Value,
            pleaseEnterCustomerCode = Localizer["PleaseEnterCustomerCode"].Value,
            customerCreatedSuccess = Localizer["CustomerCreatedSuccess"].Value,
            customerCreateFailed = Localizer["CustomerCreateFailed"].Value,
            printReportStarted = Localizer["PrintReportStarted"].Value,
            pleaseSelectCustomer = Localizer["PleaseSelectCustomer"].Value,
            pleaseEnterJobName = Localizer["PleaseEnterJobName"].Value,
            pleaseEnterStartDate = Localizer["PleaseEnterStartDate"].Value,
            serverError = Localizer["ServerError"].Value,
            connectionError = Localizer["ConnectionError"].Value,
            workflowConfirmTitle = Localizer["WorkflowConfirmTitle"].Value,
            workflowConfirmText = Localizer["WorkflowConfirmText"].Value,
            workflowLoadingTitle = Localizer["WorkflowLoadingTitle"].Value,
            workflowLoadingText = Localizer["WorkflowLoadingText"].Value
        }));
    </script>

    <!-- Site JavaScript -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Component Scripts -->
    <script src="~/js/components/customer-select-modal.js" asp-append-version="true"></script>
    <script src="~/js/components/employee-select-modal.js" asp-append-version="true"></script>
    <script src="~/js/components/product-select-modal.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const flashMessages = @Html.Raw(JsonSerializer.Serialize(new
            {
                success = TempData["SuccessMessage"]?.ToString(),
                error = TempData["ErrorMessage"]?.ToString()
            }));

            if (flashMessages.success) {
                Swal.fire({
                    icon: 'success',
                    title: '@Localizer["SuccessTitle"]',
                    text: flashMessages.success,
                    confirmButtonColor: '#3085d6',
                    confirmButtonText: '@Localizer["Ok"]'
                });
            }

            if (flashMessages.error) {
                Swal.fire({
                    icon: 'error',
                    title: '@Localizer["ErrorTitle"]',
                    text: flashMessages.error,
                    confirmButtonColor: '#d33',
                    confirmButtonText: '@Localizer["Ok"]'
                });
            }
        });
    </script>
</body>
</html>
