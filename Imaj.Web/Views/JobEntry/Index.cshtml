@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@using System.Globalization
@using System.Text.Json
@inject IStringLocalizer<SharedResource> Localizer
@model JobViewModel

@{
    ViewData["Title"] = Localizer["JobOperations"];
    var filter = Model.Filter ?? new JobFilterModel();
    string JsonValue(string? value) => JsonSerializer.Serialize(value ?? string.Empty);
    string JsonDate(DateTime? value) => JsonSerializer.Serialize(value?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? string.Empty);
    string JsonDecimal(decimal? value) => JsonSerializer.Serialize(value.HasValue ? value.Value.ToString(CultureInfo.InvariantCulture) : string.Empty);
    var firstValue = filter.First.HasValue && filter.First.Value > 0 ? filter.First.Value : (filter.PageSize > 0 ? filter.PageSize : 10);
    var pageSizeValue = filter.PageSize > 0 ? filter.PageSize : 10;
}

<div x-data="jobEntryPage()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@product-selected.window="handleProductSelection($event.detail)" @@employee-selected.window="handleEmployeeSelection($event.detail)" class="job-page-shell job-index-shell job-index-reference page-shell--wide space-y-2">
    <div class="text-center job-index-heading">
        <h2 class="job-page-title job-page-title--orange">
            @Localizer["JobSearch"]
        </h2>
    </div>

    <form method="get" action="/JobEntry/List" class="job-index-form space-y-2 text-left">
        <div class="dense-panel-grid job-index-reference-grid">
            <div class="dense-panel-grid__column">
                <section class="dense-panel job-index-reference-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["JobCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body mobile-stack-form">
                        <div class="dense-form-grid job-index-criteria-list">
                            <div class="dense-form-row">
                                <label for="JobEntryFunction">@Localizer["Function"]</label>
                                <select id="JobEntryFunction" name="Filter.Function" x-model="filter.function" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["SelectPrompt"]</option>
                                    @if (ViewBag.Functions != null)
                                    {
                                        @foreach (var func in ViewBag.Functions)
                                        {
                                            <option value="@func.Id">@func.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["Customer"]</label>
                                <div class="job-index-selector">
                                    <input type="hidden" name="Filter.CustomerCode" x-model="filter.customerCode">
                                    <input type="hidden" name="Filter.CustomerId" x-model="filter.customerId">
                                    <input type="hidden" name="Filter.CustomerName" x-model="customerName">
                                    <span class="job-index-selector__value" x-text='customerName || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AllOption"].Value))'></span>
                                    <span class="job-index-selector__separator">-</span>
                                    <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'jobFilter', searchEndpoint: '/JobEntry/CustomerSearch', jobStatesEndpoint: '/JobEntry/CustomerJobStates' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["ReferenceRange"]</label>
                                <div class="job-index-range">
                                    <input type="text" name="Filter.ReferenceStart" x-model="filter.referenceStart" class="dense-input job-index-input--range">
                                    <input type="text" name="Filter.ReferenceEnd" x-model="filter.referenceEnd" class="dense-input job-index-input--range">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryReference">@Localizer["Reference"]</label>
                                <input id="JobEntryReference" type="text" name="Filter.ReferenceList" x-model="filter.referenceList" class="dense-input job-index-input--wide">
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryName">@Localizer["Name"]</label>
                                <input id="JobEntryName" type="text" name="Filter.JobName" x-model="filter.jobName" class="dense-input job-index-input--medium">
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryRelated">@Localizer["Related"]</label>
                                <input id="JobEntryRelated" type="text" name="Filter.RelatedPerson" x-model="filter.relatedPerson" class="dense-input job-index-input--medium">
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["StartDateRange"]</label>
                                <div class="job-index-range">
                                    <input type="date" name="Filter.StartDateStart" x-model="filter.startDateStart" class="dense-input job-index-input--date">
                                    <input type="date" name="Filter.StartDateEnd" x-model="filter.startDateEnd" class="dense-input job-index-input--date">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["EndDateRange"]</label>
                                <div class="job-index-range">
                                    <input type="date" name="Filter.EndDateStart" x-model="filter.endDateStart" class="dense-input job-index-input--date">
                                    <input type="date" name="Filter.EndDateEnd" x-model="filter.endDateEnd" class="dense-input job-index-input--date">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryStatus">@Localizer["Status"]</label>
                                <select id="JobEntryStatus" name="Filter.Status" x-model="filter.status" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.States != null)
                                    {
                                        @foreach (var state in ViewBag.States)
                                        {
                                            <option value="@state.Id">@state.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryEmailSent">@Localizer["EmailSent"]</label>
                                <select id="JobEntryEmailSent" name="Filter.EmailSent" x-model="filter.emailSent" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryEvaluated">@Localizer["Evaluated"]</label>
                                <select id="JobEntryEvaluated" name="Filter.Evaluated" x-model="filter.evaluated" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="dense-panel-grid__column job-index-side-column">
                <section class="dense-panel job-index-reference-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["OvertimeCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body mobile-stack-form">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label>@Localizer["Employee"]</label>
                                <div class="job-index-selector">
                                    <input type="hidden" name="Filter.EmployeeCode" x-model="filter.employeeCode">
                                    <input type="hidden" name="Filter.EmployeeName" x-model="filter.employeeName">
                                    <span class="job-index-selector__value" x-text='filter.employeeName || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AllOption"].Value))'></span>
                                    <span class="job-index-selector__separator">-</span>
                                    <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'jobEmployee', showFilter: true })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryTaskType">@Localizer["WorkType"]</label>
                                <select id="JobEntryTaskType" name="Filter.TaskType" x-model="filter.taskType" class="dense-input job-index-input--side-select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.WorkTypes != null)
                                    {
                                        @foreach (var wt in ViewBag.WorkTypes)
                                        {
                                            <option value="@wt.Id">@wt.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryOvertimeType">@Localizer["TimeType"]</label>
                                <select id="JobEntryOvertimeType" name="Filter.OvertimeType" x-model="filter.overtimeType" class="dense-input job-index-input--side-select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.TimeTypes != null)
                                    {
                                        @foreach (var tt in ViewBag.TimeTypes)
                                        {
                                            <option value="@tt.Id">@tt.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="dense-panel job-index-reference-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["ProductCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body dense-panel__body--tight mobile-stack-form">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label>@Localizer["Product"]</label>
                                <div class="job-index-selector">
                                    <input type="hidden" name="Filter.ProductId" x-model="filter.productId">
                                    <input type="hidden" name="Filter.ProductCode" x-model="filter.productCode">
                                    <input type="hidden" name="Filter.ProductName" x-model="filter.productName">
                                    <span class="job-index-selector__value" x-text='filter.productName || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AllOption"].Value))'></span>
                                    <span class="job-index-selector__separator">-</span>
                                    <button type="button" @@click="$dispatch('product-select-open', { targetId: 'jobProduct', searchEndpoint: '/JobEntry/ProductSearch', categoriesEndpoint: '/JobEntry/ProductCategories', productGroupsEndpoint: '/JobEntry/ProductGroups', functionsEndpoint: '/JobEntry/ProductFunctions', functionId: filter.function || '' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <input type="hidden" name="Filter.Page" value="1">

        <div class="dense-toolbar job-index-toolbar">
            <label for="JobEntryFirst" class="dense-toolbar__label">@Localizer["First"]</label>
            <input id="JobEntryFirst" type="number" name="Filter.First" x-model="filter.first" min="1" class="dense-input dense-toolbar__input">
            <label for="JobEntryPageSize" class="dense-toolbar__label">@Localizer["PageSize"]</label>
            <input id="JobEntryPageSize" type="number" name="Filter.PageSize" x-model="filter.pageSize" min="1" class="dense-input dense-toolbar__input">
            <button type="submit" class="inline-flex items-center px-4 py-1 border border-blue-300 text-sm font-medium rounded shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["Search"]
            </button>
        </div>
    </form>

    <section class="job-index-section job-index-section--narrow">
        <h3 class="job-index-section__title">@Localizer["JobCreation"]</h3>
        <section class="dense-panel job-index-create-panel">
            <div class="dense-panel__header">
                <h4 class="dense-panel__title">@Localizer["PreInformation"]</h4>
            </div>
            <div class="dense-panel__body job-index-create-panel__body">
                <div class="dense-form-row">
                    <label for="JobEntryCreateFunction">@Localizer["Function"]</label>
                    <select id="JobEntryCreateFunction" x-model="filter.function" class="dense-input job-index-input--select">
                        <option value="">@Localizer["SelectPrompt"]</option>
                        @if (ViewBag.Functions != null)
                        {
                            @foreach (var func in ViewBag.Functions)
                            {
                                <option value="@func.Id">@func.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </section>
        <div class="job-index-create-cta">
            <a :href="filter.function ? '/JobEntry/Create?functionId=' + encodeURIComponent(filter.function) : '/JobEntry/Create'" class="inline-flex items-center justify-center px-5 py-2 border border-blue-300 text-sm font-bold rounded shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["CreateNewJob"]
            </a>
        </div>
    </section>

    <partial name="_CustomerSelectModal" />
    <partial name="_ProductSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script>
    function jobEntryPage() {
        return {
            filter: {
                function: @Html.Raw(JsonValue(filter.Function)),
                customerCode: @Html.Raw(JsonValue(filter.CustomerCode)), customerId: @Html.Raw(JsonDecimal(filter.CustomerId)),
                referenceStart: @Html.Raw(JsonValue(filter.ReferenceStart)), referenceEnd: @Html.Raw(JsonValue(filter.ReferenceEnd)), referenceList: @Html.Raw(JsonValue(filter.ReferenceList)),
                jobName: @Html.Raw(JsonValue(filter.JobName)), relatedPerson: @Html.Raw(JsonValue(filter.RelatedPerson)),
                startDateStart: @Html.Raw(JsonDate(filter.StartDateStart)),
                startDateEnd: @Html.Raw(JsonDate(filter.StartDateEnd)),
                endDateStart: @Html.Raw(JsonDate(filter.EndDateStart)), endDateEnd: @Html.Raw(JsonDate(filter.EndDateEnd)),
                status: @Html.Raw(JsonValue(filter.Status)), emailSent: @Html.Raw(JsonValue(filter.EmailSent)), evaluated: @Html.Raw(JsonValue(filter.Evaluated)),
                employeeCode: @Html.Raw(JsonValue(filter.EmployeeCode)), employeeName: @Html.Raw(JsonValue(filter.EmployeeName)),
                taskType: @Html.Raw(JsonValue(filter.TaskType)), overtimeType: @Html.Raw(JsonValue(filter.OvertimeType)),
                productId: @Html.Raw(JsonDecimal(filter.ProductId)), productCode: @Html.Raw(JsonValue(filter.ProductCode)), productName: @Html.Raw(JsonValue(filter.ProductName)),
                page: 1,
                first: @firstValue,
                pageSize: @pageSizeValue
            },

            customerName: @Html.Raw(JsonValue(filter.CustomerName)),

            init() {},

            handleCustomerSelection(detail) {
                if (detail.targetId === 'jobFilter') {
                    this.filter.customerCode = detail.customer.code;
                    this.filter.customerId = detail.customer.id;
                    this.customerName = detail.customer.name;
                }
            },

            handleProductSelection(detail) {
                if (detail.targetId === 'jobProduct') {
                    const product = detail.product || (detail.products && detail.products[0]);
                    if (product) {
                        this.filter.productId = product.id;
                        this.filter.productName = product.name;
                        this.filter.productCode = product.code;
                    }
                }
            },

            handleEmployeeSelection(detail) {
                if (detail.targetId === 'jobEmployee') {
                    const emp = detail.employee;
                    if (emp) {
                        this.filter.employeeName = emp.name;
                        this.filter.employeeCode = emp.code;
                    } else {
                        this.filter.employeeName = '';
                        this.filter.employeeCode = '';
                    }
                }
            }
        }
    }
</script>
