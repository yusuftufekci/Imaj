@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model JobViewModel

@{
    ViewData["Title"] = Localizer["JobOperations"];
}

<div x-data="jobEntryPage()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@product-selected.window="handleProductSelection($event.detail)" @@employee-selected.window="handleEmployeeSelection($event.detail)" class="job-page-shell job-index-shell page-shell--wide space-y-2">
    <div class="text-center">
        <h2 class="job-page-title job-page-title--orange">
            @Localizer["JobSearch"]
        </h2>
    </div>

    <form method="get" action="/JobEntry/List" class="space-y-2 text-left">
        <div class="dense-panel-grid">
            <div class="dense-panel-grid__column">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["JobCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body mobile-stack-form">
                        <div class="job-index-main-grid">
                            <div class="dense-form-grid">
                                <div class="dense-form-row">
                                    <label for="JobEntryFunction">@Localizer["Function"]</label>
                                    <select id="JobEntryFunction" name="Filter.Function" x-model="filter.function" class="dense-input">
                                        <option value="">@Localizer["SelectPrompt"]</option>
                                        @if (ViewBag.Functions != null)
                                        {
                                            @foreach (var func in ViewBag.Functions)
                                            {
                                                <option value="@func.Id">@func.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["Customer"]</label>
                                    <div class="picker-inline flex items-center gap-2">
                                        <input type="hidden" name="Filter.CustomerCode" x-model="filter.customerCode">
                                        <input type="hidden" name="Filter.CustomerId" x-model="filter.customerId">
                                        <input type="text" readonly x-model="customerName" class="dense-input bg-gray-50" placeholder="@Localizer["AllOption"]">
                                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'jobFilter', searchEndpoint: '/JobEntry/CustomerSearch', jobStatesEndpoint: '/JobEntry/CustomerJobStates' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                            @Localizer["Select"]
                                        </button>
                                    </div>
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["ReferenceRange"]</label>
                                    <div class="picker-inline flex items-center gap-2">
                                        <input type="text" name="Filter.ReferenceStart" x-model="filter.referenceStart" class="dense-input">
                                        <input type="text" name="Filter.ReferenceEnd" x-model="filter.referenceEnd" class="dense-input">
                                    </div>
                                </div>
                                <div class="dense-form-row">
                                    <label for="JobEntryReference">@Localizer["Reference"]</label>
                                    <input id="JobEntryReference" type="text" name="Filter.ReferenceList" x-model="filter.referenceList" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label for="JobEntryName">@Localizer["Name"]</label>
                                    <input id="JobEntryName" type="text" name="Filter.JobName" x-model="filter.jobName" class="dense-input">
                                </div>
                            </div>
                            <div class="dense-form-grid">
                                <div class="dense-form-row">
                                    <label for="JobEntryRelated">@Localizer["Related"]</label>
                                    <input id="JobEntryRelated" type="text" name="Filter.RelatedPerson" x-model="filter.relatedPerson" class="dense-input">
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["StartDateRange"]</label>
                                    <div class="picker-inline flex items-center gap-2">
                                        <input type="date" name="Filter.StartDateStart" x-model="filter.startDateStart" class="dense-input" value="@Model.Filter.StartDateStart?.ToString("yyyy-MM-dd")">
                                        <input type="date" name="Filter.StartDateEnd" x-model="filter.startDateEnd" class="dense-input" value="@Model.Filter.StartDateEnd?.ToString("yyyy-MM-dd")">
                                    </div>
                                </div>
                                <div class="dense-form-row">
                                    <label>@Localizer["EndDateRange"]</label>
                                    <div class="picker-inline flex items-center gap-2">
                                        <input type="date" name="Filter.EndDateStart" x-model="filter.endDateStart" class="dense-input">
                                        <input type="date" name="Filter.EndDateEnd" x-model="filter.endDateEnd" class="dense-input">
                                    </div>
                                </div>
                                <div class="dense-form-row">
                                    <label for="JobEntryStatus">@Localizer["Status"]</label>
                                    <select id="JobEntryStatus" name="Filter.Status" x-model="filter.status" class="dense-input">
                                        <option value="">@Localizer["AllOption"]</option>
                                        @if (ViewBag.States != null)
                                        {
                                            @foreach (var state in ViewBag.States)
                                            {
                                                <option value="@state.Id">@state.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="dense-form-row">
                                    <label for="JobEntryEmailSent">@Localizer["EmailSent"]</label>
                                    <select id="JobEntryEmailSent" name="Filter.EmailSent" x-model="filter.emailSent" class="dense-input">
                                        <option value="">@Localizer["AllOption"]</option>
                                        <option value="true">@Localizer["Yes"]</option>
                                        <option value="false">@Localizer["No"]</option>
                                    </select>
                                </div>
                                <div class="dense-form-row">
                                    <label for="JobEntryEvaluated">@Localizer["Evaluated"]</label>
                                    <select id="JobEntryEvaluated" name="Filter.Evaluated" x-model="filter.evaluated" class="dense-input">
                                        <option value="">@Localizer["AllOption"]</option>
                                        <option value="true">@Localizer["Yes"]</option>
                                        <option value="false">@Localizer["No"]</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="dense-panel-grid__column">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["OvertimeCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body mobile-stack-form">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label>@Localizer["Employee"]</label>
                                <div class="picker-inline flex items-center gap-2">
                                    <input type="hidden" name="Filter.EmployeeCode" x-model="filter.employeeCode">
                                    <input type="text" readonly x-model="filter.employeeName" class="dense-input bg-gray-50" placeholder="@Localizer["AllOption"]">
                                    <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'jobEmployee', showFilter: true })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryTaskType">@Localizer["WorkType"]</label>
                                <select id="JobEntryTaskType" name="Filter.TaskType" x-model="filter.taskType" class="dense-input">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.WorkTypes != null)
                                    {
                                        @foreach (var wt in ViewBag.WorkTypes)
                                        {
                                            <option value="@wt.Id">@wt.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEntryOvertimeType">@Localizer["TimeType"]</label>
                                <select id="JobEntryOvertimeType" name="Filter.OvertimeType" x-model="filter.overtimeType" class="dense-input">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.TimeTypes != null)
                                    {
                                        @foreach (var tt in ViewBag.TimeTypes)
                                        {
                                            <option value="@tt.Id">@tt.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["ProductCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body dense-panel__body--tight mobile-stack-form">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label>@Localizer["Product"]</label>
                                <div class="picker-inline flex items-center gap-2">
                                    <input type="hidden" name="Filter.ProductId" x-model="filter.productId">
                                    <input type="hidden" name="Filter.ProductCode" x-model="filter.productCode">
                                    <input type="text" readonly x-model="filter.productName" class="dense-input bg-gray-50" placeholder="@Localizer["AllOption"]">
                                    <button type="button" @@click="$dispatch('product-select-open', { targetId: 'jobProduct', searchEndpoint: '/JobEntry/ProductSearch', categoriesEndpoint: '/JobEntry/ProductCategories', productGroupsEndpoint: '/JobEntry/ProductGroups', functionsEndpoint: '/JobEntry/ProductFunctions' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <input type="hidden" name="Filter.Page" value="1">

        <div class="dense-toolbar">
            <label for="JobEntryFirst" class="dense-toolbar__label">@Localizer["First"]</label>
            <input id="JobEntryFirst" type="number" name="Filter.First" x-model="filter.first" min="1" class="dense-input dense-toolbar__input">
            <label for="JobEntryPageSize" class="dense-toolbar__label">@Localizer["PageSize"]</label>
            <input id="JobEntryPageSize" type="number" name="Filter.PageSize" x-model="filter.pageSize" min="1" class="dense-input dense-toolbar__input">
            <button type="submit" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                @Localizer["Search"]
            </button>
        </div>
    </form>

    <div class="dense-action-grid">
        <section class="dense-action-card">
            <div class="dense-action-card__header">
                <h3 class="dense-action-card__title">@Localizer["JobCreation"]</h3>
            </div>
            <div class="dense-action-card__body flex-col items-stretch">
                <div class="dense-form-row">
                    <label for="JobEntryCreateFunction">@Localizer["Function"]</label>
                    <select id="JobEntryCreateFunction" x-model="filter.function" class="dense-input">
                        <option value="">@Localizer["SelectPrompt"]</option>
                        @if (ViewBag.Functions != null)
                        {
                            @foreach (var func in ViewBag.Functions)
                            {
                                <option value="@func.Id">@func.Name</option>
                            }
                        }
                    </select>
                </div>
                <a :href="filter.function ? '/JobEntry/Create?functionId=' + encodeURIComponent(filter.function) : '/JobEntry/Create'" class="inline-flex items-center justify-center px-5 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                    @Localizer["CreateNewJob"]
                </a>
            </div>
        </section>
    </div>

    <partial name="_CustomerSelectModal" />
    <partial name="_ProductSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script>
    function jobEntryPage() {
        return {
            filter: {
                function: '',
                customerCode: '', customerId: '',
                referenceStart: '', referenceEnd: '', referenceList: '',
                jobName: '', relatedPerson: '',
                startDateStart: '@Model.Filter.StartDateStart?.ToString("yyyy-MM-dd")',
                startDateEnd: '@Model.Filter.StartDateEnd?.ToString("yyyy-MM-dd")',
                endDateStart: '', endDateEnd: '',
                status: '', emailSent: '', evaluated: '',
                employeeCode: '', employeeName: '',
                taskType: '', overtimeType: '',
                productId: '', productCode: '', productName: '',
                page: 1,
                first: @((Model.Filter.First.HasValue && Model.Filter.First.Value > 0 ? Model.Filter.First.Value : (Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 10))),
                pageSize: @(Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 10)
            },

            customerName: '',

            init() {},

            handleCustomerSelection(detail) {
                if (detail.targetId === 'jobFilter') {
                    this.filter.customerCode = detail.customer.code;
                    this.filter.customerId = detail.customer.id;
                    this.customerName = detail.customer.name;
                }
            },

            handleProductSelection(detail) {
                if (detail.targetId === 'jobProduct') {
                    const product = detail.product || (detail.products && detail.products[0]);
                    if (product) {
                        this.filter.productId = product.id;
                        this.filter.productName = product.name;
                        this.filter.productCode = product.code;
                    }
                }
            },

            handleEmployeeSelection(detail) {
                if (detail.targetId === 'jobEmployee') {
                    const emp = detail.employee;
                    if (emp) {
                        this.filter.employeeName = emp.name;
                        this.filter.employeeCode = emp.code;
                    } else {
                        this.filter.employeeName = '';
                        this.filter.employeeCode = '';
                    }
                }
            }
        }
    }
</script>
