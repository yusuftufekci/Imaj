@using System.Text.Json
@model JobCreateViewModel

@{
    ViewData["Title"] = Localizer["CreateNewJob"];
    var currentFunctionId = Model.FunctionId?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
    var defaultWorkTypeId = (ViewBag.WorkTypes != null && ((List<Imaj.Service.DTOs.WorkTypeDto>)ViewBag.WorkTypes).Count > 0)
        ? ((List<Imaj.Service.DTOs.WorkTypeDto>)ViewBag.WorkTypes)[0].Id
        : 0;
    var defaultWorkTypeName = (ViewBag.WorkTypes != null && ((List<Imaj.Service.DTOs.WorkTypeDto>)ViewBag.WorkTypes).Count > 0)
        ? ((List<Imaj.Service.DTOs.WorkTypeDto>)ViewBag.WorkTypes)[0].Name
        : string.Empty;
    var defaultTimeTypeId = (ViewBag.TimeTypes != null && ((List<Imaj.Service.DTOs.TimeTypeDto>)ViewBag.TimeTypes).Count > 0)
        ? ((List<Imaj.Service.DTOs.TimeTypeDto>)ViewBag.TimeTypes)[0].Id
        : 0;
    var workTypeNames = (ViewBag.WorkTypes != null
        ? ((List<Imaj.Service.DTOs.WorkTypeDto>)ViewBag.WorkTypes).ToDictionary(
            x => x.Id.ToString(System.Globalization.CultureInfo.InvariantCulture),
            x => x.Name)
        : new Dictionary<string, string>());
    var initialStateJson = JsonSerializer.Serialize(new
    {
        defaultWorkTypeId,
        defaultWorkTypeName,
        workTypeNames,
        defaultTimeTypeId,
        productPicker = new
        {
            functionId = currentFunctionId,
            functionName = Model.FunctionName ?? string.Empty,
            searchEndpoint = "/JobEntry/ProductSearch",
            categoriesEndpoint = "/JobEntry/ProductCategories",
            productGroupsEndpoint = "/JobEntry/ProductGroups",
            functionsEndpoint = "/JobEntry/ProductFunctions",
            defaultPageSize = 16
        },
        customerPicker = new
        {
            searchEndpoint = "/JobEntry/CustomerSearch",
            jobStatesEndpoint = "/JobEntry/CustomerJobStates",
            defaultPageSize = 16
        },
        customerProductCategoriesEndpoint = "/JobEntry/CustomerProductCategories",
        form = new
        {
            customerId = Model.CustomerId,
            customerCode = Model.CustomerCode ?? string.Empty,
            customerName = Model.CustomerName ?? string.Empty,
            name = Model.Name ?? string.Empty,
            relatedPerson = Model.RelatedPerson ?? string.Empty,
            startDate = Model.StartDate.ToString("yyyy-MM-ddTHH:mm"),
            endDate = Model.EndDate.ToString("yyyy-MM-ddTHH:mm")
        },
        overtimes = Model.Overtimes.Select(x => new
        {
            employeeId = x.EmployeeId,
            employeeCode = x.EmployeeCode ?? string.Empty,
            employeeName = x.EmployeeName ?? string.Empty,
            workTypeId = x.WorkTypeId,
            timeTypeId = x.TimeTypeId,
            quantity = x.Quantity,
            amount = x.Amount,
            notes = x.Notes ?? string.Empty
        }).ToList(),
        autoOvertimeTemplates = Model.AutoOvertimeTemplates.Select(x => new
        {
            employeeId = x.EmployeeId,
            employeeCode = x.EmployeeCode ?? string.Empty,
            employeeName = x.EmployeeName ?? string.Empty,
            workTypeId = x.WorkTypeId,
            timeTypeId = x.TimeTypeId,
            quantity = x.Quantity,
            amount = x.Amount,
            notes = x.Notes ?? string.Empty
        }).ToList(),
        products = Model.Products.Select(x => new
        {
            id = x.ProductId,
            code = x.Code ?? string.Empty,
            name = x.Name ?? string.Empty,
            quantity = x.Quantity,
            price = x.Price,
            notes = x.Notes ?? string.Empty
        }).ToList()
    });
}

<div x-data='jobCreate(@Html.Raw(initialStateJson))'
     x-init="init()"
     @@customer-selected.window="handleCustomer($event.detail)"
     @@employee-selected.window="addEmployee($event.detail)"
     @@product-selected.window="addProduct($event.detail)"
     class="job-page-shell job-form-page job-form-page--compact job-create-reference page-shell--wide space-y-2 pb-6">

    <div x-show="validationError || (validationErrorDetails && validationErrorDetails.length > 0)" x-cloak class="rounded-md bg-yellow-50 p-4 border border-yellow-200 mb-4">
        <div class="flex">
            <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                </svg>
            </div>
            <div class="ml-3">
                <p class="text-sm font-medium text-yellow-800" x-text="validationError"></p>
                <ul x-show="validationErrorDetails && validationErrorDetails.length > 0" class="mt-2 list-disc pl-5 text-sm text-yellow-700">
                    <template x-for="error in validationErrorDetails" :key="error">
                        <li x-text="error"></li>
                    </template>
                </ul>
            </div>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-md bg-red-50 p-4 border border-red-200">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-red-800">@TempData["ErrorMessage"]</p>
                </div>
            </div>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="rounded-md bg-red-50 p-4 border border-red-200">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">@Localizer["PleaseCheckFormFields"]</h3>
                    <div class="mt-2 text-sm text-red-700">
                        <div asp-validation-summary="All" class="list-disc pl-5"></div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="text-center">
        <h2 class="job-page-title job-page-title--orange">
            @Localizer["JobCreation"]
        </h2>
    </div>

    <form method="post" action="/JobEntry/Create" x-ref="createJobForm" @@submit.prevent="validateAndSubmit()" class="space-y-2">
        @Html.AntiForgeryToken()
        <input type="hidden" name="FunctionId" value="@Model.FunctionId" />
        
        <div class="job-form-layout">
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
                </div>
                <div class="dense-panel__body mobile-stack-form">
                    <div class="job-create-basic-grid">
                        <div class="dense-form-grid job-create-basic-fields">
                            <div class="dense-form-row">
                                <label>@Localizer["Function"]</label>
                                <div class="job-create-static job-create-static--strong">@Model.FunctionName</div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["Reference"]</label>
                                <div class="job-create-static">@Localizer["AutoGenerated"]</div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["Customer"]</label>
                                <div class="job-create-selector">
                                    <input type="hidden" name="CustomerId" :value="form.customerId">
                                    <input type="hidden" name="CustomerCode" x-model="form.customerCode">
                                    <input type="hidden" name="CustomerName" x-model="form.customerName">
                                    <span class="job-create-selector__value" x-text="form.customerName || '-'"></span>
                                    <span class="job-create-selector__separator">-</span>
                                    <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'createJob', searchEndpoint: '/JobEntry/CustomerSearch', jobStatesEndpoint: '/JobEntry/CustomerJobStates' })" class="job-create-link-button">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="CreateJobEntryName">@Localizer["Name"]</label>
                                <input id="CreateJobEntryName" type="text" name="Name" x-model="form.name" class="dense-input job-create-input--name">
                            </div>
                            <div class="dense-form-row">
                                <label for="CreateJobEntryRelated">@Localizer["Related"]</label>
                                <input id="CreateJobEntryRelated" type="text" name="RelatedPerson" x-model="form.relatedPerson" class="dense-input job-create-input--name">
                            </div>
                            <div class="dense-form-row">
                                <label for="CreateJobEntryStartDate">@Localizer["StartDate"]</label>
                                <div class="job-create-datetime">
                                    <input id="CreateJobEntryStartDate" type="datetime-local" name="StartDate" x-model="form.startDate" class="dense-input job-create-input--datetime">
                                    <span class="job-create-datetime__day" x-text="formatWeekday(form.startDate)"></span>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="CreateJobEntryEndDate">@Localizer["EndDate"]</label>
                                <div class="job-create-datetime">
                                    <input id="CreateJobEntryEndDate" type="datetime-local" name="EndDate" x-model="form.endDate" class="dense-input job-create-input--datetime">
                                    <span class="job-create-datetime__day" x-text="formatWeekday(form.endDate)"></span>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["Status"]</label>
                                <div class="job-create-static">@Localizer["OpenStatus"]</div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["EmailSent"]</label>
                                <div class="job-create-flag">
                                    <input type="checkbox" name="IsEmailSent" class="job-create-checkbox">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["Evaluated"]</label>
                                <div class="job-create-flag">
                                    <input type="checkbox" name="IsEvaluated" class="job-create-checkbox">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["Invoice"]</label>
                                <div class="job-create-static">-</div>
                            </div>
                        </div>

                        <div class="job-create-quick-tools">
                            <div class="job-create-quick-tools__row">
                                <label for="CreateJobEntryQuickCode">@Localizer["Code"]</label>
                                <input id="CreateJobEntryQuickCode" type="text" x-model="quickCustomerCode" class="dense-input job-create-input--code">
                                <label for="CreateJobEntryQuickPageSize">@Localizer["PageSize"]</label>
                                <input id="CreateJobEntryQuickPageSize" type="number" min="1" x-model="customerPickerPageSize" class="dense-input job-create-input--page-size">
                                <button type="button" @@click="openQuickCustomerPicker()" class="job-create-link-button">
                                    @Localizer["Select"]
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <div class="job-note-stack">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["AdminNotes"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <textarea name="AdminNotes" rows="3" class="dense-input job-create-note-area"></textarea>
                    </div>
                </section>
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["CustomerNotes"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <textarea name="CustomerNotes" rows="3" class="dense-input job-create-note-area"></textarea>
                    </div>
                </section>
            </div>
        </div>

        <section class="job-table-card">
            <div class="job-table-card__header">
                <h3 class="job-table-card__title">@Localizer["Overtime"] (<span x-text="overtimes.length"></span>)</h3>
            </div>
            <div x-show="overtimes.length > 0" x-cloak class="job-table-wrap">
                <table class="job-table job-table--compact">
                    <thead>
                        <tr>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Delete"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700 w-20">@Localizer["Code"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["WorkType"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["TimeType"]</th>
                            <th class="px-4 py-2 text-right text-xs font-bold text-gray-700 w-20">@Localizer["Quantity"]</th>
                            <th class="px-4 py-2 text-right text-xs font-bold text-gray-700 w-24">@Localizer["Amount"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Notes"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(item, index) in overtimes" :key="index">
                            <tr>
                                <td class="px-4 py-2">
                                    <button type="button" @@click="removeOvertime(index)" class="text-red-600 hover:text-red-900 text-xs font-bold">@Localizer["Delete"]</button>
                                </td>
                                <td class="px-4 py-2 text-xs font-bold text-gray-900">
                                    <span x-text="item.code"></span>
                                    <input type="hidden" :name="'Overtimes[' + index + '].EmployeeId'" :value="item.id">
                                    <input type="hidden" :name="'Overtimes[' + index + '].EmployeeCode'" :value="item.code">
                                </td>
                                <td class="px-4 py-2 text-xs text-gray-900">
                                    <span x-text="item.name"></span>
                                    <input type="hidden" :name="'Overtimes[' + index + '].EmployeeName'" :value="item.name">
                                </td>
                                <td class="px-4 py-2">
                                    <span x-text="item.taskTypeName || resolveWorkTypeName(item.taskType) || '-'" class="text-xs text-gray-900"></span>
                                    <input type="hidden" :name="'Overtimes[' + index + '].WorkTypeId'" :value="item.taskType">
                                </td>
                                <td class="px-4 py-2">
                                    <select x-model="item.overtimeType" :name="'Overtimes[' + index + '].TimeTypeId'" class="job-table-select">
                                        @if (ViewBag.TimeTypes != null)
                                        {
                                            @foreach (var tt in ViewBag.TimeTypes)
                                            {
                                                <option value="@tt.Id">@tt.Name</option>
                                            }
                                        }
                                    </select>
                                </td>
                                <td class="px-4 py-2">
                                    <input type="number" step="0.01" x-model="item.quantity" :name="'Overtimes[' + index + '].Quantity'" class="job-table-input job-table-input--money">
                                </td>
                                <td class="px-4 py-2">
                                    <input type="number" step="0.01" x-model="item.amount" :name="'Overtimes[' + index + '].Amount'" class="job-table-input job-table-input--money">
                                </td>
                                <td class="px-4 py-2">
                                    <textarea x-model="item.notes" :name="'Overtimes[' + index + '].Notes'" rows="2" class="job-table-textarea job-table-textarea--single"></textarea>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
            <div x-show="overtimes.length === 0" class="job-create-empty-band"></div>
            <div class="job-create-toolbar">
                <div class="job-create-toolbar__group">
                    <span x-show="overtimes.length > 0">
                        <button type="button" class="job-create-link-button">@Localizer["Delete"]</button>
                    </span>
                    <label for="CreateJobEntryOvertimePageSize" class="job-create-toolbar__label">@Localizer["PageSize"]</label>
                    <input id="CreateJobEntryOvertimePageSize" type="number" min="1" x-model="overtimePickerPageSize" class="dense-input job-create-input--page-size">
                    <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'overtimeAdd', isMultiSelect: true, functionId: '@currentFunctionId', allowQuantity: true, defaultQuantity: 1, pageSize: normalizeOvertimePickerPageSize() })" class="job-create-link-button">@Localizer["Add"]</button>
                </div>
                <div class="job-create-toolbar__total">
                    <span>@Localizer["Total"]</span>
                    <strong x-text="formatMoney(calculateOvertimeTotal())"></strong>
                </div>
            </div>
        </section>

        <section class="job-table-card">
            <div class="job-table-card__header">
                <h3 class="job-table-card__title">@Localizer["Product"] (<span x-text="products.length"></span>)</h3>
            </div>
            <div class="job-table-wrap">
                <table class="job-table job-table--compact">
                    <thead>
                        <tr>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Delete"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700 w-20">@Localizer["Code"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                            <th class="px-4 py-2 text-right text-xs font-bold text-gray-700 w-20">@Localizer["Quantity"]</th>
                            <th class="px-4 py-2 text-right text-xs font-bold text-gray-700 w-24">@Localizer["Price"]</th>
                            <th class="px-4 py-2 text-right text-xs font-bold text-gray-700 w-24">@Localizer["SubTotal"]</th>
                            <th class="px-4 py-2 text-right text-xs font-bold text-gray-700 w-24">@Localizer["NetAmount"]</th>
                            <th class="px-4 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Notes"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(item, index) in products" :key="index">
                            <tr>
                                <td class="px-4 py-2">
                                    <button type="button" @@click="removeProduct(index)" class="text-red-600 hover:text-red-900 text-xs font-bold">@Localizer["Delete"]</button>
                                </td>
                                <td class="px-4 py-2 text-xs font-bold text-gray-900">
                                    <span x-text="item.code"></span>
                                    <input type="hidden" :name="'Products[' + index + '].ProductId'" :value="item.id">
                                    <input type="hidden" :name="'Products[' + index + '].Code'" :value="item.code">
                                </td>
                                <td class="px-4 py-2 text-xs text-gray-900">
                                    <span x-text="item.name"></span>
                                    <input type="hidden" :name="'Products[' + index + '].Name'" :value="item.name">
                                </td>
                                <td class="px-4 py-2">
                                    <input type="number" step="0.01" x-model="item.quantity" :name="'Products[' + index + '].Quantity'" class="job-table-input job-table-input--money">
                                </td>
                                <td class="px-4 py-2">
                                    <input type="number" step="0.01" x-model="item.price" :name="'Products[' + index + '].Price'" class="job-table-input job-table-input--money">
                                </td>
                                <td class="px-4 py-2 text-right text-xs font-bold bg-gray-50" x-text="(item.quantity * item.price).toFixed(2)"></td>
                                <td class="px-4 py-2 text-right text-xs font-bold bg-gray-50 text-indigo-700" x-text="(item.quantity * item.price).toFixed(2)"></td>
                                <td class="px-4 py-2">
                                    <textarea x-model="item.notes" :name="'Products[' + index + '].Notes'" rows="2" class="job-table-textarea"></textarea>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
            <div class="job-picker-panel">
                <div class="job-picker-panel__row">
                    <div class="job-picker-links">
                        <button type="button" @@click="openProductPicker()" class="job-picker-link">
                            @Localizer["Add"]
                        </button>
                    </div>
                    <div class="job-create-toolbar__total">
                        <span>@Localizer["Total"]</span>
                        <strong x-text="formatMoney(calculateProductTotal())"></strong>
                    </div>
                </div>
                <div class="job-picker-panel__row">
                    <div class="job-picker-controls">
                        <label for="CreateJobEntryProductGroup">@Localizer["ProductGroup"]</label>
                        <select id="CreateJobEntryProductGroup"
                                x-model="selectedProductGroup"
                                :disabled="productGroups.length === 0"
                                class="job-picker-select">
                            <option value="" x-show="productGroups.length === 0">@Localizer["SelectPrompt"]</option>
                            <template x-for="grp in productGroups" :key="grp.id">
                                <option :value="grp.name" x-text="grp.name"></option>
                            </template>
                        </select>
                        <label for="CreateJobEntryProductPageSize">@Localizer["PageSize"]</label>
                        <input id="CreateJobEntryProductPageSize"
                               type="number"
                               min="1"
                               x-model="productPickerPageSize"
                               class="job-picker-page-size">
                        <button type="button"
                                @@click="openGroupedProductPicker()"
                                :disabled="productGroups.length === 0"
                                :class="{ 'job-picker-link--disabled': productGroups.length === 0 }"
                                class="job-picker-link">
                            @Localizer["AddBySelection"]
                        </button>
                    </div>
                </div>
            </div>
        </section>
        
        <div class="job-footer-bar job-footer-bar--center">
            <button type="submit" class="job-create-action-button">
                @Localizer["Save"]
            </button>
            <button type="button" onclick="history.back()" class="job-create-action-button job-create-action-button--danger">
                @Localizer["Cancel"]
            </button>
        </div>
    </form>
    
    <partial name="_CustomerSelectModal" />
    <partial name="_ProductSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script src="~/js/pages/job-create.js"></script>
<script>
    document.addEventListener('alpine:init', () => {
    });
</script>
