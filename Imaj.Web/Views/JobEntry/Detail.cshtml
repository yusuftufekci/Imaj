@using System.Net
@using System.Collections.Generic
@model JobDetailViewModel

@{
    ViewData["Title"] = Localizer["JobDetail"];

    string BuildNavUrl(int index) {
        if (Model.SelectedIds == null || Model.SelectedIds.Count == 0) return "#";

        if (index < 0) index = 0;
        if (index >= Model.SelectedIds.Count) index = Model.SelectedIds.Count - 1;

        var nextId = Model.SelectedIds[index];
        var idsQuery = string.Join("&selectedIds=", Model.SelectedIds);

        var url = $"/JobEntry/Detail?id={nextId}&currentIndex={index}&selectedIds={idsQuery}";
        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }
        return url;
    }

    var selectedIds = Model.SelectedIds ?? new List<string>();
}

<div x-data="jobDetail()" class="job-page-shell page-shell--wide space-y-3">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="job-page-title">
                @Localizer["Job"]: <span class="text-indigo-600">@Model.Code</span>
            </h2>
        </div>
        <div class="mt-3 md:mt-0 job-page-actions">
            <a href="@(string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/JobEntry/List" : Model.ReturnUrl)" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                @Localizer["Back"]
            </a>
        </div>
    </div>

    <div class="job-detail-grid">
        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="job-detail-list">
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Function"]</dt>
                        <dd class="job-detail-item__value">@Model.Function</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Reference"]</dt>
                        <dd class="job-detail-item__value">@Model.Code</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Customer"]</dt>
                        <dd class="job-detail-item__value">@Model.CustomerName</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Name"]</dt>
                        <dd class="job-detail-item__value">@Model.Name</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Related"]</dt>
                        <dd class="job-detail-item__value">@Model.RelatedPerson</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["StartDate"]</dt>
                        <dd class="job-detail-item__value">@Model.StartDate.ToString("dd/MM/yyyy HH:mm") @Model.StartDate.ToString("dddd")</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["EndDate"]</dt>
                        <dd class="job-detail-item__value">@Model.EndDate?.ToString("dd/MM/yyyy HH:mm") @Model.EndDate?.ToString("dddd")</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Status"]</dt>
                        <dd class="job-detail-item__value">@Model.Status</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["EmailSent"]</dt>
                        <dd class="job-detail-item__value">
                            <input type="checkbox" disabled @(Model.IsEmailSent ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Evaluated"]</dt>
                        <dd class="job-detail-item__value">
                            <input type="checkbox" disabled @(Model.IsEvaluated ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Invoice"]</dt>
                        <dd class="job-detail-item__value">@Model.InvoiceStatus</dd>
                    </div>
                </dl>
            </div>
        </section>

        <div class="job-note-stack">
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["AdminNotes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <textarea readonly rows="3" class="dense-input bg-white">@Model.AdminNotes</textarea>
                </div>
            </section>
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["CustomerNotes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <textarea readonly rows="3" class="dense-input bg-white">@Model.CustomerNotes</textarea>
                </div>
            </section>
        </div>
    </div>
    
    <section class="job-table-card">
        <div class="job-table-card__header">
            <h3 class="job-table-card__title">@Localizer["Overtime"] (@Model.Overtimes.Count)</h3>
        </div>
        <div class="job-table-wrap mobile-table-panel">
            <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Selected"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Code"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["WorkType"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["TimeType"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Quantity"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Amount"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Notes"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ot in Model.Overtimes)
                    {
                        <tr>
                            <td class="px-6 py-2 whitespace-nowrap">
                                <input type="checkbox" disabled @(ot.IsSelected ? "checked" : "") class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@ot.EmployeeCode</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@ot.EmployeeName</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@ot.TaskType</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@ot.OvertimeType</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@ot.Quantity</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@ot.Amount.ToString("N2")</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@ot.Notes</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="6" class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Localizer["Total"]</td>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Model.TotalOvertimeAmount.ToString("N2")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>
    
    <section class="job-table-card">
        <div class="job-table-card__header">
            <h3 class="job-table-card__title">@Localizer["Product"] (@Model.Products.Count)</h3>
        </div>
        <div class="job-table-wrap mobile-table-panel">
            <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Selected"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Code"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Quantity"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Price"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["SubTotal"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["NetAmount"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Notes"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var prod in Model.Products)
                    {
                        <tr>
                            <td class="px-6 py-2 whitespace-nowrap">
                                <input type="checkbox" disabled @(prod.IsSelected ? "checked" : "") class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@prod.Code</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@prod.Name</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@prod.Quantity</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@prod.Price.ToString("N2")</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@prod.SubTotal.ToString("N2")</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@prod.NetTotal.ToString("N2")</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@prod.Notes</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="5" class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Localizer["Total"]</td>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Model.Products.Sum(x => x.SubTotal).ToString("N2")</td>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Model.TotalProductAmount.ToString("N2")</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>

    <section class="job-table-card">
        <div class="job-table-card__header">
            <h3 class="job-table-card__title">@Localizer["ProductCategory"] (@Model.ProductCategories.Count)</h3>
        </div>
        <div class="job-table-wrap mobile-table-panel">
            <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["SubTotal"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Discount"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["DiscountAmount"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["NetAmount"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in Model.ProductCategories)
                    {
                        <tr>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@cat.Name</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@cat.SubTotal.ToString("N2")</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@cat.Discount.ToString("N0")</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@cat.DiscountAmount.ToString("N2")</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">@cat.NetTotal.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Localizer["Total"]</td>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Model.ProductCategories.Sum(x => x.SubTotal).ToString("N2")</td>
                        <td></td>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Model.ProductCategories.Sum(x => x.DiscountAmount).ToString("N2")</td>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Model.TotalCategoryAmount.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>
    
    <div class="space-y-3">
        <partial name="_DetailNavigator" model="@(new DetailNavigatorViewModel {
            Header = Localizer["JobNavigation"],
            CurrentIndex = Model.CurrentIndex,
            TotalCount = Model.TotalSelected,
            FirstUrl = BuildNavUrl(0),
            PreviousUrl = BuildNavUrl(Model.CurrentIndex - 1),
            NextUrl = BuildNavUrl(Model.CurrentIndex + 1),
            LastUrl = BuildNavUrl(selectedIds.Count - 1),
            FormAction = "/JobEntry/Detail",
            SelectedIds = selectedIds,
            ReturnUrl = Model.ReturnUrl
        })" />
         
        <div class="job-footer-bar job-footer-bar--center responsive-action-group">
            <a href="@(string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/JobEntry/List" : Model.ReturnUrl)" class="inline-flex items-center px-4 py-1 border border-blue-400 text-sm font-bold rounded shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">@Localizer["Back"]</a>
            <a href="/JobEntry/GetHistory/@Model.Code" class="inline-flex items-center px-4 py-1 border border-blue-400 text-sm font-bold rounded shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["ViewHistory"]
            </a>
        </div>
    </div>
</div>

@section Scripts {
}
