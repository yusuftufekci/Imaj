@model Imaj.Web.Models.JobHistoryViewModel

@{
    ViewData["Title"] = Localizer["JobHistory"];
}

<div class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between bg-blue-900 p-2 rounded-t-lg">
        <div class="flex-1 min-w-0">
             <h2 class="text-xl font-bold leading-7 text-white sm:truncate text-center">
                @Localizer["JobHistory"]
            </h2>
        </div>
    </div>

    <!-- Info Sections -->
    <div class="bg-white border border-gray-200 shadow sm:rounded-b-lg p-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <!-- Left: Basic Info -->
            <div class="bg-blue-50 p-4 rounded border border-blue-200 space-y-2 text-sm">
                <h3 class="font-bold text-gray-800 border-b border-blue-200 pb-1 mb-2">Temel Bilgiler</h3>
                
                <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">Fonksiyon</span>
                    <span class="col-span-2 text-gray-900">@Model.Function</span>
                </div>
                 <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">Referans</span>
                    <span class="col-span-2 text-gray-900">@Model.Reference</span>
                </div>
                 <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">Müşteri</span>
                    <span class="col-span-2 text-gray-900">@Model.CustomerName</span>
                </div>
                 <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">Ad</span>
                    <span class="col-span-2 text-gray-900">@Model.ContactName</span>
                </div>
                <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">İlgili</span>
                    <span class="col-span-2 text-gray-900">@Model.RelatedPerson</span>
                </div>
                 <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">@Localizer["StartDate"]</span>
                    <span class="col-span-2 text-gray-900">@Model.StartDate.ToString("dd/MM/yyyy HH:mm") @Model.StartDate.ToString("dddd")</span>
                </div>
                 <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">@Localizer["EndDate"]</span>
                    <span class="col-span-2 text-gray-900">@Model.EndDate.ToString("dd/MM/yyyy HH:mm") @Model.EndDate.ToString("dddd")</span>
                </div>
                 <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">Durum</span>
                    <span class="col-span-2 text-gray-900">@Model.Status</span>
                </div>
                <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">@Localizer["EmailSent"]</span>
                    <span class="col-span-2">
                         <input type="checkbox" disabled @(Model.IsEmailSent ? "checked" : "") class="h-4 w-4 text-blue-600 border-gray-300 rounded">
                    </span>
                </div>
                 <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">Değerlendirildi</span>
                    <span class="col-span-2">
                         <input type="checkbox" disabled @(Model.IsEvaluated ? "checked" : "") class="h-4 w-4 text-blue-600 border-gray-300 rounded">
                    </span>
                </div>
                <div class="grid grid-cols-3 gap-2">
                    <span class="font-bold text-right text-blue-900">Fatura</span>
                    <span class="col-span-2 text-gray-900">@Model.InvoiceStatus</span>
                </div>
            </div>

            <!-- Right: Notes -->
            <div class="space-y-4">
                <div class="bg-gray-50 border border-gray-200 rounded p-2">
                     <h3 class="font-bold text-gray-700 bg-blue-100 px-2 py-1 mb-2 text-sm rounded">@Localizer["AdminNotes"]</h3>
                     <textarea readonly rows="6" class="w-full text-sm border-gray-300 rounded bg-white">@Model.AdminNotes</textarea>
                </div>
                 <div class="bg-gray-50 border border-gray-200 rounded p-2">
                     <h3 class="font-bold text-gray-700 bg-blue-100 px-2 py-1 mb-2 text-sm rounded">@Localizer["CustomerNotes"]</h3>
                     <textarea readonly rows="6" class="w-full text-sm border-gray-300 rounded bg-white">@Model.CustomerNotes</textarea>
                </div>
            </div>
        </div>
    </div>
    
    <!-- History Table Section -->
    <div class="mt-6">
        <div class="bg-blue-200 px-4 py-2 rounded-t-lg border border-blue-300 flex justify-between items-center">
             <h3 class="font-bold text-gray-800 text-sm">Geçmiş (@Model.Items.Count)</h3>
        </div>
        <div class="bg-white border border-gray-200 shadow overflow-hidden sm:rounded-b-lg">
             <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-yellow-50">
                    <tr>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">Kullanıcı</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">Ad</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">Tarih</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">Hareket</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">E-Posta Adresi</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-blue-50 even:bg-yellow-50">
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.UserCode</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.UserName</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.Date.ToString("dd/MM/yyyy HH:mm dddd")</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900 font-bold">@item.Action</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-500">@item.UserEmail</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">
                                @Localizer["HistoryRecordNotFound"]
                            </td>
                        </tr>
                    }
                </tbody>
             </table>
        </div>
    </div>

    <!-- Footer Button -->
    <div class="flex justify-center py-4">
        <a href="/JobEntry/Detail?id=@Model.Reference" class="inline-flex items-center px-4 py-1 border border-blue-600 text-sm font-bold rounded shadow-sm text-white bg-blue-500 hover:bg-blue-700 focus:outline-none">
             Geri
        </a>
    </div>

    <div class="text-center text-xs text-white bg-blue-900 py-2 mt-4">
        © 2005 Imajonline.com - Her hakkı saklıdır.
    </div>
</div>
