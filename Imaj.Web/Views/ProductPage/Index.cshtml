@using Imaj.Web.Authorization
@model ProductPageIndexViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["ProductSearchTitle"];
    var canAdd = await PermissionViewService.CanExecuteMethodAsync(1275);
    var firstValue = Model.Filter.First.HasValue && Model.Filter.First.Value > 0
        ? Model.Filter.First.Value
        : (Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 16);
}

<div class="job-page-shell job-index-shell job-index-reference product-index-reference page-shell--wide space-y-2">
    <div class="text-center job-index-heading">
        <h2 class="job-page-title job-page-title--orange">
            @Localizer["ProductSearchTitle"]
        </h2>
    </div>

    <form method="get" action="/Product/List" class="job-index-form space-y-2 text-left">
        <section class="dense-panel job-index-reference-panel product-index-search-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["MainCriteria"]</h3>
            </div>
            <div class="dense-panel__body mobile-stack-form">
                <div class="dense-form-grid product-index-criteria-list">
                    <div class="dense-form-row">
                        <label for="ProductFilterCode">@Localizer["Code"]</label>
                        <input id="ProductFilterCode"
                               type="text"
                               name="Code"
                               value="@Model.Filter.Code"
                               maxlength="8"
                               class="dense-input uppercase" />
                    </div>
                    <div class="dense-form-row">
                        <label for="ProductFilterCategory">@Localizer["ProductCategory"]</label>
                        <select id="ProductFilterCategory" name="ProductCategoryId" class="dense-input">
                            <option value="">@Localizer["AllOption"]</option>
                            @foreach (var option in Model.ProductCategoryOptions)
                            {
                                if (Model.Filter.ProductCategoryId == option.Id)
                                {
                                    <option value="@option.Id" selected>@option.Name</option>
                                }
                                else
                                {
                                    <option value="@option.Id">@option.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="dense-form-row">
                        <label for="ProductFilterGroup">@Localizer["ProductGroup"]</label>
                        <select id="ProductFilterGroup" name="ProductGroupId" class="dense-input">
                            <option value="">@Localizer["AllOption"]</option>
                            @foreach (var option in Model.ProductGroupOptions)
                            {
                                if (Model.Filter.ProductGroupId == option.Id)
                                {
                                    <option value="@option.Id" selected>@option.Name</option>
                                }
                                else
                                {
                                    <option value="@option.Id">@option.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="dense-form-row">
                        <label for="ProductFilterFunction">@Localizer["Function"]</label>
                        <select id="ProductFilterFunction" name="FunctionId" class="dense-input">
                            <option value="">@Localizer["AllOption"]</option>
                            @foreach (var option in Model.FunctionOptions)
                            {
                                if (Model.Filter.FunctionId == option.Id)
                                {
                                    <option value="@option.Id" selected>@option.Name</option>
                                }
                                else
                                {
                                    <option value="@option.Id">@option.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="dense-form-row">
                        <label for="ProductFilterInvalid">@Localizer["Invalid"]</label>
                        <select id="ProductFilterInvalid" name="IsInvalid" class="dense-input">
                            <option value="">@Localizer["AllOption"]</option>
                            @if (Model.Filter.IsInvalid == false)
                            {
                                <option value="false" selected>@Localizer["No"]</option>
                            }
                            else
                            {
                                <option value="false">@Localizer["No"]</option>
                            }

                            @if (Model.Filter.IsInvalid == true)
                            {
                                <option value="true" selected>@Localizer["Yes"]</option>
                            }
                            else
                            {
                                <option value="true">@Localizer["Yes"]</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </section>

        <input type="hidden" name="Page" value="1">

        <div class="dense-toolbar job-index-toolbar">
            <label for="ProductFilterFirst" class="dense-toolbar__label">@Localizer["First"]</label>
            <input id="ProductFilterFirst" type="number" name="First" value="@firstValue" min="1" class="dense-input dense-toolbar__input" />
            <label for="ProductFilterPageSize" class="dense-toolbar__label">@Localizer["PageSize"]</label>
            <input id="ProductFilterPageSize" type="number" name="PageSize" value="@(Model.Filter.PageSize <= 0 ? 16 : Model.Filter.PageSize)" min="1" class="dense-input dense-toolbar__input" />
            <button type="submit" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                @Localizer["Search"]
            </button>
            <a href="/Product" class="inline-flex items-center px-4 py-1 border border-gray-300 text-sm font-medium rounded shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                @Localizer["Clear"]
            </a>
        </div>
    </form>

    @if (canAdd)
    {
        <form method="get" action="/Product/Create" class="job-index-section job-index-section--narrow product-index-create-form">
            <h3 class="job-index-section__title">@Localizer["ProductCreation"]</h3>
            <section class="dense-panel job-index-create-panel product-index-create-panel">
                <div class="dense-panel__header">
                    <h4 class="dense-panel__title">@Localizer["PreInformation"]</h4>
                </div>
                <div class="dense-panel__body job-index-create-panel__body">
                    <div class="dense-form-row">
                        <label for="ProductCreateCode">@Localizer["Code"]</label>
                        <input id="ProductCreateCode" type="text" name="code" value="@Model.CreateCode" maxlength="8" class="dense-input uppercase" />
                    </div>
                </div>
            </section>
            <div class="job-index-create-cta">
                <button type="submit" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                    @Localizer["ProductCreation"]
                </button>
            </div>
        </form>
    }
</div>
