@using System.Net
@using System.Collections.Generic
@using Imaj.Web.Authorization
@using Imaj.Web.Models.Components
@model ProductPageListViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["Product"];
    var canView = await PermissionViewService.CanExecuteMethodAsync(1272);
    var canEdit = await PermissionViewService.CanExecuteMethodAsync(1273);

    var queryParts = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Filter.Code))
    {
        queryParts.Add($"Code={WebUtility.UrlEncode(Model.Filter.Code)}");
    }
    if (Model.Filter.ProductCategoryId.HasValue)
    {
        queryParts.Add($"ProductCategoryId={Model.Filter.ProductCategoryId.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
    }
    if (Model.Filter.ProductGroupId.HasValue)
    {
        queryParts.Add($"ProductGroupId={Model.Filter.ProductGroupId.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
    }
    if (Model.Filter.FunctionId.HasValue)
    {
        queryParts.Add($"FunctionId={Model.Filter.FunctionId.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
    }
    if (Model.Filter.IsInvalid.HasValue)
    {
        queryParts.Add($"IsInvalid={Model.Filter.IsInvalid.Value.ToString().ToLowerInvariant()}");
    }
    if (Model.Filter.PageSize > 0)
    {
        queryParts.Add($"PageSize={Model.Filter.PageSize}");
    }
    if (Model.Filter.First.HasValue && Model.Filter.First.Value > 0)
    {
        queryParts.Add($"First={Model.Filter.First.Value}");
    }

    var queryString = string.Join("&", queryParts);
    var allIds = Model.Items.Select(x => $"'{x.Id.ToString(System.Globalization.CultureInfo.InvariantCulture)}'");
}

<div x-data="productPageListPage()" class="product-page-shell product-list-shell job-index-reference page-shell--wide space-y-2">
    <div class="text-center job-index-heading">
        <h2 class="job-page-title job-page-title--orange">@Localizer["Product"]</h2>
    </div>

    <form x-ref="listForm" method="post" action="/Product/Detail" class="job-table-card product-list-card">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

        <div class="job-table-card__header">
            <h3 class="job-table-card__title">@Localizer["Product"]</h3>
            <span class="job-table__count">@string.Format(Localizer["EmployeeTotalFormat"], Model.TotalCount)</span>
        </div>

        <div class="job-table-wrap">
            <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th class="w-12 text-left">
                            <input type="checkbox" @@click="toggleAll" :checked="allSelected" class="h-4 w-4 text-indigo-600 border-gray-300 rounded" />
                        </th>
                        <th>@Localizer["Code"]</th>
                        <th>@Localizer["Name"]</th>
                        <th>@Localizer["Category"]</th>
                        <th>@Localizer["ProductGroup"]</th>
                        <th class="text-right">@Localizer["Price"]</th>
                        <th class="text-center">@Localizer["Invalid"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Count > 0)
                    {
                        foreach (var item in Model.Items)
                        {
                            var itemId = item.Id.ToString(System.Globalization.CultureInfo.InvariantCulture);
                            <tr class="cursor-pointer" @@click="toggleRow('@itemId')">
                                <td class="whitespace-nowrap">
                                    <input type="checkbox"
                                           name="selectedIds"
                                           value="@itemId"
                                           x-model="selectedIds"
                                           @@click.stop
                                           class="h-4 w-4 text-indigo-600 border-gray-300 rounded" />
                                </td>
                                <td class="whitespace-nowrap font-semibold">@item.Code</td>
                                <td class="whitespace-nowrap">@item.Name</td>
                                <td class="whitespace-nowrap">@item.ProductCategoryName</td>
                                <td class="whitespace-nowrap">@item.ProductGroupName</td>
                                <td class="whitespace-nowrap text-right">@item.Price.ToString("N2")</td>
                                <td class="whitespace-nowrap text-center">
                                    <input type="checkbox" disabled @(item.IsInvalid ? "checked" : string.Empty) class="h-4 w-4 text-gray-400 border-gray-300 rounded" />
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="job-empty-state">@Localizer["NoRecordsFound"]</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="product-list-card__footer">
            @if (Model.TotalCount > 0)
            {
                <partial name="Components/_Pagination" model="@(new PaginationModel
                {
                    CurrentPage = Model.Page,
                    TotalCount = Model.TotalCount,
                    PageSize = Model.PageSize,
                    BaseUrl = "/Product/List",
                    QueryString = queryString
                })" />
            }

            <div class="product-list-actions responsive-action-group">
                @if (canView)
                {
                    <button type="button" @@click="submitTo('/Product/Detail')" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none">@Localizer["View"]</button>
                }
                @if (canEdit)
                {
                    <button type="button" @@click="submitTo('/Product/Edit')" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none">
                        @Localizer["Edit"]
                    </button>
                }
                <a href="/Product" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Back"]</a>
            </div>
        </div>
    </form>
</div>

<script>
    function productPageListPage() {
        return {
            selectedIds: [],
            allPageIds: [@Html.Raw(string.Join(",", allIds))],

            get allSelected() {
                return this.allPageIds.length > 0 && this.selectedIds.length === this.allPageIds.length;
            },

            toggleAll() {
                if (this.allSelected) {
                    this.selectedIds = [];
                } else {
                    this.selectedIds = [...this.allPageIds];
                }
            },

            toggleRow(id) {
                const index = this.selectedIds.indexOf(id);
                if (index === -1) {
                    this.selectedIds.push(id);
                } else {
                    this.selectedIds.splice(index, 1);
                }
            },

            submitTo(action) {
                if (this.selectedIds.length === 0) {
                    if (window.Toast && typeof window.Toast.error === 'function') {
                        window.Toast.error('@Localizer["PleaseSelectAtLeastOneProduct"]');
                    } else {
                        alert('@Localizer["PleaseSelectAtLeastOneProduct"]');
                    }
                    return;
                }

                this.$refs.listForm.action = action;
                this.$refs.listForm.submit();
            }
        };
    }
</script>
