@model Imaj.Web.Models.JobHistoryViewModel

@{
    ViewData["Title"] = Localizer["JobHistory"];
}

<div class="job-page-shell page-shell--wide space-y-3">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="job-page-title">
                @Localizer["JobHistory"]: <span class="text-indigo-600">@Model.Reference</span>
            </h2>
        </div>
        <div class="mt-3 md:mt-0 job-page-actions">
            <a href="/Job/Detail?id=@Model.JobId" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                @Localizer["Back"]
            </a>
        </div>
    </div>

    <div class="job-detail-grid">
        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="job-detail-list">
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Function"]</dt>
                        <dd class="job-detail-item__value">@Model.Function</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Reference"]</dt>
                        <dd class="job-detail-item__value">@Model.Reference</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Customer"]</dt>
                        <dd class="job-detail-item__value">@Model.CustomerName</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Name"]</dt>
                        <dd class="job-detail-item__value">@Model.ContactName</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Related"]</dt>
                        <dd class="job-detail-item__value">@Model.RelatedPerson</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["StartDate"]</dt>
                        <dd class="job-detail-item__value">@Model.StartDate.ToString("dd/MM/yyyy HH:mm") @Model.StartDate.ToString("dddd")</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["EndDate"]</dt>
                        <dd class="job-detail-item__value">@Model.EndDate.ToString("dd/MM/yyyy HH:mm") @Model.EndDate.ToString("dddd")</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Status"]</dt>
                        <dd class="job-detail-item__value">@Model.Status</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["EmailSent"]</dt>
                        <dd class="job-detail-item__value">
                            <input type="checkbox" disabled @(Model.IsEmailSent ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Evaluated"]</dt>
                        <dd class="job-detail-item__value">
                            <input type="checkbox" disabled @(Model.IsEvaluated ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Invoice"]</dt>
                        <dd class="job-detail-item__value">@Model.InvoiceStatus</dd>
                    </div>
                </dl>
            </div>
        </section>

        <div class="job-note-stack">
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["AdminNotes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <textarea readonly rows="5" class="dense-input bg-white">@Model.AdminNotes</textarea>
                </div>
            </section>
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["CustomerNotes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <textarea readonly rows="5" class="dense-input bg-white">@Model.CustomerNotes</textarea>
                </div>
            </section>
        </div>
    </div>
    
    <section class="job-table-card">
        <div class="job-table-card__header">
             <h3 class="job-table-card__title">@Localizer["ViewHistory"] (@Model.Items.Count)</h3>
        </div>
        <div class="job-table-wrap">
             <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["User"]</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Name"]</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Date"]</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Description"]</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Email"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-blue-50 even:bg-yellow-50">
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.UserCode</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.UserName</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.Date.ToString("dd/MM/yyyy HH:mm dddd")</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900 font-bold">@item.Action</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-500">@item.UserEmail</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-4 text-center text-sm text-gray-500">
                                @Localizer["HistoryRecordNotFound"]
                            </td>
                        </tr>
                    }
                </tbody>
             </table>
        </div>
    </section>

    <div class="job-footer-bar job-footer-bar--center">
        <a href="/Job/Detail?id=@Model.JobId" class="inline-flex items-center px-4 py-1 border border-blue-600 text-sm font-bold rounded shadow-sm text-white bg-blue-500 hover:bg-blue-700 focus:outline-none">@Localizer["Back"]</a>
    </div>

    <div class="text-center text-xs text-white bg-blue-900 py-2 mt-4">
        © 2005 Imajonline.com - Her hakkı saklıdır.
    </div>
</div>
