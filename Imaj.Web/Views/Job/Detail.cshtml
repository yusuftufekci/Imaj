@using System.Net
@using System.Collections.Generic
@using System.Globalization
@using System.Text.Json
@using Imaj.Web.Authorization
@using Imaj.Service.DTOs
@model JobDetailViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["JobDetail"];
    
    // Logic to build query string for navigation
    string BuildNavUrl(int index) {
        if(Model.SelectedIds == null || Model.SelectedIds.Count == 0) return "#";
        
        // Clamp
        if (index < 0) index = 0;
        if (index >= Model.SelectedIds.Count) index = Model.SelectedIds.Count - 1;
        
        var nextId = Model.SelectedIds[index];
        var idsQuery = string.Join("&selectedIds=", Model.SelectedIds);
        
        var url = $"/Job/Detail?id={nextId}&currentIndex={index}&selectedIds={idsQuery}";
        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }
        return url;
    }

    var selectedIds = Model.SelectedIds ?? new List<string>();
    var parsedReference = int.TryParse(Model.Code, out var reference);
    var stateId = Model.StateId;
    var isOpen = stateId == 1m || stateId == 110m;
    var isCompleted = stateId == 120m;
    var isPriced = stateId == 130m;
    var isInvoiced = stateId == 140m;
    var isClosed = stateId == 150m;
    var isDiscarded = stateId == 160m;

    var canComplete = await PermissionViewService.CanExecuteMethodAsync(1334m, write: true);
    var canUndoComplete = await PermissionViewService.CanExecuteMethodAsync(1333m, write: true);
    var canPrice = await PermissionViewService.CanExecuteMethodAsync(1336m, write: true);
    var canUndoPrice = await PermissionViewService.CanExecuteMethodAsync(1335m, write: true);
    var canClose = await PermissionViewService.CanExecuteMethodAsync(1344m, write: true);
    var canUndoClose = await PermissionViewService.CanExecuteMethodAsync(1338m, write: true);
    var canDiscard = await PermissionViewService.CanExecuteMethodAsync(1340m, write: true);
    var canUndoDiscard = await PermissionViewService.CanExecuteMethodAsync(1339m, write: true);
    var canEvaluate = await PermissionViewService.CanExecuteMethodAsync(1341m, write: true);
    var canUndoEvaluate = await PermissionViewService.CanExecuteMethodAsync(1488m, write: true);
    var canPrintJobForm = await PermissionViewService.CanExecuteMethodAsync(1501m);
    var canEditJob = await PermissionViewService.CanExecuteMethodAsync(1397m, write: true);

    var canDoComplete = parsedReference && canComplete && !Model.IsEvaluated && isOpen;
    var canDoUndoComplete = parsedReference && canUndoComplete && !Model.IsEvaluated && isCompleted;
    var canDoPrice = parsedReference && canPrice && !Model.IsEvaluated && isCompleted;
    var canDoUndoPrice = parsedReference && canUndoPrice && !Model.IsEvaluated && isPriced;
    var canDoClose = parsedReference && canClose && !Model.IsEvaluated && isCompleted;
    var canDoUndoClose = parsedReference && canUndoClose && !Model.IsEvaluated && isClosed;
    var canDoDiscard = parsedReference && canDiscard && !Model.IsEvaluated && isOpen;
    var canDoUndoDiscard = parsedReference && canUndoDiscard && !Model.IsEvaluated && isDiscarded;
    var canDoEvaluate = parsedReference && canEvaluate && !Model.IsEvaluated && (isClosed || isDiscarded);
    var canDoUndoEvaluate = parsedReference && canUndoEvaluate && Model.IsEvaluated && (isClosed || isDiscarded);
    var canShowPrintJobForm = parsedReference && canPrintJobForm && (isCompleted || isPriced || isInvoiced);
    var detailStateJson = JsonSerializer.Serialize(new
    {
        customerId = Model.CustomerId.ToString(CultureInfo.InvariantCulture),
        customerName = Model.CustomerName ?? string.Empty
    });
}

<div x-data='jobDetail(@Html.Raw(detailStateJson))'
     @@customer-selected.window="handleCustomerSelection($event.detail)"
     class="job-page-shell page-shell--wide space-y-3">
    <form id="jobDetailEditForm" method="post" action="/Job/UpdateDetail" class="hidden">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Code" value="@Model.Code" />
        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
        @foreach (var selectedId in selectedIds)
        {
            <input type="hidden" name="SelectedIds" value="@selectedId" />
        }
    </form>

    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="job-page-title">
                @Localizer["Job"]: <span class="text-indigo-600">@Model.Code</span>
            </h2>
        </div>
        <div class="mt-3 md:mt-0 job-page-actions">
            <a href="@(string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/Job/List" : Model.ReturnUrl)" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                @Localizer["Back"]
            </a>
        </div>
    </div>

    <div class="job-detail-grid">
        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="job-detail-list">
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Function"]</dt>
                        <dd class="job-detail-item__value">
                            <span x-show="!isEditing">@Model.Function</span>
                            <select x-show="isEditing" x-cloak name="FunctionId" form="jobDetailEditForm" :disabled="!isEditing" class="dense-input">
                                @if (ViewBag.Functions != null)
                                {
                                    @foreach (var func in ViewBag.Functions)
                                    {
                                        <option value="@func.Id" selected="@(func.Id == Model.FunctionId)">@func.Name</option>
                                    }
                                }
                            </select>
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Reference"]</dt>
                        <dd class="job-detail-item__value">@Model.Code</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Customer"]</dt>
                        <dd class="job-detail-item__value">
                            <span x-show="!isEditing" x-text="customerName || '-'"></span>
                            <div x-show="isEditing" x-cloak class="job-detail-edit-selector">
                                <input type="hidden" name="CustomerId" form="jobDetailEditForm" :value="customerId" :disabled="!isEditing">
                                <span class="job-detail-edit-selector__value" x-text="customerName || '-'"></span>
                                <button type="button"
                                        @@click="$dispatch('customer-select-open', { targetId: 'jobDetailEdit', searchEndpoint: '/Job/CustomerSearch', jobStatesEndpoint: '/Job/CustomerJobStates' })"
                                        class="job-picker-link">
                                    @Localizer["Select"]
                                </button>
                            </div>
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Name"]</dt>
                        <dd class="job-detail-item__value">
                            <span x-show="!isEditing">@Model.Name</span>
                            <input x-show="isEditing" x-cloak type="text" name="Name" value="@Model.Name" form="jobDetailEditForm" :disabled="!isEditing" class="dense-input">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Related"]</dt>
                        <dd class="job-detail-item__value">
                            <span x-show="!isEditing">@Model.RelatedPerson</span>
                            <input x-show="isEditing" x-cloak type="text" name="RelatedPerson" value="@Model.RelatedPerson" form="jobDetailEditForm" :disabled="!isEditing" class="dense-input">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["StartDate"]</dt>
                        <dd class="job-detail-item__value">
                            <span x-show="!isEditing">@Model.StartDate.ToString("dd/MM/yyyy HH:mm") @Model.StartDate.ToString("dddd")</span>
                            <input x-show="isEditing" x-cloak type="datetime-local" name="StartDate" value="@Model.StartDate.ToString("yyyy-MM-ddTHH:mm")" form="jobDetailEditForm" :disabled="!isEditing" class="dense-input">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["EndDate"]</dt>
                        <dd class="job-detail-item__value">
                            <span x-show="!isEditing">@Model.EndDate?.ToString("dd/MM/yyyy HH:mm") @Model.EndDate?.ToString("dddd")</span>
                            <input x-show="isEditing" x-cloak type="datetime-local" name="EndDate" value="@Model.EndDate?.ToString("yyyy-MM-ddTHH:mm")" form="jobDetailEditForm" :disabled="!isEditing" class="dense-input">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Status"]</dt>
                        <dd class="job-detail-item__value">@Model.Status</dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["EmailSent"]</dt>
                        <dd class="job-detail-item__value">
                            <input type="checkbox" disabled @(Model.IsEmailSent ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Evaluated"]</dt>
                        <dd class="job-detail-item__value">
                            <input type="checkbox" disabled @(Model.IsEvaluated ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                        </dd>
                    </div>
                    <div class="job-detail-item">
                        <dt class="job-detail-item__label">@Localizer["Invoice"]</dt>
                        <dd class="job-detail-item__value">@Model.InvoiceStatus</dd>
                    </div>
                </dl>
            </div>
        </section>

        <div class="job-note-stack">
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["AdminNotes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <textarea name="AdminNotes" form="jobDetailEditForm" :readonly="!isEditing" rows="3" class="dense-input bg-white">@Model.AdminNotes</textarea>
                </div>
            </section>
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["CustomerNotes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <textarea name="CustomerNotes" form="jobDetailEditForm" :readonly="!isEditing" rows="3" class="dense-input bg-white">@Model.CustomerNotes</textarea>
                </div>
            </section>
        </div>
    </div>
    
    <section class="job-table-card">
        <div class="job-table-card__header">
             <h3 class="job-table-card__title">@Localizer["Overtime"] (@Model.Overtimes.Count)</h3>
        </div>
        <div class="job-table-wrap mobile-table-panel">
             <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Selected"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Code"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["WorkType"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["TimeType"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Quantity"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Amount"]</th>
                         <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Notes"]</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Overtimes.Count; i++)
                    {
                        var ot = Model.Overtimes[i];
                         <tr>
                            <td class="px-6 py-2 whitespace-nowrap">
                                <input type="hidden" name="Overtimes[@i].Id" value="@ot.Id" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="hidden" name="Overtimes[@i].EmployeeId" value="@ot.EmployeeId.ToString(CultureInfo.InvariantCulture)" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="hidden" name="Overtimes[@i].IsSelected" value="false" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="checkbox" name="Overtimes[@i].IsSelected" value="true" form="jobDetailEditForm" :disabled="!isEditing" @(ot.IsSelected ? "checked" : "") class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@ot.EmployeeCode</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@ot.EmployeeName</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">
                                @ot.TaskType
                                <input type="hidden" name="Overtimes[@i].WorkTypeId" value="@ot.WorkTypeId.ToString(CultureInfo.InvariantCulture)" form="jobDetailEditForm" :disabled="!isEditing">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">
                                <span x-show="!isEditing">@ot.OvertimeType</span>
                                <select x-show="isEditing" x-cloak name="Overtimes[@i].TimeTypeId" form="jobDetailEditForm" :disabled="!isEditing" class="job-table-select">
                                    @if (ViewBag.TimeTypes != null)
                                    {
                                        @foreach (var tt in ViewBag.TimeTypes)
                                        {
                                            <option value="@tt.Id" selected="@(tt.Id == ot.TimeTypeId)">@tt.Name</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@ot.Quantity</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="Overtimes[@i].Quantity" value="@ot.Quantity.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" class="job-table-input job-table-input--money">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@ot.Amount.ToString("N2")</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="Overtimes[@i].Amount" value="@ot.Amount.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" class="job-table-input job-table-input--money">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">
                                <span x-show="!isEditing">@ot.Notes</span>
                                <textarea x-show="isEditing" x-cloak name="Overtimes[@i].Notes" form="jobDetailEditForm" :disabled="!isEditing" rows="2" class="job-table-textarea job-table-textarea--single">@ot.Notes</textarea>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                         <td colspan="6" class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Localizer["Total"]</td>
                        <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Model.TotalOvertimeAmount.ToString("N2")</td>
                        <td></td>
                    </tr>
                </tfoot>
             </table>
        </div>
    </section>
    
    <section class="job-table-card">
        <div class="job-table-card__header">
             <h3 class="job-table-card__title">@Localizer["Product"] (@Model.Products.Count)</h3>
        </div>
        <div class="job-table-wrap mobile-table-panel">
             <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Selected"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Code"]</th>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Quantity"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Price"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["SubTotal"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["NetAmount"]</th>
                         <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Notes"]</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.Products.Count; i++)
                    {
                        var prod = Model.Products[i];
                         <tr>
                            <td class="px-6 py-2 whitespace-nowrap">
                                <input type="hidden" name="Products[@i].Id" value="@prod.Id" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="hidden" name="Products[@i].ProductId" value="@prod.ProductId.ToString(CultureInfo.InvariantCulture)" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="hidden" name="Products[@i].CategoryId" value="@prod.CategoryId.ToString(CultureInfo.InvariantCulture)" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="hidden" name="Products[@i].IsSelected" value="false" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="checkbox" name="Products[@i].IsSelected" value="true" form="jobDetailEditForm" :disabled="!isEditing" @(prod.IsSelected ? "checked" : "") class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@prod.Code</td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@prod.Name</td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@prod.Quantity</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="Products[@i].Quantity" value="@prod.Quantity.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" @@input="recalculateProduct(@i)" data-product-quantity="@i" class="job-table-input job-table-input--money">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@prod.Price.ToString("N2")</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="Products[@i].Price" value="@prod.Price.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" @@input="recalculateProduct(@i)" data-product-price="@i" class="job-table-input job-table-input--money">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span data-product-subtotal-display="@i">@prod.SubTotal.ToString("N2")</span>
                                <input type="hidden" name="Products[@i].SubTotal" value="@prod.SubTotal.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" data-product-subtotal="@i">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@prod.NetTotal.ToString("N2")</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="Products[@i].NetTotal" value="@prod.NetTotal.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" @@input="recalculateProductTotals()" data-product-net-total="@i" class="job-table-input job-table-input--money">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">
                                <span x-show="!isEditing">@prod.Notes</span>
                                <textarea x-show="isEditing" x-cloak name="Products[@i].Notes" form="jobDetailEditForm" :disabled="!isEditing" rows="2" class="job-table-textarea job-table-textarea--single">@prod.Notes</textarea>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                         <td colspan="5" class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Localizer["Total"]</td>
                         <td class="px-6 py-2 text-right text-sm font-bold text-gray-900" data-product-gross-total>@Model.Products.Sum(x => x.SubTotal).ToString("N2")</td>
                         <td class="px-6 py-2 text-right text-sm font-bold text-gray-900" data-product-net-total-footer>@Model.TotalProductAmount.ToString("N2")</td>
                         <td></td>
                    </tr>
                </tfoot>
             </table>
        </div>
    </section>

    <section class="job-table-card">
        <div class="job-table-card__header">
             <h3 class="job-table-card__title">@Localizer["ProductCategory"] (@Model.ProductCategories.Count)</h3>
        </div>
        <div class="job-table-wrap mobile-table-panel">
             <table class="job-table job-table--compact">
                <thead>
                    <tr>
                        <th class="px-6 py-2 text-left text-xs font-bold text-gray-700">@Localizer["Name"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["SubTotal"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["Discount"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["DiscountAmount"]</th>
                        <th class="px-6 py-2 text-right text-xs font-bold text-gray-700">@Localizer["NetAmount"]</th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < Model.ProductCategories.Count; i++)
                    {
                        var cat = Model.ProductCategories[i];
                         <tr>
                            <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">
                                @cat.Name
                                <input type="hidden" name="ProductCategories[@i].CategoryId" value="@cat.CategoryId.ToString(CultureInfo.InvariantCulture)" form="jobDetailEditForm" :disabled="!isEditing">
                                <input type="hidden" name="ProductCategories[@i].Name" value="@cat.Name" form="jobDetailEditForm" :disabled="!isEditing">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@cat.SubTotal.ToString("N2")</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="ProductCategories[@i].SubTotal" value="@cat.SubTotal.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" @@input="recalculateCategory(@i)" data-category-subtotal="@i" class="job-table-input job-table-input--money">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@cat.Discount.ToString("N0")</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="ProductCategories[@i].Discount" value="@cat.Discount.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" @@input="recalculateCategory(@i)" data-category-discount="@i" class="job-table-input job-table-input--discount">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@cat.DiscountAmount.ToString("N2")</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="ProductCategories[@i].DiscountAmount" value="@cat.DiscountAmount.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" readonly data-category-discount-amount="@i" class="job-table-input job-table-input--money bg-gray-50">
                            </td>
                            <td class="px-6 py-2 whitespace-nowrap text-right text-sm text-gray-900">
                                <span x-show="!isEditing">@cat.NetTotal.ToString("N2")</span>
                                <input x-show="isEditing" x-cloak type="text" inputmode="decimal" name="ProductCategories[@i].NetTotal" value="@cat.NetTotal.ToString("0.##")" form="jobDetailEditForm" :disabled="!isEditing" readonly data-category-net-total="@i" class="job-table-input job-table-input--money bg-gray-50">
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                         <td class="px-6 py-2 text-right text-sm font-bold text-gray-900">@Localizer["Total"]</td>
