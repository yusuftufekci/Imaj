                     <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                     <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                     @foreach (var selectedId in selectedIds)
                     {
                         <input type="hidden" name="SelectedIds" value="@selectedId" />
                     }
                     <button type="submit" class="inline-flex items-center px-4 py-1 border border-red-400 text-sm font-bold rounded shadow-sm text-red-900 bg-red-100 hover:bg-red-200">@Localizer["WorkflowDiscard"]</button>
                 </form>
             }

             @if (canDoUndoDiscard)
             {
                 <form method="post" action="/Job/WorkflowAction" class="workflow-action-form inline-flex">
                     @Html.AntiForgeryToken()
                     <input type="hidden" name="Reference" value="@reference" />
                     <input type="hidden" name="Action" value="@((int)JobWorkflowAction.UndoDiscard)" />
                     <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                     <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                     @foreach (var selectedId in selectedIds)
                     {
