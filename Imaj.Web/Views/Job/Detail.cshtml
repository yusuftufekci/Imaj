@section Scripts {
    <script>
        function jobDetail(initialState) {
            return {
                isEditing: false,
                customerId: initialState?.customerId || '',
                customerName: initialState?.customerName || '',
                enableEdit() {
                    this.isEditing = true;
                },
                handleCustomerSelection(detail) {
                    if (detail.targetId !== 'jobDetailEdit' || !detail.customer) {
                        return;
                    }

                    this.customerId = detail.customer.id || '';
                    this.customerName = detail.customer.name || '';
                },
                parseDecimal(value) {
                    if (value === null || value === undefined) {
                        return 0;
                    }

                    let normalized = String(value).trim().replace(/\s/g, '');
                    if (!normalized) {
                        return 0;
                    }

                    const lastComma = normalized.lastIndexOf(',');
                    const lastDot = normalized.lastIndexOf('.');
                    if (lastComma > -1 && lastDot > -1) {
                        const decimalSeparator = lastComma > lastDot ? ',' : '.';
                        const thousandsSeparator = decimalSeparator === ',' ? '.' : ',';
                        normalized = normalized
                            .split(thousandsSeparator).join('')
                            .replace(decimalSeparator, '.');
                    } else {
                        normalized = normalized.replace(',', '.');
                    }

                    const parsed = Number.parseFloat(normalized);
                    return Number.isFinite(parsed) ? parsed : 0;
                },
                formatInputDecimal(value) {
                    const normalized = Number.isFinite(value) ? value : 0;
                    const lang = document.documentElement.lang || navigator.language || 'tr-TR';
                    const separator = lang.toLowerCase().startsWith('tr') ? ',' : '.';
                    return normalized.toFixed(2).replace('.', separator);
                },
                formatDisplayDecimal(value) {
                    const normalized = Number.isFinite(value) ? value : 0;
                    const lang = document.documentElement.lang || navigator.language || 'tr-TR';
                    return normalized.toLocaleString(lang, {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                },
                recalculateProduct(index) {
                    const quantityInput = document.querySelector(`[data-product-quantity="${index}"]`);
                    const priceInput = document.querySelector(`[data-product-price="${index}"]`);
                    const subtotalInput = document.querySelector(`[data-product-subtotal="${index}"]`);
                    const subtotalDisplay = document.querySelector(`[data-product-subtotal-display="${index}"]`);

                    if (!quantityInput || !priceInput || !subtotalInput || !subtotalDisplay) {
                        return;
                    }

                    const quantity = Math.max(0, this.parseDecimal(quantityInput.value));
                    const price = Math.max(0, this.parseDecimal(priceInput.value));
                    const subtotal = quantity * price;

                    subtotalInput.value = this.formatInputDecimal(subtotal);
                    subtotalDisplay.textContent = this.formatDisplayDecimal(subtotal);
                    this.recalculateProductTotals();
                },
                recalculateProductTotals() {
                    const subtotal = [...document.querySelectorAll('[data-product-subtotal]')]
                        .reduce((total, input) => total + this.parseDecimal(input.value), 0);
                    const netTotal = [...document.querySelectorAll('[data-product-net-total]')]
                        .reduce((total, input) => total + this.parseDecimal(input.value), 0);

                    const grossTotalCell = document.querySelector('[data-product-gross-total]');
                    const netTotalCell = document.querySelector('[data-product-net-total-footer]');

                    if (grossTotalCell) grossTotalCell.textContent = this.formatDisplayDecimal(subtotal);
                    if (netTotalCell) netTotalCell.textContent = this.formatDisplayDecimal(netTotal);
                },
                recalculateCategory(index) {
                    const subtotalInput = document.querySelector(`[data-category-subtotal="${index}"]`);
                    const discountInput = document.querySelector(`[data-category-discount="${index}"]`);
                    const discountAmountInput = document.querySelector(`[data-category-discount-amount="${index}"]`);
                    const netTotalInput = document.querySelector(`[data-category-net-total="${index}"]`);

                    if (!subtotalInput || !discountInput || !discountAmountInput || !netTotalInput) {
                        return;
                    }

                    const subtotal = Math.max(0, this.parseDecimal(subtotalInput.value));
                    const discount = Math.min(100, Math.max(0, this.parseDecimal(discountInput.value)));
                    const discountAmount = subtotal * discount / 100;
                    const netTotal = subtotal - discountAmount;

                    discountAmountInput.value = this.formatInputDecimal(discountAmount);
                    netTotalInput.value = this.formatInputDecimal(netTotal);
                    this.recalculateCategoryTotals();
                },
                recalculateCategoryTotals() {
                    const subtotal = [...document.querySelectorAll('[data-category-subtotal]')]
                        .reduce((total, input) => total + this.parseDecimal(input.value), 0);
                    const discountAmount = [...document.querySelectorAll('[data-category-discount-amount]')]
                        .reduce((total, input) => total + this.parseDecimal(input.value), 0);
                    const netTotal = [...document.querySelectorAll('[data-category-net-total]')]
                        .reduce((total, input) => total + this.parseDecimal(input.value), 0);

                    const grossTotalCell = document.querySelector('[data-category-gross-total]');
                    const discountTotalCell = document.querySelector('[data-category-discount-total]');
                    const netTotalCell = document.querySelector('[data-category-net-total-footer]');

                    if (grossTotalCell) grossTotalCell.textContent = this.formatDisplayDecimal(subtotal);
                    if (discountTotalCell) discountTotalCell.textContent = this.formatDisplayDecimal(discountAmount);
                    if (netTotalCell) netTotalCell.textContent = this.formatDisplayDecimal(netTotal);
                }
            }
        }
    </script>
}
