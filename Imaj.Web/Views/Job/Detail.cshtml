                     <textarea readonly rows="3" class="w-full text-sm border-gray-300 rounded bg-white">@Model.AdminNotes</textarea>
                </div>
                 <div class="bg-gray-50 border border-gray-200 rounded p-2">
                     <h3 class="font-bold text-gray-700 bg-blue-100 px-2 py-1 mb-2 text-sm rounded">@Localizer["CustomerNotes"]</h3>
                     <textarea readonly rows="3" class="w-full text-sm border-gray-300 rounded bg-white">@Model.CustomerNotes</textarea>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Overtime Section -->
