@using System.Net
@using System.Collections.Generic
@using Imaj.Web.Authorization
@using Imaj.Service.DTOs
@model JobDetailViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["JobDetail"];
    
    // Logic to build query string for navigation
    string BuildNavUrl(int index) {
        if(Model.SelectedIds == null || Model.SelectedIds.Count == 0) return "#";
        
        // Clamp
        if (index < 0) index = 0;
        if (index >= Model.SelectedIds.Count) index = Model.SelectedIds.Count - 1;
        
        var nextId = Model.SelectedIds[index];
        var idsQuery = string.Join("&selectedIds=", Model.SelectedIds);
        
        var url = $"/Job/Detail?id={nextId}&currentIndex={index}&selectedIds={idsQuery}";
        if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
        {
            url += $"&returnUrl={WebUtility.UrlEncode(Model.ReturnUrl)}";
        }
        return url;
    }

    var selectedIds = Model.SelectedIds ?? new List<string>();
    var parsedReference = int.TryParse(Model.Code, out var reference);
    var stateId = Model.StateId;
    var isOpen = stateId == 1m || stateId == 110m;
    var isCompleted = stateId == 120m;
    var isPriced = stateId == 130m;
    var isInvoiced = stateId == 140m;
    var isClosed = stateId == 150m;
    var isDiscarded = stateId == 160m;

    var canComplete = await PermissionViewService.CanExecuteMethodAsync(1334m, write: true);
    var canUndoComplete = await PermissionViewService.CanExecuteMethodAsync(1333m, write: true);
    var canPrice = await PermissionViewService.CanExecuteMethodAsync(1336m, write: true);
    var canUndoPrice = await PermissionViewService.CanExecuteMethodAsync(1335m, write: true);
    var canClose = await PermissionViewService.CanExecuteMethodAsync(1344m, write: true);
    var canUndoClose = await PermissionViewService.CanExecuteMethodAsync(1338m, write: true);
    var canDiscard = await PermissionViewService.CanExecuteMethodAsync(1340m, write: true);
    var canUndoDiscard = await PermissionViewService.CanExecuteMethodAsync(1339m, write: true);
    var canEvaluate = await PermissionViewService.CanExecuteMethodAsync(1341m, write: true);
    var canUndoEvaluate = await PermissionViewService.CanExecuteMethodAsync(1488m, write: true);
    var canPrintJobForm = await PermissionViewService.CanExecuteMethodAsync(1501m);

    var canDoComplete = parsedReference && canComplete && !Model.IsEvaluated && isOpen;
    var canDoUndoComplete = parsedReference && canUndoComplete && !Model.IsEvaluated && isCompleted;
    var canDoPrice = parsedReference && canPrice && !Model.IsEvaluated && isCompleted;
    var canDoUndoPrice = parsedReference && canUndoPrice && !Model.IsEvaluated && isPriced;
    var canDoClose = parsedReference && canClose && !Model.IsEvaluated && isCompleted;
    var canDoUndoClose = parsedReference && canUndoClose && !Model.IsEvaluated && isClosed;
    var canDoDiscard = parsedReference && canDiscard && !Model.IsEvaluated && isOpen;
    var canDoUndoDiscard = parsedReference && canUndoDiscard && !Model.IsEvaluated && isDiscarded;
    var canDoEvaluate = parsedReference && canEvaluate && !Model.IsEvaluated && (isClosed || isDiscarded);
    var canDoUndoEvaluate = parsedReference && canUndoEvaluate && Model.IsEvaluated && (isClosed || isDiscarded);
    var canShowPrintJobForm = parsedReference && canPrintJobForm && (isCompleted || isPriced || isInvoiced);
}

<div x-data="jobDetail()" class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between bg-blue-900 p-2 rounded-t-lg">
        <div class="flex-1 min-w-0">
