                     <input type="hidden" name="Reference" value="@reference" />
                     <input type="hidden" name="Action" value="@((int)JobWorkflowAction.UndoEvaluate)" />
                     <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                     <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                     @foreach (var selectedId in selectedIds)
                     {
                         <input type="hidden" name="SelectedIds" value="@selectedId" />
                     }
                     <button type="submit" class="inline-flex items-center px-4 py-1 border border-amber-400 text-sm font-bold rounded shadow-sm text-amber-900 bg-amber-100 hover:bg-amber-200">@Localizer["WorkflowUndoEvaluate"]</button>
                 </form>
             }

             <a href="/Job/GetHistory/@Model.Code" class="inline-flex items-center px-4 py-1 border border-blue-400 text-sm font-bold rounded shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["ViewHistory"]
            </a>
         </div>
    </div>
</div>

@section Scripts {
    <!-- Scripts buraya gelebilir -->
}
