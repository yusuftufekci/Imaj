@using System.Text.Json
@model JobViewModel

@{
    ViewData["Title"] = Localizer["Jobs"];
    var currentListUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var currentSearchUrl = "/Job" + (Context.Request.QueryString.HasValue ? Context.Request.QueryString.Value : string.Empty);
    var stateMapJson = JsonSerializer.Serialize(Model.Items.ToDictionary(x => x.Code ?? string.Empty, x => x.StateId));
    var allPageIdsJson = JsonSerializer.Serialize(Model.Items.Select(x => x.Code ?? string.Empty).Where(x => !string.IsNullOrWhiteSpace(x)).ToList());

    var queryParts = Context.Request.Query
        .Where(q => !string.Equals(q.Key, "page", StringComparison.OrdinalIgnoreCase)
                 && !string.Equals(q.Key, "pageSize", StringComparison.OrdinalIgnoreCase))
        .SelectMany(q => q.Value
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Select(v => $"{q.Key}={Uri.EscapeDataString(v!)}"));
    var paginationQuery = string.Join("&", queryParts);
    var selectionScopeJson = JsonSerializer.Serialize($"/Job/List?{paginationQuery}");
}

<div x-data='jobList(@Html.Raw(stateMapJson), @Html.Raw(allPageIdsJson), @Html.Raw(selectionScopeJson))' x-init="init()" class="job-page-shell page-shell--wide space-y-3">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="job-page-title">
                @Localizer["Jobs"]
            </h2>
        </div>
        <div class="mt-3 md:mt-0 job-page-actions">
            <a href="@currentSearchUrl" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                @Localizer["Back"]
            </a>
        </div>
    </div>

    <form id="resultsForm" method="post" action="/Job/Detail">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@currentListUrl" />
        <template x-for="id in selectedIds" :key="id">
            <input type="hidden" name="selectedIds" :value="id">
        </template>
        <div class="job-table-card">
            <div class="job-table-card__header">
                <h3 class="job-table-card__title">@Localizer["Job"]</h3>
                <span class="job-table__count">@Model.TotalCount</span>
            </div>
            <div class="job-table-wrap">
                <table class="job-table job-table--compact">
                    <thead>
                                <tr>
                                    <th scope="col">
                                        <div class="flex items-center">
                                            <input type="checkbox" :checked="isPageFullySelected()" @@change="toggleAll($event.target.checked)" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded mr-2">
                                            <span class="text-xs font-bold text-gray-700 uppercase tracking-wider cursor-pointer" @@click="toggleAll(!isPageFullySelected())">@Localizer["Select"]</span>
                                        </div>
                                    </th>
                                    <th scope="col">@Localizer["Function"]</th>
                                    <th scope="col">@Localizer["Reference"]</th>
                                    <th scope="col">@Localizer["StartDate"]</th>
                                    <th scope="col">@Localizer["Customer"]</th>
                                    <th scope="col">@Localizer["Name"]</th>
                                    <th scope="col">@Localizer["Status"]</th>
                                    <th scope="col" class="text-center">@Localizer["Email"]</th>
                                    <th scope="col" class="text-center">@Localizer["Evaluated"]</th>
                                </tr>
                    </thead>
                    <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="whitespace-nowrap">
                                            <input type="checkbox" value="@item.Code" :checked="isSelected('@item.Code')" @@change="toggleSelection('@item.Code', $event.target.checked)" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                        </td>
                                        <td class="whitespace-nowrap text-sm text-gray-900">@item.Function</td>
                                        <td class="whitespace-nowrap text-sm font-bold">
                                            <a href="/Job/Detail?id=@item.Code&returnUrl=@Uri.EscapeDataString(currentListUrl)" class="text-blue-600 hover:text-blue-900 underline">@item.Code</a>
                                        </td>
                                        <td class="whitespace-nowrap text-sm text-gray-500">
                                            @item.StartDate.ToString("dd/MM/yyyy HH:mm") <br/>
                                            @item.EndDate?.ToString("dd/MM/yyyy HH:mm")
                                        </td>
                                        <td class="whitespace-nowrap text-sm text-gray-900">@item.CustomerName</td>
                                        <td class="whitespace-nowrap text-sm text-gray-900">@item.Name</td>
                                        <td class="whitespace-nowrap text-sm text-gray-900">@item.Status</td>
                                        <td class="whitespace-nowrap text-center">
                                            <input type="checkbox" disabled @(item.IsEmailSent ? "checked" : "") class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                                        </td>
                                        <td class="whitespace-nowrap text-center">
                                            <input type="checkbox" disabled @(item.IsEvaluated ? "checked" : "") class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                                        </td>
                                    </tr>
                                }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-3">
            @if (Model.TotalCount > 0)
            {
                <partial name="Components/_Pagination" model="@(new Imaj.Web.Models.Components.PaginationModel 
                { 
                    CurrentPage = Model.Page, 
                    TotalCount = Model.TotalCount, 
                    PageSize = Model.PageSize,
                    BaseUrl = @"/Job/List",
                    QueryString = paginationQuery
                })" />
            }
            else
            {
                <div class="job-empty-state">@Localizer["NoRecordsFound"]</div>
            }

            <div class="job-footer-bar job-footer-bar--center responsive-action-group">
                 <button type="submit"
                         @@click.prevent="submitDetail($event)"
                         class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    @Localizer["View"]
                </button>
                <button type="submit"
                        formaction="/Job/EmailCompose"
                        formmethod="post"
                        @@click.prevent="submitEmailCompose($event)"
                        class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    @Localizer["SendEmail"]
                </button>
                <a href="@currentSearchUrl" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                    @Localizer["Back"]
                </a>
            </div>
        </div>
    </form>
</div>

<script>
    function jobList(jobStates, allPageIds, selectionScope) {
        return {
            selectedIds: [],
            selectedStateMap: {},
            jobStates: jobStates || {},
            allowedEmailStates: [120, 130, 140],
            allPageIds: allPageIds || [],
            storageKey: 'imaj.job.listSelection:' + (selectionScope || window.location.pathname),
            keepSelectionOnUnload: false,

            init() {
                this.bindSelectionLifecycle();
                this.restoreSelection();
                this.mergeKnownStates();
            },

            bindSelectionLifecycle() {
                document.addEventListener('click', event => {
                    const link = event.target.closest('a[href]');
                    if (!link) {
                        return;
                    }

                    const url = new URL(link.href, window.location.origin);
                    const isSameListFlow = url.origin === window.location.origin && url.pathname === '/Job/List';
                    this.keepSelectionOnUnload = isSameListFlow;
                    if (!isSameListFlow) {
                        this.clearStoredSelection();
                    }
                }, true);

                window.addEventListener('pagehide', () => {
                    if (!this.keepSelectionOnUnload) {
                        this.clearStoredSelection();
                    }
                });

                window.addEventListener('pageshow', () => {
                    if (!window.sessionStorage?.getItem(this.storageKey)) {
                        this.selectedIds = [];
                        this.selectedStateMap = {};
                    }
                });
            },

            restoreSelection() {
                try {
                    const stored = JSON.parse(window.sessionStorage?.getItem(this.storageKey) || '{}');
                    this.selectedIds = Array.isArray(stored.selectedIds)
                        ? [...new Set(stored.selectedIds.map(id => String(id)).filter(Boolean))]
                        : [];
                    this.selectedStateMap = stored.selectedStateMap || {};
                } catch {
                    this.selectedIds = [];
                    this.selectedStateMap = {};
                }
            },

            persistSelection() {
                window.sessionStorage?.setItem(this.storageKey, JSON.stringify({
                    selectedIds: this.selectedIds,
                    selectedStateMap: this.selectedStateMap
                }));
            },

            clearStoredSelection() {
                window.sessionStorage?.removeItem(this.storageKey);
            },

            mergeKnownStates() {
                this.selectedIds.forEach(id => {
                    if (Object.prototype.hasOwnProperty.call(this.jobStates, id)) {
                        this.selectedStateMap[id] = this.jobStates[id];
                    }
                });
                this.persistSelection();
            },

            isSelected(id) {
                return this.selectedIds.includes(String(id));
            },

            isPageFullySelected() {
                return this.allPageIds.length > 0 && this.allPageIds.every(id => this.isSelected(id));
            },

            toggleSelection(id, shouldSelect) {
                const normalizedId = String(id || '');
                if (!normalizedId) {
                    return;
                }

                if (shouldSelect) {
                    if (!this.selectedIds.includes(normalizedId)) {
                        this.selectedIds.push(normalizedId);
                    }
                    if (Object.prototype.hasOwnProperty.call(this.jobStates, normalizedId)) {
                        this.selectedStateMap[normalizedId] = this.jobStates[normalizedId];
                    }
                } else {
                    this.selectedIds = this.selectedIds.filter(selectedId => selectedId !== normalizedId);
                    delete this.selectedStateMap[normalizedId];
                }

                this.persistSelection();
            },

            toggleAll(shouldSelect) {
                this.allPageIds.forEach(id => this.toggleSelection(id, shouldSelect));
            },

            submitDetail(event) {
                if (this.selectedIds.length === 0) {
                    Toast.error('@Localizer["PleaseSelectAtLeastOneJob"]');
                    return;
                }

                this.clearStoredSelection();
                this.submitForm(event.currentTarget);
            },

            submitEmailCompose(event) {
                if (this.selectedIds.length === 0) {
                    Toast.error('@Localizer["PleaseSelectAtLeastOneJob"]');
                    return;
                }

                const hasInvalidSelection = this.selectedIds.some(id => {
                    const stateId = Number(this.selectedStateMap[id] ?? this.jobStates[id]);
                    return !this.allowedEmailStates.includes(stateId);
                });

                if (hasInvalidSelection) {
                    Toast.error('@Localizer["JobEmailEligibleStatesOnly"]');
                    return;
                }

                this.clearStoredSelection();
                this.submitForm(event.currentTarget);
            },

            submitForm(submitter) {
                const form = submitter.form;
                if (form && typeof form.requestSubmit === 'function') {
                    form.requestSubmit(submitter);
                    return;
                }

                if (form) {
                    form.submit();
                }
            }
        }
    }
</script>
