@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model JobViewModel

@{
    ViewData["Title"] = Localizer["JobOperations"];
}

<div x-data="jobPage()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@product-selected.window="handleProductSelection($event.detail)" @@employee-selected.window="handleEmployeeSelection($event.detail)" class="job-page-shell job-index-shell job-index-reference page-shell--wide space-y-2">
    <div class="text-center job-index-heading">
        <h2 class="job-page-title job-page-title--orange sm:text-3xl">
            @Localizer["JobSearch"]
        </h2>
    </div>

    <form method="get" action="/Job/List" class="job-index-form space-y-2 text-left">
        <div class="dense-panel-grid job-index-reference-grid">
            <div class="dense-panel-grid__column">
                <section class="dense-panel job-index-reference-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["JobCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body mobile-stack-form">
                        <div class="dense-form-grid job-index-criteria-list">
                            <div class="dense-form-row">
                                <label for="JobFunction">@Localizer["Function"]</label>
                                <select id="JobFunction" name="Filter.Function" x-model="filter.function" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["SelectPrompt"]</option>
                                    @if (ViewBag.Functions != null)
                                    {
                                        @foreach (var func in ViewBag.Functions)
                                        {
                                            <option value="@func.Id">@func.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["Customer"]</label>
                                <div class="job-index-selector">
                                    <input type="hidden" name="Filter.CustomerCode" x-model="filter.customerCode">
                                    <input type="hidden" name="Filter.CustomerId" x-model="filter.customerId">
                                    <span class="job-index-selector__value" x-text='customerName || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AllOption"].Value))'></span>
                                    <span class="job-index-selector__separator">-</span>
                                    <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'jobFilter', searchEndpoint: '/Job/CustomerSearch', jobStatesEndpoint: '/Job/CustomerJobStates' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["ReferenceRange"]</label>
                                <div class="job-index-range">
                                    <input type="text" name="Filter.ReferenceStart" x-model="filter.referenceStart" class="dense-input job-index-input--range">
                                    <input type="text" name="Filter.ReferenceEnd" x-model="filter.referenceEnd" class="dense-input job-index-input--range">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobReferenceList">@Localizer["Reference"]</label>
                                <input id="JobReferenceList" type="text" name="Filter.ReferenceList" x-model="filter.referenceList" class="dense-input job-index-input--wide">
                            </div>
                            <div class="dense-form-row">
                                <label for="JobName">@Localizer["Name"]</label>
                                <input id="JobName" type="text" name="Filter.JobName" x-model="filter.jobName" class="dense-input job-index-input--medium">
                            </div>
                            <div class="dense-form-row">
                                <label for="JobRelated">@Localizer["Related"]</label>
                                <input id="JobRelated" type="text" name="Filter.RelatedPerson" x-model="filter.relatedPerson" class="dense-input job-index-input--medium">
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["StartDateRange"]</label>
                                <div class="job-index-range">
                                    <input type="date" name="Filter.StartDateStart" x-model="filter.startDateStart" class="dense-input job-index-input--date" value="@Model.Filter.StartDateStart?.ToString("yyyy-MM-dd")">
                                    <input type="date" name="Filter.StartDateEnd" x-model="filter.startDateEnd" class="dense-input job-index-input--date" value="@Model.Filter.StartDateEnd?.ToString("yyyy-MM-dd")">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label>@Localizer["EndDateRange"]</label>
                                <div class="job-index-range">
                                    <input type="date" name="Filter.EndDateStart" x-model="filter.endDateStart" class="dense-input job-index-input--date">
                                    <input type="date" name="Filter.EndDateEnd" x-model="filter.endDateEnd" class="dense-input job-index-input--date">
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobStatus">@Localizer["Status"]</label>
                                <select id="JobStatus" name="Filter.Status" x-model="filter.status" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.States != null)
                                    {
                                        @foreach (var state in ViewBag.States)
                                        {
                                            <option value="@state.Id">@state.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEmailSent">@Localizer["EmailSent"]</label>
                                <select id="JobEmailSent" name="Filter.EmailSent" x-model="filter.emailSent" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobEvaluated">@Localizer["Evaluated"]</label>
                                <select id="JobEvaluated" name="Filter.Evaluated" x-model="filter.evaluated" class="dense-input job-index-input--select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="dense-panel-grid__column job-index-side-column">
                <section class="dense-panel job-index-reference-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["OvertimeCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body mobile-stack-form">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label>@Localizer["Employee"]</label>
                                <div class="job-index-selector">
                                    <input type="hidden" name="Filter.EmployeeCode" x-model="filter.employeeCode">
                                    <span class="job-index-selector__value" x-text='filter.employeeName || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AllOption"].Value))'></span>
                                    <span class="job-index-selector__separator">-</span>
                                    <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'jobEmployee', showFilter: true })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobTaskType">@Localizer["WorkType"]</label>
                                <select id="JobTaskType" name="Filter.TaskType" x-model="filter.taskType" class="dense-input job-index-input--side-select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.WorkTypes != null)
                                    {
                                        @foreach (var wt in ViewBag.WorkTypes)
                                        {
                                            <option value="@wt.Id">@wt.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="dense-form-row">
                                <label for="JobOvertimeType">@Localizer["TimeType"]</label>
                                <select id="JobOvertimeType" name="Filter.OvertimeType" x-model="filter.overtimeType" class="dense-input job-index-input--side-select">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.TimeTypes != null)
                                    {
                                        @foreach (var tt in ViewBag.TimeTypes)
                                        {
                                            <option value="@tt.Id">@tt.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="dense-panel job-index-reference-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["ProductCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body dense-panel__body--tight mobile-stack-form">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label>@Localizer["Product"]</label>
                                <div class="job-index-selector">
                                    <input type="hidden" name="Filter.ProductId" x-model="filter.productId">
                                    <input type="hidden" name="Filter.ProductCode" x-model="filter.productCode">
                                    <span class="job-index-selector__value" x-text='filter.productName || @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["AllOption"].Value))'></span>
                                    <span class="job-index-selector__separator">-</span>
                                    <button type="button" @@click="$dispatch('product-select-open', { targetId: 'jobProduct', searchEndpoint: '/Job/ProductSearch', categoriesEndpoint: '/Job/ProductCategories', productGroupsEndpoint: '/Job/ProductGroups', functionsEndpoint: '/Job/ProductFunctions', functionId: filter.function || '' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <input type="hidden" name="Filter.Page" value="1">

        <div class="dense-toolbar job-index-toolbar">
            <label for="JobFirst" class="dense-toolbar__label">@Localizer["First"]</label>
            <input id="JobFirst" type="number" name="Filter.First" x-model="filter.first" min="1" class="dense-input dense-toolbar__input">
            <label for="JobPageSize" class="dense-toolbar__label">@Localizer["PageSize"]</label>
            <input id="JobPageSize" type="number" name="Filter.PageSize" x-model="filter.pageSize" min="1" class="dense-input dense-toolbar__input">
            <button type="submit" class="inline-flex items-center px-4 py-1 border border-blue-300 text-sm font-medium rounded shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["Search"]
            </button>
        </div>
    </form>

    <section class="job-index-section">
        <h3 class="job-index-section__title">@Localizer["JobReport"]</h3>
        <div class="job-index-action-group responsive-action-group">
            <button type="button" @@click="downloadDetailedJobReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["DetailedJobReport"] - Excel
            </button>
            <button type="button" @@click="openDetailedJobReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                @Localizer["DetailedJobReport"] - PDF
            </button>
            <button type="button" @@click="downloadSummaryJobReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["SummaryJobReport"] - Excel
            </button>
            <button type="button" @@click="openSummaryJobReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                @Localizer["SummaryJobReport"] - PDF
            </button>
        </div>
    </section>

    <section class="job-index-section job-index-section--narrow">
        <h3 class="job-index-section__title">@Localizer["JobCreation"]</h3>
        <section class="dense-panel job-index-create-panel">
            <div class="dense-panel__header">
                <h4 class="dense-panel__title">@Localizer["PreInformation"]</h4>
            </div>
            <div class="dense-panel__body job-index-create-panel__body">
                <div class="dense-form-row">
                    <label for="JobCreateFunction">@Localizer["Function"]</label>
                    <select id="JobCreateFunction" x-model="filter.function" class="dense-input job-index-input--select">
                        <option value="">@Localizer["SelectPrompt"]</option>
                        @if (ViewBag.Functions != null)
                        {
                            @foreach (var func in ViewBag.Functions)
                            {
                                <option value="@func.Id">@func.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </section>
        <div class="job-index-create-cta">
            <a :href="filter.function ? '/Job/Create?functionId=' + encodeURIComponent(filter.function) : '/Job/Create'" class="inline-flex items-center justify-center px-5 py-2 border border-blue-300 text-sm font-bold rounded shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["CreateNewJob"]
            </a>
        </div>
    </section>

    <section class="job-index-section">
        <h3 class="job-index-section__title">@Localizer["Invoice"] @Localizer["JobReport"]</h3>
        <div class="job-index-action-group responsive-action-group">
            <button type="button" @@click="downloadDetailedPendingInvoiceJobsReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["DetailedPendingInvoiceJobsReport"] - Excel
            </button>
            <button type="button" @@click="openDetailedPendingInvoiceJobsReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                @Localizer["DetailedPendingInvoiceJobsReport"] - PDF
            </button>
            <button type="button" @@click="downloadSummaryPendingInvoiceJobsReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["SummaryPendingInvoiceJobsReport"] - Excel
            </button>
            <button type="button" @@click="openSummaryPendingInvoiceJobsReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                @Localizer["SummaryPendingInvoiceJobsReport"] - PDF
            </button>
        </div>
    </section>

    <partial name="_CustomerSelectModal" />
    <partial name="_ProductSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script>
    function jobPage() {
        return {
            filter: {
                function: '',
                customerCode: '', customerId: '',
                referenceStart: '', referenceEnd: '', referenceList: '',
                jobName: '', relatedPerson: '',
                startDateStart: '@Model.Filter.StartDateStart?.ToString("yyyy-MM-dd")',
                startDateEnd: '@Model.Filter.StartDateEnd?.ToString("yyyy-MM-dd")',
                endDateStart: '', endDateEnd: '',
                status: '', emailSent: '', evaluated: '',
                
                employeeCode: '', employeeName: '',
                taskType: '', overtimeType: '',
                
                productId: '', productCode: '', productName: '',
                
                page: 1,
                first: @((Model.Filter.First.HasValue && Model.Filter.First.Value > 0 ? Model.Filter.First.Value : (Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 10))),
                pageSize: @(Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 10),
            },
            
            isReportLoading: false,
            customerName: '',
            messages: {
                startDateRangeInvalid: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartDateRangeInvalid"].Value)),
                endDateRangeInvalid: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateRangeInvalid"].Value)),
                startEndDateRequired: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartEndDateRequired"].Value)),
                endDateBeforeStart: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateBeforeStart"].Value)),
                reportDataUnavailable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ReportDataUnavailable"].Value)),
                reportLoading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value)),
                reportLoadingDetail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PrintReportStarted"].Value))
            },
            
            init() {},

            showError(message) {
                if (window.Toast && typeof window.Toast.error === 'function') {
                    window.Toast.error(message);
                    return;
                }

                alert(message);
            },

            normalizeErrorMessage(rawMessage, fallback) {
                if (!rawMessage) {
                    return fallback;
                }

                const text = rawMessage.trim();
                if (!text) {
                    return fallback;
                }

                if (text.startsWith('<')) {
                    return fallback;
                }

                const textarea = document.createElement('textarea');
                textarea.innerHTML = text;
                return textarea.value || fallback;
            },

            showLoading() {
                if (typeof Swal === 'undefined') {
                    return;
                }

                Swal.fire({
                    title: this.messages.reportLoading,
                    text: this.messages.reportLoadingDetail,
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
            },

            hideLoading() {
                if (typeof Swal !== 'undefined' && Swal.isVisible()) {
                    Swal.close();
                }
            },

            handleCustomerSelection(detail) {
                if (detail.targetId === 'jobFilter') {
                    this.filter.customerCode = detail.customer.code;
                    this.filter.customerId = detail.customer.id;
                    this.customerName = detail.customer.name;
                }
            },
            
            handleProductSelection(detail) {
                if(detail.targetId === 'jobProduct') {
                    // Tek ürün veya çoklu ürün seçimi için
                    const product = detail.product || (detail.products && detail.products[0]);
                    if (product) {
                        this.filter.productId = product.id;
                        this.filter.productName = product.name;
                        this.filter.productCode = product.code;
                    }
                }
            },
            
            handleEmployeeSelection(detail) {
                if(detail.targetId === 'jobEmployee') {
                    const emp = detail.employee;
                    if (emp) {
                       this.filter.employeeName = emp.name;
                       this.filter.employeeCode = emp.code; 
                    } else {
                       this.filter.employeeName = '';
                       this.filter.employeeCode = '';
                    }
                }
            },

            buildJobReportParams() {
                const hasStartInput = !!this.filter.startDateStart || !!this.filter.startDateEnd;
                const hasEndInput = !!this.filter.endDateStart || !!this.filter.endDateEnd;
                const hasStartRange = !!this.filter.startDateStart && !!this.filter.startDateEnd;
                const hasEndRange = !!this.filter.endDateStart && !!this.filter.endDateEnd;

                if (hasStartInput && !hasStartRange) {
                    this.showError(this.messages.startDateRangeInvalid);
                    return null;
                }

                if (hasEndInput && !hasEndRange) {
                    this.showError(this.messages.endDateRangeInvalid);
                    return null;
                }

                if (!hasStartRange && !hasEndRange) {
                    this.showError(this.messages.startEndDateRequired);
                    return null;
                }

                if (hasStartRange && new Date(this.filter.startDateEnd) < new Date(this.filter.startDateStart)) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                if (hasEndRange && new Date(this.filter.endDateEnd) < new Date(this.filter.endDateStart)) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                const params = new URLSearchParams();

                if (this.filter.function) params.append('function', this.filter.function);
                if (this.filter.customerCode) params.append('customerCode', this.filter.customerCode);
                if (this.filter.customerId) params.append('customerId', this.filter.customerId);
                if (this.customerName) params.append('customerName', this.customerName);
                if (this.filter.referenceStart) params.append('referenceStart', this.filter.referenceStart);
                if (this.filter.referenceEnd) params.append('referenceEnd', this.filter.referenceEnd);
                if (this.filter.referenceList) params.append('referenceList', this.filter.referenceList);
                if (this.filter.jobName) params.append('jobName', this.filter.jobName);
                if (this.filter.relatedPerson) params.append('relatedPerson', this.filter.relatedPerson);
                if (this.filter.startDateStart) params.append('startDateStart', this.filter.startDateStart);
                if (this.filter.startDateEnd) params.append('startDateEnd', this.filter.startDateEnd);
                if (this.filter.endDateStart) params.append('endDateStart', this.filter.endDateStart);
                if (this.filter.endDateEnd) params.append('endDateEnd', this.filter.endDateEnd);
                if (this.filter.status) params.append('status', this.filter.status);
                if (this.filter.emailSent) params.append('emailSent', this.filter.emailSent);
                if (this.filter.evaluated) params.append('evaluated', this.filter.evaluated);
                if (this.filter.employeeCode) params.append('employeeCode', this.filter.employeeCode);
                if (this.filter.employeeName) params.append('employeeName', this.filter.employeeName);
                if (this.filter.taskType) params.append('taskType', this.filter.taskType);
                if (this.filter.overtimeType) params.append('overtimeType', this.filter.overtimeType);
                if (this.filter.productId) params.append('productId', this.filter.productId);
                if (this.filter.productCode) params.append('productCode', this.filter.productCode);
                if (this.filter.productName) params.append('productName', this.filter.productName);

                return params.toString();
            },

            async downloadReport(url) {
                if (this.isReportLoading) {
                    return;
                }

                this.isReportLoading = true;
                this.showLoading();
                let loadingClosed = false;
                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        const rawMessage = await response.text();
                        const fallback = this.messages.reportDataUnavailable;
                        this.hideLoading();
                        loadingClosed = true;
                        this.showError(this.normalizeErrorMessage(rawMessage, fallback));
                        return;
                    }

                    const blob = await response.blob();
                    const contentDisposition = response.headers.get('content-disposition') || '';
                    const fileNameUtfMatch = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
                    const fileNameMatch = contentDisposition.match(/filename="?([^\";]+)"?/i);

                    let fileName = 'report.xlsx';
                    if (fileNameUtfMatch && fileNameUtfMatch[1]) {
                        fileName = decodeURIComponent(fileNameUtfMatch[1]);
                    } else if (fileNameMatch && fileNameMatch[1]) {
                        fileName = fileNameMatch[1];
                    }

                    const objectUrl = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = objectUrl;
                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(objectUrl);
                } catch (error) {
                    const fallback = (window.imajTexts && window.imajTexts.connectionError)
                        || (window.imajTexts && window.imajTexts.genericError)
                        || this.messages.reportDataUnavailable;
                    this.hideLoading();
                    loadingClosed = true;
                    this.showError(fallback);
                } finally {
                    if (!loadingClosed) {
                        this.hideLoading();
                    }
                    this.isReportLoading = false;
                }
            },

            openReportPage(url) {
                window.open(url, '_blank', 'noopener');
            },

            async downloadDetailedJobReport() {
                const query = this.buildJobReportParams();
                if (query === null) {
                    return;
                }
                await this.downloadReport('/Job/DownloadDetailedJobReportExcel' + (query ? `?${query}` : ''));
            },

            openDetailedJobReportPage() {
                const query = this.buildJobReportParams();
                if (query === null) {
                    return;
                }
