@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model JobViewModel

@{
    ViewData["Title"] = Localizer["JobOperations"];
}

<div x-data="jobPage()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@product-selected.window="handleProductSelection($event.detail)" @@employee-selected.window="handleEmployeeSelection($event.detail)" class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
             <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["JobSearch"]
            </h2>
        </div>
    </div>

    <form method="get" action="/Job/List">
        <!-- Main Filter Card -->
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 overflow-hidden">
            <div class="px-4 py-5 sm:p-6 mobile-stack-form">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                    
                    <!-- COLUMN 1: İŞ KRİTERİ (Job Criteria) -->
                    <div class="lg:col-span-6 border border-blue-200 rounded-lg overflow-hidden bg-white">
                        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                            <h3 class="text-lg font-semibold text-gray-800">@Localizer["JobCriteria"]</h3>
                        </div>
                        <div class="p-4 space-y-4">
                        
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Function"]</label>
                            <div class="col-span-8">
                                <select name="Filter.Function" x-model="filter.function" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                    <option value="">@Localizer["SelectPrompt"]</option>
                                    @if (ViewBag.Functions != null)
                                    {
                                        @foreach (var func in ViewBag.Functions)
                                        {
                                            <option value="@func.Id">@func.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- Müşteri -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Customer"]</label>
                            <div class="col-span-8 flex space-x-2 picker-inline">
                                <input type="hidden" name="Filter.CustomerCode" x-model="filter.customerCode">
                                <input type="hidden" name="Filter.CustomerId" x-model="filter.customerId">
                                <input type="text" readonly x-model="customerName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md bg-gray-50" placeholder="@Localizer["AllOption"]">
                                <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'jobFilter', searchEndpoint: '/Job/CustomerSearch', jobStatesEndpoint: '/Job/CustomerJobStates' })" class="text-blue-600 font-bold hover:underline text-sm">@Localizer["Select"]</button>
                            </div>
                        </div>

                        <!-- @Localizer["ReferenceRange"] -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["ReferenceRange"]</label>
                            <div class="col-span-8 flex space-x-2 picker-inline">
                                <input type="text" name="Filter.ReferenceStart" x-model="filter.referenceStart" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-1/2 sm:text-sm border-gray-300 rounded-md">
                                <input type="text" name="Filter.ReferenceEnd" x-model="filter.referenceEnd" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-1/2 sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <!-- @Localizer["Reference"] Listesi -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Reference"]</label>
                            <div class="col-span-8">
                                <input type="text" name="Filter.ReferenceList" x-model="filter.referenceList" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <!-- Ad -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Name"]</label>
                            <div class="col-span-8">
                                <input type="text" name="Filter.JobName" x-model="filter.jobName" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>
                        
                        <!-- İlgili -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Related"]</label>
                            <div class="col-span-8">
                                <input type="text" name="Filter.RelatedPerson" x-model="filter.relatedPerson" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <!-- @Localizer["StartDate"] -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["StartDateRange"]</label>
                            <div class="col-span-8 flex space-x-2 picker-inline">
                                <input type="date" name="Filter.StartDateStart" x-model="filter.startDateStart" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.Filter.StartDateStart?.ToString("yyyy-MM-dd")">
                                <input type="date" name="Filter.StartDateEnd" x-model="filter.startDateEnd" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.Filter.StartDateEnd?.ToString("yyyy-MM-dd")">
                            </div>
                        </div>
                        
                        <!-- @Localizer["EndDate"] -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["EndDateRange"]</label>
                            <div class="col-span-8 flex space-x-2 picker-inline">
                                <input type="date" name="Filter.EndDateStart" x-model="filter.endDateStart" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                <input type="date" name="Filter.EndDateEnd" x-model="filter.endDateEnd" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>

                        <!-- Durum -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Status"]</label>
                            <div class="col-span-8">
                                <select name="Filter.Status" x-model="filter.status" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @if (ViewBag.States != null)
                                    {
                                        @foreach (var state in ViewBag.States)
                                        {
                                            <option value="@state.Id">@state.Name</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <!-- @Localizer["EmailSent"] -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["EmailSent"]</label>
                            <div class="col-span-8">
                                <select name="Filter.EmailSent" x-model="filter.emailSent" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                </select>
                            </div>
                        </div>

                        <!-- Değerlendirildi -->
                        <div class="grid grid-cols-12 gap-4 items-center">
                            <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Evaluated"]</label>
                            <div class="col-span-8">
                                <select name="Filter.Evaluated" x-model="filter.evaluated" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                </select>
                            </div>
                        </div>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN WRAPPER -->
                    <div class="lg:col-span-6 space-y-6">
                        
                        <!-- COLUMN 2: MESAI KRİTERİ (Overtime Criteria) -->
                        <div class="border border-blue-200 rounded-lg overflow-hidden bg-white">
                            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                                <h3 class="text-lg font-semibold text-gray-800">@Localizer["OvertimeCriteria"]</h3>
                            </div>
                            <div class="p-4 space-y-4">
                                <!-- Çalışan -->
                                <div class="grid grid-cols-12 gap-4 items-center">
                                    <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Employee"]</label>
                                    <div class="col-span-8 flex space-x-2 picker-inline">
                                        <input type="hidden" name="Filter.EmployeeCode" x-model="filter.employeeCode">
                                        <input type="text" readonly x-model="filter.employeeName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md bg-gray-50" placeholder="@Localizer["AllOption"]">
                                        <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'jobEmployee', showFilter: true })" class="text-blue-600 font-bold hover:underline text-sm">@Localizer["Select"]</button>
                                    </div>
                                </div>

                                <!-- Görev Tipi -->
                                <div class="grid grid-cols-12 gap-4 items-center">
                                    <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["WorkType"]</label>
                                    <div class="col-span-8">
                                        <select name="Filter.TaskType" x-model="filter.taskType" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                            <option value="">@Localizer["AllOption"]</option>
                                            @if (ViewBag.WorkTypes != null)
                                            {
                                                @foreach (var wt in ViewBag.WorkTypes)
                                                {
                                                    <option value="@wt.Id">@wt.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>

                                <!-- Mesai Tipi -->
                                <div class="grid grid-cols-12 gap-4 items-center">
                                    <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["TimeType"]</label>
                                    <div class="col-span-8">
                                        <select name="Filter.OvertimeType" x-model="filter.overtimeType" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                                            <option value="">@Localizer["AllOption"]</option>
                                            @if (ViewBag.TimeTypes != null)
                                            {
                                                @foreach (var tt in ViewBag.TimeTypes)
                                                {
                                                    <option value="@tt.Id">@tt.Name</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- COLUMN 3: ÜRÜN KRİTERİ (Product Criteria) -->
                        <div class="border border-blue-200 rounded-lg overflow-hidden bg-white">
                            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                                <h3 class="text-lg font-semibold text-gray-800">@Localizer["ProductCriteria"]</h3>
                            </div>
                            <div class="p-4">
                                <!-- Ürün -->
                                <div class="grid grid-cols-12 gap-4 items-center">
                                    <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Product"]</label>
                                    <div class="col-span-8 flex space-x-2 picker-inline">
                                        <input type="hidden" name="Filter.ProductId" x-model="filter.productId">
                                        <input type="hidden" name="Filter.ProductCode" x-model="filter.productCode">
                                        <input type="text" readonly x-model="filter.productName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md bg-gray-50" placeholder="@Localizer["AllOption"]">
                                        <button type="button" @@click="$dispatch('product-select-open', { targetId: 'jobProduct', searchEndpoint: '/Job/ProductSearch', categoriesEndpoint: '/Job/ProductCategories', productGroupsEndpoint: '/Job/ProductGroups', functionsEndpoint: '/Job/ProductFunctions' })" class="text-blue-600 font-bold hover:underline text-sm">@Localizer["Select"]</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
                
                <!-- BUTTONS -->
                <div class="mt-8 flex flex-col items-center space-y-4 border-t border-gray-200 pt-6">
                    <div class="flex items-center space-x-3 responsive-inline-group">
                        <label class="text-sm text-blue-900 font-semibold">@Localizer["First"]</label>
                        <input type="number" name="Filter.First" x-model="filter.first" min="1" class="w-20 shadow-sm border-gray-300 rounded-md sm:text-sm text-center">
                        <label class="text-sm text-blue-900 font-semibold">@Localizer["PageSize"]</label>
                        <input type="number" name="Filter.PageSize" x-model="filter.pageSize" min="1" class="w-20 shadow-sm border-gray-300 rounded-md sm:text-sm text-center">
                        <input type="hidden" name="Filter.Page" value="1">
                        <button type="submit" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                            @Localizer["Search"]
                        </button>
                    </div>
                    <div class="flex flex-wrap items-center justify-center gap-3">
                        <button type="button" @@click="downloadDetailedJobReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                            @Localizer["DetailedJobReport"] - Excel
                        </button>
                        <button type="button" @@click="openDetailedJobReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                            @Localizer["DetailedJobReport"] - PDF
                        </button>
                        <button type="button" @@click="downloadSummaryJobReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                            @Localizer["SummaryJobReport"] - Excel
                        </button>
                        <button type="button" @@click="openSummaryJobReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                            @Localizer["SummaryJobReport"] - PDF
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
    
    <!-- Job Creation Section -->
    <div class="text-center mt-10">
         <h2 class="text-xl font-bold text-orange-600 mb-4">@Localizer["JobCreation"]</h2>
         <div class="bg-gradient-to-b from-white to-blue-50 shadow sm:rounded-lg border border-gray-200 inline-block w-full max-w-4xl overflow-hidden">
             <div class="px-4 py-3 bg-blue-100 border-b border-blue-200 text-left">
                 <h3 class="text-lg font-semibold text-gray-800">@Localizer["PreInformation"]</h3>
             </div>
             <div class="p-6 mobile-stack-form">
                 <div class="grid grid-cols-12 gap-4 items-center justify-center">
                     <label class="col-span-4 text-right text-sm font-medium text-gray-700">@Localizer["Function"]</label>
                     <div class="col-span-6">
                         <select x-model="filter.function" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                             <option value="">@Localizer["SelectPrompt"]</option>
                             @if (ViewBag.Functions != null)
                             {
                                 @foreach (var func in ViewBag.Functions)
                                 {
                                     <option value="@func.Id">@func.Name</option>
                                 }
                             }
                         </select>
                     </div>
                 </div>
                 <div class="mt-4 flex justify-center responsive-action-group">
                     <a :href="filter.function ? '/Job/Create?functionId=' + encodeURIComponent(filter.function) : '/Job/Create'" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["CreateNewJob"]
                    </a>
                 </div>
             </div>
         </div>
    </div>
    
    <!-- Invoice Report Section -->
    <div class="text-center mt-10 mb-10">
         <h2 class="text-xl font-bold text-orange-600 mb-4">@Localizer["JobReport"]</h2>
          <div class="flex flex-wrap justify-center gap-4 responsive-action-group">
              <button type="button" @@click="downloadDetailedPendingInvoiceJobsReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-2 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["DetailedPendingInvoiceJobsReport"] - Excel
            </button>
            <button type="button" @@click="openDetailedPendingInvoiceJobsReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-2 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                @Localizer["DetailedPendingInvoiceJobsReport"] - PDF
            </button>
            <button type="button" @@click="downloadSummaryPendingInvoiceJobsReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-2 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                @Localizer["SummaryPendingInvoiceJobsReport"] - Excel
            </button>
            <button type="button" @@click="openSummaryPendingInvoiceJobsReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-2 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                @Localizer["SummaryPendingInvoiceJobsReport"] - PDF
            </button>
         </div>
    </div>

    <!-- Shared Customer & Product & Employee Modal -->
    <partial name="_CustomerSelectModal" />
    <partial name="_ProductSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script>
    function jobPage() {
        return {
            filter: {
                function: '',
                customerCode: '', customerId: '',
                referenceStart: '', referenceEnd: '', referenceList: '',
                jobName: '', relatedPerson: '',
                startDateStart: '@Model.Filter.StartDateStart?.ToString("yyyy-MM-dd")',
                startDateEnd: '@Model.Filter.StartDateEnd?.ToString("yyyy-MM-dd")',
                endDateStart: '', endDateEnd: '',
                status: '', emailSent: '', evaluated: '',
                
                employeeCode: '', employeeName: '',
                taskType: '', overtimeType: '',
                
                productId: '', productCode: '', productName: '',
                
                page: 1,
                first: @((Model.Filter.First.HasValue && Model.Filter.First.Value > 0 ? Model.Filter.First.Value : (Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 10))),
                pageSize: @(Model.Filter.PageSize > 0 ? Model.Filter.PageSize : 10),
            },
            
            isReportLoading: false,
            customerName: '',
            messages: {
                startDateRangeInvalid: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartDateRangeInvalid"].Value)),
                endDateRangeInvalid: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateRangeInvalid"].Value)),
                startEndDateRequired: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartEndDateRequired"].Value)),
                endDateBeforeStart: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateBeforeStart"].Value)),
                reportDataUnavailable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ReportDataUnavailable"].Value)),
                reportLoading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value)),
                reportLoadingDetail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PrintReportStarted"].Value))
            },
            
            init() {},

            showError(message) {
                if (window.Toast && typeof window.Toast.error === 'function') {
                    window.Toast.error(message);
                    return;
                }

                alert(message);
            },

            normalizeErrorMessage(rawMessage, fallback) {
                if (!rawMessage) {
                    return fallback;
                }

                const text = rawMessage.trim();
                if (!text) {
                    return fallback;
                }

                if (text.startsWith('<')) {
                    return fallback;
                }

                const textarea = document.createElement('textarea');
                textarea.innerHTML = text;
                return textarea.value || fallback;
            },

            showLoading() {
                if (typeof Swal === 'undefined') {
                    return;
                }

                Swal.fire({
                    title: this.messages.reportLoading,
                    text: this.messages.reportLoadingDetail,
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
            },

            hideLoading() {
                if (typeof Swal !== 'undefined' && Swal.isVisible()) {
                    Swal.close();
                }
            },

            handleCustomerSelection(detail) {
                if (detail.targetId === 'jobFilter') {
                    this.filter.customerCode = detail.customer.code;
                    this.filter.customerId = detail.customer.id;
                    this.customerName = detail.customer.name;
                }
            },
            
            handleProductSelection(detail) {
                if(detail.targetId === 'jobProduct') {
                    // Tek ürün veya çoklu ürün seçimi için
                    const product = detail.product || (detail.products && detail.products[0]);
                    if (product) {
                        this.filter.productId = product.id;
                        this.filter.productName = product.name;
                        this.filter.productCode = product.code;
                    }
                }
            },
            
            handleEmployeeSelection(detail) {
                if(detail.targetId === 'jobEmployee') {
                    const emp = detail.employee;
                    if (emp) {
                       this.filter.employeeName = emp.name;
                       this.filter.employeeCode = emp.code; 
                    } else {
                       this.filter.employeeName = '';
                       this.filter.employeeCode = '';
                    }
                }
            },

            buildJobReportParams() {
                const hasStartInput = !!this.filter.startDateStart || !!this.filter.startDateEnd;
                const hasEndInput = !!this.filter.endDateStart || !!this.filter.endDateEnd;
                const hasStartRange = !!this.filter.startDateStart && !!this.filter.startDateEnd;
                const hasEndRange = !!this.filter.endDateStart && !!this.filter.endDateEnd;

                if (hasStartInput && !hasStartRange) {
                    this.showError(this.messages.startDateRangeInvalid);
                    return null;
                }

                if (hasEndInput && !hasEndRange) {
                    this.showError(this.messages.endDateRangeInvalid);
                    return null;
                }

                if (!hasStartRange && !hasEndRange) {
                    this.showError(this.messages.startEndDateRequired);
                    return null;
                }

                if (hasStartRange && new Date(this.filter.startDateEnd) < new Date(this.filter.startDateStart)) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                if (hasEndRange && new Date(this.filter.endDateEnd) < new Date(this.filter.endDateStart)) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                const params = new URLSearchParams();

                if (this.filter.function) params.append('function', this.filter.function);
                if (this.filter.customerCode) params.append('customerCode', this.filter.customerCode);
                if (this.filter.customerId) params.append('customerId', this.filter.customerId);
                if (this.customerName) params.append('customerName', this.customerName);
                if (this.filter.referenceStart) params.append('referenceStart', this.filter.referenceStart);
                if (this.filter.referenceEnd) params.append('referenceEnd', this.filter.referenceEnd);
                if (this.filter.referenceList) params.append('referenceList', this.filter.referenceList);
                if (this.filter.jobName) params.append('jobName', this.filter.jobName);
                if (this.filter.relatedPerson) params.append('relatedPerson', this.filter.relatedPerson);
                if (this.filter.startDateStart) params.append('startDateStart', this.filter.startDateStart);
                if (this.filter.startDateEnd) params.append('startDateEnd', this.filter.startDateEnd);
                if (this.filter.endDateStart) params.append('endDateStart', this.filter.endDateStart);
                if (this.filter.endDateEnd) params.append('endDateEnd', this.filter.endDateEnd);
                if (this.filter.status) params.append('status', this.filter.status);
                if (this.filter.emailSent) params.append('emailSent', this.filter.emailSent);
                if (this.filter.evaluated) params.append('evaluated', this.filter.evaluated);
                if (this.filter.employeeCode) params.append('employeeCode', this.filter.employeeCode);
                if (this.filter.employeeName) params.append('employeeName', this.filter.employeeName);
                if (this.filter.taskType) params.append('taskType', this.filter.taskType);
                if (this.filter.overtimeType) params.append('overtimeType', this.filter.overtimeType);
                if (this.filter.productId) params.append('productId', this.filter.productId);
                if (this.filter.productCode) params.append('productCode', this.filter.productCode);
                if (this.filter.productName) params.append('productName', this.filter.productName);

                return params.toString();
            },

            async downloadReport(url) {
                if (this.isReportLoading) {
                    return;
                }

                this.isReportLoading = true;
                this.showLoading();
                let loadingClosed = false;
                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        const rawMessage = await response.text();
                        const fallback = this.messages.reportDataUnavailable;
                        this.hideLoading();
                        loadingClosed = true;
                        this.showError(this.normalizeErrorMessage(rawMessage, fallback));
                        return;
                    }

                    const blob = await response.blob();
                    const contentDisposition = response.headers.get('content-disposition') || '';
                    const fileNameUtfMatch = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
                    const fileNameMatch = contentDisposition.match(/filename="?([^\";]+)"?/i);

                    let fileName = 'report.xlsx';
                    if (fileNameUtfMatch && fileNameUtfMatch[1]) {
                        fileName = decodeURIComponent(fileNameUtfMatch[1]);
                    } else if (fileNameMatch && fileNameMatch[1]) {
                        fileName = fileNameMatch[1];
                    }

                    const objectUrl = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = objectUrl;
                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(objectUrl);
                } catch (error) {
                    const fallback = (window.imajTexts && window.imajTexts.connectionError)
                        || (window.imajTexts && window.imajTexts.genericError)
                        || this.messages.reportDataUnavailable;
                    this.hideLoading();
                    loadingClosed = true;
                    this.showError(fallback);
                } finally {
                    if (!loadingClosed) {
                        this.hideLoading();
                    }
                    this.isReportLoading = false;
                }
            },

            openReportPage(url) {
                window.open(url, '_blank', 'noopener');
            },

            async downloadDetailedJobReport() {
                const query = this.buildJobReportParams();
                if (query === null) {
                    return;
                }
                await this.downloadReport('/Job/DownloadDetailedJobReportExcel' + (query ? `?${query}` : ''));
            },

