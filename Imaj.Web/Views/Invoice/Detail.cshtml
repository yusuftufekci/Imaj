@using System.Net
@using System.Collections.Generic
@using System.Globalization
@using System.Text.Json
@using Imaj.Web.Authorization
@using Imaj.Service.DTOs
@model InvoiceDisplayViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["Invoice"];
    var invoice = Model.Invoices.FirstOrDefault();
    var lineTotal = invoice?.Lines.Sum(x => x.Amount) ?? 0m;
    var taxTotal = invoice?.Taxes.Sum(x => x.TaxAmount) ?? 0m;
    var netTotal = invoice?.Taxes.Sum(x => x.NetTotal) ?? 0m;
    var returnUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/Invoice/Results" : Model.ReturnUrl;
    var queryParts = new List<string>();
    if (Model.SelectedReferences.Any())
    {
        queryParts.AddRange(Model.SelectedReferences.Select(x => "selectedReferences=" + WebUtility.UrlEncode(x)));
    }
    if (!string.IsNullOrWhiteSpace(returnUrl))
    {
        queryParts.Add("returnUrl=" + WebUtility.UrlEncode(returnUrl));
    }
    var queryString = string.Join("&", queryParts);
    var currentUrl = "/Invoice/Detail?reference=" + invoice?.Reference + "&page=" + (Model.CurrentIndex + 1) + (string.IsNullOrWhiteSpace(queryString) ? string.Empty : "&" + queryString);
    var selectedReferences = Model.SelectedReferences ?? new List<string>();
    string BuildJobPickerUrl(string context, decimal? lineId = null, InvoiceAddJobsMode mode = InvoiceAddJobsMode.SingleLine)
    {
        var pickerParts = new List<string>
        {
            "reference=" + WebUtility.UrlEncode(invoice?.Reference ?? string.Empty),
            "context=" + WebUtility.UrlEncode(context),
            "mode=" + ((int)mode).ToString(CultureInfo.InvariantCulture),
            "currentIndex=" + Model.CurrentIndex.ToString(CultureInfo.InvariantCulture),
            "returnUrl=" + WebUtility.UrlEncode(returnUrl)
        };

        if (lineId.HasValue)
        {
            pickerParts.Add("lineId=" + lineId.Value.ToString(CultureInfo.InvariantCulture));
        }

        pickerParts.AddRange(selectedReferences.Select(x => "selectedReferences=" + WebUtility.UrlEncode(x)));
        return "/Invoice/JobPicker?" + string.Join("&", pickerParts);
    }
    var parsedReference = int.TryParse(invoice?.Reference, out var reference);
    var stateId = invoice?.StateId ?? 0m;
    var isEvaluated = invoice?.Evaluated ?? false;
    var isOpen = stateId == 210m;
    var isConfirmed = stateId == 220m;
    var isIssued = stateId == 230m
        || string.Equals(invoice?.Status, "Kesildi", StringComparison.OrdinalIgnoreCase)
        || string.Equals(invoice?.Status, "Issued", StringComparison.OrdinalIgnoreCase);
    var isKilled = stateId == 240m;
    var isDiscarded = stateId == 250m;
    var issueDateValue = (invoice?.IssueDate ?? DateTime.Today).ToString("yyyy-MM-dd");

    var canConfirm = await PermissionViewService.CanExecuteMethodAsync(1385m, write: true);
    var canUndoConfirm = await PermissionViewService.CanExecuteMethodAsync(1386m, write: true);
    var canIssue = await PermissionViewService.CanExecuteMethodAsync(1388m, write: true);
    var canKill = await PermissionViewService.CanExecuteMethodAsync(1389m, write: true);
    var canDiscard = await PermissionViewService.CanExecuteMethodAsync(1387m, write: true);
    canKill = canKill || canDiscard;
    var canEvaluate = await PermissionViewService.CanExecuteMethodAsync(1390m, write: true);
    var canUndoEvaluate = await PermissionViewService.CanExecuteMethodAsync(1490m, write: true);
    var canEditInvoice = await PermissionViewService.CanExecuteMethodAsync(1360m, write: true);

    var canDoConfirm = parsedReference && canConfirm && !isEvaluated && isOpen;
    var canDoUndoConfirm = parsedReference && canUndoConfirm && !isEvaluated && isConfirmed;
    var canDoIssue = parsedReference && canIssue && !isEvaluated && isConfirmed;
    var canDoKill = parsedReference && canKill && !isEvaluated && isIssued;
    var canDoDiscard = parsedReference && canDiscard && !isEvaluated && isOpen;
    var canDoEvaluate = parsedReference && canEvaluate && !isEvaluated && (isIssued || isKilled || isDiscarded);
    var canDoUndoEvaluate = parsedReference && canUndoEvaluate && isEvaluated && (isIssued || isKilled || isDiscarded);
    var canPrintInvoice = parsedReference && !isEvaluated && (isOpen || isConfirmed || isIssued);
    var canDoEdit = parsedReference && canEditInvoice && !isEvaluated && isOpen;
    var canEditJobs = canDoEdit;
    var detailStateJson = JsonSerializer.Serialize(new
    {
        reference,
        jobCustomerCode = invoice?.JobCustomerCode ?? string.Empty,
        jobCustomerName = invoice?.JobCustomer ?? string.Empty,
        jobCustomerDisplay = string.IsNullOrWhiteSpace(invoice?.JobCustomerCode)
            ? invoice?.JobCustomer ?? string.Empty
            : invoice?.JobCustomerCode + " - " + invoice?.JobCustomer,
        invoiceCustomerCode = invoice?.InvoiceCustomerCode ?? string.Empty,
        invoiceCustomerName = invoice?.InvoiceCustomer ?? string.Empty,
        invoiceCustomerDisplay = string.IsNullOrWhiteSpace(invoice?.InvoiceCustomerCode)
            ? invoice?.InvoiceCustomer ?? string.Empty
            : invoice?.InvoiceCustomerCode + " - " + invoice?.InvoiceCustomer,
        defaultVatRate = 20
    });
}

<div x-data="invoiceDetailEdit($el.dataset.invoiceState)"
     data-invoice-state="@detailStateJson"
     @@customer-selected.window="handleCustomerSelection($event.detail)"
     class="invoice-page-shell invoice-legacy-detail page-shell--wide space-y-3">
    @if (invoice == null)
    {
        <div class="invoice-empty-state invoice-table-card">
            @Localizer["NoRecordsFound"]
        </div>
    }
    else
    {
        <div class="space-y-3">
            <form id="invoiceDetailEditForm" x-ref="editForm" method="post" action="/Invoice/UpdateDetail" class="hidden">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Reference" value="@reference" />
                <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                <input type="hidden" name="InvoiceCustomerCode" x-model="invoiceCustomerCode" />
                <input type="hidden" name="InvoiceCustomerName" x-model="invoiceCustomerName" />
                @foreach (var selectedReference in selectedReferences)
                {
                    <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                }
            </form>
            @if (canEditJobs)
            {
                <form x-ref="deleteJobsFromLineForm" method="post" action="/Invoice/DeleteJobsFromInvoiceLine" class="hidden">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Reference" value="@reference" />
                    <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                    <input type="hidden" name="LineId" x-model="deleteLineId" />
                    @foreach (var selectedReference in selectedReferences)
                    {
                        <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                    }
                    <span x-ref="deleteJobsContainer"></span>
                </form>
                <form x-ref="deleteJobLinesForm" method="post" action="/Invoice/DeleteJobLines" class="hidden">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Reference" value="@reference" />
                    <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                    @foreach (var selectedReference in selectedReferences)
                    {
                        <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                    }
                    <span x-ref="deleteJobLinesContainer"></span>
                </form>
            }

            <div class="md:flex md:items-center md:justify-between">
                <div class="flex-1 min-w-0">
                    <h2 class="invoice-page-title invoice-page-title--orange">@Localizer["Invoice"]</h2>
                </div>
                <div class="mt-3 md:mt-0 invoice-page-actions">
                    <a href="@returnUrl" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Back"]</a>
                </div>
            </div>

            <div class="invoice-detail-grid">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <dl class="invoice-detail-list">
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["Reference"]</dt>
                                <dd class="invoice-detail-item__value">@invoice.Reference</dd>
                            </div>
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["JobCustomer"]</dt>
                                <dd class="invoice-detail-item__value">@invoice.JobCustomer</dd>
                            </div>
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["InvoiceCustomer"]</dt>
                                <dd class="invoice-detail-item__value">
                                    <span x-show="!isEditing" x-text="invoiceCustomerDisplay || '-'"></span>
                                    <div x-show="isEditing" x-cloak class="job-detail-edit-selector">
                                        <span class="job-detail-edit-selector__value" x-text="invoiceCustomerDisplay || '-'"></span>
                                        <button type="button"
                                                @@click="$dispatch('customer-select-open', { targetId: 'invoiceDetail', code: invoiceCustomerCode, autoSearch: !!invoiceCustomerCode })"
                                                class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                            @Localizer["Select"]
                                        </button>
                                    </div>
                                </dd>
                            </div>
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["Name"]</dt>
                                <dd class="invoice-detail-item__value">
                                    <span x-show="!isEditing">@invoice.Name</span>
                                    <input x-show="isEditing"
                                           x-cloak
                                           type="text"
                                           name="Name"
                                           value="@invoice.Name"
                                           form="invoiceDetailEditForm"
                                           :disabled="!isEditing"
                                           maxlength="32"
                                           required
                                           class="dense-input invoice-detail-edit-input" />
                                </dd>
                            </div>
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["Related"]</dt>
                                <dd class="invoice-detail-item__value">
                                    <span x-show="!isEditing">@invoice.RelatedPerson</span>
                                    <input x-show="isEditing"
                                           x-cloak
                                           type="text"
                                           name="RelatedPerson"
                                           value="@invoice.RelatedPerson"
                                           form="invoiceDetailEditForm"
                                           :disabled="!isEditing"
                                           maxlength="32"
                                           class="dense-input invoice-detail-edit-input" />
                                </dd>
                            </div>
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["Date"]</dt>
                                <dd class="invoice-detail-item__value">@invoice.IssueDate?.ToString("dd/MM/yyyy dddd") ?? "-"</dd>
                            </div>
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["Status"]</dt>
                                <dd class="invoice-detail-item__value">@invoice.Status</dd>
                            </div>
                            <div class="invoice-detail-item">
                                <dt class="invoice-detail-item__label">@Localizer["Evaluated"]</dt>
                                <dd class="invoice-detail-item__value">
                                    <input type="checkbox" disabled @(invoice.Evaluated ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                                </dd>
                            </div>
                        </dl>
                    </div>
                </section>

                <div class="invoice-note-stack">
                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h3 class="dense-panel__title">@Localizer["Notes"]</h3>
                        </div>
                        <div class="dense-panel__body">
                            <div x-show="!isEditing" class="invoice-detail-item__value whitespace-pre-wrap">@invoice.Notes</div>
                            <textarea x-show="isEditing"
                                      x-cloak
                                      name="Notes"
                                      form="invoiceDetailEditForm"
                                      :disabled="!isEditing"
                                      class="dense-input invoice-detail-edit-textarea">@invoice.Notes</textarea>
                        </div>
                    </section>
                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h3 class="dense-panel__title">@Localizer["Footnote"]</h3>
                        </div>
                        <div class="dense-panel__body">
                            <div x-show="!isEditing" class="invoice-detail-item__value whitespace-pre-wrap">@invoice.FooterNote</div>
                            <textarea x-show="isEditing"
                                      x-cloak
                                      name="FooterNote"
                                      form="invoiceDetailEditForm"
                                      :disabled="!isEditing"
                                      class="dense-input invoice-detail-edit-textarea">@invoice.FooterNote</textarea>
                        </div>
                    </section>
                </div>
            </div>

            <section class="invoice-table-card">
                <div class="invoice-table-card__header">
                    <h3 class="invoice-table-card__title">@Localizer["Line"] (@invoice.Lines.Count)</h3>
                </div>
                <div class="invoice-table-wrap mobile-table-panel">
                    <table class="invoice-table invoice-table--compact">
                        <thead>
                            <tr>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Selected"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Sequence"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Notes"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Quantity"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Price"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Amount"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["TaxType"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var productCategoryFormIndex = 0;
                            }
                            @for (var i = 0; i < invoice.Lines.Count; i++)
                            {
                                var line = invoice.Lines[i];
                                <tr>
                                    <td class="px-4 py-2">
                                        @if (canEditJobs && !line.FreeFormat && line.WorkItems.Any())
                                        {
                                            <input type="checkbox"
                                                   value="@line.Id.ToString(CultureInfo.InvariantCulture)"
                                                   data-invoice-line-checkbox
                                                   :disabled="isEditing"
                                                   class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                        }
                                        else
                                        {
                                            <input type="checkbox" disabled @(line.Selected ? "checked" : "") class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                        }
                                    </td>
                                    <td class="px-4 py-2 text-gray-900">@line.LineNo</td>
                                    <td class="px-4 py-2 text-gray-900">
                                        <span x-show="!isEditing">@line.Notes</span>
                                        <input type="hidden"
                                               name="Lines[@i].Id"
                                               value="@line.Id.ToString(CultureInfo.InvariantCulture)"
                                               form="invoiceDetailEditForm"
                                               :disabled="!isEditing" />
                                        <input x-show="isEditing"
                                               x-cloak
                                               type="text"
                                               name="Lines[@i].Notes"
                                               value="@line.Notes"
                                               form="invoiceDetailEditForm"
                                               :disabled="!isEditing"
                                               class="dense-input invoice-line-note-input" />
                                    </td>
                                    <td class="px-4 py-2 text-right text-gray-900">@line.Quantity</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@line.Price.ToString("N2")</td>
                                    <td class="px-4 py-2 text-right text-gray-900">
                                        @if (line.FreeFormat)
                                        {
                                            <span x-show="!isEditing">@line.Amount.ToString("N2")</span>
                                            <input x-show="isEditing"
                                                   x-cloak
                                                   type="text"
                                                   inputmode="decimal"
                                                   name="Lines[@i].Amount"
                                                   value="@line.Amount.ToString("0.##")"
                                                   form="invoiceDetailEditForm"
                                                   :disabled="!isEditing"
                                                   @@input="updateLineTotals()"
                                                   data-invoice-line-amount
                                                   class="job-table-input job-table-input--money invoice-detail-money-input" />
                                        }
                                        else
                                        {
                                            <span data-invoice-line-static-amount="@line.Amount.ToString(CultureInfo.InvariantCulture)">@line.Amount.ToString("N2")</span>
                                            <input type="hidden"
                                                   name="Lines[@i].Amount"
                                                   value="@line.Amount.ToString(CultureInfo.InvariantCulture)"
                                                   form="invoiceDetailEditForm"
                                                   :disabled="!isEditing" />
                                        }
                                    </td>
                                    <td class="px-4 py-2 text-gray-900">
                                        @if (line.FreeFormat)
                                        {
                                            <span x-show="!isEditing">@line.TaxType</span>
                                            <input x-show="isEditing"
                                                   x-cloak
                                                   type="text"
                                                   inputmode="numeric"
                                                   name="Lines[@i].VatRate"
                                                   value="@line.VatRate.ToString("0.##")"
                                                   form="invoiceDetailEditForm"
                                                   :disabled="!isEditing"
                                                   class="job-table-input job-table-input--discount invoice-detail-tax-input" />
                                        }
                                        else
                                        {
                                            <span>@line.TaxType</span>
                                            <input type="hidden"
                                                   name="Lines[@i].VatRate"
                                                   value="@line.VatRate.ToString(CultureInfo.InvariantCulture)"
                                                   form="invoiceDetailEditForm"
                                                   :disabled="!isEditing" />
                                        }
                                    </td>
                                </tr>

                                if (line.WorkItems.Any() || line.ProductCategories.Any())
                                {
                                    <tr class="bg-blue-50">
                                        <td colspan="7" class="px-4 py-4">
                                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                                                <div class="border border-blue-200 rounded">
                                                    <div class="bg-blue-100 px-3 py-2 text-sm font-bold text-gray-800">@Localizer["Job"] (@line.WorkItems.Count)</div>
                                                    <table class="invoice-table invoice-table--compact">
                                                        <thead>
                                                            <tr>
                                                                <th class="px-3 py-2 text-left font-bold text-gray-700">@Localizer["Selected"]</th>
                                                                <th class="px-3 py-2 text-left font-bold text-gray-700">@Localizer["Reference"]</th>
                                                                <th class="px-3 py-2 text-left font-bold text-gray-700">@Localizer["Name"]</th>
                                                                <th class="px-3 py-2 text-right font-bold text-gray-700">@Localizer["Amount"]</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var work in line.WorkItems)
                                                            {
                                                                <tr>
                                                                    <td class="px-3 py-2">
                                                                        @if (canEditJobs)
                                                                        {
                                                                           <input type="checkbox"
                                                                                   value="@work.Reference"
                                                                                   data-invoice-job-checkbox
                                                                                   data-line-id="@line.Id.ToString(CultureInfo.InvariantCulture)"
                                                                                   :disabled="isEditing"
                                                                                   class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                                                        }
                                                                        else
                                                                        {
                                                                            <input type="checkbox" disabled @(work.Selected ? "checked" : "") class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                                                        }
                                                                    </td>
                                                                <td class="px-3 py-2 text-gray-900">
                                                                    <a href="/Job/Detail?id=@work.Reference&returnUrl=@WebUtility.UrlEncode(currentUrl)" class="text-blue-600 hover:text-blue-900 underline">
                                                                        @work.Reference
                                                                    </a>
                                                                </td>
                                                                    <td class="px-3 py-2 text-gray-900">@work.Name</td>
                                                                    <td class="px-3 py-2 text-right text-gray-900">@work.Amount.ToString("N2")</td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                        <tfoot>
                                                            <tr>
                                                                <td colspan="3" class="px-3 py-2 text-right font-bold text-gray-900">@Localizer["Total"]</td>
                                                                <td class="px-3 py-2 text-right font-bold text-gray-900">@line.WorkItems.Sum(x => x.Amount).ToString("N2")</td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                    @if (canEditJobs)
                                                    {
                                                        <div class="invoice-footer-bar" x-show="!isEditing" x-cloak>
                                                            <button type="button"
                                                                    @@click="submitDeleteJobs('@line.Id.ToString(CultureInfo.InvariantCulture)')"
                                                                    class="text-red-600 hover:text-red-900 font-bold underline text-sm">
                                                                İş Sil
                                                            </button>
                                                            <a href="@BuildJobPickerUrl("line", line.Id)"
                                                               class="text-indigo-600 hover:text-indigo-900 font-bold underline text-sm">
                                                                İş Ekle
                                                            </a>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="border border-blue-200 rounded">
                                                    <div class="bg-blue-100 px-3 py-2 text-sm font-bold text-gray-800">@Localizer["ProductCategories"] (@line.ProductCategories.Count)</div>
                                                    <table class="invoice-table invoice-table--compact">
                                                        <thead>
                                                            <tr>
                                                                <th class="px-3 py-2 text-left font-bold text-gray-700">@Localizer["ProductCategory"]</th>
                                                                <th class="px-3 py-2 text-right font-bold text-gray-700">@Localizer["SubTotal"]</th>
                                                                <th class="px-3 py-2 text-right font-bold text-gray-700">@Localizer["NetAmount"]</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @for (var catIndex = 0; catIndex < line.ProductCategories.Count; catIndex++)
                                                            {
                                                                var cat = line.ProductCategories[catIndex];
                                                                var categoryFormIndex = productCategoryFormIndex++;
                                                                <tr>
                                                                    <td class="px-3 py-2 text-gray-900">
                                                                        @cat.Name
                                                                        <input type="hidden"
                                                                               name="ProductCategories[@categoryFormIndex].LineId"
                                                                               value="@line.Id.ToString(CultureInfo.InvariantCulture)"
                                                                               form="invoiceDetailEditForm"
                                                                               :disabled="!isEditing" />
                                                                        <input type="hidden"
                                                                               name="ProductCategories[@categoryFormIndex].ProdCatId"
                                                                               value="@cat.ProdCatId.ToString(CultureInfo.InvariantCulture)"
                                                                               form="invoiceDetailEditForm"
                                                                               :disabled="!isEditing" />
                                                                    </td>
                                                                    <td class="px-3 py-2 text-right text-gray-900">@cat.SubTotal.ToString("N2")</td>
                                                                    <td class="px-3 py-2 text-right text-gray-900">
                                                                        <span x-show="!isEditing">@cat.NetTotal.ToString("N2")</span>
                                                                        <input x-show="isEditing"
                                                                               x-cloak
                                                                               type="text"
                                                                               inputmode="decimal"
                                                                               name="ProductCategories[@categoryFormIndex].NetTotal"
                                                                               value="@cat.NetTotal.ToString("0.##")"
                                                                               form="invoiceDetailEditForm"
                                                                               :disabled="!isEditing"
                                                                               @@input="updateCategoryTotals()"
                                                                               data-invoice-category-net
                                                                               data-line-category-net="@line.Id.ToString(CultureInfo.InvariantCulture)"
                                                                               class="job-table-input job-table-input--money invoice-detail-money-input" />
                                                                    </td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                        <tfoot>
                                                            <tr>
                                                                <td class="px-3 py-2 text-right font-bold text-gray-900">@Localizer["Total"]</td>
                                                                <td class="px-3 py-2 text-right font-bold text-gray-900">@line.ProductCategories.Sum(x => x.SubTotal).ToString("N2")</td>
                                                                <td class="px-3 py-2 text-right font-bold text-gray-900"
                                                                    data-line-category-net-total="@line.Id.ToString(CultureInfo.InvariantCulture)">
                                                                    @line.ProductCategories.Sum(x => x.NetTotal).ToString("N2")
                                                                </td>
                                                            </tr>
                                                        </tfoot>
                                                    </table>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            <template x-for="(line, index) in newFreeLines" :key="line.key">
                                <tr>
                                    <td class="px-4 py-2">
                                        <button type="button"
                                                @@click="removeFreeLine(index)"
                                                class="text-red-600 hover:text-red-900 text-sm font-bold underline">
                                            @Localizer["Delete"]
                                        </button>
                                    </td>
                                    <td class="px-4 py-2 text-gray-900">-</td>
                                    <td class="px-4 py-2 text-gray-900">
                                        <input type="text"
                                               x-model="line.description"
                                               :name="'NewFreeLines[' + index + '].Description'"
                                               form="invoiceDetailEditForm"
                                               class="dense-input invoice-line-note-input" />
                                    </td>
                                    <td class="px-4 py-2 text-right text-gray-900">1</td>
                                    <td class="px-4 py-2 text-right text-gray-900">
                                        <input type="text"
                                               inputmode="decimal"
                                               x-model="line.amount"
                                               :name="'NewFreeLines[' + index + '].Amount'"
                                               form="invoiceDetailEditForm"
                                               @@input="updateLineTotals()"
                                               class="job-table-input job-table-input--money invoice-detail-money-input" />
                                    </td>
                                    <td class="px-4 py-2 text-right text-gray-900" x-text="formatMoney(parseDecimal(line.amount))"></td>
                                    <td class="px-4 py-2 text-gray-900">
                                        <input type="text"
                                               inputmode="numeric"
                                               x-model="line.vatRate"
                                               :name="'NewFreeLines[' + index + '].VatRate'"
                                               form="invoiceDetailEditForm"
                                               class="job-table-input job-table-input--discount invoice-detail-tax-input" />
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="px-4 py-2 text-right font-bold text-gray-900">@Localizer["Total"]</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900" data-invoice-line-total>@lineTotal.ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                <div class="invoice-footer-bar" x-show="isEditing" x-cloak>
                    <button type="button"
                            @@click="addFreeLine()"
                            class="text-indigo-600 hover:text-indigo-900 font-bold underline text-sm">
                        @Localizer["AddFreeLine"]
                    </button>
                </div>
            </section>

            @if (invoice.WorkItems.Any() || canEditJobs)
            {
                var firstWorkReference = invoice.WorkItems.FirstOrDefault()?.Reference ?? string.Empty;
                <div class="invoice-footer-bar invoice-footer-bar--start" x-show="!isEditing" x-cloak>
                    @if (invoice.WorkItems.Any())
                    {
                        <button type="button"
                                @@click="viewSelectedJob('@firstWorkReference')"
                                class="text-blue-600 hover:text-blue-900 underline text-sm font-bold">
                            @Localizer["ViewJob"]
                        </button>
                    }
                    @if (canEditJobs)
                    {
                        <button type="button"
                                @@click="submitDeleteJobLines()"
                                class="text-red-600 hover:text-red-900 underline text-sm font-bold">
                            İş Satırı Sil
                        </button>
                        <a href="@BuildJobPickerUrl("invoice")"
                           class="text-indigo-600 hover:text-indigo-900 underline text-sm font-bold">
                            İş Satırı Ekle
                        </a>
                    }
                </div>
            }

            <section class="invoice-table-card">
                <div class="invoice-table-card__header">
                    <h3 class="invoice-table-card__title">@Localizer["Taxes"] (@invoice.Taxes.Count)</h3>
                </div>
                <div class="invoice-table-wrap mobile-table-panel">
                    <table class="invoice-table invoice-table--compact">
                        <thead>
                            <tr>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Code"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Name"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["SubTotal"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Percentage"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["TaxAmount"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["NetAmount"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var taxIndex = 0; taxIndex < invoice.Taxes.Count; taxIndex++)
                            {
                                var tax = invoice.Taxes[taxIndex];
                                <tr>
                                    <td class="px-4 py-2 text-gray-900">@tax.Code</td>
                                    <td class="px-4 py-2 text-gray-900">@tax.Name</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@tax.SubTotal.ToString("N2")</td>
                                    <td class="px-4 py-2 text-right text-gray-900">
                                        <span x-show="!isEditing">@tax.Rate.ToString("N0")</span>
                                        <input type="hidden"
                                               name="Taxes[@taxIndex].TaxTypeId"
                                               value="@tax.TaxTypeId.ToString(CultureInfo.InvariantCulture)"
                                               form="invoiceDetailEditForm"
                                               :disabled="!isEditing" />
                                        <input x-show="isEditing"
                                               x-cloak
                                               type="text"
                                               inputmode="numeric"
                                               name="Taxes[@taxIndex].Rate"
                                               value="@tax.Rate.ToString("0.##")"
                                               form="invoiceDetailEditForm"
                                               :disabled="!isEditing"
                                               @@input="updateTaxTotals()"
                                               data-invoice-tax-rate
                                               data-invoice-tax-subtotal="@tax.SubTotal.ToString(CultureInfo.InvariantCulture)"
                                               data-invoice-tax-amount-target="invoice-tax-amount-@taxIndex"
                                               data-invoice-tax-net-target="invoice-tax-net-@taxIndex"
                                               class="job-table-input job-table-input--discount invoice-detail-tax-input" />
                                    </td>
                                    <td id="invoice-tax-amount-@taxIndex" class="px-4 py-2 text-right text-gray-900" data-invoice-tax-amount>@tax.TaxAmount.ToString("N2")</td>
                                    <td id="invoice-tax-net-@taxIndex" class="px-4 py-2 text-right text-gray-900" data-invoice-tax-net>@tax.NetTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2" class="px-4 py-2 text-right font-bold text-gray-900">@Localizer["Total"]</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900">@invoice.Taxes.Sum(x => x.SubTotal).ToString("N2")</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900"></td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900" data-invoice-tax-amount-total>@taxTotal.ToString("N2")</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900" data-invoice-tax-net-total>@netTotal.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </section>

            @if (selectedReferences.Count > 1)
            {
                <div class="mt-4">
                    <partial name="Components/_Pagination" model="@(new Imaj.Web.Models.Components.PaginationModel
                    {
                        CurrentPage = Model.CurrentIndex + 1,
                        TotalCount = selectedReferences.Count,
                        PageSize = 1,
                        BaseUrl = "/Invoice/Detail",
                        QueryString = queryString
                    })" />
                </div>
            }

            <div class="invoice-footer-bar invoice-footer-bar--center responsive-action-group">
                <div class="flex flex-wrap justify-center gap-2 w-full">
                    @if (canDoEdit)
                    {
                        <button type="button"
                                x-show="!isEditing"
                                @@click="enableEdit()"
                                class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                            @Localizer["Edit"]
                        </button>
                        <button type="submit"
                                form="invoiceDetailEditForm"
                                x-show="isEditing"
                                x-cloak
                                class="inline-flex items-center px-4 py-2 border border-emerald-400 text-sm font-medium rounded-md text-emerald-900 bg-emerald-100 hover:bg-emerald-200 focus:outline-none">
                            @Localizer["Save"]
                        </button>
                        <button type="button"
                                x-show="isEditing"
                                x-cloak
                                @@click="cancelEdit()"
                                class="inline-flex items-center px-4 py-2 border border-red-400 text-sm font-medium rounded-md text-red-900 bg-red-100 hover:bg-red-200 focus:outline-none">
                            @Localizer["Cancel"]
                        </button>
                    }
                    <a href="@returnUrl" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">@Localizer["Back"]</a>
                </div>

                <div class="flex flex-wrap justify-center gap-2 w-full">
                    <a href="/Invoice/Summary?reference=@invoice.Reference&page=@(Model.CurrentIndex + 1)&@queryString" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">
                        @Localizer["ViewSummary"]
                    </a>

                    @if (isOpen)
                    {
                        @if (canDoConfirm)
                        {
                            <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Reference" value="@reference" />
                                <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Confirm)" />
                                <input type="hidden" name="SourceView" value="Detail" />
                                <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                @foreach (var selectedReference in selectedReferences)
                                {
                                    <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                                }
                                <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowConfirm"]</button>
                            </form>
                        }
                        @if (canDoDiscard)
                        {
                            <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Reference" value="@reference" />
                                <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Discard)" />
                                <input type="hidden" name="SourceView" value="Detail" />
                                <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                @foreach (var selectedReference in selectedReferences)
                                {
                                    <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                                }
                                <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">Reddet</button>
                            </form>
                        }
                    }

                    @if (isConfirmed)
                    {
                        @if (canDoUndoConfirm)
                        {
                            <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Reference" value="@reference" />
                                <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.UndoConfirm)" />
                                <input type="hidden" name="SourceView" value="Detail" />
                                <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                @foreach (var selectedReference in selectedReferences)
                                {
                                    <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                                }
                                <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowUndoConfirm"]</button>
                            </form>
                        }
                    }

                    @if (isIssued)
                    {
                        @if (canDoKill)
                        {
                            <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Reference" value="@reference" />
                                <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Kill)" />
                                <input type="hidden" name="SourceView" value="Detail" />
                                <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                @foreach (var selectedReference in selectedReferences)
                                {
                                    <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                                }
                                <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowKill"]</button>
                            </form>
                        }
                    }

                    @if (isIssued || isKilled || isDiscarded)
                    {
                        @if (canDoEvaluate)
                        {
                            <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Reference" value="@reference" />
                                <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Evaluate)" />
                                <input type="hidden" name="SourceView" value="Detail" />
                                <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                @foreach (var selectedReference in selectedReferences)
                                {
                                    <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                                }
                                <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowEvaluate"]</button>
                            </form>
                        }
                        @if (canDoUndoEvaluate)
                        {
                            <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Reference" value="@reference" />
                                <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.UndoEvaluate)" />
                                <input type="hidden" name="SourceView" value="Detail" />
                                <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                                <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                                @foreach (var selectedReference in selectedReferences)
                                {
                                    <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                                }
                                <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowUndoEvaluate"]</button>
                            </form>
                        }
                    }

                    @if (canPrintInvoice)
                    {
                        <a href="/Invoice/Print?reference=@reference"
                           target="_blank"
                           rel="noopener noreferrer"
                           class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">
                            Fatura Bas
                        </a>
                    }

                    <a href="/Invoice/History?reference=@invoice.Reference&returnUrl=@WebUtility.UrlEncode(currentUrl)" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                        @Localizer["ViewHistory"]
                    </a>
                </div>

                @if (canDoIssue)
                {
                    <div class="flex flex-wrap justify-center gap-2 w-full">
                        <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex items-center gap-2 flex-wrap justify-center">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Reference" value="@reference" />
                            <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Issue)" />
                            <input type="hidden" name="SourceView" value="Detail" />
                            <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                            @foreach (var selectedReference in selectedReferences)
                            {
                                <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                            }
                            <label for="invoice-issue-date-detail" class="text-sm font-medium text-blue-900">@Localizer["InvoiceIssueDate"]</label>
                            <input id="invoice-issue-date-detail"
                                   type="date"
                                   name="IssueDate"
                                   value="@issueDateValue"
                                   required
                                   class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm rounded-md text-gray-900 bg-white" />
                            <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowIssue"]</button>
                        </form>
                    </div>
                }
            </div>
            <partial name="_CustomerSelectModal" />
        </div>
    }
</div>

@section Scripts {
    <script>
        function invoiceDetailEdit(initialState) {
            if (typeof initialState === 'string') {
                try {
                    initialState = JSON.parse(initialState);
                } catch (error) {
                    initialState = {};
                }
            }
            initialState = initialState || {};

            return {
                isEditing: false,
                invoiceCustomerCode: initialState?.invoiceCustomerCode || '',
                invoiceCustomerName: initialState?.invoiceCustomerName || '',
                invoiceCustomerDisplay: initialState?.invoiceCustomerDisplay || '',
                jobCustomerCode: initialState?.jobCustomerCode || '',
                jobCustomerName: initialState?.jobCustomerName || '',
                jobCustomerDisplay: initialState?.jobCustomerDisplay || '',
                defaultVatRate: initialState?.defaultVatRate || 20,
                nextFreeLineKey: 1,
                newFreeLines: [],
                deleteLineId: '',
                enableEdit() {
                    this.isEditing = true;
                    this.$nextTick(() => {
                        this.updateLineTotals();
                        this.updateCategoryTotals();
                        this.updateTaxTotals();
                    });
                },
                cancelEdit() {
                    if (this.$refs.editForm) {
                        this.$refs.editForm.reset();
                    }
                    this.newFreeLines = [];
                    this.isEditing = false;
                    this.$nextTick(() => {
                        this.updateLineTotals();
                        this.updateCategoryTotals();
                        this.updateTaxTotals();
                    });
                },
                handleCustomerSelection(detail) {
                    if (detail.targetId === 'invoiceDetail') {
                        this.invoiceCustomerCode = detail.customer.code || '';
                        this.invoiceCustomerName = detail.customer.name || '';
                        this.invoiceCustomerDisplay = this.invoiceCustomerCode
                            ? this.invoiceCustomerCode + ' - ' + this.invoiceCustomerName
                            : this.invoiceCustomerName;
                    }
                },
                addFreeLine() {
                    this.newFreeLines.push({
                        key: this.nextFreeLineKey++,
                        description: '',
                        amount: 0,
                        vatRate: this.defaultVatRate
                    });
                    this.$nextTick(() => this.updateLineTotals());
                },
                removeFreeLine(index) {
                    this.newFreeLines.splice(index, 1);
                    this.$nextTick(() => this.updateLineTotals());
                },
                populateDynamicInputs(container, name, values) {
                    if (!container) {
                        return;
                    }
                    container.innerHTML = '';
                    values.forEach((value, index) => {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = name + '[' + index + ']';
                        input.value = value;
                        container.appendChild(input);
                    });
                },
                submitDeleteJobs(lineId) {
                    const selector = '[data-invoice-job-checkbox][data-line-id="' + lineId + '"]:checked';
                    const selected = Array.from(document.querySelectorAll(selector)).map(input => input.value);
                    if (selected.length === 0) {
                        window.alert('Silmek için en az bir iş seçin.');
                        return;
                    }
                    this.deleteLineId = lineId;
                    this.populateDynamicInputs(this.$refs.deleteJobsContainer, 'JobReferences', selected);
                    this.$nextTick(() => this.$refs.deleteJobsFromLineForm?.submit());
                },
                submitDeleteJobLines() {
                    const selected = Array.from(document.querySelectorAll('[data-invoice-line-checkbox]:checked')).map(input => input.value);
                    if (selected.length === 0) {
                        window.alert('Silmek için en az bir iş satırı seçin.');
                        return;
                    }
                    this.populateDynamicInputs(this.$refs.deleteJobLinesContainer, 'LineIds', selected);
                    this.$nextTick(() => this.$refs.deleteJobLinesForm?.submit());
                },
                viewSelectedJob(defaultReference) {
                    const selected = document.querySelector('[data-invoice-job-checkbox]:checked');
                    const reference = selected?.value || defaultReference;
                    if (!reference) {
                        return;
                    }
                    const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                    window.location.href = '/Job/Detail?id=' + encodeURIComponent(reference) + '&returnUrl=' + returnUrl;
                },
                parseDecimal(value) {
                    let text = String(value || '').trim().replace(/\s/g, '');
                    if (!text) return 0;
                    const hasComma = text.includes(',');
                    const hasDot = text.includes('.');
                    if (hasComma && hasDot) {
                        text = text.lastIndexOf(',') > text.lastIndexOf('.')
                            ? text.replace(/\./g, '').replace(',', '.')
                            : text.replace(/,/g, '');
                    } else if (hasComma) {
                        text = text.replace(',', '.');
                    }
                    const parsed = Number.parseFloat(text);
                    return Number.isFinite(parsed) ? parsed : 0;
                },
                formatMoney(value) {
                    return new Intl.NumberFormat(document.documentElement.lang || 'tr-TR', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    }).format(value || 0);
                },
                updateCategoryTotals() {
                    document.querySelectorAll('[data-line-category-net-total]').forEach((cell) => {
                        const lineId = cell.dataset.lineCategoryNetTotal;
                        let total = 0;
                        document.querySelectorAll(`[data-invoice-category-net][data-line-category-net="${lineId}"]`).forEach((input) => {
                            total += this.parseDecimal(input.value);
                        });
                        cell.textContent = this.formatMoney(total);
                    });
                },
                updateLineTotals() {
                    let total = 0;
                    document.querySelectorAll('[data-invoice-line-static-amount]').forEach((cell) => {
                        total += this.parseDecimal(cell.dataset.invoiceLineStaticAmount);
                    });
                    document.querySelectorAll('[data-invoice-line-amount]').forEach((input) => {
                        total += this.parseDecimal(input.value);
                    });
                    this.newFreeLines.forEach((line) => {
                        total += this.parseDecimal(line.amount);
                    });
                    document.querySelectorAll('[data-invoice-line-total]').forEach((cell) => {
                        cell.textContent = this.formatMoney(total);
                    });
                },
                updateTaxTotals() {
                    let taxTotal = 0;
                    let netTotal = 0;
                    document.querySelectorAll('[data-invoice-tax-rate]').forEach((input) => {
                        const subTotal = this.parseDecimal(input.dataset.invoiceTaxSubtotal);
                        const rate = this.parseDecimal(input.value);
                        const taxAmount = Math.round((subTotal * rate / 100) * 100) / 100;
                        const netAmount = Math.round((subTotal + taxAmount) * 100) / 100;
                        taxTotal += taxAmount;
                        netTotal += netAmount;

                        const taxTarget = document.getElementById(input.dataset.invoiceTaxAmountTarget);
                        const netTarget = document.getElementById(input.dataset.invoiceTaxNetTarget);
                        if (taxTarget) taxTarget.textContent = this.formatMoney(taxAmount);
                        if (netTarget) netTarget.textContent = this.formatMoney(netAmount);
                    });
                    document.querySelectorAll('[data-invoice-tax-amount-total]').forEach((cell) => {
                        cell.textContent = this.formatMoney(taxTotal);
                    });
                    document.querySelectorAll('[data-invoice-tax-net-total]').forEach((cell) => {
                        cell.textContent = this.formatMoney(netTotal);
                    });
                }
            };
        }
    </script>
}
