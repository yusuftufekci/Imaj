@using System.Text.Json
@using Microsoft.Extensions.Localization
@using Imaj.Web
@using Imaj.Service.DTOs
@inject IStringLocalizer<SharedResource> Localizer
@model InvoiceCreateViewModel

@{
    ViewData["Title"] = Localizer["Invoice"];
    var taxTypes = ViewBag.TaxTypes as List<TaxTypeListItemDto> ?? new List<TaxTypeListItemDto>();
    var defaultTaxType = taxTypes.FirstOrDefault(x => x.TaxPercentage == 18) ?? taxTypes.FirstOrDefault();
    var defaultVatRate = defaultTaxType?.TaxPercentage ?? 18;
    var initialStateJson = JsonSerializer.Serialize(new
    {
        invoiceCustomerCode = Model.InvoiceCustomerCode ?? string.Empty,
        invoiceCustomerName = Model.InvoiceCustomerName ?? string.Empty,
        invoiceCustomerDisplay = string.IsNullOrWhiteSpace(Model.InvoiceCustomerCode)
            ? string.Empty
            : string.Concat(Model.InvoiceCustomerCode, " - ", Model.InvoiceCustomerName ?? string.Empty),
        lines = Model.Lines.Select(line => new
        {
            description = line.Description ?? string.Empty,
            quantity = 1,
            price = line.Amount,
            taxTypeId = line.TaxTypeId,
            vatRate = line.VatRate == 0 ? defaultVatRate : line.VatRate
        }).ToList(),
        defaultVatRate,
        taxTypes = taxTypes.Select(taxType => new
        {
            id = taxType.Id,
            code = taxType.Code ?? string.Empty,
            name = string.IsNullOrWhiteSpace(taxType.Name) ? taxType.Code : taxType.Name,
            rate = taxType.TaxPercentage
        }).ToList(),
        labels = new
        {
            selectLineToDelete = "Silmek için en az bir serbest satır seçin."
        }
    });
}

<div x-data='invoiceCreate(@Html.Raw(initialStateJson))'
     @@customer-selected.window="handleCustomerSelection($event.detail)"
     class="invoice-page-shell invoice-form-page invoice-legacy-detail page-shell--wide space-y-3">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-md bg-red-50 p-4 border border-red-200">
            <p class="text-sm font-medium text-red-800">@TempData["ErrorMessage"]</p>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="rounded-md bg-red-50 p-4 border border-red-200">
            <h3 class="text-sm font-medium text-red-800">@Localizer["PleaseCheckFormFields"]</h3>
            <div class="mt-2 text-sm text-red-700" asp-validation-summary="All"></div>
        </div>
    }

    <div class="text-center">
        <h2 class="invoice-page-title invoice-page-title--orange">@Localizer["Invoice"]</h2>
    </div>

    <form method="post" action="/Invoice/Save" class="space-y-3 mobile-stack-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Reference" value="@Model.Reference">
        <input type="hidden" name="JobCustomerCode" value="@Model.JobCustomerCode">
        <input type="hidden" name="JobCustomerName" value="@Model.JobCustomerName">
        <input type="hidden" name="IssueDate" value="@Model.IssueDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)">

        <div class="invoice-detail-grid">
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
                </div>
                <div class="dense-panel__body">
                    <dl class="invoice-detail-list">
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["Reference"]</dt>
                            <dd class="invoice-detail-item__value">@Model.Reference</dd>
                        </div>
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["JobCustomer"]</dt>
                            <dd class="invoice-detail-item__value">@Model.JobCustomerCode - @Model.JobCustomerName</dd>
                        </div>
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["InvoiceCustomer"]</dt>
                            <dd class="invoice-detail-item__value">
                                <span class="job-detail-edit-selector">
                                    <span class="job-detail-edit-selector__value" x-text="invoiceCustomerDisplay || '-'"></span>
                                    <input type="hidden" name="InvoiceCustomerCode" x-model="invoiceCustomerCode">
                                    <input type="hidden" name="InvoiceCustomerName" x-model="invoiceCustomerName">
                                    <button type="button"
                                            @@click="$dispatch('customer-select-open', { targetId: 'invoice' })"
                                            class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                        @Localizer["Select"]
                                    </button>
                                </span>
                            </dd>
                        </div>
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["Name"]</dt>
                            <dd class="invoice-detail-item__value">
                                <input type="text" name="Ad" value="@Model.Ad" maxlength="32" class="dense-input invoice-detail-edit-input">
                            </dd>
                        </div>
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["Related"]</dt>
                            <dd class="invoice-detail-item__value">
                                <input type="text" name="RelatedPerson" value="@Model.RelatedPerson" maxlength="32" class="dense-input invoice-detail-edit-input">
                            </dd>
                        </div>
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["Date"]</dt>
                            <dd class="invoice-detail-item__value">@Model.IssueDate.ToString("dd.MM.yyyy")</dd>
                        </div>
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["Status"]</dt>
                            <dd class="invoice-detail-item__value">@Localizer["OpenStatus"]</dd>
                        </div>
                        <div class="invoice-detail-item">
                            <dt class="invoice-detail-item__label">@Localizer["Evaluated"]</dt>
                            <dd class="invoice-detail-item__value">
                                <input type="checkbox" name="IsEvaluated" @(Model.IsEvaluated ? "checked" : "") class="dense-checkbox text-indigo-600 border-gray-300 rounded">
                            </dd>
                        </div>
                    </dl>
                </div>
            </section>

            <div class="invoice-note-stack">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["Notes"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <textarea name="Notes" rows="4" class="dense-input">@Model.Notes</textarea>
                    </div>
                </section>

                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["Footnote"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <textarea name="Footnote" rows="4" class="dense-input">@Model.Footnote</textarea>
                    </div>
                </section>
            </div>
        </div>

        <section class="invoice-table-card">
            <div class="invoice-table-card__header">
                <h3 class="invoice-table-card__title">@Localizer["Line"] (<span x-text="lines.length"></span>)</h3>
            </div>
            <div class="invoice-table-wrap" x-show="lines.length > 0" x-cloak>
                <table class="invoice-table invoice-table--compact">
                    <thead>
                        <tr>
                            <th scope="col" class="w-20">@Localizer["Selected"]</th>
                            <th scope="col" class="w-20">@Localizer["Sequence"]</th>
                            <th scope="col">@Localizer["Notes"]</th>
                            <th scope="col" class="text-right w-28">@Localizer["Quantity"]</th>
                            <th scope="col" class="text-right w-36">@Localizer["Price"]</th>
                            <th scope="col" class="text-right w-36">@Localizer["Amount"]</th>
                            <th scope="col" class="w-40">@Localizer["TaxType"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(line, index) in lines" :key="line.key">
                            <tr>
                                <td class="text-center">
                                    <input type="checkbox" x-model="line.selected">
                                </td>
                                <td>
                                    <input type="text" x-model="line.sequence" class="dense-input invoice-create-sequence-input">
                                </td>
                                <td>
                                    <textarea x-model="line.description"
                                              :name="'Lines[' + index + '].Description'"
                                              rows="2"
                                              class="dense-input invoice-create-line-notes"></textarea>
                                    <input type="hidden" :name="'Lines[' + index + '].Amount'" :value="formatDecimalForPost(lineAmount(line))">
                                    <input type="hidden" :name="'Lines[' + index + '].TaxTypeId'" :value="line.taxTypeId || ''">
                                    <input type="hidden" :name="'Lines[' + index + '].VatRate'" :value="line.vatRate">
                                </td>
                                <td>
                                    <input type="text"
                                           inputmode="decimal"
                                           x-model="line.quantity"
                                           @@input="clearCalculatedTaxes()"
                                           class="dense-input text-right invoice-create-quantity-input">
                                </td>
                                <td>
                                    <input type="text"
                                           inputmode="decimal"
                                           x-model="line.price"
                                           @@input="clearCalculatedTaxes()"
                                           class="dense-input text-right invoice-create-money-input">
                                </td>
                                <td class="text-right text-sm font-medium text-gray-900">
                                    <span x-text="formatMoney(lineAmount(line))"></span>
                                </td>
                                <td>
                                    <span x-text="taxTypeLabelForLine(line)"></span>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
            <div class="invoice-footer-bar invoice-footer-bar--inline-actions">
                <button type="button" x-show="lines.length > 0" x-cloak @@click="removeSelectedLines()" class="text-red-600 hover:text-red-900 font-bold underline text-sm">
                    Serbest Satır Sil
                </button>
                <button type="submit"
                        formaction="/Invoice/FreeLineTaxTypes"
                        formmethod="post"
                        class="text-indigo-600 hover:text-indigo-900 font-bold underline text-sm">
                    @Localizer["AddFreeLine"]
                </button>
            </div>
        </section>

        <section class="invoice-table-card invoice-create-tax-card">
            <div class="invoice-table-card__header">
                <h3 class="invoice-table-card__title">@Localizer["Taxes"] (<span x-text="taxes.length"></span>)</h3>
            </div>
            <div class="invoice-table-wrap">
                <table class="invoice-table invoice-table--compact">
                    <thead x-show="taxes.length > 0" x-cloak>
                        <tr>
                            <th scope="col">@Localizer["Code"]</th>
                            <th scope="col">@Localizer["Name"]</th>
                            <th scope="col" class="text-right">@Localizer["SubTotal"]</th>
                            <th scope="col" class="text-right">@Localizer["Percentage"]</th>
                            <th scope="col" class="text-right">@Localizer["TaxAmount"]</th>
                            <th scope="col" class="text-right">@Localizer["NetAmount"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="tax in taxes" :key="tax.id || tax.rate">
                            <tr>
                                <td x-text="tax.code"></td>
                                <td x-text="tax.name"></td>
                                <td class="text-right" x-text="formatMoney(tax.subTotal)"></td>
                                <td class="text-right" x-text="formatRate(tax.rate)"></td>
                                <td class="text-right" x-text="formatMoney(tax.taxAmount)"></td>
                                <td class="text-right" x-text="formatMoney(tax.netTotal)"></td>
                            </tr>
                        </template>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="2" class="text-right font-bold">@Localizer["Total"]</td>
                            <td class="text-right font-bold" x-text="formatMoney(taxSubTotal)"></td>
                            <td></td>
                            <td class="text-right font-bold" x-text="formatMoney(taxTotal)"></td>
                            <td class="text-right font-bold" x-text="formatMoney(taxNetTotal)"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>

        <div class="invoice-footer-bar invoice-footer-bar--center responsive-action-group">
            <div class="flex flex-wrap justify-center gap-1">
                <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-600 shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                    @Localizer["Save"]
                </button>
                <button type="button" onclick="history.back()" class="inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-white bg-red-400 hover:bg-red-500 focus:outline-none">
                    @Localizer["Cancel"]
                </button>
            </div>
            <div class="flex flex-wrap justify-center gap-1">
                <button type="button" @@click="showSummary()" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">
                    @Localizer["ViewSummary"]
                </button>
                <button type="button" @@click="calculateTaxes()" class="inline-flex items-center px-4 py-2 border border-slate-400 text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                    @Localizer["Calculate"]
                </button>
            </div>
        </div>
    </form>

    <partial name="_CustomerSelectModal" />
</div>

<script>
    function invoiceCreate(initialState) {
        return {
            invoiceCustomerCode: initialState?.invoiceCustomerCode || '',
            invoiceCustomerName: initialState?.invoiceCustomerName || '',
            invoiceCustomerDisplay: initialState?.invoiceCustomerDisplay || '',
            defaultVatRate: parseFloat(initialState?.defaultVatRate) || 18,
            taxTypes: Array.isArray(initialState?.taxTypes) ? initialState.taxTypes.map(taxType => ({
                id: parseFloat(taxType.id) || 0,
                code: taxType.code || '',
                name: taxType.name || taxType.code || '',
                rate: parseFloat(taxType.rate) || 0
            })).filter(taxType => taxType.rate >= 0) : [],
            lines: [],
            taxes: [],
            nextLineKey: 1,
            labels: initialState?.labels || {},

            init() {
                if (this.taxTypes.length === 0) {
                    this.taxTypes.push({
                        id: 0,
                        code: 'KDV' + this.defaultVatRate,
                        name: 'KDV %' + this.defaultVatRate,
                        rate: this.defaultVatRate
                    });
                }

                const initialLines = Array.isArray(initialState?.lines) ? initialState.lines : [];
                this.lines = initialLines.map((line, index) => ({
                    key: this.nextLineKey++,
                    selected: false,
                    sequence: index === 0 ? '0' : String(index),
                    description: line.description || '',
                    quantity: String(line.quantity || 1),
                    price: String(line.price ?? line.amount ?? 0).replace('.', ','),
                    taxTypeId: parseFloat(line.taxTypeId) || null,
                    vatRate: parseFloat(line.vatRate) || this.defaultVatRate
                }));
            },

            handleCustomerSelection(detail) {
                if (detail.targetId === 'invoice') {
                    this.invoiceCustomerCode = detail.customer?.code || '';
                    this.invoiceCustomerName = detail.customer?.name || '';
                    this.invoiceCustomerDisplay = this.invoiceCustomerCode
                        ? this.invoiceCustomerCode + ' - ' + this.invoiceCustomerName
                        : this.invoiceCustomerName;
                }
            },

            addLine() {
                this.lines.push({
                    key: this.nextLineKey++,
                    selected: false,
                    sequence: '0',
                    description: '',
                    quantity: '1',
                    price: '0',
                    taxTypeId: null,
                    vatRate: this.defaultVatRate
                });
                this.clearCalculatedTaxes();
            },

            removeSelectedLines() {
                if (!this.lines.some(line => line.selected)) {
                    window.alert(this.labels.selectLineToDelete || 'Silmek için satır seçin.');
                    return;
                }

                this.lines = this.lines.filter(line => !line.selected);
                this.clearCalculatedTaxes();
            },

            clearCalculatedTaxes() {
                this.taxes = [];
            },

            showSummary() {
                this.calculateTaxes();
            },

            calculateTaxes() {
                const groups = new Map();
                this.lines.forEach((line) => {
                    const amount = this.lineAmount(line);
                    if (amount <= 0) {
                        return;
                    }

                    const rate = parseFloat(line.vatRate) || 0;
                    const taxType = this.taxTypeForLine(line) || { id: 0, code: 'KDV' + rate, name: 'KDV %' + rate, rate };
                    const key = taxType.id > 0 ? 'id:' + taxType.id : 'rate:' + rate;
                    const current = groups.get(key) || { taxType, subTotal: 0 };
                    current.subTotal += amount;
                    groups.set(key, current);
                });

                this.taxes = Array.from(groups.values())
                    .sort((a, b) => Number(a.taxType.rate) - Number(b.taxType.rate) || String(a.taxType.code).localeCompare(String(b.taxType.code)))
                    .map(({ taxType, subTotal }) => {
                        const rate = parseFloat(taxType.rate) || 0;
                        const roundedSubTotal = this.roundMoney(subTotal);
                        const taxAmount = this.roundMoney(roundedSubTotal * rate / 100);
                        return {
                            id: taxType.id || 0,
                            rate,
                            code: taxType?.code || ('KDV' + rate),
                            name: taxType?.name || ('KDV %' + rate),
                            subTotal: roundedSubTotal,
                            taxAmount,
                            netTotal: this.roundMoney(roundedSubTotal + taxAmount)
                        };
                    });
            },

            parseDecimal(value) {
                let text = String(value || '').trim().replace(/\s/g, '');
                if (!text) return 0;
                const hasComma = text.includes(',');
                const hasDot = text.includes('.');
                if (hasComma && hasDot) {
                    text = text.lastIndexOf(',') > text.lastIndexOf('.')
                        ? text.replace(/\./g, '').replace(',', '.')
                        : text.replace(/,/g, '');
                } else if (hasComma) {
                    text = text.replace(',', '.');
                }
                const parsed = Number.parseFloat(text);
                return Number.isFinite(parsed) ? parsed : 0;
            },

            lineAmount(line) {
                return this.roundMoney(this.parseDecimal(line.quantity) * this.parseDecimal(line.price));
            },

            roundMoney(value) {
                return Math.round((Number(value) || 0) * 100) / 100;
            },

            findTaxType(rate) {
                return this.taxTypes.find(taxType => Number(taxType.rate) === Number(rate));
            },

            findTaxTypeById(id) {
                return this.taxTypes.find(taxType => Number(taxType.id) === Number(id));
            },

            taxTypeForLine(line) {
                return this.findTaxTypeById(line.taxTypeId) || this.findTaxType(line.vatRate);
            },

            taxTypeLabel(taxType) {
                if (!taxType) {
                    return '';
                }
                return taxType.code || taxType.name || ('KDV' + taxType.rate);
            },

            taxTypeLabelForRate(rate) {
                return this.taxTypeLabel(this.findTaxType(rate));
            },

            taxTypeLabelForLine(line) {
                return this.taxTypeLabel(this.taxTypeForLine(line));
            },

            get totalAmount() {
                return this.roundMoney(this.lines.reduce((sum, line) => sum + this.lineAmount(line), 0));
            },

            get taxSubTotal() {
                return this.roundMoney(this.taxes.reduce((sum, tax) => sum + tax.subTotal, 0));
            },

            get taxTotal() {
                return this.roundMoney(this.taxes.reduce((sum, tax) => sum + tax.taxAmount, 0));
            },

            get taxNetTotal() {
                if (this.taxes.length === 0) {
                    return 0;
                }
                return this.roundMoney(this.taxes.reduce((sum, tax) => sum + tax.netTotal, 0));
            },

            formatMoney(value) {
                return new Intl.NumberFormat(document.documentElement.lang || 'tr-TR', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                }).format(value || 0);
            },

            formatRate(value) {
                return new Intl.NumberFormat(document.documentElement.lang || 'tr-TR', {
                    maximumFractionDigits: 0
                }).format(value || 0);
            },

            formatDecimalForPost(value) {
                return this.roundMoney(value).toFixed(2);
            }
        };
    }
</script>
