@using System.Text.Json
@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model InvoiceCreateViewModel

@{
    ViewData["Title"] = Localizer["Invoice"];
    var initialStateJson = JsonSerializer.Serialize(new
    {
        invoiceCustomerCode = Model.InvoiceCustomerCode ?? string.Empty,
        invoiceCustomerName = Model.InvoiceCustomerName ?? string.Empty,
        invoiceCustomerDisplay = string.IsNullOrWhiteSpace(Model.InvoiceCustomerCode)
            ? string.Empty
            : string.Concat(Model.InvoiceCustomerCode, " - ", Model.InvoiceCustomerName ?? string.Empty),
        jobCustomerCode = Model.JobCustomerCode ?? string.Empty,
        lines = Model.Lines.Select(line => new
        {
            description = line.Description ?? string.Empty,
            amount = line.Amount,
            vatRate = line.VatRate
        }).ToList(),
        jobs = Model.Jobs.Select(job => new
        {
            reference = job.Reference,
            name = job.Name ?? string.Empty,
            productAmount = job.ProductAmount,
            workAmount = job.WorkAmount
        }).ToList(),
        labels = new
        {
            loadError = Localizer["GenericError"].Value
        }
    });
}

<div x-data='invoiceCreate(@Html.Raw(initialStateJson))'
     @@customer-selected.window="handleCustomerSelection($event.detail)"
     class="invoice-page-shell invoice-form-page page-shell--wide space-y-3">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-md bg-red-50 p-4 border border-red-200">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-red-800">@TempData["ErrorMessage"]</p>
                </div>
            </div>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="rounded-md bg-red-50 p-4 border border-red-200">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">@Localizer["PleaseCheckFormFields"]</h3>
                    <div class="mt-2 text-sm text-red-700">
                        <div asp-validation-summary="All" class="list-disc pl-5"></div>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="text-center">
        <h2 class="invoice-page-title invoice-page-title--orange">
            @Localizer["InvoiceCreation"]
        </h2>
    </div>

    <form method="post" action="/Invoice/Save" class="space-y-3 mobile-stack-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Reference" value="@Model.Reference">
        <input type="hidden" name="JobCustomerCode" value="@Model.JobCustomerCode">
        <input type="hidden" name="JobCustomerName" value="@Model.JobCustomerName">
        <input type="hidden" name="IssueDate" value="@Model.IssueDate.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)">

        <div class="invoice-form-layout">
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
                </div>
                <div class="dense-panel__body">
                    <div class="dense-form-grid">
                        <div class="dense-form-row">
                            <label>@Localizer["Reference"]</label>
                            <div class="invoice-detail-item__value font-semibold">@Model.Reference</div>
                        </div>
                        <div class="dense-form-row">
                            <label>@Localizer["JobCustomer"]</label>
                            <div class="invoice-detail-item__value">@Model.JobCustomerCode - @Model.JobCustomerName</div>
                        </div>
                        <div class="dense-form-row">
                            <label>@Localizer["InvoiceCustomer"]</label>
                            <div class="picker-inline flex items-center gap-2">
                                <input type="text"
                                       readonly
                                       x-model="invoiceCustomerDisplay"
                                       class="dense-input bg-gray-50"
                                       placeholder="@Localizer["SelectPrompt"]">
                                <input type="hidden" name="InvoiceCustomerCode" x-model="invoiceCustomerCode">
                                <input type="hidden" name="InvoiceCustomerName" x-model="invoiceCustomerName">
                                <button type="button"
                                        @@click="$dispatch('customer-select-open', { targetId: 'invoice' })"
                                        class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                                    @Localizer["Select"]
                                </button>
                            </div>
                        </div>
                        <div class="dense-form-row">
                            <label for="InvoiceCreateName">@Localizer["Name"]</label>
                            <input id="InvoiceCreateName"
                                   type="text"
                                   name="Ad"
                                   value="@Model.Ad"
                                   class="dense-input">
                        </div>
                        <div class="dense-form-row">
                            <label for="InvoiceCreateRelated">@Localizer["Related"]</label>
                            <input id="InvoiceCreateRelated"
                                   type="text"
                                   name="RelatedPerson"
                                   value="@Model.RelatedPerson"
                                   class="dense-input">
                        </div>
                        <div class="dense-form-row">
                            <label>@Localizer["Date"]</label>
                            <div class="invoice-detail-item__value font-medium">@Model.IssueDate.ToString("dd.MM.yyyy")</div>
                        </div>
                        <div class="dense-form-row">
                            <label>@Localizer["Status"]</label>
                            <div class="invoice-detail-item__value font-medium">@Localizer["OpenStatus"]</div>
                        </div>
                        <div class="dense-form-row">
                            <label>@Localizer["Evaluated"]</label>
                            <div class="invoice-detail-item__value">
                                <input type="checkbox"
                                       name="IsEvaluated"
                                       class="dense-checkbox text-indigo-600 border-gray-300 rounded"
                                       @(Model.IsEvaluated ? "checked" : "")>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <div class="invoice-note-stack">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["Notes"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <textarea name="Notes" rows="4" class="dense-input">@Model.Notes</textarea>
                    </div>
                </section>

                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["Notes"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <textarea name="Footnote" rows="4" class="dense-input">@Model.Footnote</textarea>
                    </div>
                </section>
            </div>
        </div>

        <section class="invoice-table-card">
            <div class="invoice-table-card__header">
                <h3 class="invoice-table-card__title">
                    @Localizer["PricedJobs"] (<span x-text="jobs.length"></span>)
                </h3>
            </div>
            <div class="invoice-footer-bar">
                <div class="flex items-center gap-2 w-full md:w-auto">
                    <input type="text"
                           x-model="jobSearch"
                           @@keydown.enter.prevent="fetchPricedJobs()"
                           class="dense-input"
                           placeholder="@($"{Localizer["Reference"].Value} / {Localizer["Name"].Value}")">
                    <button type="button"
                            @@click="fetchPricedJobs()"
                            class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                        @Localizer["Search"]
                    </button>
                </div>
                <div class="flex items-center gap-2 font-bold text-gray-900">
                    <span>@Localizer["ProductAmount"]</span>
                    <span x-text="formatMoney(selectedJobProductTotal)"></span>
                </div>
            </div>
            <div class="px-4 pb-2 text-sm text-red-700" x-show="jobLoadError" x-cloak x-text="jobLoadError"></div>
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-3 p-3">
                <div class="invoice-table-wrap">
                    <table class="invoice-table invoice-table--compact">
                        <thead>
                            <tr>
                                <th scope="col">@Localizer["Reference"]</th>
                                <th scope="col">@Localizer["Name"]</th>
                                <th scope="col" class="text-right">@Localizer["ProductAmount"]</th>
                                <th scope="col" class="text-right">@Localizer["WorkAmount"]</th>
                                <th scope="col" class="w-20">
                                    <span class="sr-only">@Localizer["Add"]</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-if="isLoadingJobs">
                                <tr>
                                    <td colspan="5" class="px-4 py-3 text-center text-sm text-gray-500">@Localizer["Loading"]</td>
                                </tr>
                            </template>
                            <template x-if="!isLoadingJobs && availableJobsForDisplay.length === 0">
                                <tr>
                                    <td colspan="5" class="px-4 py-3 text-center text-sm text-gray-500">@Localizer["NoPricedJobsFound"]</td>
                                </tr>
                            </template>
                            <template x-for="job in availableJobsForDisplay" :key="job.reference">
                                <tr>
                                    <td class="text-sm font-medium text-gray-900" x-text="job.reference"></td>
                                    <td class="text-sm text-gray-900" x-text="job.name"></td>
                                    <td class="text-right text-sm text-gray-900" x-text="formatMoney(job.productAmount)"></td>
                                    <td class="text-right text-sm text-gray-900" x-text="formatMoney(job.workAmount)"></td>
                                    <td class="text-right">
                                        <button type="button"
                                                @@click="addJob(job)"
                                                class="text-indigo-600 hover:text-indigo-900 font-bold underline text-sm">
                                            @Localizer["Add"]
                                        </button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>

                <div class="invoice-table-wrap">
                    <table class="invoice-table invoice-table--compact">
                        <thead>
                            <tr>
                                <th scope="col">@Localizer["SelectedJobs"]</th>
                                <th scope="col">@Localizer["Name"]</th>
                                <th scope="col" class="text-right">@Localizer["ProductAmount"]</th>
                                <th scope="col" class="w-10">
                                    <span class="sr-only">@Localizer["Delete"]</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-if="jobs.length === 0">
                                <tr>
                                    <td colspan="4" class="px-4 py-3 text-center text-sm text-gray-500">@Localizer["NoRecordsFound"]</td>
                                </tr>
                            </template>
                            <template x-for="(job, index) in jobs" :key="job.reference">
                                <tr>
                                    <td class="text-sm font-medium text-gray-900">
                                        <span x-text="job.reference"></span>
                                        <input type="hidden" :name="'Jobs[' + index + '].Reference'" :value="job.reference">
                                        <input type="hidden" :name="'Jobs[' + index + '].Name'" :value="job.name">
                                        <input type="hidden" :name="'Jobs[' + index + '].ProductAmount'" :value="job.productAmount">
                                        <input type="hidden" :name="'Jobs[' + index + '].WorkAmount'" :value="job.workAmount">
                                    </td>
                                    <td class="text-sm text-gray-900" x-text="job.name"></td>
                                    <td class="text-right text-sm text-gray-900" x-text="formatMoney(job.productAmount)"></td>
                                    <td class="text-right">
                                        <button type="button" @@click="removeJob(index)" class="text-red-600 hover:text-red-900">
                                            <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                                <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 000-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                            </svg>
                                        </button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="invoice-table-card">
            <div class="invoice-table-card__header">
                <h3 class="invoice-table-card__title">
                    @Localizer["Line"] (<span x-text="lines.length"></span>)
                </h3>
            </div>
            <div class="invoice-footer-bar">
                <button type="button" @@click="addLine()" class="text-indigo-600 hover:text-indigo-900 font-bold underline text-sm">
                    @Localizer["AddFreeLine"]
                </button>
            </div>
            <div class="invoice-table-wrap">
                <table class="invoice-table invoice-table--compact">
                    <thead>
                        <tr>
                            <th scope="col">@Localizer["Description"]</th>
                            <th scope="col" class="text-right w-32">@Localizer["Amount"]</th>
                            <th scope="col" class="text-right w-24">@Localizer["TaxRate"]</th>
                            <th scope="col" class="text-right w-32">@Localizer["Total"]</th>
                            <th scope="col" class="w-10">
                                <span class="sr-only">@Localizer["Delete"]</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <template x-for="(line, index) in lines" :key="index">
                            <tr>
                                <td>
                                    <input type="text"
                                           x-model="line.description"
                                           :name="'Lines[' + index + '].Description'"
                                           class="dense-input">
                                </td>
                                <td>
                                    <input type="number"
                                           step="0.01"
                                           min="0"
                                           x-model.number="line.amount"
                                           :name="'Lines[' + index + '].Amount'"
                                           class="dense-input text-right">
                                </td>
                                <td>
                                    <input type="number"
                                           step="1"
                                           min="0"
                                           max="100"
                                           x-model.number="line.vatRate"
                                           :name="'Lines[' + index + '].VatRate'"
                                           class="dense-input text-right">
                                </td>
                                <td class="text-right text-sm font-medium text-gray-900">
                                    <span x-text="formatMoney(line.amount * (1 + line.vatRate / 100))"></span>
                                </td>
                                <td class="text-right text-sm font-medium">
                                    <button type="button" @@click="removeLine(index)" class="text-red-600 hover:text-red-900">
                                        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 000-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
                                        </svg>
                                    </button>
                                </td>
                            </tr>
                        </template>
                    </tbody>
                </table>
            </div>
            <div class="invoice-footer-bar">
                <div class="flex items-center gap-2 font-bold text-gray-900">
                    <span>@Localizer["Total"]</span>
                    <span x-text="formatMoney(totalAmount)"></span>
                </div>
                <div class="flex items-center gap-2 font-bold text-gray-900">
                    <span>@Localizer["Total"]</span>
                    <span x-text="formatMoney(grandTotal)"></span>
                </div>
            </div>
        </section>

        <div class="invoice-footer-bar invoice-footer-bar--center responsive-action-group">
            <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-600 shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                @Localizer["Save"]
            </button>
            <button type="button" onclick="history.back()" class="inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-white bg-red-400 hover:bg-red-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                @Localizer["Cancel"]
            </button>
        </div>
    </form>

    <partial name="_CustomerSelectModal" />
</div>

<script>
    function invoiceCreate(initialState) {
        return {
            invoiceCustomerCode: initialState?.invoiceCustomerCode || '',
            invoiceCustomerName: initialState?.invoiceCustomerName || '',
            invoiceCustomerDisplay: initialState?.invoiceCustomerDisplay || '',
            jobCustomerCode: initialState?.jobCustomerCode || '',
            lines: Array.isArray(initialState?.lines) ? initialState.lines : [],
            jobs: Array.isArray(initialState?.jobs) ? initialState.jobs.map(job => ({
                reference: parseInt(job.reference, 10) || 0,
                name: job.name || '',
                productAmount: parseFloat(job.productAmount) || 0,
                workAmount: parseFloat(job.workAmount) || 0
            })).filter(job => job.reference > 0) : [],
            availableJobs: [],
            jobSearch: '',
            isLoadingJobs: false,
            jobLoadError: '',
            labels: initialState?.labels || {},

            init() {
                if (this.lines.length === 0) {
                    this.addLine();
                }
                this.fetchPricedJobs();
            },

            handleCustomerSelection(detail) {
                if (detail.targetId === 'invoice') {
                    this.invoiceCustomerCode = detail.customer.code;
                    this.invoiceCustomerName = detail.customer.name;
                    this.invoiceCustomerDisplay = detail.customer.code + ' - ' + detail.customer.name;
                }
            },

            addLine() {
                this.lines.push({ description: '', amount: 0, vatRate: 20 });
            },

            removeLine(index) {
                this.lines.splice(index, 1);
            },

            async fetchPricedJobs() {
                this.isLoadingJobs = true;
                this.jobLoadError = '';
                const params = new URLSearchParams();
                if (this.jobCustomerCode) {
                    params.set('jobCustomerCode', this.jobCustomerCode);
                }
                if (this.jobSearch) {
                    params.set('search', this.jobSearch);
                }
                params.set('first', '100');

                try {
                    const response = await fetch('/Invoice/PricedJobs?' + params.toString(), {
                        headers: { 'Accept': 'application/json' }
                    });
                    if (!response.ok) {
                        throw new Error('job-load-failed');
                    }
                    const payload = await response.json();
                    this.availableJobs = Array.isArray(payload.items)
                        ? payload.items.map(job => ({
                            reference: parseInt(job.reference, 10) || 0,
                            name: job.name || '',
                            productAmount: parseFloat(job.productAmount) || 0,
                            workAmount: parseFloat(job.workAmount) || 0
                        })).filter(job => job.reference > 0)
                        : [];
                } catch (error) {
                    this.availableJobs = [];
                    this.jobLoadError = this.labels.loadError || 'Error';
                } finally {
                    this.isLoadingJobs = false;
                }
            },

            addJob(job) {
                if (!job || !job.reference || this.jobs.some(selected => selected.reference === job.reference)) {
                    return;
                }
                this.jobs.push({ ...job });
            },

            removeJob(index) {
                this.jobs.splice(index, 1);
            },

            get availableJobsForDisplay() {
                const selectedReferences = new Set(this.jobs.map(job => job.reference));
                return this.availableJobs.filter(job => !selectedReferences.has(job.reference));
            },

            get selectedJobProductTotal() {
                return this.jobs.reduce((sum, job) => sum + (parseFloat(job.productAmount) || 0), 0);
            },

            get totalAmount() {
                return this.selectedJobProductTotal + this.lines.reduce((sum, line) => sum + (parseFloat(line.amount) || 0), 0);
            },

            get grandTotal() {
                return this.selectedJobProductTotal + this.lines.reduce((sum, line) => {
                    const amount = parseFloat(line.amount) || 0;
                    const vatRate = parseFloat(line.vatRate) || 0;
                    return sum + amount + (amount * vatRate / 100);
                }, 0);
            },

            formatMoney(value) {
                return new Intl.NumberFormat('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(value || 0);
            }
        }
    }
</script>
