@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@using System.Text.Json
@inject IStringLocalizer<SharedResource> Localizer
@model InvoiceViewModel

@{
    ViewData["Title"] = Localizer["InvoiceSearch"];
    string JsonValue(string? value) => JsonSerializer.Serialize(value ?? string.Empty);
    var firstValue = Model.First.HasValue && Model.First.Value > 0
        ? Model.First.Value
        : 100;
    var pageSizeValue = Model.PageSize > 0 ? Model.PageSize : 16;
}

<div x-data="invoicePage()" @@customer-selected.window="handleSelection($event.detail)" class="invoice-page-shell invoice-index-shell invoice-index-reference page-shell--wide space-y-2">
    <div class="text-center job-index-heading">
        <h2 class="invoice-page-title invoice-page-title--orange">
            @Localizer["InvoiceSearch"]
        </h2>
    </div>

    <section class="dense-panel invoice-index-search-panel">
        <div class="dense-panel__header">
            <h3 class="dense-panel__title">@Localizer["MainCriteria"]</h3>
        </div>
        <div class="dense-panel__body mobile-stack-form">
            <div class="dense-form-grid invoice-index-criteria-list">
                <div class="dense-form-row">
                    <label>@Localizer["JobCustomer"]</label>
                    <div class="invoice-index-selector">
                        <span class="invoice-index-selector__value" x-text="jobCustomerName || '-'"></span>
                        <span class="invoice-index-selector__separator">-</span>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'job' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                            @Localizer["Select"]
                        </button>
                    </div>
                </div>
                <div class="dense-form-row">
                    <label>@Localizer["InvoiceCustomer"]</label>
                    <div class="invoice-index-selector">
                        <span class="invoice-index-selector__value" x-text="invoiceCustomerName || '-'"></span>
                        <span class="invoice-index-selector__separator">-</span>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'invoice' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                            @Localizer["Select"]
                        </button>
                    </div>
                </div>
                <div class="dense-form-row">
                    <label>@Localizer["ReferenceRange"]</label>
                    <div class="picker-inline picker-inline--range invoice-index-range">
                        <input type="text" x-model="filter.referenceStart" class="dense-input">
                        <input type="text" x-model="filter.referenceEnd" class="dense-input">
                    </div>
                </div>
                <div class="dense-form-row">
                    <label for="InvoiceName">@Localizer["Name"]</label>
                    <input id="InvoiceName" type="text" x-model="filter.name" class="dense-input">
                </div>
                <div class="dense-form-row">
                    <label for="InvoiceRelated">@Localizer["Related"]</label>
                    <input id="InvoiceRelated" type="text" x-model="filter.relatedPerson" class="dense-input">
                </div>
                <div class="dense-form-row">
                    <label>@Localizer["InvoiceIssueDate"]</label>
                    <div class="picker-inline picker-inline--range invoice-index-range">
                        <input type="date" x-model="filter.issueDateStart" class="dense-input">
                        <input type="date" x-model="filter.issueDateEnd" class="dense-input">
                    </div>
                </div>
                <div class="dense-form-row">
                    <label for="InvoiceStatus">@Localizer["Status"]</label>
                    <select id="InvoiceStatus" x-model="filter.status" class="dense-input">
                        <option value="">@Localizer["AllOption"]</option>
                        @{
                            var invoiceStates = ViewBag.InvoiceStates as List<Imaj.Service.DTOs.StateDto> ?? new List<Imaj.Service.DTOs.StateDto>();
                        }
                        @foreach (var state in invoiceStates)
                        {
                            @* state.Id decimal tipinde; InvariantCulture ile yazmazsak Türkçe kültürde "210,00" gibi render olur
                               ve controller'daki decimal.TryParse başarısız olur → durum filtresi çalışmaz *@
                            <option value="@state.Id.ToString(System.Globalization.CultureInfo.InvariantCulture)">@state.Name</option>
                        }
                    </select>
                </div>
                <div class="dense-form-row">
                    <label for="InvoiceEvaluated">@Localizer["Evaluated"]</label>
                    <select id="InvoiceEvaluated" x-model="filter.evaluated" class="dense-input">
                        <option value="">@Localizer["AllOption"]</option>
                        <option value="true">@Localizer["Yes"]</option>
                        <option value="false">@Localizer["No"]</option>
                    </select>
                </div>
            </div>
        </div>
    </section>

    <div class="dense-toolbar invoice-index-toolbar">
        <label class="dense-toolbar__label">@Localizer["First"]</label>
        <input type="number" x-model="filter.first" min="1" class="dense-input dense-toolbar__input">
        <label class="dense-toolbar__label">@Localizer["PageSize"]</label>
        <input type="number" x-model="filter.pageSize" min="1" class="dense-input dense-toolbar__input">
        <button type="button" @@click="searchInvoices()" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
            @Localizer["Search"]
        </button>
        <button type="button" @@click="resetFilters()" class="inline-flex items-center px-4 py-1 border border-gray-300 text-sm font-medium rounded shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
            @Localizer["Clear"]
        </button>
    </div>

    <div class="job-index-action-group invoice-index-report-group">
        <button type="button" @@click="openDetailedInvoiceReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
            @Localizer["DetailedInvoiceReport"]
        </button>
        <button type="button" @@click="openSummaryInvoiceReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
            @Localizer["SummaryInvoiceReport"]
        </button>
    </div>

    <div class="job-index-section job-index-section--narrow invoice-index-create-section">
        <h3 class="job-index-section__title">@Localizer["InvoiceCreation"]</h3>
        <section class="dense-panel job-index-create-panel invoice-index-create-panel">
            <div class="dense-panel__header">
                <h4 class="dense-panel__title">@Localizer["PreInformation"]</h4>
            </div>
            <div class="dense-panel__body job-index-create-panel__body">
                <div class="dense-form-row">
                    <label>@Localizer["JobCustomer"]</label>
                    <div class="invoice-index-selector">
                        <span class="invoice-index-selector__value" x-text="newJobCustomerName || '-'"></span>
                        <span class="invoice-index-selector__separator">-</span>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'newJob' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                            @Localizer["Select"]
                        </button>
                    </div>
                </div>
            </div>
        </section>
        <div class="job-index-create-cta">
            <button type="button" @@click="createInvoice()" class="inline-flex items-center justify-center px-5 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                @Localizer["CreateNewInvoice"]
            </button>
        </div>
    </div>

    <partial name="_CustomerSelectModal" />
</div>

<script>
    function invoicePage() {
        return {
            // Filter Models
            jobCustomerCode: @Html.Raw(JsonValue(Model.JobCustomerCode)),
            jobCustomerName: @Html.Raw(JsonValue(Model.JobCustomerName)),
            
            invoiceCustomerCode: @Html.Raw(JsonValue(Model.InvoiceCustomerCode)),
            invoiceCustomerName: @Html.Raw(JsonValue(Model.InvoiceCustomerName)),
            
            newJobCustomerCode: @Html.Raw(JsonValue(Model.NewJobCustomerCode)),
            newJobCustomerName: @Html.Raw(JsonValue(Model.NewJobCustomerName)),

            isReportLoading: false,

            filter: {
                 referenceStart: @Html.Raw(JsonValue(Model.ReferenceStart)), referenceEnd: @Html.Raw(JsonValue(Model.ReferenceEnd)),
                 name: @Html.Raw(JsonValue(Model.Name)), relatedPerson: @Html.Raw(JsonValue(Model.RelatedPerson)),
                 // IssueDateStart/End artık string tipinde; .ToString("yyyy-MM-dd") çağrısı gerekmiyor
                 issueDateStart: @Html.Raw(JsonValue(Model.IssueDateStart)), issueDateEnd: @Html.Raw(JsonValue(Model.IssueDateEnd)),
                 status: @Html.Raw(JsonValue(Model.Status)), evaluated: @Html.Raw(JsonValue(Model.Evaluated)),
                 first: @firstValue,
                 pageSize: @pageSizeValue
            },

            messages: {
                issueDateRangeInvalid: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["IssueDateRangeInvalid"].Value)),
                startEndDateRequired: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartEndDateRequired"].Value)),
                endDateBeforeStart: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateBeforeStart"].Value)),
                reportDataUnavailable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ReportDataUnavailable"].Value)),
                reportLoading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value)),
                reportLoadingDetail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PrintReportStarted"].Value)),
                pleaseSelectCustomer: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PleaseSelectCustomer"].Value))
            },

            handleSelection(detail) {
                const cust = detail.customer;
                const target = detail.targetId;
                
                if (target === 'job') {
                    this.jobCustomerName = cust.name;
                    this.jobCustomerCode = cust.code;
                } else if (target === 'invoice') {
                    this.invoiceCustomerName = cust.name;
                    this.invoiceCustomerCode = cust.code;
                } else if (target === 'newJob') {
                    this.newJobCustomerName = cust.name;
                    this.newJobCustomerCode = cust.code;
                }
            },

            showError(message) {
                if (window.Toast && typeof window.Toast.error === 'function') {
                    window.Toast.error(message);
                    return;
                }

                alert(message);
            },

            normalizeErrorMessage(rawMessage, fallback) {
                if (!rawMessage) {
                    return fallback;
                }

                const text = rawMessage.trim();
                if (!text || text.startsWith('<')) {
                    return fallback;
                }

                return text;
            },

            showLoading() {
                if (typeof Swal === 'undefined') {
                    return;
                }

                Swal.fire({
                    title: this.messages.reportLoading,
                    text: this.messages.reportLoadingDetail,
                    icon: 'info',
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
            },

            hideLoading() {
                if (typeof Swal !== 'undefined' && Swal.isVisible()) {
                    Swal.close();
                }
            },

            async searchInvoices() {
                const params = new URLSearchParams();

                if (this.jobCustomerCode) params.set('JobCustomerCode', this.jobCustomerCode);
                if (this.jobCustomerName) params.set('JobCustomerName', this.jobCustomerName);
                if (this.invoiceCustomerCode) params.set('InvoiceCustomerCode', this.invoiceCustomerCode);
                if (this.invoiceCustomerName) params.set('InvoiceCustomerName', this.invoiceCustomerName);
                if (this.filter.referenceStart) params.set('ReferenceStart', this.filter.referenceStart);
                if (this.filter.referenceEnd) params.set('ReferenceEnd', this.filter.referenceEnd);
                if (this.filter.name) params.set('Name', this.filter.name);
                if (this.filter.relatedPerson) params.set('RelatedPerson', this.filter.relatedPerson);
                if (this.filter.issueDateStart) params.set('IssueDateStart', this.filter.issueDateStart);
                if (this.filter.issueDateEnd) params.set('IssueDateEnd', this.filter.issueDateEnd);
                if (this.filter.status) params.set('Status', this.filter.status);
                if (this.filter.evaluated) params.set('Evaluated', this.filter.evaluated);
                params.set('Page', '1');
                if (this.filter.pageSize) params.set('PageSize', this.filter.pageSize);
                if (this.filter.first) params.set('First', this.filter.first);

                const query = params.toString();
                window.location.href = '/Invoice/Results' + (query ? '?' + query : '');
            },

            buildInvoiceReportParams() {
                const hasStartDate = !!this.filter.issueDateStart;
                const hasEndDate = !!this.filter.issueDateEnd;

                if (hasStartDate !== hasEndDate) {
                    this.showError(this.messages.issueDateRangeInvalid);
                    return null;
                }

                if (!hasStartDate) {
                    this.showError(this.messages.startEndDateRequired);
                    return null;
                }

                if (new Date(this.filter.issueDateEnd) < new Date(this.filter.issueDateStart)) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                const params = new URLSearchParams();
                if (this.jobCustomerCode) params.set('JobCustomerCode', this.jobCustomerCode);
                if (this.jobCustomerName) params.set('JobCustomerName', this.jobCustomerName);
                if (this.invoiceCustomerCode) params.set('InvoiceCustomerCode', this.invoiceCustomerCode);
                if (this.invoiceCustomerName) params.set('InvoiceCustomerName', this.invoiceCustomerName);
                if (this.filter.referenceStart) params.set('ReferenceStart', this.filter.referenceStart);
                if (this.filter.referenceEnd) params.set('ReferenceEnd', this.filter.referenceEnd);
                if (this.filter.name) params.set('Name', this.filter.name);
                if (this.filter.relatedPerson) params.set('RelatedPerson', this.filter.relatedPerson);
                if (this.filter.issueDateStart) params.set('IssueDateStart', this.filter.issueDateStart);
                if (this.filter.issueDateEnd) params.set('IssueDateEnd', this.filter.issueDateEnd);
                if (this.filter.status) params.set('Status', this.filter.status);
                if (this.filter.evaluated) params.set('Evaluated', this.filter.evaluated);

                return params.toString();
            },

            async downloadReport(url) {
                if (this.isReportLoading) {
                    return;
                }

                this.isReportLoading = true;
                this.showLoading();
                let loadingClosed = false;

                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        const rawMessage = await response.text();
                        const fallback = this.messages.reportDataUnavailable;
                        this.hideLoading();
                        loadingClosed = true;
                        this.showError(this.normalizeErrorMessage(rawMessage, fallback));
                        return;
                    }

                    const blob = await response.blob();
                    const contentDisposition = response.headers.get('content-disposition') || '';
                    const fileNameUtfMatch = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
                    const fileNameMatch = contentDisposition.match(/filename="?([^\";]+)"?/i);

                    let fileName = 'report.xlsx';
                    if (fileNameUtfMatch && fileNameUtfMatch[1]) {
                        fileName = decodeURIComponent(fileNameUtfMatch[1]);
                    } else if (fileNameMatch && fileNameMatch[1]) {
                        fileName = fileNameMatch[1];
                    }

                    const objectUrl = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = objectUrl;
                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(objectUrl);
                } catch (error) {
                    const fallback = (window.imajTexts && window.imajTexts.connectionError)
                        || (window.imajTexts && window.imajTexts.genericError)
                        || this.messages.reportDataUnavailable;
                    this.hideLoading();
                    loadingClosed = true;
                    this.showError(fallback);
                } finally {
                    if (!loadingClosed) {
                        this.hideLoading();
                    }
                    this.isReportLoading = false;
                }
            },

            openReportPage(url) {
                window.open(url, '_blank', 'noopener');
            },

            async downloadDetailedInvoiceReport() {
                const query = this.buildInvoiceReportParams();
                if (query === null) {
                    return;
                }

                await this.downloadReport('/Invoice/DownloadDetailedInvoiceReportExcel' + (query ? `?${query}` : ''));
            },

            openDetailedInvoiceReportPage() {
                const query = this.buildInvoiceReportParams();
                if (query === null) {
                    return;
                }

                this.openReportPage('/Invoice/ViewDetailedInvoiceReport' + (query ? `?${query}` : ''));
            },

            async downloadSummaryInvoiceReport() {
                const query = this.buildInvoiceReportParams();
                if (query === null) {
                    return;
                }

                await this.downloadReport('/Invoice/DownloadSummaryInvoiceReportExcel' + (query ? `?${query}` : ''));
            },

            openSummaryInvoiceReportPage() {
                const query = this.buildInvoiceReportParams();
                if (query === null) {
                    return;
                }

                this.openReportPage('/Invoice/ViewSummaryInvoiceReport' + (query ? `?${query}` : ''));
            },

            resetFilters() {
                this.jobCustomerCode = '';
                this.jobCustomerName = '';
                this.invoiceCustomerCode = '';
                this.invoiceCustomerName = '';
                this.filter.referenceStart = '';
                this.filter.referenceEnd = '';
                this.filter.name = '';
                this.filter.relatedPerson = '';
                // IssueDateStart/End artık string tipinde
                this.filter.issueDateStart = '@(Model.IssueDateStart ?? string.Empty)';
                this.filter.issueDateEnd = '@(Model.IssueDateEnd ?? string.Empty)';
                this.filter.status = '';
                this.filter.evaluated = '';
                this.filter.first = @firstValue;
                this.filter.pageSize = @pageSizeValue;
            },

            createInvoice() {
                if (!this.newJobCustomerCode) {
                    this.showError(this.messages.pleaseSelectCustomer);
                    return;
                }
                window.location.href = '/Invoice/Create?jobCustomerCode=' + encodeURIComponent(this.newJobCustomerCode) + '&jobCustomerName=' + encodeURIComponent(this.newJobCustomerName);
            }
        }
    }
</script>
