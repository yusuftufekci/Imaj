@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model InvoiceViewModel

@{
    ViewData["Title"] = Localizer["InvoiceOperations"];
}

<div x-data="invoicePage()" @@customer-selected.window="handleSelection($event.detail)" class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
             <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                @Localizer["InvoiceOperations"]
            </h2>
        </div>
    </div>

    <!-- Section 1: Invoice Inquiry (Fatura Sorgulama) -->
    <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 border-b border-gray-200 sm:px-6">
            <div class="flex items-center justify-between">
                <h3 class="text-lg leading-6 font-medium text-gray-900">
                    Fatura Sorgulama
                </h3>
                <div class="text-xs text-gray-500">
                    @Localizer["Last30DaysDefault"]
                </div>
            </div>
        </div>
        <div class="px-4 py-5 sm:p-6">
            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                
                <!-- Job Customer (Is Musterisi) -->
                <div class="sm:col-span-6">
                    <label class="block text-sm font-medium text-gray-700">@Localizer["JobCustomer"]</label>
                     <div class="mt-1 flex rounded-md shadow-sm">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="jobCustomerName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-400" placeholder="Tüm Müşteriler">
                        </div>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'job' })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-400 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                             <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                             <span>Seç</span>
                        </button>
                    </div>
                </div>

                <!-- Invoice Customer (Fatura Musterisi) -->
                <div class="sm:col-span-6">
                    <label class="block text-sm font-medium text-gray-700">@Localizer["InvoiceCustomer"]</label>
                     <div class="mt-1 flex rounded-md shadow-sm">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="invoiceCustomerName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-400" placeholder="Tüm Müşteriler">
                        </div>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'invoice' })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-400 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                             <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                             <span>Seç</span>
                        </button>
                    </div>
                </div>

                <!-- Reference Range -->
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">@Localizer["ReferenceRange"]</label>
                    <div class="mt-1 flex space-x-2">
                        <input type="text" x-model="filter.referenceStart" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md" placeholder="Başlangıç">
                        <input type="text" x-model="filter.referenceEnd" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md" placeholder="Bitiş">
                    </div>
                </div>

                 <!-- Name -->
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Ad</label>
                    <div class="mt-1">
                        <input type="text" x-model="filter.name" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md">
                    </div>
                </div>

                <!-- Related Person -->
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">İlgili</label>
                    <div class="mt-1">
                        <input type="text" x-model="filter.relatedPerson" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md">
                    </div>
                </div>

                <!-- Date Range -->
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Kesilme Tarihi</label>
                    <div class="mt-1 flex space-x-2">
                         <input type="date" x-model="filter.issueDateStart" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md">
                         <input type="date" x-model="filter.issueDateEnd" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md">
                    </div>
                </div>
                
                 <!-- Status -->
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Durum</label>
                    <div class="mt-1">
                        <select x-model="filter.status" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md">
                            <option value="">Tümü</option>
                            @{
                                var invoiceStates = ViewBag.InvoiceStates as List<Imaj.Service.DTOs.StateDto> ?? new List<Imaj.Service.DTOs.StateDto>();
                            }
                            @foreach (var state in invoiceStates)
                            {
                                <option value="@state.Id">@state.Name</option>
                            }
                        </select>
                    </div>
                </div>
                 
                 <!-- Evaluated (Mock) -->
                <div class="sm:col-span-3">
                    <label class="block text-sm font-medium text-gray-700">Değerlendirildi</label>
                    <div class="mt-1">
                        <select x-model="filter.evaluated" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-400 rounded-md">
                            <option value="">Tümü</option>
                            <option value="true">@Localizer["Yes"]</option>
                            <option value="false">@Localizer["No"]</option>
                        </select>
                    </div>
                </div>

            </div>
            
            <!-- Actions -->
             <div class="mt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between border-t border-gray-200 pt-4 gap-4">
                 <div class="flex items-center space-x-2">
                    <label class="text-sm text-gray-500">İlk</label>
                    <input type="number" x-model="filter.page" class="w-16 shadow-sm border-gray-400 rounded-md sm:text-sm">
                     <label class="text-sm text-gray-500">Sayfa Boyu</label>
                    <select x-model="filter.pageSize" class="shadow-sm border-gray-400 rounded-md sm:text-sm">
                        <option value="10">10</option>
                        <option value="20">20</option>
                        <option value="50">50</option>
                    </select>
                 </div>
                 <div class="flex items-center space-x-3">
                    <button type="button" @@click="resetFilters()" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        @Localizer["Clear"]
                    </button>
                    <button type="button" @@click="searchInvoices()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        Sorgula
                    </button>
                 </div>
            </div>
             <div class="mt-4 flex justify-center space-x-3">
                <button type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Detaylı Fatura Raporu Bas
                </button>
                <button type="button" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Özet Fatura Raporu Bas
                </button>
            </div>
        </div>
    </div>

    <!-- Section 2: Invoice Creation (Fatura Yaratma) -->
     <div class="bg-white shadow sm:rounded-lg mt-8">
        <div class="px-4 py-5 border-b border-gray-200 sm:px-6">
             <h3 class="text-lg leading-6 font-medium text-gray-900">
                Fatura Yaratma
            </h3>
        </div>
        <div class="px-4 py-5 sm:p-6">
             <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6 mb-4">
                 <!-- New Job Customer -->
                <div class="sm:col-span-6">
                    <label class="block text-sm font-medium text-gray-700">@Localizer["JobCustomer"]</label>
                     <div class="mt-1 flex rounded-md shadow-sm">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="newJobCustomerName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-400" placeholder="@Localizer["PleaseSelectCustomer"]">
                        </div>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'newJob' })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-400 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                             <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                             <span>Seç</span>
                        </button>
                    </div>
                </div>
            </div>
             <div class="flex justify-center">
                 <button type="button" @@click="createInvoice()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Yeni Fatura Yarat
                </button>
             </div>
        </div>
    </div>
    
    <!-- Shared Customer Select Modal -->
    <partial name="_CustomerSelectModal" />
</div>

<script>
    function invoicePage() {
        return {
            // Filter Models
            jobCustomerCode: '',
            jobCustomerName: '',
            
            invoiceCustomerCode: '',
            invoiceCustomerName: '',
            
            newJobCustomerCode: '',
            newJobCustomerName: '',

            filter: {
                 referenceStart: '', referenceEnd: '',
                 name: '', relatedPerson: '',
                 issueDateStart: '@Model.IssueDateStart?.ToString("yyyy-MM-dd")', issueDateEnd: '@Model.IssueDateEnd?.ToString("yyyy-MM-dd")',
                 status: '', evaluated: '',
                 page: 1, pageSize: 10
            },

            handleSelection(detail) {
                const cust = detail.customer;
                const target = detail.targetId;
                
                if (target === 'job') {
                    this.jobCustomerName = cust.name;
                    this.jobCustomerCode = cust.code;
                } else if (target === 'invoice') {
                    this.invoiceCustomerName = cust.name;
                    this.invoiceCustomerCode = cust.code;
                } else if (target === 'newJob') {
                    this.newJobCustomerName = cust.name;
                    this.newJobCustomerCode = cust.code;
                }
            },

            async searchInvoices() {
                const params = new URLSearchParams();

                if (this.jobCustomerCode) params.set('JobCustomerCode', this.jobCustomerCode);
                if (this.jobCustomerName) params.set('JobCustomerName', this.jobCustomerName);
                if (this.invoiceCustomerCode) params.set('InvoiceCustomerCode', this.invoiceCustomerCode);
                if (this.invoiceCustomerName) params.set('InvoiceCustomerName', this.invoiceCustomerName);
                if (this.filter.referenceStart) params.set('ReferenceStart', this.filter.referenceStart);
                if (this.filter.referenceEnd) params.set('ReferenceEnd', this.filter.referenceEnd);
                if (this.filter.name) params.set('Name', this.filter.name);
                if (this.filter.relatedPerson) params.set('RelatedPerson', this.filter.relatedPerson);
                if (this.filter.issueDateStart) params.set('IssueDateStart', this.filter.issueDateStart);
                if (this.filter.issueDateEnd) params.set('IssueDateEnd', this.filter.issueDateEnd);
                if (this.filter.status) params.set('Status', this.filter.status);
                if (this.filter.evaluated) params.set('Evaluated', this.filter.evaluated);
                if (this.filter.page) params.set('Page', this.filter.page);
                if (this.filter.pageSize) params.set('PageSize', this.filter.pageSize);

                const query = params.toString();
                window.location.href = '/Invoice/Results' + (query ? '?' + query : '');
            },

            resetFilters() {
                this.jobCustomerCode = '';
                this.jobCustomerName = '';
                this.invoiceCustomerCode = '';
                this.invoiceCustomerName = '';
                this.filter.referenceStart = '';
                this.filter.referenceEnd = '';
                this.filter.name = '';
                this.filter.relatedPerson = '';
                this.filter.issueDateStart = '@Model.IssueDateStart?.ToString("yyyy-MM-dd")';
                this.filter.issueDateEnd = '@Model.IssueDateEnd?.ToString("yyyy-MM-dd")';
                this.filter.status = '';
                this.filter.evaluated = '';
                this.filter.page = 1;
                this.filter.pageSize = 10;
            },

            createInvoice() {
                if (!this.newJobCustomerCode) {
                    alert('Lütfen bir iş müşterisi seçiniz.');
                    return;
                }
                window.location.href = '/Invoice/Create?jobCustomerCode=' + encodeURIComponent(this.newJobCustomerCode) + '&jobCustomerName=' + encodeURIComponent(this.newJobCustomerName);
            }
        }
    }
</script>
