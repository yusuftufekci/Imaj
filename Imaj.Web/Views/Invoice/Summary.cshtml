@using System.Net
@using System.Collections.Generic
@using Imaj.Web.Authorization
@using Imaj.Service.DTOs
@model InvoiceDisplayViewModel
@inject IPermissionViewService PermissionViewService

@{
    ViewData["Title"] = Localizer["InvoiceSummary"];
    var invoice = Model.Invoices.FirstOrDefault();
    var lineTotal = invoice?.Lines.Sum(x => x.Amount) ?? 0m;
    var taxTotal = invoice?.Taxes.Sum(x => x.TaxAmount) ?? 0m;
    var netTotal = invoice?.Taxes.Sum(x => x.NetTotal) ?? 0m;
    var returnUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/Invoice/Results" : Model.ReturnUrl;
    var queryParts = new List<string>();
    if (Model.SelectedReferences.Any())
    {
        queryParts.AddRange(Model.SelectedReferences.Select(x => "selectedReferences=" + WebUtility.UrlEncode(x)));
    }
    if (!string.IsNullOrWhiteSpace(returnUrl))
    {
        queryParts.Add("returnUrl=" + WebUtility.UrlEncode(returnUrl));
    }
    var queryString = string.Join("&", queryParts);
    var currentUrl = "/Invoice/Summary?reference=" + invoice?.Reference + "&page=" + (Model.CurrentIndex + 1) + (string.IsNullOrWhiteSpace(queryString) ? string.Empty : "&" + queryString);
    var selectedReferences = Model.SelectedReferences ?? new List<string>();
    var parsedReference = int.TryParse(invoice?.Reference, out var reference);
    var stateId = invoice?.StateId ?? 0m;
    var isEvaluated = invoice?.Evaluated ?? false;
    var isOpen = stateId == 210m;
    var isConfirmed = stateId == 220m;
    var isIssued = stateId == 230m;
    var isKilled = stateId == 240m;
    var isDiscarded = stateId == 250m;
    var issueDateValue = (invoice?.IssueDate ?? DateTime.Today).ToString("yyyy-MM-dd");

    var canConfirm = await PermissionViewService.CanExecuteMethodAsync(1385m, write: true);
    var canUndoConfirm = await PermissionViewService.CanExecuteMethodAsync(1386m, write: true);
    var canIssue = await PermissionViewService.CanExecuteMethodAsync(1388m, write: true);
    var canKill = await PermissionViewService.CanExecuteMethodAsync(1389m, write: true);
    var canDiscard = await PermissionViewService.CanExecuteMethodAsync(1387m, write: true);
    var canEvaluate = await PermissionViewService.CanExecuteMethodAsync(1390m, write: true);
    var canUndoEvaluate = await PermissionViewService.CanExecuteMethodAsync(1490m, write: true);

    var canDoConfirm = parsedReference && canConfirm && !isEvaluated && isOpen;
    var canDoUndoConfirm = parsedReference && canUndoConfirm && !isEvaluated && isConfirmed;
    var canDoIssue = parsedReference && canIssue && !isEvaluated && isConfirmed;
    var canDoKill = parsedReference && canKill && !isEvaluated && isIssued;
    var canDoDiscard = parsedReference && canDiscard && !isEvaluated && isOpen;
    var canDoEvaluate = parsedReference && canEvaluate && !isEvaluated && (isIssued || isKilled || isDiscarded);
    var canDoUndoEvaluate = parsedReference && canUndoEvaluate && isEvaluated && (isIssued || isKilled || isDiscarded);
    var canPrintInvoice = parsedReference && !isEvaluated && (isOpen || isConfirmed || isIssued);
}

<div class="space-y-8">
    @if (invoice == null)
    {
        <div class="bg-white border border-gray-200 shadow sm:rounded-lg p-6 text-center text-sm text-gray-500">
            @Localizer["NoRecordsFound"]
        </div>
    }
    else
    {
        <div class="space-y-6">
            <div class="md:flex md:items-center md:justify-between bg-blue-900 p-2 rounded-t-lg">
                <div class="flex-1 min-w-0">
                    <h2 class="text-xl font-bold leading-7 text-white sm:truncate text-center">
                        @Localizer["Invoice"]
                    </h2>
                </div>
            </div>

            <div class="bg-white border border-gray-200 shadow sm:rounded-b-lg p-4">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="bg-blue-50 p-4 rounded border border-blue-200 space-y-2 text-sm">
                        <h3 class="font-bold text-gray-800 border-b border-blue-200 pb-1 mb-2">@Localizer["BasicInfo"]</h3>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["Reference"]</span>
                            <span class="col-span-2 text-gray-900">@invoice.Reference</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["JobCustomer"]</span>
                            <span class="col-span-2 text-gray-900">@invoice.JobCustomer</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["InvoiceCustomer"]</span>
                            <span class="col-span-2 text-gray-900">@invoice.InvoiceCustomer</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["Name"]</span>
                            <span class="col-span-2 text-gray-900">@invoice.Name</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["Related"]</span>
                            <span class="col-span-2 text-gray-900">@invoice.RelatedPerson</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["Date"]</span>
                            <span class="col-span-2 text-gray-900">@invoice.IssueDate?.ToString("dd/MM/yyyy dddd") ?? "-"</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["Status"]</span>
                            <span class="col-span-2 text-gray-900">@invoice.Status</span>
                        </div>
                        <div class="grid grid-cols-3 gap-2">
                            <span class="font-bold text-right text-blue-900">@Localizer["Evaluated"]</span>
                            <span class="col-span-2">
                                <input type="checkbox" disabled @(invoice.Evaluated ? "checked" : "") class="h-4 w-4 text-blue-600 border-gray-300 rounded">
                            </span>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="bg-gray-50 border border-gray-200 rounded p-2">
                            <h3 class="font-bold text-gray-700 bg-blue-100 px-2 py-1 mb-2 text-sm rounded">@Localizer["Notes"]</h3>
                            <div class="w-full text-sm border border-gray-300 rounded bg-white px-3 py-2">@invoice.Notes</div>
                        </div>
                        <div class="bg-gray-50 border border-gray-200 rounded p-2">
                            <h3 class="font-bold text-gray-700 bg-blue-100 px-2 py-1 mb-2 text-sm rounded">@Localizer["Notes"]</h3>
                            <div class="w-full text-sm border border-gray-300 rounded bg-white px-3 py-2">@invoice.FooterNote</div>
                        </div>
                    </div>
                </div>
            </div>

            <div>
                <div class="bg-blue-200 px-4 py-2 rounded-t-lg border border-blue-300 flex justify-between items-center">
                    <h3 class="font-bold text-gray-800 text-sm">@Localizer["Line"] (@invoice.Lines.Count)</h3>
                </div>
                <div class="bg-white border border-gray-200 shadow overflow-hidden sm:rounded-b-lg">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-yellow-50">
                            <tr>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Selected"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Sequence"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Notes"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Quantity"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Price"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Amount"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["TaxType"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var line in invoice.Lines)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-2">
                                        <input type="checkbox" disabled @(line.Selected ? "checked" : "") class="h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                    </td>
                                    <td class="px-4 py-2 text-gray-900">@line.LineNo</td>
                                    <td class="px-4 py-2 text-gray-900">@line.Notes</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@line.Quantity</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@line.Price.ToString("N2")</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@line.Amount.ToString("N2")</td>
                                    <td class="px-4 py-2 text-gray-900">@line.TaxType</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-yellow-50">
                            <tr>
                                <td colspan="5" class="px-4 py-2 text-right font-bold text-gray-900">@Localizer["Total"]</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900">@lineTotal.ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <div>
                <div class="bg-blue-200 px-4 py-2 rounded-t-lg border border-blue-300 flex justify-between items-center">
                    <h3 class="font-bold text-gray-800 text-sm">@Localizer["Taxes"] (@invoice.Taxes.Count)</h3>
                </div>
                <div class="bg-white border border-gray-200 shadow overflow-hidden sm:rounded-b-lg">
                    <table class="min-w-full divide-y divide-gray-200 text-sm">
                        <thead class="bg-yellow-50">
                            <tr>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Code"]</th>
                                <th class="px-4 py-2 text-left font-bold text-gray-700">@Localizer["Name"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["SubTotal"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["Percentage"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["TaxAmount"]</th>
                                <th class="px-4 py-2 text-right font-bold text-gray-700">@Localizer["NetAmount"]</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var tax in invoice.Taxes)
                            {
                                <tr>
                                    <td class="px-4 py-2 text-gray-900">@tax.Code</td>
                                    <td class="px-4 py-2 text-gray-900">@tax.Name</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@tax.SubTotal.ToString("N2")</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@tax.Rate.ToString("N0")</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@tax.TaxAmount.ToString("N2")</td>
                                    <td class="px-4 py-2 text-right text-gray-900">@tax.NetTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="bg-yellow-50">
                            <tr>
                                <td colspan="2" class="px-4 py-2 text-right font-bold text-gray-900">@Localizer["Total"]</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900">@invoice.Taxes.Sum(x => x.SubTotal).ToString("N2")</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900"></td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900">@taxTotal.ToString("N2")</td>
                                <td class="px-4 py-2 text-right font-bold text-gray-900">@netTotal.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            @if (selectedReferences.Count > 1)
            {
                <div class="mt-4">
                    <partial name="Components/_Pagination" model="@(new Imaj.Web.Models.Components.PaginationModel
                    {
                        CurrentPage = Model.CurrentIndex + 1,
                        TotalCount = selectedReferences.Count,
                        PageSize = 1,
                        BaseUrl = "/Invoice/Summary",
                        QueryString = queryString
                    })" />
                </div>
            }

            <div class="flex flex-wrap justify-center gap-2">
                <a href="@returnUrl" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">@Localizer["Back"]</a>
                <a href="/Invoice/Detail?reference=@invoice.Reference&page=@(Model.CurrentIndex + 1)&@queryString" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    @Localizer["ViewDetail"]
                </a>

                @if (canPrintInvoice)
                {
                    <a href="/Invoice/Print?reference=@reference"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="inline-flex items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200">
                        @Localizer["PrintInvoice"] PDF
                    </a>
                    <a href="/Invoice/DownloadPrintExcel?reference=@reference"
                       class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">
                        @Localizer["PrintInvoice"] Excel
                    </a>
                }

                @if (canDoConfirm)
                {
                    <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Reference" value="@reference" />
                        <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Confirm)" />
                        <input type="hidden" name="SourceView" value="Summary" />
                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                        @foreach (var selectedReference in selectedReferences)
                        {
                            <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                        }
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowConfirm"]</button>
                    </form>
                }

                @if (canDoUndoConfirm)
                {
                    <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Reference" value="@reference" />
                        <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.UndoConfirm)" />
                        <input type="hidden" name="SourceView" value="Summary" />
                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                        @foreach (var selectedReference in selectedReferences)
                        {
                            <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                        }
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowUndoConfirm"]</button>
                    </form>
                }

                @if (canDoIssue)
                {
                    <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex items-center gap-2 flex-wrap justify-center">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Reference" value="@reference" />
                        <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Issue)" />
                        <input type="hidden" name="SourceView" value="Summary" />
                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                        @foreach (var selectedReference in selectedReferences)
                        {
                            <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                        }
                        <label for="invoice-issue-date-summary" class="text-sm font-medium text-gray-700">@Localizer["InvoiceIssueDate"]</label>
                        <input id="invoice-issue-date-summary"
                               type="date"
                               name="IssueDate"
                               value="@issueDateValue"
                               required
                               class="inline-flex items-center px-3 py-2 border border-gray-300 text-sm rounded-md text-gray-900 bg-white" />
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-blue-400 text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200">@Localizer["WorkflowIssue"]</button>
                    </form>
                }

                @if (canDoKill)
                {
                    <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Reference" value="@reference" />
                        <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Kill)" />
                        <input type="hidden" name="SourceView" value="Summary" />
                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                        @foreach (var selectedReference in selectedReferences)
                        {
                            <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                        }
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-red-400 text-sm font-medium rounded-md text-red-900 bg-red-100 hover:bg-red-200">@Localizer["WorkflowKill"]</button>
                    </form>
                }

                @if (canDoDiscard)
                {
                    <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Reference" value="@reference" />
                        <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Discard)" />
                        <input type="hidden" name="SourceView" value="Summary" />
                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                        @foreach (var selectedReference in selectedReferences)
                        {
                            <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                        }
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-red-400 text-sm font-medium rounded-md text-red-900 bg-red-100 hover:bg-red-200">@Localizer["WorkflowDiscard"]</button>
                    </form>
                }

                @if (canDoEvaluate)
                {
                    <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Reference" value="@reference" />
                        <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.Evaluate)" />
                        <input type="hidden" name="SourceView" value="Summary" />
                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                        @foreach (var selectedReference in selectedReferences)
                        {
                            <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                        }
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-emerald-400 text-sm font-medium rounded-md text-emerald-900 bg-emerald-100 hover:bg-emerald-200">@Localizer["WorkflowEvaluate"]</button>
                    </form>
                }

                @if (canDoUndoEvaluate)
                {
                    <form method="post" action="/Invoice/WorkflowAction" class="workflow-action-form inline-flex">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Reference" value="@reference" />
                        <input type="hidden" name="Action" value="@((int)InvoiceWorkflowAction.UndoEvaluate)" />
                        <input type="hidden" name="SourceView" value="Summary" />
                        <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
                        <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                        @foreach (var selectedReference in selectedReferences)
                        {
                            <input type="hidden" name="SelectedReferences" value="@selectedReference" />
                        }
                        <button type="submit" class="inline-flex items-center px-4 py-2 border border-amber-400 text-sm font-medium rounded-md text-amber-900 bg-amber-100 hover:bg-amber-200">@Localizer["WorkflowUndoEvaluate"]</button>
                    </form>
                }

                <a href="/Invoice/History?reference=@invoice.Reference&returnUrl=@WebUtility.UrlEncode(currentUrl)" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    @Localizer["ViewHistory"]
                </a>
            </div>
        </div>
    }
</div>
