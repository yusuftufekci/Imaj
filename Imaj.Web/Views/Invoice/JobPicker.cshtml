@using System.Net
@using System.Globalization
@using System.Text.Json
@using Imaj.Service.DTOs
@model InvoiceJobPickerViewModel

@{
    ViewData["Title"] = Model.Searched ? "İşler" : "İş Sorgulama";
    var backParts = new List<string>
    {
        "reference=" + Model.Reference.ToString(CultureInfo.InvariantCulture),
        "page=" + (Model.CurrentIndex + 1).ToString(CultureInfo.InvariantCulture)
    };
    backParts.AddRange(Model.SelectedReferences.Select(x => "selectedReferences=" + WebUtility.UrlEncode(x)));
    if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
    {
        backParts.Add("returnUrl=" + WebUtility.UrlEncode(Model.ReturnUrl));
    }
    var backUrl = "/Invoice/Detail?" + string.Join("&", backParts);
    var actionUrl = Model.Context == "line" ? "/Invoice/AddJobsToInvoiceLine" : "/Invoice/AddJobsToInvoice";
    string JsonValue(string? value) => JsonSerializer.Serialize(value ?? string.Empty);
    var criteriaParts = new List<string>
    {
        "Reference=" + Model.Reference.ToString(CultureInfo.InvariantCulture),
        "LineId=" + WebUtility.UrlEncode(Model.LineId?.ToString(CultureInfo.InvariantCulture) ?? string.Empty),
        "Context=" + WebUtility.UrlEncode(Model.Context),
        "Mode=" + ((int)Model.Mode).ToString(CultureInfo.InvariantCulture),
        "CurrentIndex=" + Model.CurrentIndex.ToString(CultureInfo.InvariantCulture),
        "ReturnUrl=" + WebUtility.UrlEncode(Model.ReturnUrl ?? string.Empty),
        "JobCustomerCode=" + WebUtility.UrlEncode(Model.JobCustomerCode),
        "JobCustomerName=" + WebUtility.UrlEncode(Model.JobCustomerName),
        "Function=" + WebUtility.UrlEncode(Model.Function),
        "ReferenceStart=" + WebUtility.UrlEncode(Model.ReferenceStart),
        "ReferenceEnd=" + WebUtility.UrlEncode(Model.ReferenceEnd),
        "ReferenceList=" + WebUtility.UrlEncode(Model.ReferenceList),
        "Name=" + WebUtility.UrlEncode(Model.Name),
        "RelatedPerson=" + WebUtility.UrlEncode(Model.RelatedPerson),
        "StartDateStart=" + WebUtility.UrlEncode(Model.StartDateStart),
        "StartDateEnd=" + WebUtility.UrlEncode(Model.StartDateEnd),
        "EndDateStart=" + WebUtility.UrlEncode(Model.EndDateStart),
        "EndDateEnd=" + WebUtility.UrlEncode(Model.EndDateEnd),
        "EmailSent=" + WebUtility.UrlEncode(Model.EmailSent),
        "EmployeeCode=" + WebUtility.UrlEncode(Model.EmployeeCode),
        "EmployeeName=" + WebUtility.UrlEncode(Model.EmployeeName),
        "TaskType=" + WebUtility.UrlEncode(Model.TaskType),
        "OvertimeType=" + WebUtility.UrlEncode(Model.OvertimeType),
        "ProductId=" + WebUtility.UrlEncode(Model.ProductId),
        "ProductCode=" + WebUtility.UrlEncode(Model.ProductCode),
        "ProductName=" + WebUtility.UrlEncode(Model.ProductName),
        "First=" + Model.First.ToString(CultureInfo.InvariantCulture),
        "PageSize=" + Model.PageSize.ToString(CultureInfo.InvariantCulture)
    };
    criteriaParts.AddRange(Model.SelectedReferences.Select(x => "SelectedReferences=" + WebUtility.UrlEncode(x)));
    criteriaParts.AddRange(Model.JobReferences.Select(x => "JobReferences=" + x.ToString(CultureInfo.InvariantCulture)));
    var criteriaUrl = "/Invoice/JobPicker?" + string.Join("&", criteriaParts);
    var totalCount = Model.TotalCount > 0 ? Model.TotalCount : Model.Items.Count;
    var totalPages = Model.PageSize > 0
        ? (int)Math.Ceiling((double)totalCount / Model.PageSize)
        : 1;
    totalPages = Math.Max(totalPages, 1);
    var paginationQueryParts = Context.Request.Query
        .Where(q => !string.Equals(q.Key, "page", StringComparison.OrdinalIgnoreCase)
                 && !string.Equals(q.Key, "pageSize", StringComparison.OrdinalIgnoreCase))
        .SelectMany(q => q.Value
            .Where(v => !string.IsNullOrWhiteSpace(v))
            .Select(v => $"{q.Key}={Uri.EscapeDataString(v!)}"));
    var paginationQuery = string.Join("&", paginationQueryParts);
    var previousPageUrl = Model.Page > 1
        ? $"/Invoice/JobPicker?{paginationQuery}&page={Model.Page - 1}&pageSize={Model.PageSize}"
        : string.Empty;
    var nextPageUrl = Model.Page < totalPages
        ? $"/Invoice/JobPicker?{paginationQuery}&page={Model.Page + 1}&pageSize={Model.PageSize}"
        : string.Empty;
    var currentPageReferences = Model.Items.Select(x => x.Reference).ToHashSet();
    var persistedJobReferences = Model.JobReferences
        .Where(x => !currentPageReferences.Contains(x))
        .Distinct()
        .ToList();
    var selectedJobReferencesJson = JsonSerializer.Serialize(Model.JobReferences.Distinct().ToList());
}

<div x-data="invoiceJobPicker()"
     @@customer-selected.window="handleCustomerSelection($event.detail)"
     @@product-selected.window="handleProductSelection($event.detail)"
     @@employee-selected.window="handleEmployeeSelection($event.detail)"
     class="invoice-page-shell invoice-legacy-detail invoice-job-picker page-shell--wide space-y-3">
    <h2 class="invoice-page-title invoice-page-title--orange">@(Model.Searched ? "İşler" : "İş Sorgulama")</h2>

    @if (!Model.Searched)
    {
        <form method="get" action="/Invoice/JobPicker" class="space-y-3">
            <input type="hidden" name="Reference" value="@Model.Reference" />
            <input type="hidden" name="LineId" value="@Model.LineId" />
            <input type="hidden" name="Context" value="@Model.Context" />
            @if (Model.Context == "line")
            {
                <input type="hidden" name="Mode" value="@((int)Model.Mode)" />
            }
            <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            <input type="hidden" name="Searched" value="true" />
            <input type="hidden" name="JobCustomerCode" x-model="filter.jobCustomerCode" />
            <input type="hidden" name="JobCustomerName" x-model="filter.jobCustomerName" />
            @foreach (var selectedReference in Model.SelectedReferences)
            {
                <input type="hidden" name="SelectedReferences" value="@selectedReference" />
            }
            @foreach (var jobReference in Model.JobReferences)
            {
                <input type="hidden" name="JobReferences" value="@jobReference" />
            }

            <div class="invoice-job-picker__criteria-grid">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">İş Kriteri</h3>
                    </div>
                    <div class="dense-panel__body">
                        <div class="invoice-job-picker__form">
                            <label>
                                <span>Fonksiyon</span>
                                <select name="Function" class="dense-input" x-model="filter.function">
                                    <option value=""></option>
                                    @if (ViewBag.Functions != null)
                                    {
                                        @foreach (var func in ViewBag.Functions)
                                        {
                                            <option value="@func.Id">@func.Name</option>
                                        }
                                    }
                                </select>
                            </label>
                            <label>
                                <span>Müşteri</span>
                                <span class="invoice-job-picker__customer-selector">
                                    <strong x-text="customerDisplay"></strong>
                                    <span>-</span>
                                    <a href="#" @@click.prevent="$dispatch('customer-select-open', { targetId: 'invoiceJobCustomer', searchEndpoint: '/Job/CustomerSearch', jobStatesEndpoint: '/Job/CustomerJobStates' })">Seç</a>
                                </span>
                            </label>
                            <label>
                                <span>Referans Aralığı</span>
                                <span class="invoice-job-picker__range">
                                    <input type="text" name="ReferenceStart" value="@Model.ReferenceStart" class="dense-input" />
                                    <input type="text" name="ReferenceEnd" value="@Model.ReferenceEnd" class="dense-input" />
                                </span>
                            </label>
                            <label>
                                <span>Referans Listesi</span>
                                <input type="text" name="ReferenceList" value="@Model.ReferenceList" class="dense-input invoice-job-picker__wide-input" />
                            </label>
                            <label>
                                <span>Ad</span>
                                <input type="text" name="Name" value="@Model.Name" class="dense-input invoice-job-picker__name-input" />
                            </label>
                            <label>
                                <span>İlgili</span>
                                <input type="text" name="RelatedPerson" value="@Model.RelatedPerson" class="dense-input invoice-job-picker__name-input" />
                            </label>
                            <label>
                                <span>Başlangıç Tarihi Aralığı</span>
                                <span class="invoice-job-picker__range invoice-job-picker__date-range">
                                    <input type="date" name="StartDateStart" value="@Model.StartDateStart" class="dense-input" />
                                    <input type="date" name="StartDateEnd" value="@Model.StartDateEnd" class="dense-input" />
                                </span>
                            </label>
                            <label>
                                <span>Bitiş Tarihi Aralığı</span>
                                <span class="invoice-job-picker__range invoice-job-picker__date-range">
                                    <input type="date" name="EndDateStart" value="@Model.EndDateStart" class="dense-input" />
                                    <input type="date" name="EndDateEnd" value="@Model.EndDateEnd" class="dense-input" />
                                </span>
                            </label>
                            <label>
                                <span>Durum</span>
                                <strong>Fiyatlandı</strong>
                            </label>
                            <label>
                                <span>E-Posta Yollandı</span>
                                <select name="EmailSent" class="dense-input invoice-job-picker__short-input" x-model="filter.emailSent">
                                    <option value=""></option>
                                    <option value="true">Evet</option>
                                    <option value="false">Hayır</option>
                                </select>
                            </label>
                            <label>
                                <span>Değerlendirildi</span>
                                <strong>Hayır</strong>
                            </label>
                        </div>
                    </div>
                </section>

                <div class="invoice-job-picker__side">
                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h3 class="dense-panel__title">Mesai Kriteri</h3>
                        </div>
                        <div class="dense-panel__body">
                        <div class="invoice-job-picker__mini-criteria">
                            <input type="hidden" name="EmployeeCode" x-model="filter.employeeCode" />
                            <input type="hidden" name="EmployeeName" x-model="filter.employeeName" />
                            <span>Çalışan</span>
                            <span>-</span>
                            <span class="invoice-job-picker__selected-value" x-text="filter.employeeName || ''"></span>
                            <a href="#" @@click.prevent="$dispatch('employee-select-open', { targetId: 'invoiceJobEmployee', showFilter: true })">Seç</a>
                            <span>Görev Tipi</span>
                            <select name="TaskType" class="dense-input" x-model="filter.taskType">
                                <option value=""></option>
                                @if (ViewBag.WorkTypes != null)
                                {
                                    @foreach (var wt in ViewBag.WorkTypes)
                                    {
                                        <option value="@wt.Id">@wt.Name</option>
                                    }
                                }
                            </select>
                            <span>Mesai Tipi</span>
                            <select name="OvertimeType" class="dense-input" x-model="filter.overtimeType">
                                <option value=""></option>
                                @if (ViewBag.TimeTypes != null)
                                {
                                    @foreach (var tt in ViewBag.TimeTypes)
                                    {
                                        <option value="@tt.Id">@tt.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        </div>
                    </section>
                    <section class="dense-panel">
                        <div class="dense-panel__header">
                            <h3 class="dense-panel__title">Ürün Kriteri</h3>
                        </div>
                        <div class="dense-panel__body">
                        <div class="invoice-job-picker__mini-criteria invoice-job-picker__mini-criteria--product">
                            <input type="hidden" name="ProductId" x-model="filter.productId" />
                            <input type="hidden" name="ProductCode" x-model="filter.productCode" />
                            <input type="hidden" name="ProductName" x-model="filter.productName" />
                            <span>Ürün</span>
                            <span>-</span>
                            <span class="invoice-job-picker__selected-value" x-text="filter.productName || ''"></span>
                            <a href="#" @@click.prevent="$dispatch('product-select-open', { targetId: 'invoiceJobProduct', searchEndpoint: '/Job/ProductSearch', categoriesEndpoint: '/Job/ProductCategories', productGroupsEndpoint: '/Job/ProductGroups', functionsEndpoint: '/Job/ProductFunctions', functionId: filter.function || '' })">Seç</a>
                        </div>
                        </div>
                    </section>
                </div>
            </div>

            <div class="invoice-footer-bar invoice-footer-bar--center">
                <div class="flex flex-wrap justify-center items-center gap-1">
                    <label>İlk <input type="text" name="First" value="@Model.First" class="dense-input invoice-job-picker__tiny-input" /></label>
                    <label>Sayfa Boyu <input type="text" name="PageSize" value="@Model.PageSize" class="dense-input invoice-job-picker__tiny-input" /></label>
                    <button type="submit" class="inline-flex items-center border border-blue-400 text-sm font-medium text-blue-900 bg-blue-100 hover:bg-blue-200">Sorgula</button>
                    <a href="@backUrl" class="inline-flex items-center border border-blue-400 text-sm font-medium text-blue-900 bg-blue-100 hover:bg-blue-200">Geri</a>
                </div>
            </div>
        </form>
    }
    else
    {
        <form method="post" action="@actionUrl">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Reference" value="@Model.Reference" />
            <input type="hidden" name="LineId" value="@Model.LineId" />
            <input type="hidden" name="Context" value="@Model.Context" />
            <input type="hidden" name="Mode" value="@((int)Model.Mode)" />
            <input type="hidden" name="CurrentIndex" value="@Model.CurrentIndex" />
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            <input type="hidden" name="Searched" value="true" />
            <input type="hidden" name="JobCustomerCode" value="@Model.JobCustomerCode" />
            <input type="hidden" name="JobCustomerName" value="@Model.JobCustomerName" />
            <input type="hidden" name="Function" value="@Model.Function" />
            <input type="hidden" name="ReferenceStart" value="@Model.ReferenceStart" />
            <input type="hidden" name="ReferenceEnd" value="@Model.ReferenceEnd" />
            <input type="hidden" name="ReferenceList" value="@Model.ReferenceList" />
            <input type="hidden" name="Name" value="@Model.Name" />
            <input type="hidden" name="RelatedPerson" value="@Model.RelatedPerson" />
            <input type="hidden" name="StartDateStart" value="@Model.StartDateStart" />
            <input type="hidden" name="StartDateEnd" value="@Model.StartDateEnd" />
            <input type="hidden" name="EndDateStart" value="@Model.EndDateStart" />
            <input type="hidden" name="EndDateEnd" value="@Model.EndDateEnd" />
            <input type="hidden" name="EmailSent" value="@Model.EmailSent" />
            <input type="hidden" name="EmployeeCode" value="@Model.EmployeeCode" />
            <input type="hidden" name="EmployeeName" value="@Model.EmployeeName" />
            <input type="hidden" name="TaskType" value="@Model.TaskType" />
            <input type="hidden" name="OvertimeType" value="@Model.OvertimeType" />
            <input type="hidden" name="ProductId" value="@Model.ProductId" />
            <input type="hidden" name="ProductCode" value="@Model.ProductCode" />
            <input type="hidden" name="ProductName" value="@Model.ProductName" />
            <input type="hidden" name="First" value="@Model.First" />
            <input type="hidden" name="PageSize" value="@Model.PageSize" />
            @foreach (var selectedReference in Model.SelectedReferences)
            {
                <input type="hidden" name="SelectedReferences" value="@selectedReference" />
            }
            @foreach (var jobReference in persistedJobReferences)
            {
                <input type="hidden" name="JobReferences" value="@jobReference" data-job-picker-persisted-reference />
            }

            <section class="invoice-table-card">
                <div class="invoice-table-card__header">
                    <h3 class="invoice-table-card__title">İş (@Model.Items.Count)</h3>
                </div>
                <div class="invoice-table-wrap">
                    <table class="invoice-table invoice-table--compact">
                        <thead>
                            <tr>
                                <th class="text-center">
                                    <input type="checkbox"
                                           aria-label="Tüm işleri seç"
                                           data-job-picker-select-all />
                                </th>
                                <th>Fonksiyon</th>
                                <th>Referans</th>
                                <th>Başlangıç Tarihi</th>
                                <th>Bitiş Tarihi</th>
                                <th>Müşteri</th>
                                <th>Ad</th>
                                <th>Durum</th>
                                <th>Değerlendirildi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < Model.Items.Count; i++)
                            {
                                var item = Model.Items[i];
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox"
                                               name="JobReferences"
                                               value="@item.Reference"
                                               @(Model.JobReferences.Contains(item.Reference) ? "checked" : "")
                                               data-job-picker-row-checkbox />
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Function) ? "-" : item.Function)</td>
                                    <td>@item.Reference</td>
                                    <td>@item.StartDate.ToString("dd/MM/yyyy HH:mm", CultureInfo.InvariantCulture)</td>
                                    <td>@item.EndDate.ToString("dd/MM/yyyy HH:mm", CultureInfo.InvariantCulture)</td>
                                    <td>@item.CustomerName</td>
                                    <td>@item.Name</td>
                                    <td>Fiyatlandı</td>
                                    <td class="text-center"><input type="checkbox" disabled /></td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr>
                                    <td colspan="9" class="text-center">Kayıt bulunamadı.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <div class="invoice-footer-bar invoice-footer-bar--center">
                @if (totalCount > 0)
                {
                    <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Sayfalama">
                        @if (!string.IsNullOrWhiteSpace(previousPageUrl))
                        {
                            <a href="@previousPageUrl"
                               data-job-picker-page-link
                               class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                               title="Önceki">
                                <span class="sr-only">Önceki</span>
                                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                                </svg>
                            </a>
                        }
                        else
                        {
                            <span class="relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400 cursor-not-allowed">
                                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        }

                        @if (!string.IsNullOrWhiteSpace(nextPageUrl))
                        {
                            <a href="@nextPageUrl"
                               data-job-picker-page-link
                               class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50"
                               title="Sonraki">
                                <span class="sr-only">Sonraki</span>
                                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                </svg>
                            </a>
                        }
                        else
                        {
                            <span class="relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-gray-100 text-sm font-medium text-gray-400 cursor-not-allowed">
                                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        }
                    </nav>
                }
                <div class="flex flex-wrap justify-center gap-1">
                    @if (Model.Context == "line")
                    {
                        <button type="submit" class="inline-flex items-center border border-blue-400 text-sm font-medium text-blue-900 bg-blue-100 hover:bg-blue-200">
                            Fatura Satırına Ekle
                        </button>
                    }
                    else
                    {
                        <button type="submit"
                                name="Mode"
                                value="@((int)InvoiceAddJobsMode.SingleLine)"
                                class="inline-flex items-center border border-blue-400 text-sm font-medium text-blue-900 bg-blue-100 hover:bg-blue-200">
                            Faturaya Ekle
                        </button>
                        <button type="submit"
                                name="Mode"
                                value="@((int)InvoiceAddJobsMode.GroupByName)"
                                class="inline-flex items-center border border-blue-400 text-sm font-medium text-blue-900 bg-blue-100 hover:bg-blue-200">
                            İsme Göre Faturaya Ekle
                        </button>
                    }
                    <a href="@criteriaUrl" class="inline-flex items-center border border-blue-400 text-sm font-medium text-blue-900 bg-blue-100 hover:bg-blue-200">Geri</a>
                </div>
            </div>
        </form>
    }

    <div class="invoice-job-picker__copyright">© 2005 Imajonline.com - Her hakkı saklıdır.</div>

    <partial name="_ProductSelectModal" />
    <partial name="_EmployeeSelectModal" />
    <partial name="_CustomerSelectModal" />
</div>

<script>
    function invoiceJobPicker() {
        return {
            selectedJobReferences: @Html.Raw(selectedJobReferencesJson),
            filter: {
                jobCustomerCode: @Html.Raw(JsonValue(Model.JobCustomerCode)),
                jobCustomerName: @Html.Raw(JsonValue(Model.JobCustomerName)),
                function: @Html.Raw(JsonValue(Model.Function)),
                employeeCode: @Html.Raw(JsonValue(Model.EmployeeCode)),
                employeeName: @Html.Raw(JsonValue(Model.EmployeeName)),
                taskType: @Html.Raw(JsonValue(Model.TaskType)),
                overtimeType: @Html.Raw(JsonValue(Model.OvertimeType)),
                emailSent: @Html.Raw(JsonValue(Model.EmailSent)),
                productId: @Html.Raw(JsonValue(Model.ProductId)),
                productCode: @Html.Raw(JsonValue(Model.ProductCode)),
                productName: @Html.Raw(JsonValue(Model.ProductName))
            },
            get customerDisplay() {
                if (this.filter.jobCustomerCode && this.filter.jobCustomerName) {
                    return this.filter.jobCustomerCode + ' - ' + this.filter.jobCustomerName;
                }
                return this.filter.jobCustomerCode || this.filter.jobCustomerName || '';
            },
            handleCustomerSelection(detail) {
                if (detail.targetId !== 'invoiceJobCustomer') {
                    return;
                }
                const customer = detail.customer;
                this.filter.jobCustomerCode = customer?.code || '';
                this.filter.jobCustomerName = customer?.name || '';
            },
            handleProductSelection(detail) {
                if (detail.targetId !== 'invoiceJobProduct') {
                    return;
                }
                const product = detail.product || (detail.products && detail.products[0]);
                if (!product) {
                    return;
                }
                this.filter.productId = product.id || '';
                this.filter.productCode = product.code || '';
                this.filter.productName = product.name || '';
            },
            handleEmployeeSelection(detail) {
                if (detail.targetId !== 'invoiceJobEmployee') {
                    return;
                }
                const employee = detail.employee;
                this.filter.employeeCode = employee?.code || '';
                this.filter.employeeName = employee?.name || '';
            }
        };
    }

    function getCurrentPageJobReferences() {
        return Array.from(document.querySelectorAll('[data-job-picker-row-checkbox]'))
            .map(function (checkbox) {
                return checkbox.value;
            });
    }

    function collectSelectedJobReferences() {
        const currentPageReferences = new Set(getCurrentPageJobReferences());
        const selected = new Set();

        document
            .querySelectorAll('input[name="JobReferences"]')
            .forEach(function (input) {
                if (!input.value || currentPageReferences.has(input.value)) {
                    return;
                }
                selected.add(input.value);
            });

        document
            .querySelectorAll('[data-job-picker-row-checkbox]:checked')
            .forEach(function (checkbox) {
                selected.add(checkbox.value);
            });

        return Array.from(selected);
    }

    function appendSelectedJobsToUrl(url) {
        const target = new URL(url, window.location.origin);
        target.searchParams.delete('JobReferences');
        collectSelectedJobReferences().forEach(function (reference) {
            target.searchParams.append('JobReferences', reference);
        });
        return target.pathname + target.search + target.hash;
    }

    function refreshHeaderCheckbox() {
        const rowCheckboxes = Array.from(document.querySelectorAll('[data-job-picker-row-checkbox]'));
        const checkedCount = rowCheckboxes.filter(function (checkbox) {
            return checkbox.checked;
        }).length;
        const headerCheckbox = document.querySelector('[data-job-picker-select-all]');

        if (!headerCheckbox) {
            return;
        }

        headerCheckbox.checked = rowCheckboxes.length > 0 && checkedCount === rowCheckboxes.length;
        headerCheckbox.indeterminate = checkedCount > 0 && checkedCount < rowCheckboxes.length;
    }

    document.addEventListener('DOMContentLoaded', refreshHeaderCheckbox);

    document.addEventListener('click', function (event) {
        const pageLink = event.target.closest('[data-job-picker-page-link]');
        if (!pageLink) {
            return;
        }

        event.preventDefault();
        window.location.href = appendSelectedJobsToUrl(pageLink.href);
    });

    document.addEventListener('submit', function (event) {
        const form = event.target.closest('form[action="/Invoice/AddJobsToInvoice"], form[action="/Invoice/AddJobsToInvoiceLine"]');
        if (!form) {
            return;
        }

        const selectedReferences = collectSelectedJobReferences();
        const currentPageReferences = new Set(getCurrentPageJobReferences());
        form.querySelectorAll('[data-job-picker-persisted-reference]').forEach(function (input) {
            input.remove();
        });

        selectedReferences.forEach(function (reference) {
            if (currentPageReferences.has(reference)) {
                return;
            }

            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'JobReferences';
            input.value = reference;
            input.dataset.jobPickerPersistedReference = 'true';
            form.appendChild(input);
        });
    });

    document.addEventListener('change', function (event) {
        const selectAll = event.target.closest('[data-job-picker-select-all]');
        if (selectAll) {
            document
                .querySelectorAll('[data-job-picker-row-checkbox]')
                .forEach(function (checkbox) {
                    checkbox.checked = selectAll.checked;
                });
            selectAll.indeterminate = false;
            return;
        }

        if (!event.target.closest('[data-job-picker-row-checkbox]')) {
            return;
        }
        refreshHeaderCheckbox();
    });
</script>
