@using System.Text.Json
@using System.Net
@model InvoiceViewModel

@{
    ViewData["Title"] = Localizer["Invoice"];

    var query = new Dictionary<string, string>();
    if (!string.IsNullOrWhiteSpace(Model.JobCustomerCode)) query.Add("JobCustomerCode", Model.JobCustomerCode);
    if (!string.IsNullOrWhiteSpace(Model.JobCustomerName)) query.Add("JobCustomerName", Model.JobCustomerName);
    if (!string.IsNullOrWhiteSpace(Model.InvoiceCustomerCode)) query.Add("InvoiceCustomerCode", Model.InvoiceCustomerCode);
    if (!string.IsNullOrWhiteSpace(Model.InvoiceCustomerName)) query.Add("InvoiceCustomerName", Model.InvoiceCustomerName);
    if (!string.IsNullOrWhiteSpace(Model.ReferenceStart)) query.Add("ReferenceStart", Model.ReferenceStart);
    if (!string.IsNullOrWhiteSpace(Model.ReferenceEnd)) query.Add("ReferenceEnd", Model.ReferenceEnd);
    if (!string.IsNullOrWhiteSpace(Model.Name)) query.Add("Name", Model.Name);
    if (!string.IsNullOrWhiteSpace(Model.RelatedPerson)) query.Add("RelatedPerson", Model.RelatedPerson);
    if (Model.IssueDateStart.HasValue) query.Add("IssueDateStart", Model.IssueDateStart.Value.ToString("yyyy-MM-dd"));
    if (Model.IssueDateEnd.HasValue) query.Add("IssueDateEnd", Model.IssueDateEnd.Value.ToString("yyyy-MM-dd"));
    if (!string.IsNullOrWhiteSpace(Model.Status)) query.Add("Status", Model.Status);
    if (!string.IsNullOrWhiteSpace(Model.Evaluated)) query.Add("Evaluated", Model.Evaluated);
    if (Model.First.HasValue && Model.First.Value > 0) query.Add("First", Model.First.Value.ToString());

    var queryString = string.Join("&", query.Select(x => x.Key + "=" + WebUtility.UrlEncode(x.Value)));
    var returnUrl = "/Invoice/Results" + (Context.Request.QueryString.HasValue ? Context.Request.QueryString.Value : string.Empty);
    var allRefs = Model.Items.Select(x => x.Reference ?? string.Empty).Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
}

<div x-data="invoiceResults()" class="invoice-page-shell page-shell--wide space-y-3">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="invoice-page-title">
                @Localizer["InvoiceList"]
            </h2>
        </div>
        <div class="mt-3 md:mt-0 invoice-page-actions">
            <a href="/Invoice" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["NewSearch"]</a>
        </div>
    </div>

    <form method="get" action="/Invoice/Detail">
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        <div class="invoice-table-card">
            <div class="invoice-table-card__header">
                <h3 class="invoice-table-card__title">@Localizer["Invoice"]</h3>
                <span class="invoice-table__count">@Model.TotalCount</span>
            </div>
            <div class="invoice-table-wrap">
                <table class="invoice-table invoice-table--compact">
                    <thead>
                                <tr>
                                    <th scope="col">
                                        <div class="flex items-center">
                                            <input type="checkbox" @@click="toggleAll" x-model="allSelected" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded mr-2">
                                            <span class="text-xs font-bold text-gray-700 uppercase tracking-wider cursor-pointer" @@click="toggleAll(); allSelected = !allSelected">@Localizer["Select"]</span>
                                        </div>
                                    </th>
                                    <th scope="col">@Localizer["Reference"]</th>
                                    <th scope="col">@Localizer["JobCustomer"]</th>
                                    <th scope="col">@Localizer["InvoiceCustomer"]</th>
                                    <th scope="col">@Localizer["Name"]</th>
                                    <th scope="col">@Localizer["Date"]</th>
                                    <th scope="col">@Localizer["Status"]</th>
                                    <th scope="col" class="text-right">@Localizer["Amount"]</th>
                                    <th scope="col">@Localizer["Evaluated"]</th>
                                </tr>
                    </thead>
                    <tbody>
                                @if (Model.Items.Any())
                                {
                                    foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="whitespace-nowrap">
                                                <input type="checkbox" name="selectedReferences" value="@item.Reference" x-model="selectedReferences" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                            </td>
                                            <td class="whitespace-nowrap text-sm font-bold">
                                                <a href="/Invoice/Detail?reference=@item.Reference&returnUrl=@WebUtility.UrlEncode(returnUrl)" class="text-blue-600 hover:text-blue-900 underline">@item.Reference</a>
                                            </td>
                                            <td class="whitespace-nowrap text-sm text-gray-900">@item.JobCustomer</td>
                                            <td class="whitespace-nowrap text-sm text-gray-900">@item.InvoiceCustomer</td>
                                            <td class="whitespace-nowrap text-sm text-gray-900">@item.Name</td>
                                            <td class="whitespace-nowrap text-sm text-gray-700">@item.IssueDate?.ToString("dd/MM/yyyy")</td>
                                            <td class="whitespace-nowrap text-sm text-gray-700">@item.Status</td>
                                            <td class="whitespace-nowrap text-sm text-gray-900 text-right">@item.Amount.ToString("N2")</td>
                                            <td class="whitespace-nowrap text-sm text-gray-700">
                                                @if (item.Evaluated)
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">@Localizer["Yes"]</span>
                                                }
                                                else
                                                {
                                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">@Localizer["No"]</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="9" class="text-center text-sm text-gray-500">@Localizer["NoRecordsFound"]</td>
                                    </tr>
                                }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-3">
            @if (Model.TotalCount > 0)
            {
                <partial name="Components/_Pagination" model="@(new Imaj.Web.Models.Components.PaginationModel 
                { 
                    CurrentPage = Model.Page, 
                    TotalCount = Model.TotalCount, 
                    PageSize = Model.PageSize,
                    BaseUrl = @"/Invoice/Results",
                    QueryString = queryString
                })" />
            }

            <div class="invoice-footer-bar invoice-footer-bar--center responsive-action-group">
                <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50" :disabled="selectedReferences.length === 0">
                    @Localizer["ViewDetail"]
                </button>
                <button type="submit" formaction="/Invoice/Summary" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50" :disabled="selectedReferences.length === 0">
                    @Localizer["ViewSummary"]
                </button>
            </div>
        </div>
    </form>
</div>

<script>
    function invoiceResults() {
        return {
            selectedReferences: [],
            allSelected: false,
            allPageReferences: @Html.Raw(JsonSerializer.Serialize(allRefs)),

            toggleAll() {
                this.allSelected = !this.allSelected;
                this.selectedReferences = this.allSelected ? [...this.allPageReferences] : [];
            }
        }
    }
</script>
