@model InvoiceHistoryViewModel

@{
    ViewData["Title"] = Localizer["InvoiceHistory"];
}

<div class="invoice-page-shell page-shell--wide space-y-3">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="invoice-page-title">
                @Localizer["InvoiceHistory"]: <span class="text-indigo-600">@Model.Invoice.Reference</span>
            </h2>
        </div>
        <div class="mt-3 md:mt-0 invoice-page-actions">
            <a href="@Model.ReturnUrl" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">@Localizer["Back"]</a>
        </div>
    </div>

    <div class="invoice-detail-grid">
        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="invoice-detail-list">
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["Reference"]</dt>
                        <dd class="invoice-detail-item__value">@Model.Invoice.Reference</dd>
                    </div>
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["JobCustomer"]</dt>
                        <dd class="invoice-detail-item__value">@Model.Invoice.JobCustomer</dd>
                    </div>
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["InvoiceCustomer"]</dt>
                        <dd class="invoice-detail-item__value">@Model.Invoice.InvoiceCustomer</dd>
                    </div>
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["Name"]</dt>
                        <dd class="invoice-detail-item__value">@Model.Invoice.Name</dd>
                    </div>
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["Related"]</dt>
                        <dd class="invoice-detail-item__value">@Model.Invoice.RelatedPerson</dd>
                    </div>
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["Date"]</dt>
                        <dd class="invoice-detail-item__value">@Model.Invoice.IssueDate?.ToString("dd/MM/yyyy dddd") ?? "-"</dd>
                    </div>
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["Status"]</dt>
                        <dd class="invoice-detail-item__value">@Model.Invoice.Status</dd>
                    </div>
                    <div class="invoice-detail-item">
                        <dt class="invoice-detail-item__label">@Localizer["Evaluated"]</dt>
                        <dd class="invoice-detail-item__value">
                            <input type="checkbox" disabled @(Model.Invoice.Evaluated ? "checked" : "") class="dense-checkbox text-blue-600 border-gray-300 rounded">
                        </dd>
                    </div>
                </dl>
            </div>
        </section>

        <div class="invoice-note-stack">
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["Notes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <div class="invoice-detail-item__value whitespace-pre-wrap">@Model.Invoice.Notes</div>
                </div>
            </section>
            <section class="dense-panel">
                <div class="dense-panel__header">
                    <h3 class="dense-panel__title">@Localizer["Notes"]</h3>
                </div>
                <div class="dense-panel__body">
                    <div class="invoice-detail-item__value whitespace-pre-wrap">@Model.Invoice.FooterNote</div>
                </div>
            </section>
        </div>
    </div>

    <section class="invoice-table-card">
        <div class="invoice-table-card__header">
            <h3 class="invoice-table-card__title">@Localizer["ViewHistory"] (@Model.Items.Count)</h3>
        </div>
        <div class="invoice-table-wrap">
            <table class="invoice-table invoice-table--compact">
                <thead>
                    <tr>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Code"]</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Name"]</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Date"]</th>
                        <th scope="col" class="px-6 py-2 text-left text-xs font-bold text-gray-700 uppercase">@Localizer["Description"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Items.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-blue-50 even:bg-yellow-50">
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.UserCode</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.UserName</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900">@item.Date.ToString("dd/MM/yyyy HH:mm dddd")</td>
                                <td class="px-6 py-2 whitespace-nowrap text-sm text-gray-900 font-bold">@item.Action</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500">
                                @Localizer["HistoryRecordNotFound"]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <div class="invoice-footer-bar invoice-footer-bar--center">
        <a href="@Model.ReturnUrl" class="inline-flex items-center px-4 py-1 border border-blue-600 text-sm font-bold rounded shadow-sm text-white bg-blue-500 hover:bg-blue-700 focus:outline-none">@Localizer["Back"]</a>
    </div>

    <div class="text-center text-xs text-white bg-blue-900 py-2 mt-4">
        © 2005 Imajonline.com - Her hakkı saklıdır.
    </div>
</div>
