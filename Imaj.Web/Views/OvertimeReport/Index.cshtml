@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@model OvertimeReportViewModel

@{
    ViewData["Title"] = Localizer["OvertimeReport"];
}

<div x-data="overtimeReport()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@employee-selected.window="handleEmployeeSelection($event.detail)" class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                @Localizer["OvertimeReport"]
            </h2>
        </div>
    </div>

    <!-- Main Query Card -->
    <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                
                <!-- Date Range -->
                <div class="sm:col-span-3">
                    <label for="start-date" class="block text-sm font-medium text-gray-700">Başlangıç Tarihi</label>
                    <div class="mt-1">
                        <input type="date" name="start-date" id="start-date" x-model="startDate" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <div class="sm:col-span-3">
                    <label for="end-date" class="block text-sm font-medium text-gray-700">Bitiş Tarihi</label>
                    <div class="mt-1">
                        <input type="date" name="end-date" id="end-date" x-model="endDate" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <!-- Employee Selection -->
                <div class="sm:col-span-6">
                    <label class="block text-sm font-medium text-gray-700">Çalışan</label>
                    <div class="mt-1 flex rounded-md shadow-sm">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="selectedEmployeeName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300" placeholder="Tüm Çalışanlar">
                        </div>
                        <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'mainEmployee', isMultiSelect: true })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                            <!-- Search Icon -->
                            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                            <span>Seç</span>
                        </button>
                    </div>
                </div>

                <!-- Customer Selection -->
                <div class="sm:col-span-6">
                    <label class="block text-sm font-medium text-gray-700">Müşteri</label>
                     <div class="mt-1 flex rounded-md shadow-sm">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="selectedCustomerName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300" placeholder="Tüm Müşteriler">
                        </div>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'main' })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                             <span>Seç</span>
                        </button>
                    </div>
                </div>

            </div>
            
            <!-- Action Buttons -->
            <div class="mt-8 flex justify-end space-x-3">
                 <button type="button" @@click="downloadDetailedReport()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Detay Rapor Bas
                </button>
                <button type="button" @@click="downloadSummaryReport()" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    Özet Rapor Bas
                </button>
                 <button type="button" @@click="downloadAdministrativeSummaryReport()" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    İdari Özet Raporu Bas
                </button>
            </div>
        </div>
    </div>

    <!-- Modals -->
    <partial name="_CustomerSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script>
    function overtimeReport() {
        return {
            startDate: '@Model.StartDate.ToString("yyyy-MM-dd")',
            endDate: '@Model.EndDate.ToString("yyyy-MM-dd")',
            selectedEmployeeName: '',
            selectedEmployees: [], 
            
            selectedCustomerName: '',
            selectedCustomerCode: '',

            init() {
                // Initialize
            },
            
            // Shared Modal Handlers
            handleCustomerSelection(detail) {
                if(detail.targetId === 'main') {
                    this.selectedCustomerName = detail.customer.name;
                    this.selectedCustomerCode = detail.customer.code;
                }
            },
            
            handleEmployeeSelection(detail) {
                if(detail.targetId === 'mainEmployee') {
                    const employees = detail.employees || (detail.employee ? [detail.employee] : []);
                    this.selectedEmployees = employees;
                    
                    if (employees.length > 0) {
                        this.selectedEmployeeName = employees.map(e => e.name).join(', ');
                    } else {
                        this.selectedEmployeeName = '';
                    }
                }
            },

            buildDownloadParams() {
                if (!this.startDate || !this.endDate) {
                    alert('Başlangıç ve bitiş tarihi zorunludur.');
                    return null;
                }

                const employeeCodes = this.selectedEmployees
                    .map(e => e.code)
                    .filter(Boolean);

                const employeeNames = this.selectedEmployees
                    .map(e => e.name)
                    .filter(Boolean);

                const params = new URLSearchParams({
                    startDate: this.startDate,
                    endDate: this.endDate
                });

                if (this.selectedCustomerCode) {
                    params.append('customerCode', this.selectedCustomerCode);
                }
                if (this.selectedCustomerName) {
                    params.append('customerName', this.selectedCustomerName);
                }
                if (employeeCodes.length > 0) {
                    params.append('employeeCodes', employeeCodes.join(','));
                }
                if (employeeNames.length > 0) {
                    params.append('employeeNames', employeeNames.join(', '));
                }

                return params;
            },

            downloadReport(actionName) {
                const params = this.buildDownloadParams();
                if (!params) {
                    return;
                }

                window.location.href = `/OvertimeReport/${actionName}?${params.toString()}`;
            },

            downloadDetailedReport() {
                this.downloadReport('DownloadDetailedExcel');
            },

            downloadSummaryReport() {
                this.downloadReport('DownloadSummaryExcel');
            },

            downloadAdministrativeSummaryReport() {
                this.downloadReport('DownloadAdministrativeSummaryExcel');
            }
        }
    }
</script>
