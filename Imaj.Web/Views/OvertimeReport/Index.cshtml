@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Imaj.Web.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@inject IPermissionViewService PermissionViewService
@model OvertimeReportViewModel

@{
    ViewData["Title"] = Localizer["OvertimeReport"];
    var canDownloadDetailed = await PermissionViewService.CanExecuteMethodAsync(1698);
    var canDownloadSummary = await PermissionViewService.CanExecuteMethodAsync(1745);
    var canDownloadAdministrativeSummary = await PermissionViewService.CanExecuteMethodAsync(2917);
}

<div x-data="overtimeReport()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@employee-selected.window="handleEmployeeSelection($event.detail)" class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["OvertimeReport"]
            </h2>
        </div>
    </div>

    <div class="bg-white shadow sm:rounded-lg border border-gray-200 w-full max-w-5xl mx-auto text-left">
        <div class="px-4 py-5 sm:p-6 space-y-6 mobile-stack-form">
            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                
                <!-- Date Range -->
                <div class="sm:col-span-3">
                    <label for="start-date" class="block text-sm font-medium text-gray-700">@Localizer["StartDate"]</label>
                    <div class="mt-1">
                        <input type="date" name="start-date" id="start-date" x-model="startDate" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <div class="sm:col-span-3">
                    <label for="end-date" class="block text-sm font-medium text-gray-700">@Localizer["EndDate"]</label>
                    <div class="mt-1">
                        <input type="date" name="end-date" id="end-date" x-model="endDate" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <!-- Employee Selection -->
                <div class="sm:col-span-6">
                    <label class="block text-sm font-medium text-gray-700">@Localizer["Employee"]</label>
                    <div class="mt-1 flex rounded-md shadow-sm picker-combo">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="selectedEmployeeName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300" placeholder="@Localizer["AllOption"]">
                        </div>
                        <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'mainEmployee', isMultiSelect: true })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                            <!-- Search Icon -->
                            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                            <span>@Localizer["Select"]</span>
                        </button>
                    </div>
                </div>

                <!-- Customer Selection -->
                <div class="sm:col-span-6">
                    <label class="block text-sm font-medium text-gray-700">@Localizer["Customer"]</label>
                     <div class="mt-1 flex rounded-md shadow-sm picker-combo">
                        <div class="relative flex-grow focus-within:z-10">
                             <input type="text" readonly x-model="selectedCustomerName" class="focus:ring-indigo-500 focus:border-indigo-500 block w-full rounded-none rounded-l-md sm:text-sm border-gray-300" placeholder="@Localizer["AllOption"]">
                        </div>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'main', searchEndpoint: '/OvertimeReport/CustomerSearch', jobStatesEndpoint: '/OvertimeReport/CustomerJobStates' })" class="-ml-px relative inline-flex items-center space-x-2 px-4 py-2 border border-gray-300 text-sm font-medium rounded-r-md text-gray-700 bg-gray-50 hover:bg-gray-100 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                            <svg class="h-5 w-5 text-gray-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                            </svg>
                             <span>@Localizer["Select"]</span>
                        </button>
                    </div>
                </div>

            </div>

            <div class="pt-6 border-t border-gray-200">
                <div class="flex flex-wrap items-center justify-center gap-3 responsive-action-group">
                @if (canDownloadDetailed)
                {
                    <button type="button" @@click="downloadDetailedReport()" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["PrintReport"]
                    </button>
                }
                @if (canDownloadSummary)
                {
                    <button type="button" @@click="downloadSummaryReport()" class="inline-flex items-center px-4 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                        @Localizer["PrintReport"]
                    </button>
                }
                @if (canDownloadAdministrativeSummary)
                {
                    <button type="button" @@click="downloadAdministrativeSummaryReport()" class="inline-flex items-center px-4 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                        @Localizer["AdminSummaryReport"]
                    </button>
                }
                @if (!canDownloadDetailed && !canDownloadSummary && !canDownloadAdministrativeSummary)
                {
                    <span class="text-sm text-gray-500">@Localizer["ReportDataUnavailable"]</span>
                }
                </div>
            </div>
        </div>
    </div>

    <partial name="_CustomerSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script>
    function overtimeReport() {
        return {
            startDate: '@Model.StartDate.ToString("yyyy-MM-dd")',
            endDate: '@Model.EndDate.ToString("yyyy-MM-dd")',
            selectedEmployeeName: '',
            selectedEmployees: [], 
            isReportLoading: false,
            selectedCustomerName: '',
            selectedCustomerCode: '',
            messages: {
                startEndDateRequired: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartEndDateRequired"].Value)),
                endDateBeforeStart: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateBeforeStart"].Value)),
                reportDataUnavailable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ReportDataUnavailable"].Value)),
                reportLoading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value)),
                reportLoadingDetail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PrintReportStarted"].Value))
            },

            init() {
                // Initialize
            },
            
            // Shared Modal Handlers
            handleCustomerSelection(detail) {
                if(detail.targetId === 'main') {
                    this.selectedCustomerName = detail.customer.name;
                    this.selectedCustomerCode = detail.customer.code;
                }
            },
            
            handleEmployeeSelection(detail) {
                if(detail.targetId === 'mainEmployee') {
                    const employees = detail.employees || (detail.employee ? [detail.employee] : []);
                    this.selectedEmployees = employees;
                    
                    if (employees.length > 0) {
                        this.selectedEmployeeName = employees.map(e => e.name).join(', ');
                    } else {
                        this.selectedEmployeeName = '';
                    }
                }
            },

            showError(message) {
                if (window.Toast && typeof window.Toast.error === 'function') {
                    window.Toast.error(message);
                    return;
                }

                alert(message);
            },

            showLoading() {
                if (typeof Swal === 'undefined') {
                    return;
                }

                Swal.fire({
                    title: this.messages.reportLoading,
                    text: this.messages.reportLoadingDetail,
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
            },

            hideLoading() {
                if (typeof Swal !== 'undefined' && Swal.isVisible()) {
                    Swal.close();
                }
            },

            normalizeErrorMessage(rawMessage, fallback) {
                if (!rawMessage) {
                    return fallback;
                }

                const text = rawMessage.trim();
                if (!text) {
                    return fallback;
                }

                if (text.startsWith('<')) {
                    return fallback;
                }

                const textarea = document.createElement('textarea');
                textarea.innerHTML = text;
                return textarea.value || fallback;
            },

            buildDownloadParams() {
                if (!this.startDate || !this.endDate) {
                    this.showError(this.messages.startEndDateRequired);
                    return null;
                }

                if (this.endDate < this.startDate) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                const employeeCodes = this.selectedEmployees
                    .map(e => e.code)
                    .filter(Boolean);

                const employeeNames = this.selectedEmployees
                    .map(e => e.name)
                    .filter(Boolean);

                const params = new URLSearchParams({
                    startDate: this.startDate,
                    endDate: this.endDate
                });

                if (this.selectedCustomerCode) {
                    params.append('customerCode', this.selectedCustomerCode);
                }
                if (this.selectedCustomerName) {
                    params.append('customerName', this.selectedCustomerName);
                }
                if (employeeCodes.length > 0) {
                    params.append('employeeCodes', employeeCodes.join(','));
                }
                if (employeeNames.length > 0) {
                    params.append('employeeNames', employeeNames.join(', '));
                }

                return params;
            },

            async downloadReport(actionName) {
                const params = this.buildDownloadParams();
                if (!params) {
                    return;
                }

                if (this.isReportLoading) {
                    return;
                }

                this.isReportLoading = true;
                this.showLoading();
                let loadingClosed = false;

                try {
                    const response = await fetch(`/OvertimeReport/${actionName}?${params.toString()}`, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        const rawMessage = await response.text();
                        const fallback = this.messages.reportDataUnavailable;
                        this.hideLoading();
                        loadingClosed = true;
                        this.showError(this.normalizeErrorMessage(rawMessage, fallback));
                        return;
                    }

                    const blob = await response.blob();
                    const contentDisposition = response.headers.get('content-disposition') || '';
                    const fileNameUtfMatch = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
                    const fileNameMatch = contentDisposition.match(/filename=\"?([^\";]+)\"?/i);

                    let fileName = 'report.xlsx';
                    if (fileNameUtfMatch && fileNameUtfMatch[1]) {
                        fileName = decodeURIComponent(fileNameUtfMatch[1]);
                    } else if (fileNameMatch && fileNameMatch[1]) {
                        fileName = fileNameMatch[1];
                    }

                    const objectUrl = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = objectUrl;
                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(objectUrl);
                } catch (error) {
                    const fallback = (window.imajTexts && window.imajTexts.connectionError)
                        || (window.imajTexts && window.imajTexts.genericError)
                        || this.messages.reportDataUnavailable;

                    this.hideLoading();
                    loadingClosed = true;
                    this.showError(fallback);
                } finally {
                    if (!loadingClosed) {
                        this.hideLoading();
                    }

                    this.isReportLoading = false;
                }
            },

            async downloadDetailedReport() {
                await this.downloadReport('DownloadDetailedExcel');
            },

            async downloadSummaryReport() {
                await this.downloadReport('DownloadSummaryExcel');
            },

            async downloadAdministrativeSummaryReport() {
                await this.downloadReport('DownloadAdministrativeSummaryExcel');
            }
        }
    }
</script>
