@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web
@using Imaj.Web.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResource> Localizer
@inject IPermissionViewService PermissionViewService
@model OvertimeReportViewModel

@{
    ViewData["Title"] = Localizer["OvertimeReport"];
    var canDownloadDetailed = await PermissionViewService.CanExecuteMethodAsync(1698);
    var canDownloadSummary = await PermissionViewService.CanExecuteMethodAsync(1745);
    var canDownloadAdministrativeSummary = await PermissionViewService.CanExecuteMethodAsync(2917);
}

<div x-data="overtimeReport()" @@customer-selected.window="handleCustomerSelection($event.detail)" @@employee-selected.window="handleEmployeeSelection($event.detail)" class="job-page-shell job-index-shell job-index-reference report-index-reference overtime-report-index-reference page-shell--wide space-y-2">
    <div class="text-center job-index-heading">
        <h2 class="job-page-title job-page-title--orange">
            @Localizer["OvertimeReport"]
        </h2>
    </div>

    <section class="dense-panel report-index-panel">
        <div class="dense-panel__header">
            <h3 class="dense-panel__title">@Localizer["MainCriteria"]</h3>
        </div>
        <div class="dense-panel__body mobile-stack-form">
            <div class="dense-form-grid report-index-criteria-list">
                <div class="dense-form-row">
                    <label for="OvertimeReportStartDate">@Localizer["StartDate"]</label>
                    <input type="date" name="start-date" id="OvertimeReportStartDate" x-model="startDate" class="dense-input" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="dense-form-row">
                    <label for="OvertimeReportEndDate">@Localizer["EndDate"]</label>
                    <input type="date" name="end-date" id="OvertimeReportEndDate" x-model="endDate" class="dense-input" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="dense-form-row">
                    <label>@Localizer["Employee"]</label>
                    <div class="report-index-selector">
                        <span class="report-index-selector__value" x-text="selectedEmployeeName || '-'"></span>
                        <span class="report-index-selector__separator">-</span>
                        <button type="button" @@click="$dispatch('employee-select-open', { targetId: 'mainEmployee', isMultiSelect: true })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                            @Localizer["Select"]
                        </button>
                    </div>
                </div>
                <div class="dense-form-row">
                    <label>@Localizer["Customer"]</label>
                    <div class="report-index-selector">
                        <span class="report-index-selector__value" x-text="selectedCustomerName || '-'"></span>
                        <span class="report-index-selector__separator">-</span>
                        <button type="button" @@click="$dispatch('customer-select-open', { targetId: 'main', searchEndpoint: '/OvertimeReport/CustomerSearch', jobStatesEndpoint: '/OvertimeReport/CustomerJobStates' })" class="inline-flex items-center px-3 py-1 border border-blue-300 rounded-md bg-blue-100 text-blue-900 font-semibold hover:bg-blue-200">
                            @Localizer["Select"]
                        </button>
                    </div>
                </div>
            </div>

            <div class="report-index-panel__actions">
                <div class="job-index-action-group report-index-report-group responsive-action-group">
                    @if (canDownloadDetailed)
                    {
                        <button type="button" @@click="downloadDetailedReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                            @Localizer["DetailedOvertimeReportTitle"] - Excel
                        </button>
                        <button type="button" @@click="openDetailedReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                            @Localizer["DetailedOvertimeReportTitle"] - PDF
                        </button>
                    }
                    @if (canDownloadSummary)
                    {
                        <button type="button" @@click="downloadSummaryReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                            @Localizer["SummaryOvertimeReportTitle"] - Excel
                        </button>
                        <button type="button" @@click="openSummaryReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                            @Localizer["SummaryOvertimeReportTitle"] - PDF
                        </button>
                    }
                    @if (canDownloadAdministrativeSummary)
                    {
                        <button type="button" @@click="downloadAdministrativeSummaryReport()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-blue-300 shadow-sm text-sm font-medium rounded-md text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                            @Localizer["AdminSummaryOvertimeReportTitle"] - Excel
                        </button>
                        <button type="button" @@click="openAdministrativeSummaryReportPage()" :disabled="isReportLoading" :class="{ 'opacity-50 cursor-not-allowed': isReportLoading }" class="inline-flex items-center px-4 py-1 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                            @Localizer["AdminSummaryOvertimeReportTitle"] - PDF
                        </button>
                    }
                    @if (!canDownloadDetailed && !canDownloadSummary && !canDownloadAdministrativeSummary)
                    {
                        <span class="text-sm text-gray-500">@Localizer["ReportDataUnavailable"]</span>
                    }
                </div>
            </div>
        </div>
    </section>

    <partial name="_CustomerSelectModal" />
    <partial name="_EmployeeSelectModal" />
</div>

<script>
    function overtimeReport() {
        return {
            startDate: '@Model.StartDate.ToString("yyyy-MM-dd")',
            endDate: '@Model.EndDate.ToString("yyyy-MM-dd")',
            selectedEmployeeName: '',
            selectedEmployees: [], 
            isReportLoading: false,
            selectedCustomerName: '',
            selectedCustomerCode: '',
            messages: {
                startEndDateRequired: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["StartEndDateRequired"].Value)),
                endDateBeforeStart: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["EndDateBeforeStart"].Value)),
                reportDataUnavailable: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["ReportDataUnavailable"].Value)),
                reportLoading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value)),
                reportLoadingDetail: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["PrintReportStarted"].Value))
            },

            init() {
                // Initialize
            },
            
            // Shared Modal Handlers
            handleCustomerSelection(detail) {
                if(detail.targetId === 'main') {
                    this.selectedCustomerName = detail.customer.name;
                    this.selectedCustomerCode = detail.customer.code;
                }
            },
            
            handleEmployeeSelection(detail) {
                if(detail.targetId === 'mainEmployee') {
                    const employees = detail.employees || (detail.employee ? [detail.employee] : []);
                    this.selectedEmployees = employees;
                    
                    if (employees.length > 0) {
                        this.selectedEmployeeName = employees.map(e => e.name).join(', ');
                    } else {
                        this.selectedEmployeeName = '';
                    }
                }
            },

            showError(message) {
                if (window.Toast && typeof window.Toast.error === 'function') {
                    window.Toast.error(message);
                    return;
                }

                alert(message);
            },

            showLoading() {
                if (typeof Swal === 'undefined') {
                    return;
                }

                Swal.fire({
                    title: this.messages.reportLoading,
                    text: this.messages.reportLoadingDetail,
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    showConfirmButton: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
            },

            hideLoading() {
                if (typeof Swal !== 'undefined' && Swal.isVisible()) {
                    Swal.close();
                }
            },

            normalizeErrorMessage(rawMessage, fallback) {
                if (!rawMessage) {
                    return fallback;
                }

                const text = rawMessage.trim();
                if (!text) {
                    return fallback;
                }

                if (text.startsWith('<')) {
                    return fallback;
                }

                const textarea = document.createElement('textarea');
                textarea.innerHTML = text;
                return textarea.value || fallback;
            },

            buildDownloadParams() {
                if (!this.startDate || !this.endDate) {
                    this.showError(this.messages.startEndDateRequired);
                    return null;
                }

                if (this.endDate < this.startDate) {
                    this.showError(this.messages.endDateBeforeStart);
                    return null;
                }

                const employeeCodes = this.selectedEmployees
                    .map(e => e.code)
                    .filter(Boolean);

                const employeeNames = this.selectedEmployees
                    .map(e => e.name)
                    .filter(Boolean);

                const params = new URLSearchParams({
                    startDate: this.startDate,
                    endDate: this.endDate
                });

                if (this.selectedCustomerCode) {
                    params.append('customerCode', this.selectedCustomerCode);
                }
                if (this.selectedCustomerName) {
                    params.append('customerName', this.selectedCustomerName);
                }
                if (employeeCodes.length > 0) {
                    params.append('employeeCodes', employeeCodes.join(','));
                }
                if (employeeNames.length > 0) {
                    params.append('employeeNames', employeeNames.join(', '));
                }

                return params;
            },

            async downloadReport(actionName) {
                const params = this.buildDownloadParams();
                if (!params) {
                    return;
                }

                if (this.isReportLoading) {
                    return;
                }

                this.isReportLoading = true;
                this.showLoading();
                let loadingClosed = false;

                try {
                    const response = await fetch(`/OvertimeReport/${actionName}?${params.toString()}`, {
                        method: 'GET',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (!response.ok) {
                        const rawMessage = await response.text();
                        const fallback = this.messages.reportDataUnavailable;
                        this.hideLoading();
                        loadingClosed = true;
                        this.showError(this.normalizeErrorMessage(rawMessage, fallback));
                        return;
                    }

                    const blob = await response.blob();
                    const contentDisposition = response.headers.get('content-disposition') || '';
                    const fileNameUtfMatch = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
                    const fileNameMatch = contentDisposition.match(/filename=\"?([^\";]+)\"?/i);

                    let fileName = 'report.xlsx';
                    if (fileNameUtfMatch && fileNameUtfMatch[1]) {
                        fileName = decodeURIComponent(fileNameUtfMatch[1]);
                    } else if (fileNameMatch && fileNameMatch[1]) {
                        fileName = fileNameMatch[1];
                    }

                    const objectUrl = URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = objectUrl;
                    link.download = fileName;
                    document.body.appendChild(link);
                    link.click();
                    link.remove();
                    URL.revokeObjectURL(objectUrl);
                } catch (error) {
                    const fallback = (window.imajTexts && window.imajTexts.connectionError)
                        || (window.imajTexts && window.imajTexts.genericError)
                        || this.messages.reportDataUnavailable;

                    this.hideLoading();
                    loadingClosed = true;
                    this.showError(fallback);
                } finally {
                    if (!loadingClosed) {
                        this.hideLoading();
                    }

                    this.isReportLoading = false;
                }
            },

            openReportPage(actionName) {
                const params = this.buildDownloadParams();
                if (!params) {
                    return;
                }

                window.open(`/OvertimeReport/${actionName}?${params.toString()}`, '_blank', 'noopener');
            },

            async downloadDetailedReport() {
                await this.downloadReport('DownloadDetailedExcel');
            },

            openDetailedReportPage() {
                this.openReportPage('ViewDetailedReport');
            },

            async downloadSummaryReport() {
                await this.downloadReport('DownloadSummaryExcel');
            },

            openSummaryReportPage() {
                this.openReportPage('ViewSummaryReport');
            },

            async downloadAdministrativeSummaryReport() {
                await this.downloadReport('DownloadAdministrativeSummaryExcel');
            },

            openAdministrativeSummaryReportPage() {
                this.openReportPage('ViewAdministrativeSummaryReport');
            }
        }
    }
</script>
