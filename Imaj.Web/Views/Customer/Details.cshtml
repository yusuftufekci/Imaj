@using Imaj.Web.Models
@using System.Net
@model CustomerViewModel

@{
    ViewData["Title"] = Localizer["CustomerDetails"];
    var returnUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/Customer/List" : Model.ReturnUrl;
}

<div class="customer-page-shell page-shell--wide space-y-3">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="customer-page-title">
                @Localizer["CustomerDetails"]: <span class="text-indigo-600">@Model.Code - @Model.Name</span>
            </h2>
        </div>
        <div class="mt-3 md:mt-0 customer-page-actions">
            <a href="@returnUrl" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                @Localizer["Back"]
            </a>
            <a href="/Customer/Edit/@Model.Code?returnUrl=@WebUtility.UrlEncode(returnUrl)" class="inline-flex items-center border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                @Localizer["Edit"]
            </a>
        </div>
    </div>

    <div class="customer-detail-grid">
        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["BasicInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="customer-detail-list">
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Code"]</dt>
                        <dd class="customer-detail-item__value">@Model.Code</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Name"]</dt>
                        <dd class="customer-detail-item__value">@Model.Name</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Notes"]</dt>
                        <dd class="customer-detail-item__value">@Model.Notes</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Invalid"]</dt>
                        <dd class="customer-detail-item__value">@(Model.IsInvalid ? Localizer["Yes"] : Localizer["No"])</dd>
                    </div>
                </dl>
            </div>
        </section>

        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["ContactInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="customer-detail-list">
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Owner"]</dt>
                        <dd class="customer-detail-item__value">@Model.Owner</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Related"]</dt>
                        <dd class="customer-detail-item__value">@Model.RelatedPerson</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Phone"]</dt>
                        <dd class="customer-detail-item__value">@Model.Phone</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Fax"]</dt>
                        <dd class="customer-detail-item__value">@Model.Fax</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Email"]</dt>
                        <dd class="customer-detail-item__value">@Model.Email</dd>
                    </div>
                </dl>
            </div>
        </section>

        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["AddressInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="customer-detail-list">
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Address"]</dt>
                        <dd class="customer-detail-item__value">@Model.Address</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["City"]</dt>
                        <dd class="customer-detail-item__value">@Model.City</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["AreaCode"]</dt>
                        <dd class="customer-detail-item__value">@Model.AreaCode</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Country"]</dt>
                        <dd class="customer-detail-item__value">@Model.Country</dd>
                    </div>
                </dl>
            </div>
        </section>

        <section class="dense-panel">
            <div class="dense-panel__header">
                <h3 class="dense-panel__title">@Localizer["InvoiceInfo"]</h3>
            </div>
            <div class="dense-panel__body">
                <dl class="customer-detail-list">
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["InvoiceName"]</dt>
                        <dd class="customer-detail-item__value">@Model.InvoiceName</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["TaxOffice"]</dt>
                        <dd class="customer-detail-item__value">@Model.TaxOffice</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["TaxNumber"]</dt>
                        <dd class="customer-detail-item__value">@Model.TaxNumber</dd>
                    </div>
                    <div class="customer-detail-item">
                        <dt class="customer-detail-item__label">@Localizer["Status"]</dt>
                        <dd class="customer-detail-item__value">
                            @if (!string.IsNullOrWhiteSpace(Model.JobStatus))
                            {
                                <span class="customer-tag">@Model.JobStatus</span>
                            }
                        </dd>
                    </div>
                </dl>
            </div>
        </section>

        <section class="customer-table-card customer-detail-grid__full">
            <div class="customer-table-card__header">
                <h3 class="customer-table-card__title">@Localizer["ProductCategories"]</h3>
            </div>
            @if (Model.ProductCategories != null && Model.ProductCategories.Any())
            {
                <div class="customer-table-wrap">
                    <table class="customer-table customer-table--compact">
                        <thead>
                            <tr>
                                <th scope="col">@Localizer["Name"]</th>
                                <th scope="col">@Localizer["Discount"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cat in Model.ProductCategories)
                            {
                                <tr>
                                    <td class="whitespace-nowrap">@cat.Name</td>
                                    <td class="whitespace-nowrap">%@cat.Discount.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="customer-empty-state">@Localizer["NoRecordsFound"]</div>
            }
        </section>
    </div>
</div>
