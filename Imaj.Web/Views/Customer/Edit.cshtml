@using Imaj.Web.Models
@model CustomerViewModel

@{
    ViewData["Title"] = Localizer["CustomerEdit"];
}

<div x-data="{ autoAdvance: false }" class="customer-page-shell customer-form-page page-shell--wide space-y-2">
    <div class="text-center">
        <h2 class="customer-page-title">
            @Localizer["CustomerEdit"]
        </h2>
    </div>

    <form action="/Customer/Update" method="post" class="space-y-2">
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.CustomerId)
        @Html.HiddenFor(m => m.ReturnUrl)
        
        <partial name="_CustomerForm" model="Model" />
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var hasErrors = @((!ViewData.ModelState.IsValid).ToString().ToLower());
            if (hasErrors) {
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                    text: '',
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Tamam'
                });
            }
        });
    </script>
}
    </form>
</div>
