@using Imaj.Web.Models
@model CustomerViewModel

@{
    ViewData["Title"] = Localizer["CustomerEdit"];
}

<div x-data="{ autoAdvance: false }" class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-indigo-600 sm:text-3xl sm:truncate text-center w-full">
                @Localizer["CustomerEdit"]
            </h2>
        </div>
    </div>

    <form action="/Customer/Update" method="post" class="bg-white shadow sm:rounded-lg">
        @Html.HiddenFor(m => m.CustomerId)
        
        <partial name="_CustomerForm" model="Model" />
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var hasErrors = @((!ViewData.ModelState.IsValid).ToString().ToLower());
            if (hasErrors) {
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                    text: '',
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Tamam'
                });
            }
        });
    </script>
}
    </form>
</div>
