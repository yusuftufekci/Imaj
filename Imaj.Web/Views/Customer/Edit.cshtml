@using Imaj.Web.Models
@model CustomerViewModel

@{
    ViewData["Title"] = "Müşteri Düzenle";
}

<div class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                Müşteri Düzenle: <span class="text-indigo-600">@Model.Code</span>
            </h2>
        </div>
    </div>

    <form action="/Customer/Update" method="post" class="bg-white shadow sm:rounded-lg">
        <input type="hidden" name="Code" value="@Model.Code" />
        
        <div class="px-4 py-5 sm:p-6">
             <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                 
                 <!-- Sol Kolon -->
                 <div class="space-y-6">
                     <!-- Ana Bilgiler -->
                     <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                         <h4 class="text-sm font-bold text-gray-700 mb-4 border-b pb-2">Ana Bilgiler</h4>
                         <div class="space-y-4">
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Ad</label>
                                 <input type="text" name="Name" value="@Model.Name" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                <label class="block text-sm font-medium text-gray-700">Geçersiz</label>
                                <select name="IsInvalid" class="mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                    @if(Model.IsInvalid) { <option value="false">Hayır</option> <option value="true" selected>Evet</option> }
                                    else { <option value="false" selected>Hayır</option> <option value="true">Evet</option> }
                                </select>
                            </div>
                         </div>
                     </div>

                     <!-- İletişim Bilgileri -->
                     <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                         <h4 class="text-sm font-bold text-gray-700 mb-4 border-b pb-2">İletişim Bilgileri</h4>
                         <div class="space-y-4">
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Sahibi</label>
                                 <input type="text" name="Owner" value="@Model.Owner" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">İlgili</label>
                                 <input type="text" name="RelatedPerson" value="@Model.RelatedPerson" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Telefon</label>
                                 <input type="text" name="Phone" value="@Model.Phone" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Faks</label>
                                 <input type="text" name="Fax" value="@Model.Fax" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">E-Mail</label>
                                 <input type="text" name="Email" value="@Model.Email" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                         </div>
                     </div>
                 </div>

                 <!-- Sağ Kolon -->
                 <div class="space-y-6">
                     <!-- Adres Bilgileri -->
                     <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                         <h4 class="text-sm font-bold text-gray-700 mb-4 border-b pb-2">Adres Bilgileri</h4>
                         <div class="space-y-4">
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Şehir</label>
                                 <input type="text" name="City" value="@Model.City" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Alan Kodu</label>
                                 <input type="text" name="AreaCode" value="@Model.AreaCode" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Ülke</label>
                                 <input type="text" name="Country" value="@Model.Country" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                         </div>
                     </div>

                     <!-- Fatura Bilgileri -->
                     <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                         <h4 class="text-sm font-bold text-gray-700 mb-4 border-b pb-2">Fatura Bilgileri</h4>
                         <div class="space-y-4">
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Vergi Dairesi</label>
                                 <input type="text" name="TaxOffice" value="@Model.TaxOffice" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                             <div>
                                 <label class="block text-sm font-medium text-gray-700">Vergi Numarası</label>
                                 <input type="text" name="TaxNumber" value="@Model.TaxNumber" class="mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md">
                             </div>
                         </div>
                     </div>

                     <!-- İş Bilgileri -->
                     <div class="bg-gray-50 p-4 rounded-md border border-gray-200">
                         <h4 class="text-sm font-bold text-gray-700 mb-4 border-b pb-2">İş Bilgileri</h4>
                         <div class="space-y-4">
                             <div>
                                <label class="block text-sm font-medium text-gray-700">Durum</label>
                                <select name="JobStatus" class="mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                    @if(Model.JobStatus == "Active") { <option value="Active" selected>Aktif</option> <option value="Completed">Tamamlandı</option> }
                                    else if(Model.JobStatus == "Completed") { <option value="Active">Aktif</option> <option value="Completed" selected>Tamamlandı</option> }
                                    else { <option value="">Seçiniz</option><option value="Active">Aktif</option> <option value="Completed">Tamamlandı</option> }
                                </select>
                            </div>
                         </div>
                     </div>
                 </div>

             </div>
        </div>
        
        <!-- Actions -->
        <div class="px-4 py-3 bg-gray-50 text-right sm:px-6 space-x-3">
             <a href="javascript:history.back()" class="inline-flex justify-center py-2 px-4 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Geri Dön
            </a>
            <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Değişiklikleri Kaydet
            </button>
        </div>
    </form>
</div>
