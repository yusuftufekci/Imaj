@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web.Models
@model CustomerFilterModel

@{
    ViewData["Title"] = Localizer["CustomerSearch"];
    var firstValue = Model.First.HasValue && Model.First.Value > 0
        ? Model.First.Value
        : (Model.PageSize > 0 ? Model.PageSize : 20);
}

<div x-data="customerIndex()" class="space-y-6">
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate text-center text-orange-600">
                @Localizer["CustomerOperations"]
            </h2>
        </div>
    </div>

    <form id="customer-search-form" action="/Customer/List" method="get" class="w-full max-w-5xl mx-auto text-left">
        <div class="bg-white shadow sm:rounded-lg border border-gray-200 overflow-hidden">
            <div class="px-4 py-5 sm:p-6 space-y-6">
                <h3 class="text-lg leading-6 font-medium text-orange-600 mb-4 text-center border-b pb-2">
                    @Localizer["CustomerSearch"]
                </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
                <div class="space-y-6">
                    <div class="border border-blue-200 rounded-lg overflow-hidden bg-white">
                        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["MainCriteria"]</h4>
                        </div>
                        <div class="p-4 space-y-2">
                            <div class="form-group">
                                <label class="form-label">@Localizer["Code"]</label>
                                <input type="text" name="Code" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Name"]</label>
                                <input type="text" name="Name" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Invalid"]</label>
                                <select name="IsInvalid" class="form-input">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="border border-blue-200 rounded-lg overflow-hidden bg-white">
                        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["ContactSearch"]</h4>
                        </div>
                        <div class="p-4 space-y-2">
                            <div class="form-group">
                                <label class="form-label">@Localizer["Owner"]</label>
                                <input type="text" name="Owner" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Related"]</label>
                                <input type="text" name="RelatedPerson" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Phone"]</label>
                                <input type="text" name="Phone" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Faks</label>
                                <input type="text" name="Fax" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Email"]</label>
                                <input type="text" name="Email" class="form-input">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="border border-blue-200 rounded-lg overflow-hidden bg-white">
                        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["AddressSearch"]</h4>
                        </div>
                        <div class="p-4 space-y-2">
                             <div class="form-group">
                                <label class="form-label">@Localizer["City"]</label>
                                <input type="text" name="City" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                            <div class="grid grid-cols-3 gap-4 items-center">
                                <label class="form-label">@Localizer["AreaCode"]</label>
                                <input type="text" name="AreaCode" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                            <div class="grid grid-cols-3 gap-4 items-center">
                                <label class="form-label">@Localizer["Country"]</label>
                                <input type="text" name="Country" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>
                    </div>

                    <div class="border border-blue-200 rounded-lg overflow-hidden bg-white">
                        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["InvoiceSearch"]</h4>
                        </div>
                        <div class="p-4 space-y-2">
                             <div class="form-group">
                                <label class="form-label">Vergi Dairesi</label>
                                <input type="text" name="TaxOffice" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                            <div class="grid grid-cols-3 gap-4 items-center">
                                <label class="form-label">@Localizer["TaxNumber"]</label>
                                <input type="text" name="TaxNumber" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>
                    </div>

                    <div class="border border-blue-200 rounded-lg overflow-hidden bg-white">
                        <div class="px-4 py-3 bg-blue-100 border-b border-blue-200">
                            <h4 class="text-lg font-semibold text-gray-800">@Localizer["JobSearch"]</h4>
                        </div>
                        <div class="p-4 space-y-2">
                             <div class="form-group">
                                <label class="form-label">@Localizer["Status"]</label>
                                @{
                                    // ViewBag'den State listesini al
                                    var states = ViewBag.States as List<Imaj.Service.DTOs.StateDto> ?? new List<Imaj.Service.DTOs.StateDto>();
                                }
                                <select name="JobStatus" class="col-span-2 mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @foreach (var state in states)
                                    {
                                        <option value="@state.Id">@state.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-6 border-t border-gray-200">
                <div class="flex flex-wrap items-center justify-center gap-3">
                    <label class="text-sm text-blue-900 font-semibold">@Localizer["First"]</label>
                    <input type="number" name="First" value="@firstValue" min="1" class="w-20 shadow-sm border-gray-300 rounded-md sm:text-sm text-center">
                    <label class="text-sm text-blue-900 font-semibold">@Localizer["PageSize"]</label>
                    <input type="number" name="PageSize" value="@(Model.PageSize > 0 ? Model.PageSize : 20)" min="1" class="w-20 shadow-sm border-gray-300 rounded-md sm:text-sm text-center">
                    <input type="hidden" name="Page" value="1">

                    <button type="submit" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["Search"]
                    </button>
                    <a href="/Customer" class="inline-flex items-center px-4 py-1 border border-gray-300 text-sm font-medium rounded shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                        @Localizer["Clear"]
                    </a>
                </div>
            </div>

            </div>
        </div>
    </form>

    <div class="text-center mt-10">
        <h2 class="text-xl font-bold text-orange-600 mb-4">@Localizer["CustomerCreation"]</h2>
        <div class="bg-gradient-to-b from-white to-blue-50 shadow sm:rounded-lg border border-gray-200 inline-block w-full max-w-4xl overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200 text-left">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["CustomerCreation"]</h3>
            </div>
            <div class="p-6">
                <div class="pt-4 flex justify-center">
                    <a href="/Customer/Create" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["CreateNewCustomer"]
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center mt-6">
        <h2 class="text-xl font-bold text-orange-600 mb-4">@Localizer["CustomerReports"]</h2>
        <div class="bg-gradient-to-b from-white to-blue-50 shadow sm:rounded-lg border border-gray-200 inline-block w-full max-w-4xl overflow-hidden">
            <div class="px-4 py-3 bg-blue-100 border-b border-blue-200 text-left">
                <h3 class="text-lg font-semibold text-gray-800">@Localizer["CustomerReports"]</h3>
            </div>
            <div class="p-6">
                <div class="pt-4 flex justify-center">
                    <button type="button" @@click="printReport()" class="inline-flex items-center px-6 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                        @Localizer["PrintReport"]
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function customerIndex() {
        return {
            newCustomerCode: '',
            async createCustomer() {
                if(!this.newCustomerCode) {
                    alert('');
                    return;
                }
                
                try {
                    const response = await fetch('/Customer/Create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ code: this.newCustomerCode })
                    });
                    const result = await response.json();
                    alert(result.message);
                    this.newCustomerCode = '';
                } catch(e) {
                     alert('');
                }
            },

            printReport() {
                const form = document.getElementById('customer-search-form');
                if (!form) {
                    return;
                }

                const allowedKeys = new Set([
                    'Code', 'Name', 'IsInvalid', 'City', 'AreaCode', 'Country',
                    'Owner', 'RelatedPerson', 'Phone', 'Fax', 'Email',
                    'TaxOffice', 'TaxNumber', 'JobStatus'
                ]);

                const params = new URLSearchParams();
                const formData = new FormData(form);
                for (const [key, rawValue] of formData.entries()) {
                    if (!allowedKeys.has(key)) {
                        continue;
                    }

                    const value = String(rawValue || '').trim();
                    if (!value) {
                        continue;
                    }

                    params.append(key, value);
                }

                window.location.href = `/Customer/DownloadReportExcel?${params.toString()}`;
            }
        }
    }
</script>
