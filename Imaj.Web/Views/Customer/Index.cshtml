@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web.Models
@model CustomerFilterModel

@{
    ViewData["Title"] = Localizer["CustomerSearch"];
    var firstValue = Model.First.HasValue && Model.First.Value > 0
        ? Model.First.Value
        : (Model.PageSize > 0 ? Model.PageSize : 20);
    var states = ViewBag.States as List<Imaj.Service.DTOs.StateDto> ?? new List<Imaj.Service.DTOs.StateDto>();
}

<div x-data="customerIndex()" class="customer-page-shell page-shell--wide space-y-3">
    <div class="text-center">
        <h2 class="customer-page-title customer-page-title--orange sm:text-3xl">
            @Localizer["CustomerOperations"]
        </h2>
    </div>

    <form id="customer-search-form" action="/Customer/List" method="get" class="space-y-3 text-left">
        <div class="dense-panel-grid">
            <div class="dense-panel-grid__column">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["MainCriteria"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label for="CustomerCode">@Localizer["Code"]</label>
                                <input id="CustomerCode" type="text" name="Code" value="@Model.Code" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerName">@Localizer["Name"]</label>
                                <input id="CustomerName" type="text" name="Name" value="@Model.Name" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerIsInvalid">@Localizer["Invalid"]</label>
                                <select id="CustomerIsInvalid" name="IsInvalid" class="dense-input">
                                    <option value="" selected="@(!Model.IsInvalid.HasValue)">@Localizer["AllOption"]</option>
                                    <option value="false" selected="@(Model.IsInvalid == false)">@Localizer["No"]</option>
                                    <option value="true" selected="@(Model.IsInvalid == true)">@Localizer["Yes"]</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["ContactSearch"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label for="CustomerOwner">@Localizer["Owner"]</label>
                                <input id="CustomerOwner" type="text" name="Owner" value="@Model.Owner" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerRelated">@Localizer["Related"]</label>
                                <input id="CustomerRelated" type="text" name="RelatedPerson" value="@Model.RelatedPerson" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerPhone">@Localizer["Phone"]</label>
                                <input id="CustomerPhone" type="text" name="Phone" value="@Model.Phone" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerFax">@Localizer["Fax"]</label>
                                <input id="CustomerFax" type="text" name="Fax" value="@Model.Fax" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerEmail">@Localizer["Email"]</label>
                                <input id="CustomerEmail" type="text" name="Email" value="@Model.Email" class="dense-input" />
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="dense-panel-grid__column">
                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["AddressSearch"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label for="CustomerCity">@Localizer["City"]</label>
                                <input id="CustomerCity" type="text" name="City" value="@Model.City" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerAreaCode">@Localizer["AreaCode"]</label>
                                <input id="CustomerAreaCode" type="text" name="AreaCode" value="@Model.AreaCode" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerCountry">@Localizer["Country"]</label>
                                <input id="CustomerCountry" type="text" name="Country" value="@Model.Country" class="dense-input" />
                            </div>
                        </div>
                    </div>
                </section>

                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["InvoiceSearch"]</h3>
                    </div>
                    <div class="dense-panel__body">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label for="CustomerTaxOffice">@Localizer["TaxOffice"]</label>
                                <input id="CustomerTaxOffice" type="text" name="TaxOffice" value="@Model.TaxOffice" class="dense-input" />
                            </div>
                            <div class="dense-form-row">
                                <label for="CustomerTaxNumber">@Localizer["TaxNumber"]</label>
                                <input id="CustomerTaxNumber" type="text" name="TaxNumber" value="@Model.TaxNumber" class="dense-input" />
                            </div>
                        </div>
                    </div>
                </section>

                <section class="dense-panel">
                    <div class="dense-panel__header">
                        <h3 class="dense-panel__title">@Localizer["JobSearch"]</h3>
                    </div>
                    <div class="dense-panel__body dense-panel__body--tight">
                        <div class="dense-form-grid">
                            <div class="dense-form-row">
                                <label for="CustomerJobStatus">@Localizer["Status"]</label>
                                <select id="CustomerJobStatus" name="JobStatus" class="dense-input">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @foreach (var state in states)
                                    {
                                        <option value="@state.Id" selected="@(Model.JobStatus == state.Id.ToString(System.Globalization.CultureInfo.InvariantCulture))">@state.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </div>

        <input type="hidden" name="Page" value="1" />

        <div class="dense-toolbar">
            <label for="CustomerFirst" class="dense-toolbar__label">@Localizer["First"]</label>
            <input id="CustomerFirst" type="number" name="First" value="@firstValue" min="1" class="dense-input dense-toolbar__input" />
            <label for="CustomerPageSize" class="dense-toolbar__label">@Localizer["PageSize"]</label>
            <input id="CustomerPageSize" type="number" name="PageSize" value="@(Model.PageSize > 0 ? Model.PageSize : 20)" min="1" class="dense-input dense-toolbar__input" />

            <button type="submit" class="inline-flex items-center px-4 py-1 border border-transparent text-sm font-medium rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                @Localizer["Search"]
            </button>
            <a href="/Customer" class="inline-flex items-center px-4 py-1 border border-gray-300 text-sm font-medium rounded shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                @Localizer["Clear"]
            </a>
        </div>
    </form>

    <div class="dense-action-grid">
        <section class="dense-action-card">
            <div class="dense-action-card__header">
                <h3 class="dense-action-card__title">@Localizer["CustomerCreation"]</h3>
            </div>
            <div class="dense-action-card__body">
                <a href="/Customer/Create" class="inline-flex items-center px-5 py-2 border border-transparent text-sm font-bold rounded shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none">
                    @Localizer["CreateNewCustomer"]
                </a>
            </div>
        </section>

        <section class="dense-action-card">
            <div class="dense-action-card__header">
                <h3 class="dense-action-card__title">@Localizer["CustomerReports"]</h3>
            </div>
            <div class="dense-action-card__body">
                <button type="button" @@click="downloadReportExcel()" class="inline-flex items-center px-5 py-2 border border-blue-300 text-sm font-bold rounded-md shadow-sm text-blue-900 bg-blue-100 hover:bg-blue-200 focus:outline-none">
                    @Localizer["CustomerReports"] - Excel
                </button>
                <button type="button" @@click="openReportPage()" class="inline-flex items-center px-5 py-2 border border-slate-300 text-sm font-bold rounded-md shadow-sm text-slate-900 bg-slate-100 hover:bg-slate-200 focus:outline-none">
                    @Localizer["CustomerReports"] - PDF
                </button>
            </div>
        </section>
    </div>
</div>

<script>
    function customerIndex() {
        return {
            newCustomerCode: '',
            async createCustomer() {
                if(!this.newCustomerCode) {
                    alert('');
                    return;
                }
                
                try {
                    const response = await fetch('/Customer/Create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ code: this.newCustomerCode })
                    });
                    const result = await response.json();
                    alert(result.message);
                    this.newCustomerCode = '';
                } catch(e) {
                     alert('');
                }
            },

            buildReportParams() {
                const form = document.getElementById('customer-search-form');
                if (!form) {
                    return null;
                }

                const allowedKeys = new Set([
                    'Code', 'Name', 'IsInvalid', 'City', 'AreaCode', 'Country',
                    'Owner', 'RelatedPerson', 'Phone', 'Fax', 'Email',
                    'TaxOffice', 'TaxNumber', 'JobStatus'
                ]);

                const params = new URLSearchParams();
                const formData = new FormData(form);
                for (const [key, rawValue] of formData.entries()) {
                    if (!allowedKeys.has(key)) {
                        continue;
                    }

                    const value = String(rawValue || '').trim();
                    if (!value) {
                        continue;
                    }

                    params.append(key, value);
                }

                return params;
            },

            downloadReportExcel() {
                const params = this.buildReportParams();
                if (!params) {
                    return;
                }

                window.location.href = `/Customer/DownloadReportExcel?${params.toString()}`;
            },

            openReportPage() {
                const params = this.buildReportParams();
                if (!params) {
                    return;
                }

                window.open(`/Customer/ViewReport?${params.toString()}`, '_blank', 'noopener');
            }
        }
    }
</script>
