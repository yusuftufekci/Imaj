@using Microsoft.AspNetCore.Mvc.Localization
@using Imaj.Web.Models
@model CustomerFilterModel

@{
    ViewData["Title"] = Localizer["CustomerSearch"];
}

<div x-data="customerIndex()" class="space-y-6">
    <!-- Header -->
    <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                @Localizer["CustomerOperations"]
            </h2>
        </div>
    </div>

    <!-- @Localizer["CustomerSearch"] Bölümü -->
    <form action="/Customer/List" method="get" class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-orange-600 mb-4 text-center border-b pb-2">
                @Localizer["CustomerSearch"]
            </h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-6">
                <!-- Sol Kolon -->
                <div class="space-y-6">
                    <!-- @Localizer["MainCriteria"] -->
                    <div class="bg-blue-50 p-4 rounded-md border border-blue-200">
                        <h4 class="text-sm font-bold text-gray-700 mb-3 border-b border-blue-200 pb-1">@Localizer["MainCriteria"]</h4>
                        <div class="space-y-2">
                            <div class="form-group">
                                <label class="form-label">@Localizer["Code"]</label>
                                <input type="text" name="Code" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Name"]</label>
                                <input type="text" name="Name" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Invalid"]</label>
                                <select name="IsInvalid" class="form-input">
                                    <option value="">@Localizer["AllOption"]</option>
                                    <option value="false">@Localizer["No"]</option>
                                    <option value="true">@Localizer["Yes"]</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- @Localizer["ContactSearch"] -->
                    <div class="bg-blue-50 p-4 rounded-md border border-blue-200">
                        <h4 class="text-sm font-bold text-gray-700 mb-3 border-b border-blue-200 pb-1">@Localizer["ContactSearch"]</h4>
                        <div class="space-y-2">
                            <div class="form-group">
                                <label class="form-label">@Localizer["Owner"]</label>
                                <input type="text" name="Owner" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Related"]</label>
                                <input type="text" name="RelatedPerson" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Phone"]</label>
                                <input type="text" name="Phone" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Faks</label>
                                <input type="text" name="Fax" class="form-input">
                            </div>
                            <div class="form-group">
                                <label class="form-label">@Localizer["Email"]</label>
                                <input type="text" name="Email" class="form-input">
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sağ Kolon -->
                <div class="space-y-6">
                    <!-- @Localizer["AddressSearch"] -->
                    <div class="bg-blue-50 p-4 rounded-md border border-blue-200">
                        <h4 class="text-sm font-bold text-gray-700 mb-3 border-b border-blue-200 pb-1">@Localizer["AddressSearch"]</h4>
                        <div class="space-y-2">
                             <div class="form-group">
                                <label class="form-label">@Localizer["City"]</label>
                                <input type="text" name="City" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                            <div class="grid grid-cols-3 gap-4 items-center">
                                <label class="form-label">@Localizer["AreaCode"]</label>
                                <input type="text" name="AreaCode" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                            <div class="grid grid-cols-3 gap-4 items-center">
                                <label class="form-label">@Localizer["Country"]</label>
                                <input type="text" name="Country" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>
                    </div>

                    <!-- @Localizer["InvoiceSearch"] -->
                     <div class="bg-blue-50 p-4 rounded-md border border-blue-200">
                        <h4 class="text-sm font-bold text-gray-700 mb-3 border-b border-blue-200 pb-1">@Localizer["InvoiceSearch"]</h4>
                        <div class="space-y-2">
                             <div class="form-group">
                                <label class="form-label">Vergi Dairesi</label>
                                <input type="text" name="TaxOffice" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                            <div class="grid grid-cols-3 gap-4 items-center">
                                <label class="form-label">@Localizer["TaxNumber"]</label>
                                <input type="text" name="TaxNumber" class="col-span-2 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md">
                            </div>
                        </div>
                    </div>

                    <!-- @Localizer["JobSearch"] -->
                    <div class="bg-blue-50 p-4 rounded-md border border-blue-200">
                        <h4 class="text-sm font-bold text-gray-700 mb-3 border-b border-blue-200 pb-1">@Localizer["JobSearch"]</h4>
                        <div class="space-y-2">
                             <div class="form-group">
                                <label class="form-label">@Localizer["Status"]</label>
                                @{
                                    // ViewBag'den State listesini al
                                    var states = ViewBag.States as List<Imaj.Service.DTOs.StateDto> ?? new List<Imaj.Service.DTOs.StateDto>();
                                }
                                <select name="JobStatus" class="col-span-2 mt-1 block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm">
                                    <option value="">@Localizer["AllOption"]</option>
                                    @foreach (var state in states)
                                    {
                                        <option value="@state.Id">@state.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Butonlar -->
             <div class="mt-8 flex justify-center space-x-3">
                 <div class="flex items-center space-x-2 mr-4">
                     <span class="text-sm text-gray-500">@Localizer["First"]</span>
                     <input type="number" name="Page" value="1" class="w-16 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block sm:text-sm border-gray-300 rounded-md">
                     <span class="text-sm text-gray-500">@Localizer["PageSize"]</span>
                     <input type="number" name="PageSize" value="20" class="w-16 shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block sm:text-sm border-gray-300 rounded-md">
                 </div>

                 <button type="submit" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    @Localizer["Search"]
                </button>
                <button type="reset" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    @Localizer["Clear"]
                </button>
            </div>
            
        </div>
    </form>

    <!-- @Localizer["CustomerCreation"] -->
    <div class="bg-white shadow sm:rounded-lg mt-6">
        <div class="px-4 py-5 sm:p-6 text-center">
             <h3 class="text-lg leading-6 font-medium text-orange-600 mb-4 border-b pb-2">
                @Localizer["CustomerCreation"]
            </h3>
            
            <a href="/Customer/Create" class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                @Localizer["CreateNewCustomer"]
            </a>
        </div>
    </div>

    <!-- @Localizer["CustomerReports"] -->
    <div class="bg-white shadow sm:rounded-lg mt-6 text-center">
         <div class="px-4 py-5 sm:p-6">
             <h3 class="text-lg leading-6 font-medium text-orange-600 mb-4 border-b pb-2">
                @Localizer["CustomerReports"]
            </h3>
            <button type="button" @@click="printReport()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                @Localizer["PrintReport"]
            </button>
         </div>
    </div>

</div>

<script>
    function customerIndex() {
        return {
            newCustomerCode: '',
            async createCustomer() {
                if(!this.newCustomerCode) {
                    alert('');
                    return;
                }
                
                try {
                    const response = await fetch('/Customer/Create', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ code: this.newCustomerCode })
                    });
                    const result = await response.json();
                    alert(result.message);
                    this.newCustomerCode = '';
                } catch(e) {
                     alert('');
                }
            },

            printReport() {
                alert('');
            }
        }
    }
</script>
