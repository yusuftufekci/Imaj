@using Imaj.Web.Models
@model CustomerViewModel

@{
    var returnUrl = string.IsNullOrWhiteSpace(Model.ReturnUrl) ? "/Customer" : Model.ReturnUrl;
}

<script>
    function customerFormState(initialCategories) {
        return {
            selectedProductCategories: initialCategories || [],
            addCategories(items) {
                // Yeni seçilenleri ekle (zaten varsa ekleme)
                items.forEach(newItem => {
                    if (!this.selectedProductCategories.some(existing => existing.id === newItem.id)) {
                        // Reactive olması için yeni obje oluştur
                        this.selectedProductCategories.push({
                            ...newItem,
                            discount: 0 // Varsayılan indirim
                        });
                    }
                });
            },
            removeCategory(index) {
                this.selectedProductCategories.splice(index, 1);
            }
        }
    }
</script>

<div class="space-y-2 mobile-stack-form">
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="All" class="text-red-600 font-medium p-3 bg-red-50 rounded-md border border-red-200"></div>
    }

    <div class="customer-form-layout">
        <section class="dense-panel">
            <div class="dense-panel__header">
                <h4 class="dense-panel__title">@Localizer["Description"]</h4>
            </div>
            <div class="dense-panel__body">
                <div class="dense-form-grid">
                    <div class="dense-form-row">
                        <label asp-for="Code">@Localizer["Code"] <span class="text-red-500">*</span></label>
                        <input asp-for="Code" class="dense-input" placeholder="TEST" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="Name">@Localizer["Name"] <span class="text-red-500">*</span></label>
                        <input asp-for="Name" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="Notes">@Localizer["Notes"]</label>
                        <textarea asp-for="Notes" rows="2" class="dense-input"></textarea>
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="IsInvalid">@Localizer["Invalid"]</label>
                        <div>
                            <input type="checkbox" asp-for="IsInvalid" class="dense-checkbox focus:ring-indigo-500 text-indigo-600 border-gray-300 rounded" />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="dense-panel">
            <div class="dense-panel__header">
                <h4 class="dense-panel__title">@Localizer["ContactInfo"]</h4>
            </div>
            <div class="dense-panel__body">
                <div class="dense-form-grid">
                    <div class="dense-form-row">
                        <label asp-for="Owner">@Localizer["Owner"]</label>
                        <input asp-for="Owner" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="RelatedPerson">@Localizer["Related"]</label>
                        <input asp-for="RelatedPerson" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="Phone">@Localizer["Phone"]</label>
                        <input type="tel" asp-for="Phone" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="Fax">@Localizer["Fax"]</label>
                        <input type="tel" asp-for="Fax" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="Email">@Localizer["Email"]</label>
                        <input type="email" asp-for="Email" class="dense-input" />
                    </div>
                </div>
            </div>
        </section>

        <section class="dense-panel">
            <div class="dense-panel__header">
                <h4 class="dense-panel__title">@Localizer["Address"]</h4>
            </div>
            <div class="dense-panel__body">
                <div class="dense-form-grid">
                    <div class="dense-form-row">
                        <label asp-for="Address">@Localizer["Address"] <span class="text-red-500">*</span></label>
                        <textarea asp-for="Address" rows="2" class="dense-input"></textarea>
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="City">@Localizer["City"] <span class="text-red-500">*</span></label>
                        <input asp-for="City" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="AreaCode">@Localizer["AreaCode"]</label>
                        <input asp-for="AreaCode" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="Country">@Localizer["Country"] <span class="text-red-500">*</span></label>
                        <input asp-for="Country" class="dense-input" />
                    </div>
                </div>
            </div>
        </section>

        <section class="dense-panel">
            <div class="dense-panel__header">
                <h4 class="dense-panel__title">@Localizer["Invoice"]</h4>
            </div>
            <div class="dense-panel__body">
                <div class="dense-form-grid">
                    <div class="dense-form-row">
                        <label asp-for="InvoiceName">@Localizer["InvoiceName"]</label>
                        <input asp-for="InvoiceName" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="TaxOffice">@Localizer["TaxOffice"] <span class="text-red-500">*</span></label>
                        <input asp-for="TaxOffice" class="dense-input" />
                    </div>
                    <div class="dense-form-row">
                        <label asp-for="TaxNumber">@Localizer["TaxNumber"] <span class="text-red-500">*</span></label>
                        <input inputmode="numeric" asp-for="TaxNumber" class="dense-input" />
                    </div>
                </div>
            </div>
        </section>
    </div>

    <div class="customer-table-card" x-data='customerFormState(@Json.Serialize(Model.ProductCategories.Select(x => new { id = x.Id, name = x.Name, discount = x.Discount })) || [])'
         x-on:product-categories-selected.window="addCategories($event.detail.items)">
        <partial name="_ProductCategorySelectModal" />

        <div class="customer-table-card__header">
            <h4 class="customer-table-card__title">
                @Localizer["ProductCategory"] (<span x-text="selectedProductCategories.length">0</span>)
            </h4>
            <div class="customer-page-actions">
                <button type="button" x-on:click="$dispatch('open-product-category-modal')"
                        class="inline-flex items-center border border-transparent text-xs font-medium rounded-md text-indigo-700 bg-indigo-100 hover:bg-indigo-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                    +
                </button>
                <button type="button" x-on:click="selectedProductCategories = []"
                        class="inline-flex items-center border border-gray-300 text-xs font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none">
                    @Localizer["ClearAll"]
                </button>
            </div>
        </div>

        <div class="customer-table-wrap" x-show="selectedProductCategories.length > 0">
            <table class="customer-table customer-table--compact">
                <thead>
                    <tr>
                        <th scope="col">@Localizer["Name"]</th>
                        <th scope="col" class="w-32">@Localizer["Discount"]</th>
                        <th scope="col" class="w-16 text-right">
                            <span class="sr-only">@Localizer["Delete"]</span>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    <template x-for="(category, index) in selectedProductCategories" :key="category.id">
                        <tr>
                            <td class="whitespace-nowrap">
                                <div class="flex items-center">
                                    <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-indigo-50 text-indigo-700 text-[11px] font-bold mr-2" x-text="index + 1"></span>
                                    <span class="font-medium" x-text="category.name"></span>
                                </div>
                            </td>
                            <td class="whitespace-nowrap">
                                <div class="relative">
                                    <input type="number" x-model="category.discount" class="dense-input pr-6 text-right font-mono" min="0" max="100" />
                                    <div class="absolute inset-y-0 right-0 pr-2 flex items-center pointer-events-none">
                                        <span class="text-gray-400 text-xs">%</span>
                                    </div>
                                </div>

                                <input type="hidden" :name="'ProductCategories[' + index + '].Id'" :value="category.id">
                                <input type="hidden" :name="'ProductCategories[' + index + '].Discount'" :value="category.discount">
                                <input type="hidden" :name="'ProductCategories[' + index + '].Name'" :value="category.name">
                            </td>
                            <td class="whitespace-nowrap text-right">
                                <button type="button" x-on:click="removeCategory(index)"
                                        class="text-gray-400 hover:text-red-600 bg-white hover:bg-red-50 p-1 rounded-full transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
                                        title="@Localizer["Delete"]">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>

        <div x-show="selectedProductCategories.length === 0" class="customer-empty-state">
            @Localizer["NoRecordsFound"]
        </div>
    </div>
</div>

<div class="customer-footer-bar customer-footer-bar--center responsive-action-group">
    <button type="submit" class="inline-flex justify-center border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
        @Localizer["Save"]
    </button>
    <a href="@returnUrl" class="inline-flex justify-center border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-400 hover:bg-red-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
        @Localizer["Cancel"]
    </a>
</div>
