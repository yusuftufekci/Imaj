@using Imaj.Web.Models
@using System.Text.Json
@using System.Net
@model CustomerListViewModel

@{
    ViewData["Title"] = Localizer["CustomerList"];
    var listModel = Model ?? new CustomerListViewModel();
    var currentListUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var currentSearchUrl = "/Customer" + (Context.Request.QueryString.HasValue ? Context.Request.QueryString.Value : string.Empty);
    var rows = listModel.Items;
    var allPageCodes = rows
        .Select(x => x.Code)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();
}

<div x-data="customerList()" class="customer-page-shell page-shell--wide space-y-3">
     <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="customer-page-title">
                @Localizer["CustomerList"]
            </h2>
        </div>
         <div class="mt-3 md:mt-0 customer-page-actions">
            <a href="@currentSearchUrl" class="inline-flex items-center border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                @Localizer["Back"]
            </a>
        </div>
    </div>

    <div class="customer-table-card">
        <div class="customer-table-card__header">
            <h3 class="customer-table-card__title">@Localizer["Customer"]</h3>
            <span class="customer-table__count">@listModel.TotalCount</span>
        </div>
        <div class="customer-table-wrap">
            <table class="customer-table customer-table--compact">
                <thead>
                                <tr>
                                    <th scope="col">
                                        <div class="flex items-center">
                                            <input type="checkbox" :checked="allSelected" @@change="toggleAll($event.target.checked)" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded mr-2">
                                            <span class="text-xs font-medium text-gray-500 uppercase tracking-wider">@Localizer["Select"]</span>
                                        </div>
                                    </th>
                                    <th scope="col">@Localizer["Code"]</th>
                                    <th scope="col">@Localizer["Name"]</th>
                                    <th scope="col">@Localizer["Related"]</th>
                                    <th scope="col">@Localizer["Phone"]</th>
                                    <th scope="col">@Localizer["Email"]</th>
                                    <th scope="col">@Localizer["Invalid"]</th>
                                </tr>
                </thead>
                <tbody>
                                @if (rows.Any())
                                {
                                    foreach (var item in rows)
                                    {
                                        <tr>
                                            <td class="whitespace-nowrap text-sm font-medium text-gray-900">
                                                <input type="checkbox" name="selectedCustomers" value="@item.Code" x-model="selectedCodes" @@change="syncSelectionState()" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded">
                                            </td>
                                            <td class="whitespace-nowrap text-sm font-medium text-gray-900">
                                                <a href="/Customer/Details/@Uri.EscapeDataString(item.Code)?returnUrl=@WebUtility.UrlEncode(currentListUrl)" class="text-blue-600 hover:text-blue-900 underline">
                                                    @item.Code
                                                </a>
                                            </td>
                                            <td class="whitespace-nowrap text-sm text-gray-500">@item.Name</td>
                                            <td class="whitespace-nowrap text-sm text-gray-500">@item.RelatedPerson</td>
                                            <td class="whitespace-nowrap text-sm text-gray-500">@item.Phone</td>
                                            <td class="whitespace-nowrap text-sm text-gray-500">@item.Email</td>
                                            <td class="whitespace-nowrap text-sm text-gray-500">
                                                <input type="checkbox" disabled @(item.IsInvalid ? "checked" : "") class="h-4 w-4 text-gray-400 border-gray-300 rounded">
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-sm text-gray-500">@Localizer["NoRecordsFound"]</td>
                                    </tr>
                                }
                </tbody>
            </table>
        </div>
        
        @if (listModel.TotalCount > 0)
        {
            var totalPages = (int)Math.Ceiling((double)listModel.TotalCount / listModel.PageSize);
            var prevDisabled = listModel.Page <= 1 ? "pointer-events-none opacity-50" : "";
            var nextDisabled = listModel.Page >= totalPages ? "pointer-events-none opacity-50" : "";
            
            // Helper function to build query string for pagination links
             string GetPageUrl(int page)
            {
                var query = new Dictionary<string, string>
                {
                    { "Page", page.ToString() },
                    { "PageSize", listModel.PageSize.ToString() },
                    { "First", (listModel.Filter?.First.HasValue == true && listModel.Filter.First.Value > 0 ? listModel.Filter.First.Value : (listModel.Filter?.PageSize ?? listModel.PageSize)).ToString() }
                };
                
                if (listModel.Filter != null)
                {
                    if (!string.IsNullOrEmpty(listModel.Filter.Code)) query.Add("Code", listModel.Filter.Code);
                    if (!string.IsNullOrEmpty(listModel.Filter.Name)) query.Add("Name", listModel.Filter.Name);
                    if (listModel.Filter.IsInvalid.HasValue) query.Add("IsInvalid", listModel.Filter.IsInvalid.Value.ToString().ToLowerInvariant());
                    if (!string.IsNullOrEmpty(listModel.Filter.Owner)) query.Add("Owner", listModel.Filter.Owner);
                    if (!string.IsNullOrEmpty(listModel.Filter.RelatedPerson)) query.Add("RelatedPerson", listModel.Filter.RelatedPerson);
                    if (!string.IsNullOrEmpty(listModel.Filter.Phone)) query.Add("Phone", listModel.Filter.Phone);
                    if (!string.IsNullOrEmpty(listModel.Filter.Fax)) query.Add("Fax", listModel.Filter.Fax);
                    if (!string.IsNullOrEmpty(listModel.Filter.Email)) query.Add("Email", listModel.Filter.Email);
                    if (!string.IsNullOrEmpty(listModel.Filter.City)) query.Add("City", listModel.Filter.City);
                    if (!string.IsNullOrEmpty(listModel.Filter.AreaCode)) query.Add("AreaCode", listModel.Filter.AreaCode);
                    if (!string.IsNullOrEmpty(listModel.Filter.Country)) query.Add("Country", listModel.Filter.Country);
                    if (!string.IsNullOrEmpty(listModel.Filter.TaxOffice)) query.Add("TaxOffice", listModel.Filter.TaxOffice);
                    if (!string.IsNullOrEmpty(listModel.Filter.TaxNumber)) query.Add("TaxNumber", listModel.Filter.TaxNumber);
                    if (!string.IsNullOrEmpty(listModel.Filter.JobStatus)) query.Add("JobStatus", listModel.Filter.JobStatus);
                }
                
                var queryString = "?" + string.Join("&", query.Select(x => x.Key + "=" + System.Net.WebUtility.UrlEncode(x.Value)));
                return "/Customer/List" + queryString;
            }

            <div class="customer-footer-bar">
                <div class="flex items-center justify-between w-full gap-3 flex-wrap">
                     <div class="flex-1 flex justify-between sm:hidden">
                        <a href="@GetPageUrl(listModel.Page - 1)" class="@prevDisabled relative inline-flex items-center border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                            @Localizer["Previous"]
                        </a>
                        <a href="@GetPageUrl(listModel.Page + 1)" class="@nextDisabled ml-3 relative inline-flex items-center border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">@Localizer["Next"]</a>
                    </div>
                    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                         <div>
                            <p class="customer-footer-bar__meta">
                                @Localizer["Total"] <span class="font-medium">@listModel.TotalCount</span> @Localizer["Records"],
                                @Localizer["Page"] <span class="font-medium">@listModel.Page</span> / <span class="font-medium">@totalPages</span>
                            </p>
                        </div>
                        <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                <a href="@GetPageUrl(listModel.Page - 1)" class="@prevDisabled relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    <span class="sr-only">@Localizer["Previous"]</span>
                                    <!-- Heroicon name: solid/chevron-left -->
                                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                     // Simple pagination logic: show all or just around current
                                     // For now show all if pages < 10, else simplified
                                     if(totalPages <= 10 || i == 1 || i == totalPages || (i >= listModel.Page - 2 && i <= listModel.Page + 2))
                                     {
                                         var activeClass = i == listModel.Page ? "z-10 bg-indigo-50 border-indigo-500 text-indigo-600" : "bg-white border-gray-300 text-gray-500 hover:bg-gray-50";
                                         <a href="@GetPageUrl(i)" aria-current="page" class="@activeClass relative inline-flex items-center px-4 py-2 border text-sm font-medium">
                                            @i
                                        </a>
                                     } 
                                     else if (i == listModel.Page - 3 || i == listModel.Page + 3)
                                     {
                                         <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">...</span>
                                     }
                                }
                                <a href="@GetPageUrl(listModel.Page + 1)" class="@nextDisabled relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    <span class="sr-only">@Localizer["Next"]</span>
                                    <!-- Heroicon name: solid/chevron-right -->
                                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="customer-footer-bar customer-footer-bar--center">
             <button type="button" @@click="goToDetails()" class="inline-flex justify-center border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50" :disabled="selectedCodes.length === 0">
                @Localizer["View"]
            </button>
            <button type="button" @@click="goToEdit()" class="inline-flex justify-center border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 disabled:opacity-50" :disabled="selectedCodes.length === 0">
                @Localizer["Edit"]
            </button>
        </div>
    </div>
</div>

<script>
    function customerList() {
        return {
            selectedCodes: [],
            allSelected: false,
            allPageCodes: @Html.Raw(JsonSerializer.Serialize(allPageCodes)),
            returnUrl: @Html.Raw(JsonSerializer.Serialize(currentListUrl)),

            toggleAll(checked) {
                this.allSelected = checked;
                this.selectedCodes = checked ? [...this.allPageCodes] : [];
            },

            syncSelectionState() {
                this.allSelected = this.allPageCodes.length > 0
                    && this.allPageCodes.every(code => this.selectedCodes.includes(code));
            },
            
            goToDetails() {
                if (this.selectedCodes.length > 0) {
                    window.location.href = '/Customer/Details/' + encodeURIComponent(this.selectedCodes[0]) + '?returnUrl=' + encodeURIComponent(this.returnUrl);
                }
            },
            
            goToEdit() {
                if (this.selectedCodes.length > 0) {
                    window.location.href = '/Customer/Edit/' + encodeURIComponent(this.selectedCodes[0]) + '?returnUrl=' + encodeURIComponent(this.returnUrl);
                }
            }
        }
    }
</script>
