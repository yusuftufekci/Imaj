@using Imaj.Web.Models
@model CustomerListViewModel

@{
    ViewData["Title"] = "Müşteri Listesi";
}

<div x-data="customerList()" class="space-y-6">
    <!-- Header -->
     <div class="md:flex md:items-center md:justify-between">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                Müşteri Listesi
            </h2>
        </div>
         <div class="mt-4 flex md:mt-0 md:ml-4">
            <a href="/Customer" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Geri Dön
            </a>
        </div>
    </div>

    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="flex flex-col">
            <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                     <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Seç</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kod</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Ad</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Şehir</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Telefon</th>
                                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">E-Mail</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                @if (Model.Items != null && Model.Items.Any())
                                {
                                    foreach (var item in Model.Items)
                                    {
                                        <tr class="hover:bg-gray-50 cursor-pointer" @@click="selectedCode = '@item.Code'">
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                                <input type="radio" name="selectedCustomer" value="@item.Code" x-model="selectedCode" class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300">
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@item.Code</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@item.Name</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@item.City</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@item.Phone</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@item.Email</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="px-6 py-4 text-center text-sm text-gray-500">Kayıt bulunamadı.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Pagination -->
        @if (Model.TotalCount > 0)
        {
            var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Model.PageSize);
            var prevDisabled = Model.Page <= 1 ? "pointer-events-none opacity-50" : "";
            var nextDisabled = Model.Page >= totalPages ? "pointer-events-none opacity-50" : "";
            
            // Helper function to build query string for pagination links
             string GetPageUrl(int page)
            {
                var query = new Dictionary<string, string>
                {
                    { "Page", page.ToString() },
                    { "PageSize", Model.PageSize.ToString() }
                };
                
                if (Model.Filter != null)
                {
                    if (!string.IsNullOrEmpty(Model.Filter.Code)) query.Add("Code", Model.Filter.Code);
                    if (!string.IsNullOrEmpty(Model.Filter.Name)) query.Add("Name", Model.Filter.Name);
                    if (!string.IsNullOrEmpty(Model.Filter.City)) query.Add("City", Model.Filter.City);
                    if (Model.Filter.IsInvalid == true) query.Add("IsInvalid", "true");
                    // Add other filters...
                }
                
                var queryString = "?" + string.Join("&", query.Select(x => x.Key + "=" + System.Net.WebUtility.UrlEncode(x.Value)));
                return "/Customer/List" + queryString;
            }

            <div class="px-4 py-3 bg-white border-t border-gray-200 sm:px-6">
                <div class="flex items-center justify-between">
                     <div class="flex-1 flex justify-between sm:hidden">
                        <a href="@GetPageUrl(Model.Page - 1)" class="@prevDisabled relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                            Önceki
                        </a>
                        <a href="@GetPageUrl(Model.Page + 1)" class="@nextDisabled ml-3 relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                            Sonraki
                        </a>
                    </div>
                    <div class="hidden sm:flex-1 sm:flex sm:items-center sm:justify-between">
                         <div>
                            <p class="text-sm text-gray-700">
                                Toplam <span class="font-medium">@Model.TotalCount</span> kayıt, 
                                Sayfa <span class="font-medium">@Model.Page</span> / <span class="font-medium">@totalPages</span>
                            </p>
                        </div>
                        <div>
                            <nav class="relative z-0 inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                                <a href="@GetPageUrl(Model.Page - 1)" class="@prevDisabled relative inline-flex items-center px-2 py-2 rounded-l-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    <span class="sr-only">Önceki</span>
                                    <!-- Heroicon name: solid/chevron-left -->
                                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                                @for (int i = 1; i <= totalPages; i++)
                                {
                                     // Simple pagination logic: show all or just around current
                                     // For now show all if pages < 10, else simplified
                                     if(totalPages <= 10 || i == 1 || i == totalPages || (i >= Model.Page - 2 && i <= Model.Page + 2))
                                     {
                                         var activeClass = i == Model.Page ? "z-10 bg-indigo-50 border-indigo-500 text-indigo-600" : "bg-white border-gray-300 text-gray-500 hover:bg-gray-50";
                                         <a href="@GetPageUrl(i)" aria-current="page" class="@activeClass relative inline-flex items-center px-4 py-2 border text-sm font-medium">
                                            @i
                                        </a>
                                     } 
                                     else if (i == Model.Page - 3 || i == Model.Page + 3)
                                     {
                                         <span class="relative inline-flex items-center px-4 py-2 border border-gray-300 bg-white text-sm font-medium text-gray-700">...</span>
                                     }
                                }
                                <a href="@GetPageUrl(Model.Page + 1)" class="@nextDisabled relative inline-flex items-center px-2 py-2 rounded-r-md border border-gray-300 bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                                    <span class="sr-only">Sonraki</span>
                                    <!-- Heroicon name: solid/chevron-right -->
                                    <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                    </svg>
                                </a>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Action Buttons -->
        <div class="px-4 py-3 bg-gray-50 text-right sm:px-6 space-x-3">
             <button type="button" @@click="goToDetails()" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50" :disabled="!selectedCode">
                Görüntüle
            </button>
            <button type="button" @@click="goToEdit()" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 disabled:opacity-50" :disabled="!selectedCode">
                Değiştir
            </button>
        </div>
    </div>
</div>

<script>
    function customerList() {
        return {
            selectedCode: '',
            
            goToDetails() {
                if(this.selectedCode) {
                    window.location.href = '/Customer/Details/' + this.selectedCode;
                }
            },
            
            goToEdit() {
                if(this.selectedCode) {
                    window.location.href = '/Customer/Edit/' + this.selectedCode;
                }
            }
        }
    }
</script>
