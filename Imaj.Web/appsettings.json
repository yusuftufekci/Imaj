{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "CustomerSettings": {
    "DefaultCompanyId": 7,
    "DefaultPageSize": 20
  },
  "AuthSettings": {
    "SessionTimeoutMinutes": 45
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/imaj-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}